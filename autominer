local function switchTab(tabName)
    if activeTab == tabName then
        return
    end
    activeTab = tabName
    for name, content in pairs(tabContents) do
        content.Visible = (name == tabName)
    end
    local activeData = tabButtons[tabName]
    if activeData and tabName ~= "Home" then
        if not sidebarActiveHighlight.Visible then
            sidebarActiveHighlight.Position = activeData.btn.Position
            sidebarActiveHighlight.Size = activeData.btn.Size
            sidebarActiveHighlight.Visible = true
        else
            _TweenService:Create(sidebarActiveHighlight, _TAB_SLIDE_TWEEN, {
                Position = activeData.btn.Position,
                Size = activeData.btn.Size,
            }):Play()
        end
    else
        sidebarActiveHighlight.Visible = false
    end
    for name, data in pairs(tabButtons) do
        local isActive = (name == tabName)
        if data.indicator:IsA("ImageLabel") then
            _TweenService:Create(data.indicator, TweenInfo.new(0.2), {
                ImageColor3 = isActive and Color3.new(1, 1, 1) or _TAB_ICON_BLUE,
            }):Play()
        else
            _TweenService:Create(data.indicator, TweenInfo.new(0.2), {
                BackgroundColor3 = isActive and Color3.new(1, 1, 1) or _TAB_ICON_BLUE,
            }):Play()
        end
        _TweenService:Create(data.label, TweenInfo.new(0.2), {
            TextColor3 = isActive and Color3.new(1, 1, 1) or Color3.new(0.8, 0.8, 0.8),
        }):Play()
    end
end

