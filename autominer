function looksLikePlayerCharacterModule(candidate)
    if not isTable(candidate) then
        return false
    end

    return type(rawget(candidate, "GetEquippedItem") or candidate.GetEquippedItem) == "function"
        or type(rawget(candidate, "CanSwitchToItem") or candidate.CanSwitchToItem) == "function"
        or type(rawget(candidate, "CanGetUp") or candidate.CanGetUp) == "function"
        or type(rawget(candidate, "ToggleSelfRagdoll") or candidate.ToggleSelfRagdoll) == "function"
        or type(rawget(candidate, "Ragdoll") or candidate.Ragdoll) == "function"
        or rawget(candidate, "BreakFreePerc") ~= nil
