function resolveSafeTeleportHandler(forceRefresh)
	local playerCharacter = resolvePlayerCharacterModule(forceRefresh)
	if looksLikeSafeTeleportHandler(playerCharacter) then
		return playerCharacter
	end

	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end

	if isTable(globalModule) then
		for _, key in ipairs({ "RepCharHandler", "repCharHandler", "PlayerCharacter", "playerCharacter" }) do
			local candidate = rawget(globalModule, key) or globalModule[key]
			if looksLikeSafeTeleportHandler(candidate) then
				return candidate
			end
		end
	end

	local modulesTable = resolveGameModules(forceRefresh)
	if isTable(modulesTable) then
		for _, key in ipairs({ "RepCharHandler", "repCharHandler", "plrCharacter", "PlayerCharacter", "playerCharacter" }) do
			local candidate = rawget(modulesTable, key) or modulesTable[key]
			if looksLikeSafeTeleportHandler(candidate) then
				return candidate
			end
		end
	end

	for _, root in ipairs(getEnvironmentTables()) do
		for _, key in ipairs({ "RepCharHandler", "repCharHandler", "PlayerCharacter", "playerCharacter", "plrCharacter" }) do
			local candidate = rawget(root, key) or root[key]
			if looksLikeSafeTeleportHandler(candidate) then
				return candidate
			end
		end
	end

	return nil
end

