function getCurrentScriptFilePath()
	if type(debug) ~= "table" or type(debug.info) ~= "function" then
		local cachedPath = runtimeEnv.__FOB_LAST_SCRIPT_FILE_PATH
		if type(cachedPath) == "string" and cachedPath ~= "" then
			return cachedPath
		end
		return nil
	end

	for level = 1, 10 do
		local ok, source = pcall(debug.info, level, "s")
		if ok and type(source) == "string" and string.sub(source, 1, 1) == "@" then
			local resolvedPath = string.sub(source, 2)
			runtimeEnv.__FOB_LAST_SCRIPT_FILE_PATH = resolvedPath
			return resolvedPath
		end
	end

	local cachedPath = runtimeEnv.__FOB_LAST_SCRIPT_FILE_PATH
	if type(cachedPath) == "string" and cachedPath ~= "" then
		return cachedPath
	end

	local isfileFunction = getCallableGlobal("isfile")
	local readfileFunction = getCallableGlobal("readfile")
	if type(isfileFunction) ~= "function" or type(readfileFunction) ~= "function" then
		return nil
	end

	local filePath = string.format(
		"%s\\%s_%s.txt",
		PATH_STORAGE_FOLDER,
		TELEPORT_SCRIPT_PATH_FILE_PREFIX,
		sanitizePathStorageKey(getStorageId())
	)
	local okRead, storedPath = pcall(function()
		if not isfileFunction(filePath) then
			return nil
		end
		return readfileFunction(filePath)
	end)
	if okRead and type(storedPath) == "string" then
		storedPath = string.gsub(storedPath, "^%s+", "")
		storedPath = string.gsub(storedPath, "%s+$", "")
		if storedPath ~= "" then
			runtimeEnv.__FOB_LAST_SCRIPT_FILE_PATH = storedPath
			return storedPath
		end
	end

	return nil
end

function rememberTeleportScriptFilePath(scriptFilePath)
	local normalizedPath = type(scriptFilePath) == "string" and string.gsub(scriptFilePath, "^%s+", "") or ""
	normalizedPath = string.gsub(normalizedPath, "%s+$", "")
	if normalizedPath == "" then
		return false
	end

	runtimeEnv.__FOB_LAST_SCRIPT_FILE_PATH = normalizedPath

	local makefolderFunction = getCallableGlobal("makefolder")
	local writefileFunction = getCallableGlobal("writefile")
	if type(makefolderFunction) == "function" and type(writefileFunction) == "function" then
		pcall(makefolderFunction, PATH_STORAGE_FOLDER)
		pcall(
			writefileFunction,
			string.format(
				"%s\\%s_%s.txt",
				PATH_STORAGE_FOLDER,
				TELEPORT_SCRIPT_PATH_FILE_PREFIX,
				sanitizePathStorageKey(getStorageId())
			),
			normalizedPath
		)
	end

	return true
end

function buildTeleportQueueSource(scriptFilePath)
	return string.format([[
pcall(function()
    local scriptPath = %q
    local retryAttempts = %d
    local retryDelay = %s

    local function createLoader()
        if type(loadfile) == "function" then
            local okLoader, loader = pcall(loadfile, scriptPath)
            if okLoader and type(loader) == "function" then
                return true, loader
            end
        end

        if type(readfile) == "function" and type(loadstring) == "function" then
            local okRead, source = pcall(readfile, scriptPath)
            if okRead and type(source) == "string" and source ~= "" then
                local okChunk, chunk = pcall(loadstring, source)
                if okChunk and type(chunk) == "function" then
                    return true, chunk
                end
            end
        end

        return false
    end

    local function tryLaunch()
        local okLoader, loader = createLoader()
        if not okLoader or type(loader) ~= "function" then
            return false
        end
        local okRun = pcall(loader)
        return okRun == true
    end

    pcall(function()
        if not game:IsLoaded() then
            game.Loaded:Wait()
        end
    end)

    for _ = 1, retryAttempts do
        if tryLaunch() then
            return
        end
        task.wait(retryDelay)
    end

    warn("[FOB] teleport bootstrap failed for " .. tostring(scriptPath))
end)
]], scriptFilePath, TELEPORT_QUEUE_RETRY_ATTEMPTS, tostring(TELEPORT_QUEUE_RETRY_DELAY))
end

function queueCurrentScriptForServerHop()
	local queueFunction = getTeleportQueueFunction()
	if not queueFunction then
		return false, "queue_on_teleport unavailable"
	end

	local scriptFilePath = getCurrentScriptFilePath()
	if not scriptFilePath or scriptFilePath == "" then
		return false, "current script file path unavailable"
	end

	rememberTeleportScriptFilePath(scriptFilePath)

	local queuedSource = buildTeleportQueueSource(scriptFilePath)
	local ok, err = pcall(queueFunction, queuedSource)
	if not ok then
		return false, tostring(err)
	end

	return true
end

function buildPublicServerListUrl(cursor)
	local baseUrl = string.format(
		"https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=%d&excludeFullGames=true",
		game.PlaceId,
		SERVER_HOP_PAGE_SIZE
	)

	if cursor and cursor ~= "" then
		baseUrl = baseUrl .. "&cursor=" .. HttpService:UrlEncode(cursor)
	end

	return baseUrl
end

function decodeHttpResponse(response)
	if type(response) == "string" then
		return true, 200, response
	end

	if type(response) ~= "table" then
		return false, nil, nil
	end

	local statusCode = tonumber(response.StatusCode or response.Status or response.status)
	local success = response.Success
	if success == nil then
		success = response.success
	end
	if success == nil then
		success = statusCode and statusCode >= 200 and statusCode < 300
	end

	return success == true, statusCode, response.Body or response.body
end

function fetchPublicServerPage(cursor)
	local requestFunction = getHttpRequestFunction()
	if not requestFunction then
		return nil, "executor HTTP request unavailable"
	end

	local ok, response = pcall(requestFunction, {
		Url = buildPublicServerListUrl(cursor),
		Method = "GET",
	})
	if not ok then
		return nil, "server list request errored"
	end
	local success, statusCode, body = decodeHttpResponse(response)
	if not success or type(body) ~= "string" or body == "" then
		return nil, "server list request failed (" .. tostring(statusCode or "?") .. ")"
	end

	local ok, payload = pcall(function()
		return HttpService:JSONDecode(body)
	end)
	if not ok or type(payload) ~= "table" then
		return nil, "server list JSON decode failed"
	end

	return payload, nil
end

function findSmallServerHopTarget()
	local bestServer = nil
	local cursor = nil

	for _ = 1, SERVER_HOP_PAGE_LIMIT do
		local payload, err = fetchPublicServerPage(cursor)
		if not payload then
			return nil, err
		end

		for _, server in ipairs(payload.data or {}) do
			local serverId = tostring(server.id or "")
			local playing = tonumber(server.playing) or math.huge
			local maxPlayers = tonumber(server.maxPlayers) or math.huge
			if serverId ~= "" and serverId ~= game.JobId and playing < maxPlayers then
				if not bestServer
					or playing < (tonumber(bestServer.playing) or math.huge)
					or (playing == (tonumber(bestServer.playing) or math.huge) and maxPlayers < (tonumber(bestServer.maxPlayers) or math.huge))
				then
					bestServer = server
				end
			end
		end

		cursor = payload.nextPageCursor
		if not cursor or cursor == "" then
			break
		end
	end

	if not bestServer then
		return nil, "no suitable public server found"
	end

	return bestServer, nil
end

function teleportToServerInstance(serverId)
