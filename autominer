function getResolvedInventoryContainer(playerData)
	if not isTable(playerData) then
		return nil
	end

	local container = rawget(playerData, "InventoryContainer") or playerData.InventoryContainer
	if isTable(container) then
		return container
	end

	local getContainer = rawget(playerData, "GetContainer") or playerData.GetContainer
	if type(getContainer) ~= "function" then
		return nil
	end

	local okContainer, resolvedContainer = pcall(getContainer, playerData, "Inventory")
	if okContainer and isTable(resolvedContainer) then
		playerData.InventoryContainer = resolvedContainer
		return resolvedContainer
	end

	return nil
end

function getResolvedLoadoutTable(playerData, playerCharacter)
	if isTable(playerData) then
		local getLoadout = rawget(playerData, "GetLoadout") or playerData.GetLoadout
		if type(getLoadout) == "function" then
			local okLoadout, loadout = pcall(getLoadout, playerData)
			if okLoadout and isTable(loadout) then
				return loadout
			end
		end
	end

	if isTable(playerCharacter) then
		local state = rawget(playerCharacter, "State") or playerCharacter.State
		local loadout = isTable(state) and (rawget(state, "Loadout") or state.Loadout) or nil
		if isTable(loadout) then
			return loadout
		end
	end

	return nil
end

function resolveInventoryItemById(playerData, itemId)
	if not isTable(playerData) or type(itemId) ~= "string" or itemId == "" then
		return nil
	end

	local getInventoryItemWithId = rawget(playerData, "GetInventoryItemWithId") or playerData.GetInventoryItemWithId
	if type(getInventoryItemWithId) == "function" then
		local okItem, inventoryItem = pcall(getInventoryItemWithId, playerData, itemId)
		if okItem and isTable(inventoryItem) then
			return inventoryItem
		end
	end

	local inventoryContainer = getResolvedInventoryContainer(playerData)
	if not isTable(inventoryContainer) then
		return nil
	end

	local getItem = rawget(inventoryContainer, "GetItem") or inventoryContainer.GetItem
	if type(getItem) == "function" then
		local okItem, inventoryItem = pcall(getItem, inventoryContainer, itemId)
		if okItem and isTable(inventoryItem) then
			return inventoryItem
		end
	end

	local itemsById = rawget(inventoryContainer, "ItemsById") or inventoryContainer.ItemsById
	if isTable(itemsById) then
		local inventoryItem = rawget(itemsById, itemId) or itemsById[itemId]
		if isTable(inventoryItem) then
			return inventoryItem
		end
	end

	return nil
end

function findPickaxeLoadoutItem(playerData, playerCharacter, playerItems)
	local loadout = getResolvedLoadoutTable(playerData, playerCharacter)
	if not isTable(loadout) then
		return nil
	end

	local bestItem = nil
	local bestSlotType = nil
	local bestSlotIndex = nil
	local bestScore = 0

	for slotType, slots in pairs(loadout) do
		if isTable(slots) then
			for slotIndex, assignedItem in pairs(slots) do
				local score = scorePickaxeItemCandidate(assignedItem, playerItems)
				if score > bestScore then
					local itemId = isTable(assignedItem) and (rawget(assignedItem, "Id") or assignedItem.Id) or nil
					local resolvedItem = resolveInventoryItemById(playerData, itemId) or getResolvedItemData(assignedItem)
					if isTable(resolvedItem) then
						bestScore = score
						bestItem = resolvedItem
						bestSlotType = tostring(slotType)
						bestSlotIndex = tonumber(slotIndex) or slotIndex
					end
				end
			end
		end
	end

	return bestItem, bestSlotType, bestSlotIndex
end

function findInventoryPickaxeItem(playerData, playerItems, preferredItem)
	local preferredId = isTable(preferredItem) and (rawget(preferredItem, "Id") or preferredItem.Id) or nil
	local preferredInventoryItem = resolveInventoryItemById(playerData, preferredId)

	local inventoryContainer = getResolvedInventoryContainer(playerData)
	if not isTable(inventoryContainer) then
		return isLikelyPickaxeItem(preferredInventoryItem, playerItems) and preferredInventoryItem or nil
	end

	local items = rawget(inventoryContainer, "Items") or inventoryContainer.Items
	if not isTable(items) then
		return isLikelyPickaxeItem(preferredInventoryItem, playerItems) and preferredInventoryItem or nil
	end

	local bestItem = nil
	local bestScore = scorePickaxeItemCandidate(preferredInventoryItem, playerItems)
	if bestScore > 0 then
		bestItem = preferredInventoryItem
	end
	for _, inventoryItem in pairs(items) do
		local score = scorePickaxeItemCandidate(inventoryItem, playerItems)
		if score > bestScore then
			bestScore = score
			bestItem = inventoryItem
		end
	end

	return bestItem
end

function getPickaxeEquipmentType(item, playerItems, playerData, playerCharacter)
	item = getResolvedItemData(item)
	if not isTable(item) then
		return nil
	end

	local sharedData = resolveSharedItemData(playerItems, item)
	local equipmentType = rawget(item, "EquipmentType") or item.EquipmentType
		or (isTable(sharedData) and (rawget(sharedData, "EquipmentType") or sharedData.EquipmentType))
	if type(equipmentType) == "string" and equipmentType ~= "" then
		return equipmentType
	end

	local _, slotType = findPickaxeLoadoutItem(playerData, playerCharacter, playerItems)
	return slotType
end

function findPreferredLoadoutSlot(playerData, slotType, preferredItemId)
	if type(slotType) ~= "string" or slotType == "" then
		return nil
	end

	local loadout = getResolvedLoadoutTable(playerData)
	local slots = isTable(loadout) and loadout[slotType] or nil
	if not isTable(slots) then
		return 1
	end

	local matchingIndex = nil
	local openIndex = nil
	local fallbackIndex = nil

	for slotIndex, assignedItem in pairs(slots) do
		local numericIndex = tonumber(slotIndex) or slotIndex
		if type(numericIndex) == "number" then
			if fallbackIndex == nil or numericIndex < fallbackIndex then
				fallbackIndex = numericIndex
			end

			local assignedId = isTable(assignedItem) and (rawget(assignedItem, "Id") or assignedItem.Id) or nil
			if type(preferredItemId) == "string" and assignedId == preferredItemId then
				matchingIndex = numericIndex
			elseif not assignedItem and (openIndex == nil or numericIndex < openIndex) then
				openIndex = numericIndex
			end
		end
	end

	return matchingIndex or openIndex or fallbackIndex or 1
end

function hasPendingLoadoutSync(playerData)
	local replicatedState = resolveGlobalReplicatedState(false) or resolveGlobalReplicatedState(true)
	if isTable(replicatedState) then
		local state = rawget(replicatedState, "State") or replicatedState.State
		local recent = isTable(state) and (rawget(state, "RecentlyAddedToLoadout") or state.RecentlyAddedToLoadout) or nil
