function getPlayerEspEntry(player)
    local entry = playerEspState.entries[player]
    if entry then
        return entry
    end

    local okDrawing = type(Drawing) == "table" and type(Drawing.new) == "function"
    if not okDrawing then
        if not playerEspState.warnedUnavailable then
            playerEspState.warnedUnavailable = true
            spawnNotification("Drawing API unavailable. Player ESP could not start.", "warning", true)
        end
        return nil
    end

    entry = {
        text = Drawing.new("Text"),
        box = Drawing.new("Square"),
        tracer = Drawing.new("Line"),
        figureLines = {},
    }

    entry.text.Center = true
    entry.text.Outline = true
    entry.text.Size = 13
    entry.text.Font = 2
    entry.text.Visible = false

    entry.box.Filled = false
    entry.box.Thickness = 1.6
    entry.box.Visible = false

    entry.tracer.Thickness = 1.4
    entry.tracer.Visible = false

    for index = 1, 6 do
        local line = Drawing.new("Line")
        line.Thickness = 1.3
        line.Visible = false
        entry.figureLines[index] = line
    end

    playerEspState.entries[player] = entry
    return entry
end

function hidePlayerEspEntry(entry)
    if not entry then
        return
    end

    if entry.text then
        entry.text.Visible = false
    end
    if entry.box then
        entry.box.Visible = false
    end
    if entry.tracer then
        entry.tracer.Visible = false
    end
    if type(entry.figureLines) == "table" then
        for _, line in ipairs(entry.figureLines) do
            if line then
                line.Visible = false
            end
        end
    end
end

function clearPlayerEspEntry(player)
    local entry = playerEspState.entries[player]
    if not entry then
        return
    end

    local function removeDrawingObject(object)
        if object and type(object.Remove) == "function" then
            pcall(function()
                object:Remove()
            end)
        end
    end

    removeDrawingObject(entry.text)
    removeDrawingObject(entry.box)
    removeDrawingObject(entry.tracer)
    if type(entry.figureLines) == "table" then
        for _, line in ipairs(entry.figureLines) do
            removeDrawingObject(line)
        end
    end

    playerEspState.entries[player] = nil
end

function clearAllPlayerEspEntries()
    for player in pairs(playerEspState.entries) do
        clearPlayerEspEntry(player)
    end
end

function getModelScreenBounds(camera, model)
    if not camera or not model or not model:IsA("Model") then
        return nil
    end

    local okBounds, cf, size = pcall(function()
        return model:GetBoundingBox()
    end)
    if not okBounds or not cf or not size then
        return nil
    end

    local half = size * 0.5
    local corners = {
        cf * Vector3.new(half.X, half.Y, half.Z),
        cf * Vector3.new(-half.X, half.Y, half.Z),
        cf * Vector3.new(half.X, -half.Y, half.Z),
        cf * Vector3.new(-half.X, -half.Y, half.Z),
        cf * Vector3.new(half.X, half.Y, -half.Z),
        cf * Vector3.new(-half.X, half.Y, -half.Z),
        cf * Vector3.new(half.X, -half.Y, -half.Z),
        cf * Vector3.new(-half.X, -half.Y, -half.Z),
    }

    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    local onScreen = false

    for _, corner in ipairs(corners) do
        local projected, visible = camera:WorldToViewportPoint(corner)
        if visible then
            onScreen = true
        end
        minX = math.min(minX, projected.X)
        minY = math.min(minY, projected.Y)
        maxX = math.max(maxX, projected.X)
        maxY = math.max(maxY, projected.Y)
    end

    if not onScreen or minX == math.huge or minY == math.huge then
        return nil
    end

    return minX, minY, maxX, maxY
end

function getCharacterFigureSegments(character)
    if not character then
        return {}
    end

    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso") or character:FindFirstChild("LowerTorso")
    local lowerTorso = character:FindFirstChild("LowerTorso") or torso
    local head = character:FindFirstChild("Head")
    local leftArm = character:FindFirstChild("LeftHand")
        or character:FindFirstChild("LeftLowerArm")
        or character:FindFirstChild("LeftUpperArm")
        or character:FindFirstChild("Left Arm")
    local rightArm = character:FindFirstChild("RightHand")
        or character:FindFirstChild("RightLowerArm")
        or character:FindFirstChild("RightUpperArm")
        or character:FindFirstChild("Right Arm")
    local leftLeg = character:FindFirstChild("LeftFoot")
        or character:FindFirstChild("LeftLowerLeg")
        or character:FindFirstChild("LeftUpperLeg")
        or character:FindFirstChild("Left Leg")
    local rightLeg = character:FindFirstChild("RightFoot")
        or character:FindFirstChild("RightLowerLeg")
        or character:FindFirstChild("RightUpperLeg")
        or character:FindFirstChild("Right Leg")

    local segments = {}
    local function addSegment(partA, partB)
        if partA and partB then
            table.insert(segments, {partA.Position, partB.Position})
        end
    end

    addSegment(head, torso)
    addSegment(torso, lowerTorso)
    addSegment(torso, leftArm)
    addSegment(torso, rightArm)
    addSegment(lowerTorso, leftLeg)
    addSegment(lowerTorso, rightLeg)

    return segments
end

function updatePlayerEsp()
    if not S.playerEspEnabled or destroyed or not isSessionActive() then
        for _, entry in pairs(playerEspState.entries) do
            hidePlayerEspEntry(entry)
        end
        return
    end

    local camera = workspace.CurrentCamera
    if not camera then
        return
    end

    local localCharacter = getWorldCharacterForPlayer(localPlayer) or localPlayer.Character
    local localRoot = getRootPart(localCharacter)
    local tracerStart = Vector2.new(camera.ViewportSize.X * 0.5, camera.ViewportSize.Y - 24)
    local showText = isPlayerEspMethodEnabled("Text")
    local showBox = isPlayerEspMethodEnabled("Box")
    local showTracer = isPlayerEspMethodEnabled("Tracer")
    local showFigure = isPlayerEspMethodEnabled("Figure")
    if not (showText or showBox or showTracer or showFigure) then
        for _, entry in pairs(playerEspState.entries) do
            hidePlayerEspEntry(entry)
        end
        return
    end
    if localRoot then
        local localProjected, localVisible = camera:WorldToViewportPoint(localRoot.Position)
        if localVisible then
            tracerStart = Vector2.new(localProjected.X, localProjected.Y)
        end
    end

    for _, player in ipairs(_Players:GetPlayers()) do
        if player ~= localPlayer then
            local entry = getPlayerEspEntry(player)
            if entry then
                hidePlayerEspEntry(entry)

                local character = getWorldCharacterForPlayer(player)
                local rootPart = getRootPart(character)
                if character and rootPart and isCharacterAlive(character) then
                    local rootScreen, rootVisible = camera:WorldToViewportPoint(rootPart.Position)
                    local head = character:FindFirstChild("Head") or rootPart
                    local headScreen, headVisible = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.85, 0))
                    local distance = localRoot and math.floor((rootPart.Position - localRoot.Position).Magnitude + 0.5) or 0
                    local espColor = getPlayerEspRoleColor(player)

                    if showText and headVisible then
                        entry.text.Text = string.format("%s [%d studs]", player.Name, distance)
                        entry.text.Position = Vector2.new(headScreen.X, headScreen.Y)
                        entry.text.Color = espColor
                        entry.text.Visible = true
                    end

                    if showBox then
                        local minX, minY, maxX, maxY = getModelScreenBounds(camera, character)
                        if minX and maxX and maxX > minX and maxY > minY then
                            entry.box.Position = Vector2.new(minX, minY)
                            entry.box.Size = Vector2.new(maxX - minX, maxY - minY)
                            entry.box.Color = espColor
                            entry.box.Visible = true
                        end
                    end

                    if showTracer and rootVisible then
                        entry.tracer.From = tracerStart
                        entry.tracer.To = Vector2.new(rootScreen.X, rootScreen.Y)
                        entry.tracer.Color = espColor
                        entry.tracer.Visible = true
                    end

                    if showFigure then
                        local segments = getCharacterFigureSegments(character)
                        for index, line in ipairs(entry.figureLines) do
                            local segment = segments[index]
                            if line and segment then
                                local pointA, visibleA = camera:WorldToViewportPoint(segment[1])
                                local pointB, visibleB = camera:WorldToViewportPoint(segment[2])
                                if visibleA and visibleB then
                                    line.From = Vector2.new(pointA.X, pointA.Y)
                                    line.To = Vector2.new(pointB.X, pointB.Y)
                                    line.Color = espColor
                                    line.Visible = true
                                else
                                    line.Visible = false
                                end
                            elseif line then
                                line.Visible = false
                            end
                        end
                    end
                end
            end
        end
    end
end

function ensurePlayerEspRenderLoop()
    if playerEspState.renderConnection then
        return
    end

    local renderAccumulator = 0
    playerEspState.renderConnection = _RunService.RenderStepped:Connect(function(dt)
        if destroyed or not isSessionActive() then
            if playerEspState.renderConnection then
                playerEspState.renderConnection:Disconnect()
                playerEspState.renderConnection = nil
            end
            clearAllPlayerEspEntries()
            return
        end
        renderAccumulator = renderAccumulator + (tonumber(dt) or 0.016)
        if renderAccumulator < (1 / 30) then
            return
        end
        renderAccumulator = 0
        updatePlayerEsp()
    end)
end

