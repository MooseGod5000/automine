function recomputeWorkingPathSellNode()
	pathState.sellNodeIndex = nil

	local manualSellNodeIndex = getManualPathSellNodeIndex(pathState.workingPath)
	if manualSellNodeIndex then
		pathState.workingPath.manualSellNodeIndex = manualSellNodeIndex
		pathState.sellNodeIndex = manualSellNodeIndex
		pathState.sellNodeDirty = false
		return pathState.sellNodeIndex
	end

	pathState.workingPath.manualSellNodeIndex = nil
	local forceRefresh = (not cachedAutoSellTargets)
		or (#cachedAutoSellTargets == 0 and (os.clock() - lastAutoSellTargetScanAt) >= 3)
	local _, _, bestIndex, bestDistance = getBestSellTargetForPath(pathState.workingPath, nil, forceRefresh)
	if bestIndex and bestDistance and bestDistance <= PATH_RECORD_SELL_DISTANCE then
		pathState.sellNodeIndex = bestIndex
	end
	pathState.sellNodeDirty = false

	return pathState.sellNodeIndex
end

function truncateWorkingPathFromIndex(startIndex)
	if not startIndex or startIndex < 1 then
		return
	end

	for index = #pathState.workingPath.nodes, startIndex, -1 do
		table.remove(pathState.workingPath.nodes, index)
	end

	for index = #pathState.workingPath.ores, 1, -1 do
		if (pathState.workingPath.ores[index].nodeIndex or 0) >= startIndex then
			table.remove(pathState.workingPath.ores, index)
		end
	end

	if pathState.workingPath.manualSellNodeIndex and pathState.workingPath.manualSellNodeIndex >= startIndex then
		pathState.workingPath.manualSellNodeIndex = nil
	end

	pathState.sellNodeDirty = true
	recomputeWorkingPathSellNode()
end

function getOreDepositFromInstance(instance)
	local oreDepositsGetter = rawget(_G, "getOreDepositsFolder")
	local oreDeposits = oreDepositsGetter and oreDepositsGetter() or nil
	if not oreDeposits or typeof(instance) ~= "Instance" then
		return nil
	end

	local cursor = instance
	while cursor and cursor ~= workspace do
		if cursor.Parent and cursor.Parent.Parent == oreDeposits then
			return cursor
		end
		cursor = cursor.Parent
	end

	return nil
end

function resolveSavedOreTarget(oreTarget)
	if not oreTarget or not oreTarget.groupName or not oreTarget.position then
		return nil
	end

	local oreDepositsGetter = rawget(_G, "getOreDepositsFolder")
	local orePositionGetter = rawget(_G, "getOrePosition")
	local oreAvailableGetter = rawget(_G, "isOreAvailable")
	local oreDeposits = oreDepositsGetter and oreDepositsGetter() or nil
	local oreFolder = oreDeposits and oreDeposits:FindFirstChild(oreTarget.groupName)
	if not oreFolder or not orePositionGetter or not oreAvailableGetter then
		return nil
	end

	local bestOre = nil
	local bestDistance = nil
	for _, oreDeposit in ipairs(oreFolder:GetChildren()) do
		if oreAvailableGetter(oreDeposit) then
			local orePosition = orePositionGetter(oreDeposit)
			if orePosition then
				local distance = (orePosition - oreTarget.position).Magnitude
				if not bestDistance or distance < bestDistance then
					bestDistance = distance
					bestOre = oreDeposit
				end
			end
		end
	end

	if bestDistance and bestDistance <= 18 then
		return bestOre
	end

	return nil
end

function getCustomCharacter()
