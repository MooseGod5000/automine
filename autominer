function getLassoSilentAimTargetInfo()
    local camera = workspace.CurrentCamera
    if not camera then
        return nil
    end

    local cursorPosition = getGunAimCursorPosition()
    local maxDistance = math.min(
        math.clamp(tonumber(S.silentAimDistanceLimit) or 1000, 10, 20000),
        LASSO_SILENT_AIM_MAX_DISTANCE
    )

    local function findBestTarget(candidates)
        local bestTarget = nil
        local bestScore = nil

        for _, candidate in ipairs(candidates) do
            local targetPart = candidate.part
            local targetCharacter = candidate.character
            local worldDistance = (targetPart.Position - camera.CFrame.Position).Magnitude
            if worldDistance <= maxDistance then
                local screenPoint, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                if onScreen and isSilentAimLineOfSightClear(targetPart, targetCharacter) then
                    local screenVector = Vector2.new(screenPoint.X, screenPoint.Y)
                    local screenDistance = (screenVector - cursorPosition).Magnitude
                    if not bestTarget or not bestScore or screenDistance < bestScore then
                        candidate.screenPosition = screenVector
                        candidate.screenDistance = screenDistance
                        candidate.worldDistance = worldDistance
                        candidate.position = targetPart.Position
                        bestTarget = candidate
                        bestScore = screenDistance
                    end
                end
            end
        end

        return bestTarget
    end

    local playerTargets = {}
    for _, player in ipairs(_Players:GetPlayers()) do
        if player ~= localPlayer then
            local _, character = getAliveTwwTargetData(player)
            local candidate = buildLassoSilentAimTargetInfo("Players", character, player)
            if candidate then
                table.insert(playerTargets, candidate)
            end
        end
    end
    local bestPlayerTarget = findBestTarget(playerTargets)
    if bestPlayerTarget then
        return bestPlayerTarget
    end

    local npcTargets = {}
    local entitiesFolder = workspace:FindFirstChild("WORKSPACE_Entities")
    local npcsFolder = entitiesFolder and entitiesFolder:FindFirstChild("NPCs")
    if npcsFolder then
        for _, model in ipairs(npcsFolder:GetChildren()) do
            local candidate = buildLassoSilentAimTargetInfo("NPCs", model, nil)
            if candidate then
                table.insert(npcTargets, candidate)
            end
        end
    end

    return findBestTarget(npcTargets)
end

function solveLassoSilentAimVelocity(origin, speed, targetInfo)
    if typeof(origin) ~= "Vector3" or type(speed) ~= "number" or speed <= 0.001 or not targetInfo then
        return nil
    end

    local targetPosition = targetInfo.position
    if typeof(targetPosition) ~= "Vector3" then
        return nil
    end

    local distance = (targetPosition - origin).Magnitude
    local travelTime = distance > 0.001 and (distance / speed) or 0
    local targetPart = targetInfo.part
    if targetPart and travelTime and travelTime > 0 then
        local assemblyVelocity = targetPart.AssemblyLinearVelocity
        if typeof(assemblyVelocity) == "Vector3" and assemblyVelocity.Magnitude > 0.05 then
            targetPosition = targetPosition + (assemblyVelocity * math.min(travelTime, 1.25))
        end
    end

    local directVector = targetPosition - origin
    if directVector.Magnitude > 0.001 then
        return directVector.Unit * speed
    end

    return nil
end

