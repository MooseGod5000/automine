        _TweenService:Create(resetFeedbackCdBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 28, 22)}):Play()
    end)
    resetFeedbackCdBtn.MouseButton1Click:Connect(function()
        _UTILS._createParticleBurst(resetFeedbackCdBtn)
        spawnNotification("There is no feedback cooldown in GUI-only mode.", "warning", true)
    end)

    local homeInfoLastTick = 0
    _RunService.Heartbeat:Connect(function()
        if destroyed or not isSessionActive() then
            return
        end
        local now = tick()
        if now - homeInfoLastTick < 0.3 then
            return
        end
        homeInfoLastTick = now
        if dashboardLabels.session then
            dashboardLabels.session.Text = "current session: " .. formatCompactDuration(now - _SCRIPT_SESSION_START_TICK)
        end
    end)

    refreshDashboard()
end

