        if os.clock() < ignoreHeaderToggleUntil then
            return
        end
        _UTILS._createParticleBurst(headerBtn)
        sectionIsExpanded = not sectionIsExpanded
        if sectionIsExpanded then
            local targetH = sectionLayout.AbsoluteContentSize.Y
            arrow.Text = expandedToggleText
            _TweenService:Create(sectionContainer, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                Size = UDim2.new(1, 0, 0, targetH)
            }):Play()
            _TweenService:Create(headerIcon, TweenInfo.new(0.2), {BackgroundColor3 = Color3.new(1, 1, 1)}):Play()
            _TweenService:Create(arrow, TweenInfo.new(0.2), {TextColor3 = Color3.new(1, 1, 1)}):Play()
        else
            arrow.Text = collapsedToggleText
            _TweenService:Create(sectionContainer, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
                Size = UDim2.new(1, 0, 0, 0)
            }):Play()
            _TweenService:Create(headerIcon, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 255)}):Play()
            _TweenService:Create(arrow, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
        end
    end)

    headerBtn.MouseEnter:Connect(function()
        if destroyed then
            return
        end
        _TweenService:Create(headerBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(28, 28, 28)}):Play()
        _TweenService:Create(headerLabel, TweenInfo.new(0.2), {TextColor3 = Color3.new(1, 1, 1)}):Play()
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        _TweenService:Create(headerTopLine, tweenInfo, {Size = UDim2.new(1, 0, 0, 2)}):Play()
        _TweenService:Create(headerBotLine, tweenInfo, {Size = UDim2.new(1, 0, 0, 2)}):Play()
    end)

    headerBtn.MouseLeave:Connect(function()
        if destroyed then
            return
        end
        _TweenService:Create(headerBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(18, 18, 18)}):Play()
        _TweenService:Create(headerLabel, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 150, 255)}):Play()
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        _TweenService:Create(headerTopLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
        _TweenService:Create(headerBotLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
    end)

    return sectionList, headerLabel, removeButton
end

local function getDynamitePlayerOptions()
