	local method = rawget(playerCharacter, methodName) or playerCharacter[methodName]
	if type(method) ~= "function" then
		return nil
	end

	local okResult, result = pcall(method, playerCharacter)
	if not okResult then
		return nil
	end

	return getResolvedItemData(result)
end

function getCurrentEquippedItemData(playerCharacter)
