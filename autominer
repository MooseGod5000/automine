function normalizePathSlotIndex(slotIndex)
	local numericIndex = tonumber(slotIndex)
	if not numericIndex then
		return nil
	end
	numericIndex = math.floor(numericIndex + 0.5)
	if numericIndex < 1 or numericIndex > MAX_PATH_PLAYBACK_SLOTS then
		return nil
	end
	return numericIndex
end

function ensurePathSlotState()
	if type(pathState.pathSlots) ~= "table" then
		pathState.pathSlots = {}
	end
	for slotIndex = 1, MAX_PATH_PLAYBACK_SLOTS do
		local slotName = pathState.pathSlots[slotIndex]
		pathState.pathSlots[slotIndex] = type(slotName) == "string" and slotName or nil
	end
	pathState.pathSectionCount = math.clamp(math.floor(tonumber(pathState.pathSectionCount) or 1), 1, MAX_PATH_PLAYBACK_SLOTS)
	pathState.focusedPathSlotIndex = normalizePathSlotIndex(pathState.focusedPathSlotIndex) or 1
	pathState.sequenceStartSlotIndex = normalizePathSlotIndex(pathState.sequenceStartSlotIndex) or 1
	pathState.focusedPathSlotIndex = math.clamp(pathState.focusedPathSlotIndex, 1, pathState.pathSectionCount)
	pathState.sequenceStartSlotIndex = math.clamp(pathState.sequenceStartSlotIndex, 1, pathState.pathSectionCount)
	pathState.deleteConfirmSlotIndex = normalizePathSlotIndex(pathState.deleteConfirmSlotIndex)
	pathState.spawnPlaybackPendingSlotIndex = normalizePathSlotIndex(pathState.spawnPlaybackPendingSlotIndex)
	pathState.spawnPlaybackReadySlotIndex = normalizePathSlotIndex(pathState.spawnPlaybackReadySlotIndex)
	pathState.playbackSlotIndex = normalizePathSlotIndex(pathState.playbackSlotIndex)
end

function getPathSlotSelection(slotIndex, allowMissingPath)
	ensurePathSlotState()
