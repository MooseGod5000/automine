            tryMarkHoveredOre()
            return
        end
        if gameProcessed then
            return
        end
    end)

    _UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or not pathState.editorVisible then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mouse = localPlayer:GetMouse()
            local target = mouse and mouse.Target
            local nodeIndex = target and target:GetAttribute("PathNodeIndex")
            local axisName = target and target:GetAttribute("PathNodeAxis")
            if nodeIndex then
                nodeIndex = tonumber(nodeIndex)
                if pathState.sellNodePickMode then
                    applyWorkingPathSellNodeSelection(nodeIndex)
                elseif pathState.deleteMode then
                    pathState.selectedNodeIndex = nil
                    pathState.draggingNodeIndex = nil
                    pathState.draggingNodeAxis = nil
                    pathState.dragLastPointerPosition = nil
                    truncateWorkingPathFromIndex(nodeIndex)
                    refreshPathVisuals()
                    refreshPathEditorButtons()
                    setPathEditorStatus("Deleted nodes from #" .. tostring(nodeIndex) .. " onward.", UI_COLORS.warning)
                else
                    pathState.selectedNodeIndex = nodeIndex
                    if not pathState.editNodePlacementEnabled then
                        pathState.draggingNodeIndex = nil
                        pathState.draggingNodeAxis = nil
                        pathState.dragLastPointerPosition = nil
                        refreshPathVisuals()
                        refreshPathEditorButtons()
                        setPathEditorStatus("Turn on Edit node placement to move nodes.", UI_COLORS.warning)
                        return
                    end
                    pathState.selectedNodeIndex = nodeIndex
                    pathState.draggingNodeIndex = nodeIndex
                    pathState.draggingNodeAxis = axisName and tostring(axisName) or "FREE"
                    pathState.dragLastPointerPosition = input.Position
                    refreshPathVisuals()
                    refreshPathEditorButtons()
                    if axisName then
                        setPathEditorStatus("Adjusting node #" .. tostring(nodeIndex) .. " on the " .. tostring(axisName) .. " axis.", UI_COLORS.accent)
                    else
                        setPathEditorStatus("Dragging node #" .. tostring(nodeIndex), UI_COLORS.accent)
                    end
                end
            elseif pathState.sellNodePickMode then
                setPathEditorStatus("Sell-node picker is on. Click one of the route nodes.", UI_COLORS.warning)
            elseif pathState.selectedNodeIndex then
                pathState.selectedNodeIndex = nil
                pathState.draggingNodeIndex = nil
                pathState.draggingNodeAxis = nil
                pathState.dragLastPointerPosition = nil
                refreshPathVisuals()
                refreshPathEditorButtons()
                setPathEditorStatus("Node edit cleared.", UI_COLORS.muted)
            end
        end
    end)

    _UserInputService.InputChanged:Connect(function(input)
