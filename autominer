function getSilentAimTargetsByPriority()
    local groupedTargets = {
        Players = {},
        NPCs = {},
        Entities = {},
    }

    for _, player in ipairs(_Players:GetPlayers()) do
        if player ~= localPlayer then
            local _, character = getAliveTwwTargetData(player)
            local candidate = buildSilentAimTargetInfo("Players", character, player)
            if candidate then
                table.insert(groupedTargets.Players, candidate)
            end
        end
    end

    local entitiesFolder = workspace:FindFirstChild("WORKSPACE_Entities")
    local npcsFolder = entitiesFolder and entitiesFolder:FindFirstChild("NPCs")
    if npcsFolder then
        for _, model in ipairs(npcsFolder:GetChildren()) do
            local candidate = buildSilentAimTargetInfo("NPCs", model, nil)
            if candidate then
                table.insert(groupedTargets.NPCs, candidate)
            end
        end
    end

    local animalsFolder = entitiesFolder and entitiesFolder:FindFirstChild("Animals")
    if animalsFolder then
        for _, model in ipairs(animalsFolder:GetChildren()) do
            local candidate = buildSilentAimTargetInfo("Entities", model, nil)
            if candidate then
                table.insert(groupedTargets.Entities, candidate)
            end
        end
    end

    return groupedTargets
end

function isSilentAimLineOfSightClear(targetPart, targetCharacter)
    if not S.silentAimVisibilityCheck then
        return true
    end
    if S.wallBangEnabled then
        return true
    end

    local camera = workspace.CurrentCamera
    if not camera or not targetPart then
        return false
    end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude

    local ignoreList = {}
    local localCharacter = getWorldCharacterForPlayer(localPlayer) or localPlayer.Character
    if localCharacter then
        table.insert(ignoreList, localCharacter)
    end
    local ignoreFolder = workspace:FindFirstChild("Ignore")
    if ignoreFolder then
        table.insert(ignoreList, ignoreFolder)
    end
    params.FilterDescendantsInstances = ignoreList

    local direction = targetPart.Position - camera.CFrame.Position
    local result = workspace:Raycast(camera.CFrame.Position, direction, params)
    if not result then
        return true
    end

    return targetCharacter and result.Instance and result.Instance:IsDescendantOf(targetCharacter)
end

function getSilentAimTargetInfo()
    local camera = workspace.CurrentCamera
    if not camera then
        return nil
    end

    local cursorPosition = getGunAimCursorPosition()
    local maxDistance = math.clamp(tonumber(S.silentAimDistanceLimit) or 1000, 10, 20000)
    local fovRadius = math.clamp(tonumber(S.gunFovRadius) or 200, 10, 2000)
    local useFovMode = tostring(S.silentAimMode or "FOV") == "FOV"
    local groupedTargets = getSilentAimTargetsByPriority()

    for _, priorityName in ipairs(getSilentAimPriorityOrder()) do
        local bestTarget = nil
        local bestScore = nil
        for _, candidate in ipairs(groupedTargets[priorityName] or {}) do
            local targetPart = candidate.part
            local targetCharacter = candidate.character
            local worldDistance = (targetPart.Position - camera.CFrame.Position).Magnitude
            if worldDistance <= maxDistance then
                local screenPoint, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                if onScreen and isSilentAimLineOfSightClear(targetPart, targetCharacter) then
                    local screenVector = Vector2.new(screenPoint.X, screenPoint.Y)
                    local screenDistance = (screenVector - cursorPosition).Magnitude
                    if (not useFovMode) or screenDistance <= fovRadius then
                        local candidateScore = useFovMode and screenDistance or worldDistance
                        if not bestTarget or not bestScore or candidateScore < bestScore then
                            candidate.screenPosition = screenVector
                            candidate.screenDistance = screenDistance
                            candidate.worldDistance = worldDistance
                            candidate.position = targetPart.Position
                            bestTarget = candidate
                            bestScore = candidateScore
                        end
                    end
                end
            end
        end
        if bestTarget then
            return bestTarget
        end
    end

    return nil
end

