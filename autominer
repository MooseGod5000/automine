local function remapPathSlotIndexAfterRemoval(slotIndex, removedSlotIndex, remainingCount)
	local normalizedSlotIndex = normalizePathSlotIndex(slotIndex)
	if not normalizedSlotIndex then
		return nil
	end
	if normalizedSlotIndex < removedSlotIndex then
		return normalizedSlotIndex
	end
	if normalizedSlotIndex > removedSlotIndex then
		return normalizedSlotIndex - 1
	end
	if remainingCount < 1 then
		return nil
	end
	return math.clamp(removedSlotIndex, 1, remainingCount)
end

function removePathSection(slotIndex)
	ensurePathSlotState()
	local removedSlotIndex = normalizePathSlotIndex(slotIndex)
	if not removedSlotIndex or removedSlotIndex > pathState.pathSectionCount then
		return false
	end
	if pathState.pathSectionCount <= 1 then
		notifyUser("Paths", "Keep at least one path section.", 4)
		return false
	end
	if isPathPlaybackBusy() or pathState.spawnPlaybackPending or pathState.spawnPlaybackAwaitingRespawn then
		notifyUser("Paths", "Stop path farming before removing a path section.", 4)
		return false
	end
	if pathState.editorVisible or pathState.recording then
		notifyUser("Paths", "Close the path editor before removing a path section.", 4)
		return false
	end

	local previousCount = pathState.pathSectionCount
	for index = removedSlotIndex, previousCount - 1 do
		pathState.pathSlots[index] = pathState.pathSlots[index + 1]
	end
	pathState.pathSlots[previousCount] = nil

	local remainingCount = previousCount - 1
	pathState.pathSectionCount = remainingCount
	pathState.focusedPathSlotIndex = remapPathSlotIndexAfterRemoval(pathState.focusedPathSlotIndex, removedSlotIndex, remainingCount) or 1
	pathState.sequenceStartSlotIndex = remapPathSlotIndexAfterRemoval(pathState.sequenceStartSlotIndex, removedSlotIndex, remainingCount) or 1
	pathState.spawnPlaybackPendingSlotIndex = remapPathSlotIndexAfterRemoval(pathState.spawnPlaybackPendingSlotIndex, removedSlotIndex, remainingCount)
	pathState.spawnPlaybackReadySlotIndex = remapPathSlotIndexAfterRemoval(pathState.spawnPlaybackReadySlotIndex, removedSlotIndex, remainingCount)
	pathState.playbackSlotIndex = remapPathSlotIndexAfterRemoval(pathState.playbackSlotIndex, removedSlotIndex, remainingCount)
	pathState.deleteConfirmSlotIndex = nil

	ensurePathSlotState()
	setFocusedPathSlotIndex(pathState.focusedPathSlotIndex, true)
	savePathsToStorage(false)
	return true
end

function setPathSlotSelection(slotIndex, pathName, options)
	options = options or {}
	ensurePathSlotState()
	local normalizedSlotIndex = normalizePathSlotIndex(slotIndex)
	if not normalizedSlotIndex then
		return false
	end

	local normalizedPathName = type(pathName) == "string" and pathName or nil
	if normalizedPathName and pathState.paths[normalizedPathName] == nil then
		normalizedPathName = nil
	end
	pathState.pathSlots[normalizedSlotIndex] = normalizedPathName
	if normalizedSlotIndex == (normalizePathSlotIndex(pathState.spawnPlaybackPendingSlotIndex) or 0) and normalizedPathName == nil then
		cancelPendingPathSpawnPlayback(true)
	end
	if normalizedSlotIndex == (normalizePathSlotIndex(pathState.spawnPlaybackReadySlotIndex) or 0) and normalizedPathName == nil then
		clearPathSpawnReadyState()
	end
	setFocusedPathSlotIndex(normalizedSlotIndex, options.syncSelectedPath ~= false)
	if options.updateStartSlot and normalizedPathName then
		setPathSequenceStartSlotIndex(normalizedSlotIndex)
	end
	return true
end

