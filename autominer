function getTwwPlayerFromTarget(target)
    local playersFolder = getTwwEntityPlayersFolder()
    local current = target
    while current and current ~= playersFolder do
        if current.Parent == playersFolder then
            return _Players:FindFirstChild(current.Name)
        end
        current = current.Parent
    end
    return nil
end

function getAliveTwwTargetData(playerName)
    local player = type(playerName) == "Instance" and playerName or _Players:FindFirstChild(tostring(playerName or ""))
    if not player or player == localPlayer then
        return nil
    end

    local character = getWorldCharacterForPlayer(player)
    local rootPart = getTwwModelRoot(character)
    if character and rootPart and isCharacterAlive(character) then
        return player, character, rootPart
    end

    return nil
end

function refreshDynamiteMarkVisuals()
    if type(S._dynamiteMarkVisuals) ~= "table" then
        S._dynamiteMarkVisuals = {}
    end

    local activeVisuals = {}
    if not (S.dynamiteTarget == "Player" and S.dynamiteMarkPlayersEnabled) then
        for playerName in pairs(S._dynamiteMarkVisuals) do
            destroyDynamiteMarkVisual(playerName)
        end
        return
    end

    for index, playerName in ipairs(getDynamiteMarkedPlayers()) do
        local player, character, rootPart = getAliveTwwTargetData(playerName)
        if player and character and rootPart then
            activeVisuals[player.Name] = true
            local visuals = S._dynamiteMarkVisuals[player.Name]
            if type(visuals) ~= "table" or not visuals.highlight or not visuals.highlight.Parent then
                visuals = {}

                local highlight = Instance.new("Highlight")
                highlight.Name = "FobDynamiteMark"
                highlight.FillColor = Color3.fromRGB(255, 58, 58)
                highlight.FillTransparency = 0.55
                highlight.OutlineColor = Color3.fromRGB(255, 215, 215)
                highlight.OutlineTransparency = 0
                highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                highlight.Adornee = character
                highlight.Parent = character
                visuals.highlight = highlight

                local billboard = Instance.new("BillboardGui")
                billboard.Name = "FobDynamiteMarkBillboard"
                billboard.AlwaysOnTop = true
                billboard.MaxDistance = 10000
                billboard.Size = UDim2.new(0, 40, 0, 28)
                billboard.StudsOffset = Vector3.new(0, 4.2, 0)
                billboard.Adornee = rootPart
                billboard.Parent = character
                visuals.billboard = billboard

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Font = Enum.Font.GothamBold
                label.TextScaled = true
                label.TextStrokeTransparency = 0
                label.TextColor3 = Color3.fromRGB(255, 70, 70)
                label.Parent = billboard
                visuals.label = label

                S._dynamiteMarkVisuals[player.Name] = visuals
            end

            if visuals.highlight then
                visuals.highlight.Adornee = character
                visuals.highlight.Parent = character
            end
            if visuals.billboard then
                visuals.billboard.Adornee = rootPart
                visuals.billboard.Parent = character
            end
            if visuals.label then
                visuals.label.Text = tostring(index)
            end
        end
    end

    for playerName in pairs(S._dynamiteMarkVisuals) do
        if not activeVisuals[playerName] then
            destroyDynamiteMarkVisual(playerName)
        end
    end
end

function pruneDynamiteMarkedPlayers()
    local order = getDynamiteMarkedPlayers()
    local index = 1
    local changed = false
    while index <= #order do
        local player, character = getAliveTwwTargetData(order[index])
        if not player or not character then
            destroyDynamiteMarkVisual(order[index])
            table.remove(order, index)
            changed = true
        else
            index = index + 1
        end
    end
    if changed then
        schedulePersist()
        refreshDynamiteMarkVisuals()
    end
end

