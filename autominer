function resolveGlobalReplicatedState(forceRefresh)
	local cache = rawget(_G, "__AutoMineGlobalReplicatedState")
	if isTable(cache) and type(cache.LocalSetState) == "function" then
		return cache
	end

	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end
	if not isTable(globalModule) then
		return nil
	end

	local replicatedState = rawget(globalModule, "ReplicatedState") or globalModule.ReplicatedState
	if (not isTable(replicatedState) or type(replicatedState.LocalSetState) ~= "function") and type(globalModule.LoadModule) == "function" then
		local okLoad, loadedReplicatedState = pcall(function()
			return globalModule:LoadModule("ReplicatedState")
		end)
		if okLoad and isTable(loadedReplicatedState) and type(loadedReplicatedState.LocalSetState) == "function" then
			replicatedState = loadedReplicatedState
			globalModule.ReplicatedState = loadedReplicatedState
		end
	end
	if isTable(replicatedState) and type(replicatedState.LocalSetState) == "function" then
		_G.__AutoMineGlobalReplicatedState = replicatedState
