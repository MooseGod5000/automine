function resolveSharedPlayerItemSellMetadata(forceRefresh)
	local cache = rawget(_G, "__AutoMineSharedPlayerItemSellMetadata")
	if isTable(cache) then
		return cache
	end

	local sharedData = resolveSharedDataModule(forceRefresh)
	if not isTable(sharedData) then
		return nil
	end

	local playerItemsRoot = rawget(sharedData, "PlayerItems") or sharedData.PlayerItems
	if not isTable(playerItemsRoot) then
		return nil
	end

	local metadata = {}
	for _, categoryData in pairs(playerItemsRoot) do
		if isTable(categoryData) then
			local items = rawget(categoryData, "Items") or categoryData.Items
			local categoryIsLoot = (rawget(categoryData, "IsLoot") or categoryData.IsLoot) == true
			local categoryVipValueMultiplier = tonumber(rawget(categoryData, "VIPValueMultiplier") or categoryData.VIPValueMultiplier) or 0
			if isTable(items) then
				for itemType, itemData in pairs(items) do
					if type(itemType) == "string" and isTable(itemData) then
						metadata[itemType] = {
							isLoot = ((rawget(itemData, "IsLoot") or itemData.IsLoot) == true) or categoryIsLoot,
							value = tonumber(rawget(itemData, "Value") or itemData.Value) or 0,
							stackSellSize = tonumber(rawget(itemData, "StackSellSize") or itemData.StackSellSize) or 1,
							vipValueMultiplier = tonumber(rawget(itemData, "VIPValueMultiplier") or itemData.VIPValueMultiplier) or categoryVipValueMultiplier,
							display = rawget(itemData, "Display") or itemData.Display or itemType,
						}
					end
				end
			end
		end
	end

	_G.__AutoMineSharedPlayerItemSellMetadata = metadata
	return metadata
end

function playerHasVipSellBonus(forceRefresh)
	local replicatedState = resolveGlobalReplicatedState(forceRefresh)
	if not isTable(replicatedState) then
		return false
	end

	local state = rawget(replicatedState, "State") or replicatedState.State
	if not isTable(state) then
		return false
	end

	if (rawget(state, "VIP") or state.VIP) == true or (rawget(state, "IsVIP") or state.IsVIP) == true then
		return true
	end

	local ownedGamePasses = rawget(state, "OwnedGamePasses") or state.OwnedGamePasses
	if isTable(ownedGamePasses) then
		for key, value in pairs(ownedGamePasses) do
			if value then
				local loweredKey = safeLower(key)
				if loweredKey == "vip" or string.find(loweredKey, "vip", 1, true) then
					return true
				end
			end
		end
	end

	return false
end

function formatMoneyAmount(value)
	local rounded = math.max(0, math.floor((tonumber(value) or 0) + 0.5))
	local text = tostring(rounded)
	local sign = ""
	if string.sub(text, 1, 1) == "-" then
		sign = "-"
		text = string.sub(text, 2)
	end

	while true do
		local formatted, substitutions = string.gsub(text, "^(-?%d+)(%d%d%d)", "%1,%2")
		text = formatted
		if substitutions == 0 then
			break
		end
	end

	return sign .. text
end

function getSellableLootSummary(forceRefresh)
	local filledSlots, totalSlots = getInventorySlotCounts()
	local playerData = resolvePlayerDataModule(forceRefresh)
	local playerItems = resolveSharedPlayerItems(forceRefresh)
	if not isTable(playerData) or not isTable(playerItems) then
		return nil
	end

	local inventoryContainer = getResolvedInventoryContainer(playerData)
	if not isTable(inventoryContainer) then
		return nil
	end

	local items = rawget(inventoryContainer, "Items") or inventoryContainer.Items
	if not isTable(items) then
		return nil
	end

	local sellMetadata = resolveSharedPlayerItemSellMetadata(forceRefresh)
	local hasVipSellBonus = playerHasVipSellBonus(forceRefresh)
	local lootEntryCount = 0
	local lootUnitCount = 0
	local lootValueTotal = 0
	for _, inventoryItem in pairs(items) do
		if isTable(inventoryItem) then
			local itemType = rawget(inventoryItem, "Type") or inventoryItem.Type
			local sharedItemData = type(itemType) == "string" and (rawget(playerItems, itemType) or playerItems[itemType]) or nil
			local itemSellMetadata = type(itemType) == "string" and isTable(sellMetadata) and (rawget(sellMetadata, itemType) or sellMetadata[itemType]) or nil
			local isLoot = (isTable(sharedItemData) and ((rawget(sharedItemData, "IsLoot") or sharedItemData.IsLoot) == true))
				or (isTable(itemSellMetadata) and ((rawget(itemSellMetadata, "isLoot") or itemSellMetadata.isLoot) == true))
			if isLoot then
				lootEntryCount += 1
				local stackAmount = getInventoryItemStackAmount(inventoryItem)
				lootUnitCount += stackAmount

				local baseValue = tonumber(
					(isTable(sharedItemData) and (rawget(sharedItemData, "Value") or sharedItemData.Value))
						or (isTable(itemSellMetadata) and (rawget(itemSellMetadata, "value") or itemSellMetadata.value))
						or 0
				) or 0
				local stackSellSize = tonumber(
					(isTable(sharedItemData) and (rawget(sharedItemData, "StackSellSize") or sharedItemData.StackSellSize))
						or (isTable(itemSellMetadata) and (rawget(itemSellMetadata, "stackSellSize") or itemSellMetadata.stackSellSize))
						or 1
				) or 1
				if stackSellSize < 1 then
					stackSellSize = 1
				end

				local itemValueTotal = baseValue * (stackAmount / stackSellSize)
				local vipValueMultiplier = tonumber(
					(isTable(itemSellMetadata) and (rawget(itemSellMetadata, "vipValueMultiplier") or itemSellMetadata.vipValueMultiplier))
						or (isTable(sharedItemData) and (rawget(sharedItemData, "VIPValueMultiplier") or sharedItemData.VIPValueMultiplier))
						or 0
				) or 0
				if hasVipSellBonus and vipValueMultiplier > 0 then
					itemValueTotal = itemValueTotal * (1 + vipValueMultiplier)
				end
				lootValueTotal += itemValueTotal
			end
		end
	end

	return {
		hasLoot = lootEntryCount > 0,
		lootEntryCount = lootEntryCount,
		lootUnitCount = lootUnitCount,
		lootValueTotal = lootValueTotal,
		filledSlots = filledSlots,
		totalSlots = totalSlots,
	}
end

function wasSellableLootReduced(beforeSummary, afterSummary)
	if not (isTable(beforeSummary) and isTable(afterSummary)) then
		return false
	end

	local beforeEntryCount = tonumber(rawget(beforeSummary, "lootEntryCount") or beforeSummary.lootEntryCount) or 0
	local afterEntryCount = tonumber(rawget(afterSummary, "lootEntryCount") or afterSummary.lootEntryCount) or 0
	if afterEntryCount < beforeEntryCount then
		return true
	end

	local beforeUnitCount = tonumber(rawget(beforeSummary, "lootUnitCount") or beforeSummary.lootUnitCount) or beforeEntryCount
	local afterUnitCount = tonumber(rawget(afterSummary, "lootUnitCount") or afterSummary.lootUnitCount) or afterEntryCount
	if afterUnitCount < beforeUnitCount then
		return true
	end

	local beforeValueTotal = tonumber(rawget(beforeSummary, "lootValueTotal") or beforeSummary.lootValueTotal) or beforeUnitCount
	local afterValueTotal = tonumber(rawget(afterSummary, "lootValueTotal") or afterSummary.lootValueTotal) or afterUnitCount
	if afterValueTotal < beforeValueTotal then
		return true
	end

	local beforeHasLoot = rawget(beforeSummary, "hasLoot")
	if beforeHasLoot == nil then
		beforeHasLoot = beforeSummary.hasLoot
	end
	local afterHasLoot = rawget(afterSummary, "hasLoot")
	if afterHasLoot == nil then
		afterHasLoot = afterSummary.hasLoot
	end

	return beforeHasLoot == true and afterHasLoot == false
end

function getSoldLootValue(beforeSummary, afterSummary)
	if not isTable(beforeSummary) then
		return 0
	end

	local beforeValueTotal = tonumber(rawget(beforeSummary, "lootValueTotal") or beforeSummary.lootValueTotal) or 0
	local afterValueTotal = tonumber((isTable(afterSummary) and (rawget(afterSummary, "lootValueTotal") or afterSummary.lootValueTotal)) or 0) or 0
	return math.max(0, beforeValueTotal - afterValueTotal)
end

function setAutoSellThreshold(value, totalSlotsHint)
	local totalSlots = totalSlotsHint or lastInventoryTotalSlots or 0
	if totalSlots > 0 then
		autoSellThreshold = math.clamp(math.floor((value or 1) + 0.5), 1, totalSlots)
	else
		autoSellThreshold = math.max(1, math.floor((value or 1) + 0.5))
	end
end

function updateAutoSellThresholdFromPointer(pointerX)
	if not autoSellSliderHitbox then
		return
	end

	local _, totalSlots = getInventorySlotCounts()
	if totalSlots > 0 then
		lastInventoryTotalSlots = totalSlots
	end
	totalSlots = math.max(totalSlots or lastInventoryTotalSlots or 0, 1)
	local absolutePosition = autoSellSliderHitbox.AbsolutePosition
	local absoluteSize = autoSellSliderHitbox.AbsoluteSize
	local width = math.max(absoluteSize.X, 1)
	local ratio = math.clamp((pointerX - absolutePosition.X) / width, 0, 1)
	local threshold = math.floor((ratio * math.max(totalSlots - 1, 0)) + 1.5)
	setAutoSellThreshold(threshold, totalSlots)
end

function resolveAutoSellThreshold()
	local filledSlots, totalSlots = getInventorySlotCounts()
	lastInventoryFilledSlots = filledSlots
	lastInventoryTotalSlots = totalSlots

	if totalSlots > 0 then
		if autoSellThreshold <= 0 then
			autoSellThreshold = totalSlots
		else
			setAutoSellThreshold(autoSellThreshold, totalSlots)
		end
	end

	return filledSlots, totalSlots, autoSellThreshold
end

function isAutoSellThresholdReached()
	local filledSlots, totalSlots, threshold = resolveAutoSellThreshold()
	if not autoSellEnabled or totalSlots <= 0 or threshold <= 0 then
		return false, filledSlots, totalSlots, threshold
	end

	return filledSlots >= threshold, filledSlots, totalSlots, threshold
end

function isTable(value)
	return type(value) == "table"
end

function pushUniqueTable(list, seen, value)
	if isTable(value) and not seen[value] then
		seen[value] = true
		table.insert(list, value)
	end
end

function getEnvironmentTables()
	local list = {}
	local seen = {}

	if type(getgenv) == "function" then
		local ok, genv = pcall(getgenv)
		if ok then
			pushUniqueTable(list, seen, genv)
		end
	end

	if type(getrenv) == "function" then
		local ok, renv = pcall(getrenv)
		if ok then
			pushUniqueTable(list, seen, renv)
		end
	end

	pushUniqueTable(list, seen, _G)

	local okShared, sharedTable = pcall(function()
		return shared
	end)
	if okShared then
		pushUniqueTable(list, seen, sharedTable)
	end

	return list
end

local hasPlrCharacterModule
local resolveGameModules
local resolveGlobalNetwork

function hasGetEquippedItem(owner)
	return isTable(owner) and type(owner.GetEquippedItem) == "function"
end

function looksLikeToolInfo(toolInfo)
	if not isTable(toolInfo) then
		return false
	end

	local networkActivate = rawget(toolInfo, "NetworkActivate") or toolInfo.NetworkActivate
	return type(networkActivate) == "function"
end

function tryGetToolInfoFromOwner(owner)
	if not hasGetEquippedItem(owner) then
		return nil
	end

	local ok, toolInfo = pcall(function()
		return owner:GetEquippedItem()
	end)

	if ok and looksLikeToolInfo(toolInfo) then
		return toolInfo
	end

	return nil
end

function pushUniqueOwner(list, seen, owner)
	if hasGetEquippedItem(owner) and not seen[owner] then
		seen[owner] = true
		table.insert(list, owner)
	end
end

function collectOwnerCandidates(root, owners, ownerSeen, recurseSeen, depth)
	if depth <= 0 or not isTable(root) or recurseSeen[root] then
		return
	end

	recurseSeen[root] = true
	pushUniqueOwner(owners, ownerSeen, root)

	local directKeys = {
		"plrCharacter",
		"PlrCharacter",
		"character",
		"Character",
		"playerCharacter",
		"PlayerCharacter",
		"RepCharHandler",
		"repCharHandler",
		"Modules",
		"modules",
		"mainModule",
		"MainModule",
	}

	for _, key in ipairs(directKeys) do
		local value = rawget(root, key) or root[key]
		if hasGetEquippedItem(value) then
			pushUniqueOwner(owners, ownerSeen, value)
		elseif isTable(value) then
			collectOwnerCandidates(value, owners, ownerSeen, recurseSeen, depth - 1)
		end
	end
end

function collectGcOwnerCandidates(owners, ownerSeen)
	if type(getgc) ~= "function" then
		return
	end

	local ok, gcObjects = pcall(getgc, true)
	if not ok or type(gcObjects) ~= "table" then
		return
	end

	local deadline = os.clock() + TOOLINFO_GC_SCAN_BUDGET
	for _, object in ipairs(gcObjects) do
		if os.clock() > deadline then
			break
		end

		if isTable(object) then
			pushUniqueOwner(owners, ownerSeen, object)
			local plrCharacter = rawget(object, "plrCharacter") or object.plrCharacter
			pushUniqueOwner(owners, ownerSeen, plrCharacter)
		end
	end
end

function resolveToolInfoOwner(forceRefresh)
	if cachedToolInfoOwner and hasGetEquippedItem(cachedToolInfoOwner) then
		local cachedToolInfo = tryGetToolInfoFromOwner(cachedToolInfoOwner)
		if cachedToolInfo then
			return cachedToolInfoOwner, cachedToolInfo
		end
		cachedToolInfoOwner = nil
	end

	local now = os.clock()
	if not forceRefresh and (now - lastToolInfoOwnerScanAt) < RESCAN_INTERVAL then
		return nil
	end
	lastToolInfoOwnerScanAt = now

	local owners = {}
	local ownerSeen = {}
	local recurseSeen = {}

	local modulesTable = resolveGameModules(forceRefresh)
	if hasPlrCharacterModule(modulesTable) then
		pushUniqueOwner(owners, ownerSeen, modulesTable.plrCharacter)
	end

	resolveGlobalNetwork(forceRefresh)
	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if isTable(globalModule) then
		pushUniqueOwner(owners, ownerSeen, rawget(globalModule, "PlayerCharacter") or globalModule.PlayerCharacter)
		pushUniqueOwner(owners, ownerSeen, rawget(globalModule, "playerCharacter") or globalModule.playerCharacter)
		pushUniqueOwner(owners, ownerSeen, rawget(globalModule, "RepCharHandler") or globalModule.RepCharHandler)
		pushUniqueOwner(owners, ownerSeen, rawget(globalModule, "repCharHandler") or globalModule.repCharHandler)
	end

	if isTable(cachedMainModule) then
		collectOwnerCandidates(cachedMainModule, owners, ownerSeen, recurseSeen, 3)
	end

	for _, root in ipairs(getEnvironmentTables()) do
		collectOwnerCandidates(root, owners, ownerSeen, recurseSeen, 3)
	end

	collectGcOwnerCandidates(owners, ownerSeen)

	for _, owner in ipairs(owners) do
		local toolInfo = tryGetToolInfoFromOwner(owner)
		if toolInfo then
			cachedToolInfoOwner = owner
			return owner, toolInfo
		end
	end

	return nil
end

hasPlrCharacterModule = function(modulesTable)
	if not isTable(modulesTable) then
		return false
	end

	local plrCharacter = rawget(modulesTable, "plrCharacter") or modulesTable.plrCharacter
	return isTable(plrCharacter) and type(plrCharacter.GetEquippedItem) == "function"
