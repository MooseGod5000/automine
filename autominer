function toggleHoveredDynamitePlayerMark()
    if destroyed or not isSessionActive() or not S.dynamiteMarkPlayersEnabled or S.dynamiteTarget ~= "Player" then
        return
    end

    local mouse = localPlayer and localPlayer:GetMouse()
    local hoveredPlayer = getTwwPlayerFromTarget(mouse and mouse.Target)
    if not hoveredPlayer or hoveredPlayer == localPlayer then
        return
    end

    local livePlayer = getAliveTwwTargetData(hoveredPlayer.Name)
    if not livePlayer then
        spawnNotification("That player is not alive right now.", "warning", true)
        return
    end

    local order = getDynamiteMarkedPlayers()
    local existingIndex = table.find(order, hoveredPlayer.Name)
    if existingIndex then
        table.remove(order, existingIndex)
        destroyDynamiteMarkVisual(hoveredPlayer.Name)
        refreshDynamiteMarkVisuals()
        spawnNotification("Removed " .. hoveredPlayer.Name .. " from the dynamite mark list.", "info", true)
        return
    end

    table.insert(order, hoveredPlayer.Name)
    refreshDynamiteMarkVisuals()
    spawnNotification("Marked " .. hoveredPlayer.Name .. " as target #" .. tostring(#order) .. ".", "success", true)
end

