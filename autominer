function updateAutofarmLayout()
    if pathUi.useFobRows then
        local subTabOffset = 46
        local mainHeight = pathUi.mainRowsLayout and pathUi.mainRowsLayout.AbsoluteContentSize.Y or 0
        local pathsHeight = pathUi.pathRowsLayout and pathUi.pathRowsLayout.AbsoluteContentSize.Y or 0
        local activeHeight = pathState.subTab == "Paths" and pathsHeight or mainHeight

        if pathUi.mainRowsPage then
            pathUi.mainRowsPage.Position = UDim2.fromOffset(0, subTabOffset)
            pathUi.mainRowsPage.Size = UDim2.new(1, 0, 0, mainHeight)
        end

        if pathUi.pathRowsPage then
            pathUi.pathRowsPage.Position = UDim2.fromOffset(0, subTabOffset)
            pathUi.pathRowsPage.Size = UDim2.new(1, 0, 0, pathsHeight)
        end

        local contentHeight = subTabOffset + activeHeight + 18
        if automineCanvas then
            automineCanvas.Size = UDim2.new(1, -4, 0, math.max(contentHeight, 180))
        end

        if autofarmPageRef then
            autofarmPageRef.CanvasSize = UDim2.new(0, 0, 0, math.max(contentHeight + 8, 220))
        end
        return
    end

    local subTabOffset = 46
    local autoFarmHeight = oreDropdownOpen and 284 or 156
    local pickupHeight = pickupWhitelistDropdownOpen and 296 or 156
    local movementHeight = movementModeDropdownOpen and 172 or 104
    local autoSellHeight = 186
    local liveFeedHeight = 126
    local movementY = subTabOffset + autoFarmHeight + 12
    local liveFeedY = movementY + movementHeight + 12
    local autoSellY = subTabOffset + pickupHeight + 12
    local settingsHeight = math.max(liveFeedY + liveFeedHeight, autoSellY + autoSellHeight)
    local pathsHeight = subTabOffset + ((pathUi.pathsPage and pathUi.pathsPage.AbsoluteSize.Y > 0) and math.max(pathUi.pathsPage.AbsoluteSize.Y, pathUi.managerCard and pathUi.managerCard.AbsoluteSize.Y or 238) or 238)
    local contentHeight = pathState.subTab == "Paths" and pathsHeight or settingsHeight

    if autoFarmCardFrame then
        autoFarmCardFrame.Size = UDim2.new(0.5, -6, 0, autoFarmHeight)
        autoFarmCardFrame.Position = UDim2.new(0, 0, 0, subTabOffset)
    end

    if movementCardFrame then
        movementCardFrame.Size = UDim2.new(0.5, -6, 0, movementHeight)
        movementCardFrame.Position = UDim2.new(0, 0, 0, movementY)
    end

    if pickupCardFrame then
        pickupCardFrame.Size = UDim2.new(0.5, -6, 0, pickupHeight)
        pickupCardFrame.Position = UDim2.new(0.5, 6, 0, subTabOffset)
    end

    if autoSellCardFrame then
        autoSellCardFrame.Size = UDim2.new(0.5, -6, 0, autoSellHeight)
        autoSellCardFrame.Position = UDim2.new(0.5, 6, 0, autoSellY)
    end

    if liveFeedCardFrame then
        liveFeedCardFrame.Size = UDim2.new(0.5, -6, 0, liveFeedHeight)
