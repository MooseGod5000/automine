function setAnimatedRowVisible(row, visible, expandedHeight, instant)
    if not row then
        return
    end

    local rowState = S._rowTweenState[row]
    if not rowState then
        rowState = {}
        S._rowTweenState[row] = rowState
    end

    local targetHeight = tonumber(expandedHeight) or 38
    local targetSize = visible and UDim2.new(1, 0, 0, targetHeight) or UDim2.new(1, 0, 0, 0)
    row.ClipsDescendants = true
    row.AutoButtonColor = visible == true
    row.Active = visible == true
    rowState.targetVisible = visible == true
    rowState.targetHeight = targetHeight

    if rowState.tween then
        pcall(function()
            rowState.tween:Cancel()
        end)
        rowState.tween = nil
    end

    if instant then
        row.Visible = visible == true
        row.Size = targetSize
        return
    end

    if visible then
        if not row.Visible then
            row.Visible = true
            row.Size = UDim2.new(1, 0, 0, 0)
        end
    elseif not row.Visible then
        row.Size = targetSize
        return
    end

    local tween = _TweenService:Create(row, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = targetSize,
    })
    rowState.tween = tween
    tween.Completed:Connect(function()
        if S._rowTweenState[row] ~= rowState or rowState.tween ~= tween then
            return
        end
        rowState.tween = nil
        if rowState.targetVisible then
            row.Visible = true
            row.Size = UDim2.new(1, 0, 0, rowState.targetHeight or targetHeight)
        else
            row.Visible = false
            row.Size = UDim2.new(1, 0, 0, 0)
        end
    end)
    tween:Play()
end

