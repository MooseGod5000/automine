function getOreHealthValues(oreDeposit)
	local oreRemaining = getOreRemainingValue(oreDeposit)
	if not oreRemaining then
		return nil, nil
	end

	local currentValue = tonumber(oreRemaining.Value)
	if currentValue == nil then
		return nil, nil
	end

	local roundedCurrent = math.max(0, math.floor(currentValue + 0.5))
	local depositInfo = oreDeposit and oreDeposit:FindFirstChild("DepositInfo")
	local maxValue = nil

	if depositInfo then
		for _, childName in ipairs({ "MaxOreRemaining", "MaxHealth", "MaxOreHealth" }) do
			local child = depositInfo:FindFirstChild(childName)
			if child and child:IsA("NumberValue") then
				maxValue = tonumber(child.Value)
				break
			end
		end
	end

	if type(maxValue) == "number" then
		maxValue = math.max(roundedCurrent, math.floor(maxValue + 0.5))
	end

	return roundedCurrent, maxValue
end

