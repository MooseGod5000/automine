function ensureFastReloadHook()
    if not S.fastReloadEnabled then
        return
    end

    local gunItem = getCurrentEquippedGunItem(false) or getCurrentEquippedGunItem(true)
    if not isTable(gunItem) then
        gunFeatureState.fastReloadItem = nil
        gunFeatureState.fastReloadOriginalPlayTrack = nil
        gunFeatureState.fastReloadWrapper = nil
        return
    end

    local playTrack = rawget(gunItem, "PlayTrack") or gunItem.PlayTrack
    if type(playTrack) ~= "function" then
        gunFeatureState.fastReloadItem = nil
        gunFeatureState.fastReloadOriginalPlayTrack = nil
        gunFeatureState.fastReloadWrapper = nil
        return
    end

    if type(gunFeatureState.fastReloadHooks) ~= "table" then
        gunFeatureState.fastReloadHooks = {}
    end

    local hook = gunFeatureState.fastReloadHooks[gunItem]
    if type(hook) ~= "table" then
        hook = {}
        gunFeatureState.fastReloadHooks[gunItem] = hook
    end

    if playTrack ~= hook.wrapper then
        hook.originalPlayTrack = playTrack
        hook.wrapper = function(self, trackName, ...)
            local packedArgs = table.pack(...)
            local isReloadTrack = S.fastReloadEnabled and isGunReloadTrack(trackName)
            if isReloadTrack and type(packedArgs[packedArgs.n]) == "number" then
                packedArgs[packedArgs.n] = packedArgs[packedArgs.n] * 10
            end
            local result = hook.originalPlayTrack(self, trackName, table.unpack(packedArgs, 1, packedArgs.n))
            if isReloadTrack and tostring(trackName) == "LoadStart" then
                task.spawn(function()
                    pcall(function()
                        self:StopTrack(trackName, 0.05)
                    end)
                end)
            end
            return result
        end
        gunItem.PlayTrack = hook.wrapper
    end

    gunFeatureState.fastReloadItem = gunItem
    gunFeatureState.fastReloadOriginalPlayTrack = hook.originalPlayTrack
    gunFeatureState.fastReloadWrapper = hook.wrapper
end

