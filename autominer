function ensureLassoSilentAimHook()
    if not (S.lassoSilentAimEnabled or S.fasterLassoEnabled) then
        return
    end

    local lassoItem = getCurrentEquippedLassoItem(false) or getCurrentEquippedLassoItem(true)
    if not isTable(lassoItem) then
        return
    end

    if type(gunFeatureState.lassoSilentAimHooks) ~= "table" then
        gunFeatureState.lassoSilentAimHooks = {}
    end

    local networkActivate = rawget(lassoItem, "NetworkActivate") or lassoItem.NetworkActivate
    if type(networkActivate) ~= "function" then
        return
    end

    local hook = gunFeatureState.lassoSilentAimHooks[lassoItem]
    if type(hook) ~= "table" then
        hook = {}
        gunFeatureState.lassoSilentAimHooks[lassoItem] = hook
    end

    if networkActivate ~= hook.wrapper then
        hook.originalNetworkActivate = networkActivate
        hook.wrapper = function(self, ...)
            local packedArgs = table.pack(...)
            local localVelocityOverride = nil
            local localPlatformVelocity = Vector3.zero
            local localLassoCircle = nil
            if tostring(packedArgs[1] or "") == "ThrowLasso" then
                local throwVelocity = typeof(packedArgs[3]) == "Vector3" and packedArgs[3] or nil
                local platformVelocity = typeof(packedArgs[4]) == "Vector3" and packedArgs[4] or Vector3.zero
                local lassoCircle = rawget(self, "LassoCircle") or self.LassoCircle
                local origin = lassoCircle and lassoCircle.Position or nil
                local throwSpeed = throwVelocity and throwVelocity.Magnitude or nil
                if typeof(origin) == "Vector3" and throwSpeed and throwSpeed > 0.001 then
                    local networkVelocity = throwVelocity
                    local visualVelocity = throwVelocity

                    if S.lassoSilentAimEnabled then
                        local targetInfo = getLassoSilentAimTargetInfo()
                        if targetInfo then
                            local aimedVelocity = solveLassoSilentAimVelocity(origin, throwSpeed, targetInfo)
                            if typeof(aimedVelocity) == "Vector3" and aimedVelocity.Magnitude > 0.001 then
                                networkVelocity = aimedVelocity
                                visualVelocity = aimedVelocity
                            end
                        end
                    end

                    if S.fasterLassoEnabled and typeof(visualVelocity) == "Vector3" and visualVelocity.Magnitude > 0.001 then
                        visualVelocity = visualVelocity.Unit * (throwSpeed * LASSO_FAST_THROW_MULTIPLIER)
                    end

                    if typeof(networkVelocity) == "Vector3" and networkVelocity.Magnitude > 0.001 then
                        packedArgs[3] = networkVelocity
                    end

                    if typeof(visualVelocity) == "Vector3" and visualVelocity.Magnitude > 0.001 then
                        localVelocityOverride = visualVelocity
                        localPlatformVelocity = platformVelocity
                        localLassoCircle = lassoCircle
                    end
                end
            end

            local results = table.pack(hook.originalNetworkActivate(self, table.unpack(packedArgs, 1, packedArgs.n)))

            if localLassoCircle and localLassoCircle:IsA("BasePart") and typeof(localVelocityOverride) == "Vector3" then
                localLassoCircle.Velocity = localVelocityOverride + localPlatformVelocity
                local bodyGyro = localLassoCircle:FindFirstChild("BodyGyro")
                if bodyGyro then
                    bodyGyro.CFrame = CFrame.new(localLassoCircle.Position, localLassoCircle.Position + localVelocityOverride)
                        * CFrame.Angles(0, -1.5707963267948966, 0)
                end
            end

            return table.unpack(results, 1, results.n)
        end
        lassoItem.NetworkActivate = hook.wrapper
    end

    local onHit = rawget(lassoItem, "OnHit") or lassoItem.OnHit
    if type(onHit) == "function" and onHit ~= hook.onHitWrapper then
        hook.originalOnHit = onHit
        hook.onHitWrapper = function(self, hitPart)
            if not shouldDelayFasterLassoHit(hitPart) then
                return hook.originalOnHit(self, hitPart)
            end
            if self.FastLassoHitPending then
                return
            end

            self.FastLassoHitPending = true
            local lassoCircle = rawget(self, "LassoCircle") or self.LassoCircle
            local impactCFrame = lassoCircle and lassoCircle.CFrame or nil
            local wasAnchored = lassoCircle and lassoCircle.Anchored or false
            local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)

            if lassoCircle and lassoCircle:IsA("BasePart") and typeof(impactCFrame) == "CFrame" then
                lassoCircle.Anchored = true
                lassoCircle.CFrame = impactCFrame
                lassoCircle.Velocity = Vector3.zero
                local bodyForce = lassoCircle:FindFirstChild("BodyForce")
                if bodyForce then
                    bodyForce.Force = Vector3.zero
                end
                if network then
                    pcall(network.FireServer, network, "UpdateThrownLasso", impactCFrame)
                end
            end

            task.delay(LASSO_FAST_HIT_CONFIRM_DELAY, function()
                self.FastLassoHitPending = false

                local currentCircle = rawget(self, "LassoCircle") or self.LassoCircle
                if currentCircle and currentCircle:IsA("BasePart") and typeof(impactCFrame) == "CFrame" then
                    currentCircle.CFrame = impactCFrame
                    if network then
                        pcall(network.FireServer, network, "UpdateThrownLasso", impactCFrame)
                    end
                end

                if not (self.IsEquipped and self.IsThrowingLasso) then
                    if currentCircle and currentCircle:IsA("BasePart") then
                        currentCircle.Anchored = wasAnchored
                    end
                    return
                end

                hook.originalOnHit(self, hitPart)
            end)
        end
        lassoItem.OnHit = hook.onHitWrapper
    end
end

