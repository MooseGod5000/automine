	local playerCharacter = resolvePlayerCharacterModule(forceRefresh)
	if isTable(playerCharacter) then
		local repChar = rawget(playerCharacter, "RepChar") or playerCharacter.RepChar
		if isTable(repChar) then
			return repChar
