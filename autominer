	if not normalizedSlotIndex then
		return nil
	end
	local slotName = pathState.pathSlots[normalizedSlotIndex]
	if type(slotName) ~= "string" or slotName == "" then
		return nil
	end
	if allowMissingPath or pathState.paths[slotName] ~= nil then
		return slotName
	end
	return nil
end

function getPlayablePathSlotIndex(startSlotIndex)
