do
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    local hubTargetRot = 0
    local hubCurrentRot = 0
    local lastMouseX = nil

    hubMain.InputBegan:Connect(function(input)
        if destroyed then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if pathState.editorVisible and isPointInsideGuiObject(pathUi.editorFrame, input.Position) then
                return
            end
            dragging = true
            dragStart = input.Position
            startPos = hubWrapper.Position
            hideAllDropdowns()
        end
    end)

    _UserInputService.InputChanged:Connect(function(input)
        if destroyed then
            return
        end
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            dragInput = input
        end
    end)

    _UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    _RunService.RenderStepped:Connect(function(dt)
        if destroyed or not hubWrapper.Visible then
            return
        end
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            local destination = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            hubWrapper.Position = hubWrapper.Position:Lerp(destination, math.min(dt * 20, 1))
            if lastMouseX then
                hubTargetRot = math.clamp(-(dragInput.Position.X - lastMouseX) * 0.7, -15, 15)
            end
            lastMouseX = dragInput.Position.X
        else
            lastMouseX = nil
            hubTargetRot = 0
        end
        hubCurrentRot = hubCurrentRot + (hubTargetRot - hubCurrentRot) * math.min(dt * 10, 1)
        hubWrapper.Rotation = hubCurrentRot
    end)
end

