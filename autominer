function saveConfigState(name)
    if not storageEnabled then
        return false
    end
    local trimmedName = trimConfigName(name)
    if trimmedName == "" then
        return false
    end
    local ok = pcall(function()
        ensureConfigStorageFolder()
        writefile(getConfigFilePath(trimmedName), _HttpService:JSONEncode(serializeState()))
    end)
    return ok
end

function loadConfigState(name, resetBeforeApply)
    if not storageReadAvailable then
        return false
    end
    local trimmedName = trimConfigName(name)
    if trimmedName == "" then
        return false
    end
    local okRead, raw = pcall(function()
        local filePath = getConfigFilePath(trimmedName)
        if not isfile(filePath) then
            return nil
        end
        return readfile(filePath)
    end)
    if not okRead or type(raw) ~= "string" or raw == "" then
        return false
    end
    local okDecode, data = pcall(function()
        return _HttpService:JSONDecode(raw)
    end)
    if not okDecode or type(data) ~= "table" then
        return false
    end
    if resetBeforeApply ~= false then
        resetStateToDefaults()
    end
    return applySerializedState(data)
end

function listConfigs()
    local names = {}
    local seen = {}

    for _, savedName in ipairs(normalizeSavedConfigNames(CONFIG_SYSTEM.savedConfigs)) do
        if not seen[savedName] then
            seen[savedName] = true
            table.insert(names, savedName)
        end
    end

    if type(listfiles) == "function" and storageFolderApisAvailable then
        pcall(function()
            ensureConfigStorageFolder()
            for _, filePath in ipairs(listfiles(CONFIG_SYSTEM.FOLDER)) do
                local rawName = tostring(filePath):match("([^/\\]+)%.cfg$")
                if rawName and rawName ~= CONFIG_SYSTEM.AUTOSAVE_FILE_KEY then
                    local displayName = rawName:gsub("_+", "_")
                    if displayName ~= "" and not seen[displayName] then
                        seen[displayName] = true
                        table.insert(names, displayName)
                    end
                end
            end
        end)
    end

    table.sort(names, function(a, b)
        return a:lower() < b:lower()
    end)
    return names
end

local function savePersistentState()
    if not storageEnabled then
        return false
    end
    local payload = {
        selectedConfigName = getSelectedConfigName(),
        autoLoadConfigName = getAutoLoadConfigName(),
        savedConfigs = normalizeSavedConfigNames(CONFIG_SYSTEM.savedConfigs),
    }
    local ok = pcall(function()
        ensureStorageFolder()
        writefile(storagePath, _HttpService:JSONEncode(payload))
    end)
    return ok
end

local function loadPersistentState()
    CONFIG_SYSTEM.selectedConfigName = nil
    CONFIG_SYSTEM.autoLoadConfigName = nil
    CONFIG_SYSTEM.savedConfigs = {}
    CONFIG_SYSTEM.autosaveLoadedOnStartup = false
    CONFIG_SYSTEM.autoLoadLoadedOnStartup = false

    if not storageReadAvailable then
        return false
    end

    local ok, raw = pcall(function()
        if not isfile(storagePath) then
            return nil
        end
        return readfile(storagePath)
    end)
    if not ok or not raw or raw == "" then
        return false
    end

    local decodedOk, data = pcall(function()
        return _HttpService:JSONDecode(raw)
    end)
    if not decodedOk or type(data) ~= "table" then
        return false
    end

    CONFIG_SYSTEM.savedConfigs = normalizeSavedConfigNames(data.savedConfigs)
    if type(data.selectedConfigName) == "string" and trimConfigName(data.selectedConfigName) ~= "" then
        CONFIG_SYSTEM.selectedConfigName = trimConfigName(data.selectedConfigName)
    end
    if type(data.autoLoadConfigName) == "string" and trimConfigName(data.autoLoadConfigName) ~= "" then
        CONFIG_SYSTEM.autoLoadConfigName = trimConfigName(data.autoLoadConfigName)
    end

    local autoLoadName = getAutoLoadConfigName()
    if autoLoadName then
        CONFIG_SYSTEM.selectedConfigName = autoLoadName
        CONFIG_SYSTEM.autoLoadLoadedOnStartup = loadConfigState(autoLoadName, false) == true
    elseif getSelectedConfigName() == CONFIG_SYSTEM.AUTOSAVE_NAME then
        CONFIG_SYSTEM.autosaveLoadedOnStartup = loadConfigState(CONFIG_SYSTEM.AUTOSAVE_NAME, false) == true
    end

    return true
end

local function clearPersistentState()
    if storageDeleteAvailable and storageReadAvailable then
        local ok = pcall(function()
            if isfile(storagePath) then
                delfile(storagePath)
            end
        end)
        return ok
    end
    return savePersistentState()
end

local pendingPersist = false
local function schedulePersist()
    if pendingPersist then
        return
    end
    pendingPersist = true
    task.delay(0.2, function()
        pendingPersist = false
        if not destroyed and isSessionActive() then
            storageLoaded = savePersistentState() or storageLoaded
            if getSelectedConfigName() == CONFIG_SYSTEM.AUTOSAVE_NAME then
                saveConfigState(CONFIG_SYSTEM.AUTOSAVE_NAME)
            end
        end
    end)
end

