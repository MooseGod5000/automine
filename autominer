function clearGunAimDrawings()
    hideGunAimDrawings()

    if gunFeatureState.renderConnection then
        gunFeatureState.renderConnection:Disconnect()
        gunFeatureState.renderConnection = nil
    end

    local drawings = {
        "fovCircle",
        "fovSquare",
        "snapline",
        "lassoSnapline",
    }
    for _, key in ipairs(drawings) do
        local drawingObject = gunFeatureState[key]
        if drawingObject then
            pcall(function()
                drawingObject:Remove()
            end)
        end
        gunFeatureState[key] = nil
    end

    if type(gunFeatureState.fovPolygonLines) == "table" then
        for _, line in ipairs(gunFeatureState.fovPolygonLines) do
            if line then
                pcall(function()
                    line:Remove()
                end)
            end
        end
    end
    gunFeatureState.fovPolygonLines = {}
    gunFeatureState.currentTargetInfo = nil
    gunFeatureState.currentLassoTargetInfo = nil
