        end
    end
    return DEFAULTS.pathPlayerAvoiderMethod
end

local function normalizePathPlayerAvoiderAction(value)
    local candidate = tostring(value or DEFAULTS.pathPlayerAvoiderAction)
    for _, actionName in ipairs(PATH_PLAYER_AVOIDER_ACTION_ORDER) do
        if string.lower(candidate) == string.lower(actionName) then
            return actionName
        end
    end
    return DEFAULTS.pathPlayerAvoiderAction
end

