local function createPathSlotSectionUi(parentPage, slotIndex, nextCustomOrderFn)
    local function refreshPathManagerUi()
        local refreshButtons = getCallableGlobal("refreshPathManagerButtons")
        if type(refreshButtons) == "function" then
            refreshButtons()
        end
    end

    local function refreshPathVisualsUi()
        local refreshVisuals = getCallableGlobal("refreshPathVisuals")
        if type(refreshVisuals) == "function" then
            refreshVisuals()
        end
    end

    local slotHost = nextCustomOrderFn(Instance.new("Frame"))
    slotHost.Name = "PathSectionHost" .. tostring(slotIndex)
    slotHost.Size = UDim2.new(1, 0, 0, 0)
    slotHost.AutomaticSize = Enum.AutomaticSize.Y
    slotHost.BackgroundTransparency = 1
    slotHost.BorderSizePixel = 0
    slotHost.Parent = parentPage

    local slotHostLayout = Instance.new("UIListLayout")
    slotHostLayout.Padding = UDim.new(0, 0)
    slotHostLayout.SortOrder = Enum.SortOrder.LayoutOrder
    slotHostLayout.Parent = slotHost
    slotHostLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateAutofarmLayout)

    local slotList, slotHeaderLabel, slotRemoveButton = createCollapsibleSection("Path " .. tostring(slotIndex), slotHost, {
        onRemove = function()
            if removePathSection(slotIndex) then
                refreshPathManagerUi()
                updateAutofarmLayout()
            end
        end,
    })
    local slotUi = {
        host = slotHost,
        headerLabel = slotHeaderLabel,
        removeSectionButton = slotRemoveButton,
    }

    local _, savedPathSync = createDropdownRow(
        "Saved Path",
        slotList,
        function()
            local savedNames = getSavedPathNamesOrdered()
            if #savedNames == 0 then
                return {"none"}
            end
            return savedNames
        end,
        function()
            return getPathSlotSelection(slotIndex, true) or "none"
        end,
        function(value)
            local nextPathName = tostring(value) == "none" and nil or tostring(value)
            setPathSlotSelection(slotIndex, nextPathName, {syncSelectedPath = true})
            setPathDeleteConfirmSlot(nil)
            savePathsToStorage(false)
            refreshPathManagerUi()
            refreshPathVisualsUi()
        end
    )
    slotUi.savedPathSync = savedPathSync

    local _, _, pathPlaySync = createToggleRow(
        "Play Path",
        slotList,
        function()
            return isPathPlaybackBusy() and (normalizePathSlotIndex(pathState.sequenceStartSlotIndex) or 1) == slotIndex
        end,
        function()
            togglePathLoopFromControl("button", slotIndex)
        end
    )
    slotUi.pathPlaySync = pathPlaySync

    local _, _, alwaysPlaySync = createToggleRow(
        "Always Play Path",
        slotList,
        function()
            return pathState.alwaysPlayEnabled and (normalizePathSlotIndex(pathState.sequenceStartSlotIndex) or 1) == slotIndex
        end,
        function()
            local playableSlotIndex = getPlayablePathSlotIndex(slotIndex)
            if not playableSlotIndex then
                notifyUser("Paths", "Pick a saved path first.", 4)
                return
            end

            local sameSlotEnabled = pathState.alwaysPlayEnabled
                and (normalizePathSlotIndex(pathState.sequenceStartSlotIndex) or 1) == playableSlotIndex
            setPathSequenceStartSlotIndex(playableSlotIndex)
            setFocusedPathSlotIndex(playableSlotIndex, true)
            pathState.alwaysPlayEnabled = not sameSlotEnabled
            if pathState.alwaysPlayEnabled and not autoMineEnabled then
                activeFarmMode = "path"
                local ok, started = xpcall(function()
                    return startPathPlaybackForSlot(playableSlotIndex, "alwaysplay")
                end, debug.traceback)
                if not ok then
                    autoMineEnabled = false
                    activeFarmMode = nil
                    setStatus("Path start failed", Color3.fromRGB(255, 130, 130))
                    pushDebug(started)
                elseif not started then
                    autoMineEnabled = false
                    activeFarmMode = nil
                end
            end
            savePathsToStorage(true)
            refreshPathManagerUi()
        end
    )
    slotUi.alwaysPlaySync = alwaysPlaySync

    local recordButton, _, recordLabel = createButtonRow("Record Path", slotList, function()
        setFocusedPathSlotIndex(slotIndex, false)
        if pathState.editorVisible and not pathState.editingSavedPath and pathState.focusedPathSlotIndex == slotIndex then
            closePathEditor()
            return
        end
        beginNewPathRecording(slotIndex)
        refreshPathEditorButtons()
        refreshPathManagerUi()
    end, {skipRegistry = true})
    slotUi.recordButton = recordButton
    slotUi.recordLabel = recordLabel

    local _, _, editPathSync = createToggleRow(
        "Edit Path",
        slotList,
        function()
            return pathState.editorVisible and pathState.editingSavedPath and (normalizePathSlotIndex(pathState.focusedPathSlotIndex) or 1) == slotIndex
        end,
        function()
            if pathState.editorVisible and pathState.editingSavedPath and (normalizePathSlotIndex(pathState.focusedPathSlotIndex) or 1) == slotIndex then
                closePathEditor()
                return
            end

            local selectedPathName = getPathSlotSelection(slotIndex, false)
            if not selectedPathName or not pathState.paths[selectedPathName] then
                notifyUser("Paths", "Pick a saved path first.", 4)
                return
            end
            beginPathEditing(selectedPathName, slotIndex)
            refreshPathEditorButtons()
            refreshPathManagerUi()
        end
    )
    slotUi.editPathSync = editPathSync

    local deleteButton, _, deleteLabel = createButtonRow("Delete Path", slotList, function()
        local selectedPathName = getPathSlotSelection(slotIndex, false)
        if not selectedPathName then
            notifyUser("Paths", "Pick a saved path first.", 4)
            return
        end

        setFocusedPathSlotIndex(slotIndex, true)
        if isPathDeleteConfirmArmed(slotIndex) then
            setPathDeleteConfirmSlot(nil)
            deleteSelectedPath(slotIndex)
            refreshPathManagerUi()
            return
        end

        setPathDeleteConfirmSlot(slotIndex)
        refreshPathManagerUi()
        task.delay(3, function()
            if isPathDeleteConfirmArmed(slotIndex) then
                setPathDeleteConfirmSlot(nil)
                refreshPathManagerUi()
            end
        end)
    end, {skipRegistry = true})
    slotUi.deleteButton = deleteButton
    slotUi.deleteLabel = deleteLabel

    return slotUi
end

