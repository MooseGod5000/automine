function tryPickupDroppedItemViaNetwork(network, dropItem, dropPart, actionGroupInstance, networkId)
	if not network or type(network.FireServer) ~= "function" then
		return false
	end

	local pickupItem = typeof(dropItem) == "Instance" and dropItem:FindFirstChild("PickupItem", true) or nil
	local pickupItemId = nil
	if pickupItem then
		local okAttribute, attributeValue = pcall(function()
			return pickupItem:GetAttribute("ItemId")
		end)
		if okAttribute and attributeValue ~= nil then
			pickupItemId = attributeValue
		end
		if pickupItemId == nil then
			local valueObject = pickupItem:FindFirstChild("ItemId")
			if valueObject and valueObject:IsA("StringValue") then
				pickupItemId = valueObject.Value
			end
		end
	end

	for _, payload in ipairs({
		{},
		{ dropItem },
		{ dropPart },
		{ actionGroupInstance },
		{ networkId },
		pickupItemId ~= nil and { pickupItemId } or nil,
	}) do
		if payload then
			pcall(function()
				network:FireServer("PickupItem", unpack(payload))
			end)
			if waitForDroppedItemCollected(dropItem, AUTO_PICKUP_INSTANT_CONFIRM_TIMEOUT) then
				playLocalPickupItemFeedback()
				return true
			end
		end
	end

	return false
end

function tryPickupDroppedItemViaObjectAction(network, dropItem, dropPart, actionGroupInstance, networkId)
	if not network or type(network.FireServer) ~= "function" then
		return false
	end

	if not actionGroupInstance or networkId == nil then
		actionGroupInstance, networkId = resolveDroppedPickupActionTarget(dropItem, dropPart)
	end
	if not actionGroupInstance or networkId == nil then
		pushDebugRateLimited("pickup_object_action_missing", "pickup object action group not resolved", 2)
		return false
	end

	pushDebugRateLimited(
		"pickup_object_action_target",
		string.format("pickup object action: %s | %s", tostring(actionGroupInstance.Name), tostring(actionGroupInstance:GetFullName())),
		4
	)

	local activationId = getNextAutoSellObjectActionActivationId()
	local okStart = pcall(network.FireServer, network, "ObjectActionStarted", networkId, "Primary", getSyncedNetworkTime(), activationId)
	if not okStart then
		return false
	end

	task.wait(AUTO_PICKUP_OBJECT_ACTION_DURATION)

	local finishTimestamp = getSyncedNetworkTime()
	local okFinish = pcall(network.FireServer, network, "ObjectActionFinished", activationId, finishTimestamp)
	if not okFinish then
		pcall(network.FireServer, network, "ObjectActionCancelled", activationId, finishTimestamp)
		return false
	end

	local pickedUp = waitForDroppedItemCollected(dropItem, AUTO_PICKUP_OBJECT_ACTION_CONFIRM_TIMEOUT)
	if pickedUp then
		playLocalPickupItemFeedback()
	end
	return pickedUp
end

function tryAutoSell(character, humanoid, activeToken)
	if pathState.playbackActive then
		return false
	end

	local shouldSell, filledSlots, totalSlots = isAutoSellThresholdReached()
	if not shouldSell then
		return false
	end

	currentTargetOre = nil
	local sellPart, sellInstance = findNearestAutoSellTarget(character)
	if not sellPart then
		setStatus(string.format("Bag %d/%d - no sell shop found", filledSlots, totalSlots), Color3.fromRGB(255, 190, 120))
		pushDebug("auto sell: no sell shop target found")
		pushNearbySellPromptHints(character)
		return false
	end

	pushDebug(string.format("auto sell: %d/%d slots", filledSlots, totalSlots))
	pushDebug(string.format("auto sell target: %d studs | %s", math.floor(getDistanceToPosition(character, sellPart.Position) + 0.5), sellInstance:GetFullName()))
	setStatus(string.format("Selling loot (%d/%d)", filledSlots, totalSlots), Color3.fromRGB(232, 184, 96))

	local reached = moveCharacterNearPosition(character, humanoid, sellPart.Position, 9, activeToken)
	if not reached then
		pushDebug("auto sell: failed to reach vendor")
		return false
	end

	clearMovementKeys()
	setInteractKeyHeld(false)

	if trySellLootNearTarget(sellPart, sellInstance, character) then
		local remainingSlots = select(1, getInventorySlotCounts())
		pushDebug("auto sell complete, filled slots: " .. tostring(remainingSlots))
		return true
	end

	pushDebug("auto sell: sell prompt/network attempt failed")
	return false
end

