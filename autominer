function visualizePathPoints(points, targetPosition)
	if pathState.playbackActive then
		return
	end

	local now = os.clock()
	if targetPosition and lastPathVizTarget and (now - lastPathVizAt) < PATH_VIZ_REFRESH_INTERVAL then
		local delta = (targetPosition - lastPathVizTarget).Magnitude
		if delta <= PATH_VIZ_TARGET_EPSILON and math.abs(#points - lastPathVizCount) <= 1 then
			return
		end
	end

	clearPathVisualization()
	lastPathVizAt = now
	lastPathVizTarget = targetPosition
	lastPathVizCount = #points

	local previousPosition = nil
	for index, point in ipairs(points) do
		local pointColor = index == 1 and Color3.fromRGB(80, 180, 255) or Color3.fromRGB(255, 220, 90)
		createPathMarker(point, pointColor)
		if previousPosition then
			createPathSegment(previousPosition, point, Color3.fromRGB(255, 220, 90))
		end
		previousPosition = point
	end

	if targetPosition then
		createPathMarker(targetPosition, Color3.fromRGB(110, 255, 140), Vector3.new(0.92, 0.92, 0.92))
		if previousPosition then
			createPathSegment(previousPosition, targetPosition, Color3.fromRGB(110, 255, 140))
		end
	end
end

