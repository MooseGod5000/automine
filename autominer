function solveProjectileTravel(origin, speed, targetPosition, gravityMagnitude)
    if typeof(origin) ~= "Vector3" or typeof(targetPosition) ~= "Vector3" then
        return nil, nil
    end

    local projectileSpeed = tonumber(speed)
    if not projectileSpeed or projectileSpeed <= 0 then
        return nil, nil
    end

    local displacement = targetPosition - origin
    local horizontalDisplacement = Vector3.new(displacement.X, 0, displacement.Z)
    local horizontalDistance = horizontalDisplacement.Magnitude
    if horizontalDistance <= 0.001 then
        local distance = displacement.Magnitude
        if distance <= 0.001 then
            return Vector3.new(0, 1, 0), 0
        end
        local directTime = distance / projectileSpeed
        return displacement.Unit * projectileSpeed, directTime
    end

    local travelTime = horizontalDistance / projectileSpeed
    if travelTime <= 0 then
        return nil, nil
    end

    local verticalVelocity = (displacement.Y + (0.5 * gravityMagnitude * travelTime * travelTime)) / travelTime
    local flatVelocity = horizontalDisplacement.Unit * projectileSpeed
    return Vector3.new(flatVelocity.X, verticalVelocity, flatVelocity.Z), travelTime
end

function buildProjectileBasis(direction)
    if typeof(direction) ~= "Vector3" or direction.Magnitude <= 0.001 then
        return Vector3.new(0, 0, -1), Vector3.new(1, 0, 0), Vector3.new(0, 1, 0)
    end

    local forward = direction.Unit
    local referenceUp = math.abs(forward.Y) > 0.99 and Vector3.new(1, 0, 0) or Vector3.new(0, 1, 0)
    local right = forward:Cross(referenceUp)
    if right.Magnitude <= 0.001 then
        right = forward:Cross(Vector3.new(0, 0, 1))
    end
    right = right.Unit
    local up = right:Cross(forward)
    if up.Magnitude <= 0.001 then
        up = Vector3.new(0, 1, 0)
    else
        up = up.Unit
    end

    return forward, right, up
end

function randomConeVector(randomObject, direction, maxAngle)
    local coneAngle = math.max(tonumber(maxAngle) or 0, 0)
    local forward, right, up = buildProjectileBasis(direction)
    if coneAngle <= 0 then
        return forward
    end

    local rng = randomObject
    if typeof(rng) ~= "Random" then
        rng = Random.new()
    end

    local theta = rng:NextNumber(0, coneAngle)
    local phi = rng:NextNumber(0, math.pi * 2)
    local sinTheta = math.sin(theta)
    local candidate = (forward * math.cos(theta))
        + (right * math.cos(phi) * sinTheta)
        + (up * math.sin(phi) * sinTheta)

    if candidate.Magnitude <= 0.001 then
        return forward
    end

    return candidate.Unit
end

function getSpreadVectorCompensation(seed, direction, maxAngle)
    local forward = buildProjectileBasis(direction)
    local rngSeed = tonumber(seed) or 0
    local randomized = randomConeVector(Random.new(rngSeed), forward, maxAngle)
    local compensated = forward - (randomized - forward)
    if compensated.Magnitude <= 0.001 then
        return forward
    end
    return compensated.Unit
end

function getProjectileAccuracyState(sharedData, projectileEntry)
    local data = isTable(sharedData) and sharedData or {}
    local entry = isTable(projectileEntry) and projectileEntry or {}

    local projectileAccuracy = tonumber(rawget(data, "ProjectileAccuracy") or data.ProjectileAccuracy) or 1
    if tostring(entry.ammoType or "") == "ShotgunRound" then
        projectileAccuracy = projectileAccuracy * (tonumber(rawget(data, "ShotgunRoundAccuracy") or data.ShotgunRoundAccuracy) or 1)
    end

    local projectileCount = tonumber(rawget(data, "NumProjectiles") or data.NumProjectiles) or 1
    local maxSpreadAngle = projectileCount > 1 and math.rad(10) or math.rad(12.5)
    local spreadAngle = maxSpreadAngle * math.clamp(1 - projectileAccuracy, 0, 1)

    return projectileAccuracy, projectileCount, spreadAngle
end

function applySilentAimToProjectileEntry(projectileEntry, targetInfo, projectileType, sharedData)
    if not isTable(projectileEntry) or not targetInfo then
        return false
    end

    local origin = getProjectileEntryOrigin(projectileEntry)
    if typeof(origin) ~= "Vector3" then
        return false
    end

    local data = isTable(sharedData) and sharedData or {}
    local projectileName = tostring(projectileType or "Projectile")
    local projectilePower = tonumber(rawget(data, "ProjectilePower") or data.ProjectilePower)
        or tonumber(projectileEntry.projectileSpeed)
        or tonumber(projectileEntry.speed)
        or tonumber(projectileEntry.power)
        or 1
    if projectileName == "TomahawkProjectile" then
        projectilePower = 200
    end

    local gravity = rawget(data, "Gravity") or data.Gravity
    if typeof(gravity) ~= "Vector3" then
        gravity = Vector3.new(0, -32, 0)
    end
    if projectileName == "TomahawkProjectile" then
        gravity = Vector3.new(0, -150, 0)
    end

    local gravityMultiplier = tonumber(rawget(data, "GravityMultiplier") or data.GravityMultiplier)
    if gravityMultiplier then
        gravity = gravity * gravityMultiplier
    end

    if type(projectileEntry.power) == "number" and type(projectileEntry.drawStart) == "number" then
        local drawPower = math.clamp(projectileEntry.power, 0, 1)
        if tostring(projectileEntry.arrowType or "") == "ExplosiveArrow" then
            local maxPower = tonumber(rawget(data, "MaxPower") or data.MaxPower)
            if maxPower then
                projectilePower = math.max(maxPower, drawPower)
            end
        else
            local minPower = tonumber(rawget(data, "MinPower") or data.MinPower)
            if minPower then
                projectilePower = math.max(minPower, drawPower)
            else
                projectilePower = math.max(projectilePower, drawPower)
            end
        end
    end

    local solvedVelocity, travelTime = solveProjectileTravel(origin, projectilePower, targetInfo.position, math.abs(gravity.Y))
    if typeof(solvedVelocity) ~= "Vector3" or solvedVelocity.Magnitude <= 0.001 then
        return false
    end

    local aimDirection = solvedVelocity.Unit
    local _, _, spreadAngle = getProjectileAccuracyState(data, projectileEntry)
    local changed = false

    if projectileName == "ArrowProjectile" then
        local directVector = targetInfo.position - origin
        if directVector.Magnitude > 0.001 then
            projectileEntry.direction = directVector.Unit
            changed = true
        end
        if type(projectileEntry.power) == "number" or projectileEntry.power == nil then
            projectileEntry.power = 1
            changed = true
        end
    else
        local nextDirection = aimDirection
        if projectileName ~= "TomahawkProjectile" then
            nextDirection = getSpreadVectorCompensation(projectileEntry.seed, aimDirection, spreadAngle)
        end
        projectileEntry.direction = nextDirection
        changed = true
        if projectileName ~= "TomahawkProjectile" and (type(projectileEntry.accuracy) == "number" or projectileEntry.accuracy == nil) then
            projectileEntry.accuracy = 1
            changed = true
        end
    end

    local appliedDirection = typeof(projectileEntry.direction) == "Vector3" and projectileEntry.direction or aimDirection
    if typeof(projectileEntry.velocity) == "Vector3" then
        local velocityMagnitude = projectileEntry.velocity.Magnitude
        if velocityMagnitude <= 0.001 then
            velocityMagnitude = math.max(projectilePower, 1)
        end
        projectileEntry.velocity = appliedDirection * velocityMagnitude
        changed = true
    end
    if type(projectileEntry.speed) == "number" then
        projectileEntry.speed = math.max(projectileEntry.speed, projectilePower)
        changed = true
    end
    if type(projectileEntry.projectileSpeed) == "number" then
        projectileEntry.projectileSpeed = math.max(projectileEntry.projectileSpeed, projectilePower)
        changed = true
    end
    if type(projectileEntry.power) == "number" and type(projectileEntry.drawStart) ~= "number" then
        projectileEntry.power = 1
        changed = true
    end

    gunFeatureState.lastProjectileTravelTime = travelTime
    return changed
end

function applyNoSpreadToProjectileEntry(projectileEntry, projectileType, sharedData)
    if not isTable(projectileEntry) then
        return false
    end

    local projectileName = tostring(projectileType or "Projectile")
    if projectileName == "TomahawkProjectile" or projectileName == "ArrowProjectile" then
        return false
    end

    local direction = typeof(projectileEntry.direction) == "Vector3" and projectileEntry.direction or nil
    if (not direction or direction.Magnitude <= 0.001) and typeof(projectileEntry.velocity) == "Vector3" and projectileEntry.velocity.Magnitude > 0.001 then
        direction = projectileEntry.velocity.Unit
    end
    if not direction or direction.Magnitude <= 0.001 then
        return false
    end

    local _, _, spreadAngle = getProjectileAccuracyState(sharedData, projectileEntry)
    projectileEntry.direction = getSpreadVectorCompensation(projectileEntry.seed, direction.Unit, spreadAngle)
    projectileEntry.accuracy = 1
    if type(projectileEntry.spread) == "number" then
        projectileEntry.spread = 0
    end
    return true
end

function applyFastProjectileToEntry(projectileEntry, targetInfo)
    if not isTable(projectileEntry) then
        return false
    end

    local direction = typeof(projectileEntry.direction) == "Vector3" and projectileEntry.direction or nil
    if (not direction or direction.Magnitude <= 0.001) and typeof(projectileEntry.velocity) == "Vector3" and projectileEntry.velocity.Magnitude > 0.001 then
        direction = projectileEntry.velocity.Unit
    end
    if (not direction or direction.Magnitude <= 0.001) and targetInfo and typeof(targetInfo.position) == "Vector3" then
        local origin = getProjectileEntryOrigin(projectileEntry)
        if typeof(origin) == "Vector3" then
            local toTarget = targetInfo.position - origin
            if toTarget.Magnitude > 0.001 then
                direction = toTarget.Unit
            end
        end
    end

    if typeof(direction) == "Vector3" and direction.Magnitude > 0.001 then
        if typeof(projectileEntry.direction) ~= "Vector3" or projectileEntry.direction.Magnitude <= 0.001 then
            projectileEntry.direction = direction.Unit
            return true
        end
    end

    return false
end

function getFastProjectileBulletIdList(bulletIds)
    local normalized = {}
    if type(bulletIds) == "table" then
        for _, bulletId in ipairs(bulletIds) do
            if bulletId ~= nil then
                table.insert(normalized, bulletId)
            end
        end
        if #normalized == 0 then
            for _, bulletId in pairs(bulletIds) do
                if bulletId ~= nil then
                    table.insert(normalized, bulletId)
                end
            end
        end
    elseif bulletIds ~= nil then
        table.insert(normalized, bulletIds)
    end
    return normalized
end

function isTrackedFastProjectileBullet(bulletId)
    return type(gunFeatureState.trackedFastProjectileBullets) == "table"
        and bulletId ~= nil
        and gunFeatureState.trackedFastProjectileBullets[bulletId] == true
end

function untrackFastProjectileBullet(bulletId)
    if type(gunFeatureState.trackedFastProjectileBullets) == "table" and bulletId ~= nil then
        gunFeatureState.trackedFastProjectileBullets[bulletId] = nil
    end
end

function trackFastProjectileBullets(bulletIds)
    if type(gunFeatureState.trackedFastProjectileBullets) ~= "table" then
        gunFeatureState.trackedFastProjectileBullets = {}
    end

    for _, bulletId in ipairs(getFastProjectileBulletIdList(bulletIds)) do
        gunFeatureState.trackedFastProjectileBullets[bulletId] = true
        task.delay(5, function()
            untrackFastProjectileBullet(bulletId)
        end)
    end
end

function resolveFastProjectileHitPosition(origin, targetPosition, targetPart)
    if typeof(targetPosition) ~= "Vector3" then
        return targetPart and targetPart.Position or origin
    end
    if typeof(origin) ~= "Vector3" or not targetPart then
        return targetPosition
    end

    local okRay, hitPosition = pcall(function()
        local hitPart, position = workspace:FindPartOnRayWithWhitelist(
            Ray.new(origin, targetPosition - origin),
            { targetPart }
        )
        if hitPart and typeof(position) == "Vector3" then
            return position
        end
        return targetPosition
    end)
    if okRay and typeof(hitPosition) == "Vector3" then
        return hitPosition
    end

    return targetPosition
end

function resolveFastProjectileTargetReference(network, targetInfo, playerTarget)
    local targetPart = targetInfo and targetInfo.part
    if not targetPart then
        return nil
    end

    local targetReference = nil
    if network and type(network.GetReference) == "function" then
        pcall(function()
            targetReference = network:GetReference(targetPart, "CharacterPart")
        end)
    end
    if targetReference ~= nil then
        return targetReference
    end

    if playerTarget then
        return nil
    end

    return targetPart
end

function getFastProjectileTargetFlags(targetInfo)
    local targetPart = targetInfo and targetInfo.part
    local targetCharacter = targetInfo and targetInfo.character
    local playerTarget = false
    local animalTarget = false
    local npcTarget = false

    if targetCharacter then
        playerTarget = _Players:GetPlayerFromCharacter(targetCharacter) ~= nil
    end

    if targetPart and targetPart.Parent then
        local entities = workspace:FindFirstChild("WORKSPACE_Entities")
        local animals = entities and entities:FindFirstChild("Animals")
        local npcs = entities and entities:FindFirstChild("NPCs")
        if animals then
            animalTarget = targetPart:IsDescendantOf(animals)
        end
        if npcs then
            npcTarget = targetPart:IsDescendantOf(npcs)
        end
    end

    return playerTarget, animalTarget, npcTarget
end

function estimateFastProjectileTravelTime(projectileEntry, targetInfo)
    local travelTime = tonumber(gunFeatureState.lastProjectileTravelTime)
    if travelTime and travelTime >= 0 then
        return math.clamp(travelTime, 0.01, 2)
    end

    local origin = getProjectileEntryOrigin(projectileEntry)
    local targetPosition = targetInfo and targetInfo.position
    if typeof(origin) ~= "Vector3" or typeof(targetPosition) ~= "Vector3" then
        return 0.03
    end

    local speed = tonumber(projectileEntry and projectileEntry.projectileSpeed)
        or tonumber(projectileEntry and projectileEntry.speed)
        or (typeof(projectileEntry and projectileEntry.velocity) == "Vector3" and projectileEntry.velocity.Magnitude)
        or tonumber(projectileEntry and projectileEntry.power)
        or 10000

    if speed <= 0 then
        speed = 10000
    end

    return math.clamp((targetPosition - origin).Magnitude / speed, 0.01, 2)
end

function scheduleFastProjectileFinalEvent(targetInfo, projectileEntry, bulletIds)
    local bulletIdList = getFastProjectileBulletIdList(bulletIds)
    local targetPart = targetInfo and targetInfo.part
    if #bulletIdList == 0 or not targetPart or not targetPart:IsA("BasePart") then
        return
    end

    trackFastProjectileBullets(bulletIdList)

    local origin = getProjectileEntryOrigin(projectileEntry)
    local targetPosition = targetInfo.position or targetPart.Position
    local targetCFrame = targetPart.CFrame
    local hitPosition = resolveFastProjectileHitPosition(origin, targetPosition, targetPart)
    local direction = typeof(projectileEntry and projectileEntry.direction) == "Vector3" and projectileEntry.direction or nil
    if (not direction or direction.Magnitude <= 0.001) and typeof(projectileEntry and projectileEntry.velocity) == "Vector3" then
        direction = projectileEntry.velocity
    end
    if (not direction or direction.Magnitude <= 0.001) and typeof(origin) == "Vector3" and typeof(targetPosition) == "Vector3" then
        direction = targetPosition - origin
    end
    if typeof(direction) ~= "Vector3" or direction.Magnitude <= 0.001 then
        direction = Vector3.FromNormalId(Enum.NormalId.Front)
    else
        direction = direction.Unit
    end
    local speed = tonumber(projectileEntry and projectileEntry.projectileSpeed)
        or tonumber(projectileEntry and projectileEntry.speed)
        or tonumber(projectileEntry and projectileEntry.power)
        or 1
    if speed <= 0 then
        speed = 1
    end
    local velocity = typeof(projectileEntry and projectileEntry.velocity) == "Vector3" and projectileEntry.velocity or nil
    if typeof(velocity) ~= "Vector3" or velocity.Magnitude <= 0.001 then
        velocity = direction * speed
    end

    local playerTarget, animalTarget, npcTarget = getFastProjectileTargetFlags(targetInfo)
    local travelTime = estimateFastProjectileTravelTime(projectileEntry, targetInfo)
    local npcResolvedTarget = nil
    if npcTarget then
        npcResolvedTarget = { targetPart.Parent and targetPart.Parent.Parent or targetPart.Parent, targetPart.Name }
    end
    local animalResolvedTarget = animalTarget and targetPart or nil
    local targetMaterialName = targetPart.Material.Name

    task.spawn(function()
        task.wait(travelTime)

        local network = playerState.hookedNetwork or resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
        local fireServer = type(playerState.originalNetworkFireServer) == "function" and playerState.originalNetworkFireServer
            or (network and network.FireServer)
        if not network or type(fireServer) ~= "function" then
            for _, bulletId in ipairs(bulletIdList) do
                untrackFastProjectileBullet(bulletId)
            end
            return
        end

        local targetReference = resolveFastProjectileTargetReference(network, targetInfo, playerTarget)
        if targetReference == nil and playerTarget then
            for _ = 1, 6 do
                task.wait(0.05)
                targetReference = resolveFastProjectileTargetReference(network, targetInfo, true)
                if targetReference ~= nil then
                    break
                end
            end
        end
        if targetReference == nil and playerTarget then
            for _, bulletId in ipairs(bulletIdList) do
                untrackFastProjectileBullet(bulletId)
            end
            return
        end

        local objectHit = targetCFrame:PointToObjectSpace(hitPosition)
        local frontNormal = targetCFrame:VectorToObjectSpace(Vector3.FromNormalId(Enum.NormalId.Front))
        local directionObject = targetCFrame:VectorToObjectSpace(velocity.Unit)
        local syncedTime = getSyncedNetworkTime()
        local resolvedTarget = targetReference
        if npcTarget then
            resolvedTarget = npcResolvedTarget
        elseif animalTarget then
            resolvedTarget = animalResolvedTarget
        end

        for _, bulletId in ipairs(bulletIdList) do
            pcall(fireServer, network, "ProjectileEvent", bulletId, syncedTime, "Final", resolvedTarget, objectHit, frontNormal, directionObject, hitPosition, Vector3.FromNormalId(Enum.NormalId.Front), targetMaterialName)
            task.defer(function()
                pcall(fireServer, network, "RemoveProjectile", bulletId)
            end)
            untrackFastProjectileBullet(bulletId)
        end
    end)
end

function shouldSuppressTrackedFastProjectileRemote(remoteName, packedArgs)
    if remoteName ~= "ProjectileEvent" and remoteName ~= "RemoveProjectile" then
        return false
    end

    if type(packedArgs) ~= "table" then
        return false
    end

    if isTrackedFastProjectileBullet(packedArgs[1]) then
        return true
    end

    return remoteName == "ProjectileEvent"
        and packedArgs[3] == "Final"
        and packedArgs[4] == nil
end

function collectProjectileEntries(payload, depth, seen, results)
    if not isTable(payload) or (depth or 0) > 4 then
        return results or {}
    end

    results = results or {}
    seen = seen or {}
    if seen[payload] then
        return results
    end
    seen[payload] = true

    if looksLikeProjectileEntry(payload) then
        table.insert(results, payload)
    end

    for _, value in pairs(payload) do
        if isTable(value) then
            collectProjectileEntries(value, (depth or 0) + 1, seen, results)
        end
    end

    return results
end

