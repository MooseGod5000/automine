resolveGlobalNetwork = function(forceRefresh)
	local cache = rawget(_G, "__AutoMineGlobalNetwork")
	if cache and type(cache.FireServer) == "function" then
		return cache
	end

	local lastScan = rawget(_G, "__AutoMineGlobalNetworkLastScan") or 0
	local now = os.clock()
	if not forceRefresh and (now - lastScan) < RESCAN_INTERVAL then
		return nil
	end
	_G.__AutoMineGlobalNetworkLastScan = now

	local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
	local globalModuleScript = sharedModules and sharedModules:FindFirstChild("Global")
	if not globalModuleScript or not globalModuleScript:IsA("ModuleScript") then
		return nil
	end

	local okRequire, globalModule = pcall(require, globalModuleScript)
	if not okRequire or not isTable(globalModule) then
		return nil
	end
	_G.__AutoMineGlobalModule = globalModule

	local network = rawget(globalModule, "Network") or globalModule.Network
	if (not network or type(network.FireServer) ~= "function") and type(globalModule.LoadModule) == "function" then
		local okLoad, loadedNetwork = pcall(function()
			return globalModule:LoadModule("Network")
		end)
		if okLoad and isTable(loadedNetwork) and type(loadedNetwork.FireServer) == "function" then
			network = loadedNetwork
			globalModule.Network = loadedNetwork
		end
	end
	if not network or type(network.FireServer) ~= "function" then
		return nil
	end

	_G.__AutoMineGlobalNetwork = network
	return network
end

function resolveGlobalParams(forceRefresh)
    local globalModule = rawget(_G, "__AutoMineGlobalModule")
    if not isTable(globalModule) then
        resolveGlobalNetwork(forceRefresh)
        globalModule = rawget(_G, "__AutoMineGlobalModule")
    end
    if not isTable(globalModule) then
        return nil
    end

    local params = rawget(globalModule, "Params") or globalModule.Params
    if isTable(params) then
        return params
    end

    if type(globalModule.LoadModule) == "function" then
        local okLoad, loadedParams = pcall(function()
            return globalModule:LoadModule("Params")
        end)
        if okLoad and isTable(loadedParams) then
            globalModule.Params = loadedParams
            return loadedParams
        end
    end

    return nil
end

