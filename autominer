    task.spawn(function()
        while hubGui.Parent and not destroyed and isSessionActive() do
            local character = cachedCharacter or getCustomCharacter()
            local humanoid = cachedHumanoid or getHumanoid(character)
            local rootPart = getRootPart(character)
            local now = os.clock()
            local horizontalSpeed = 0
            local displacementSpeed = 0
            local anchored = "?"
            local stateName = "nil"
            local walkSpeed = 0
            local moveDirectionMagnitude = 0
            local targetDistance = -1
            local oreHealth = "nil"

            if rootPart then
                anchored = tostring(rootPart.Anchored)
                horizontalSpeed = math.floor(Vector3.new(rootPart.AssemblyLinearVelocity.X, 0, rootPart.AssemblyLinearVelocity.Z).Magnitude * 10 + 0.5) / 10
                if lastRootSamplePosition and lastRootSampleAt > 0 then
                    local dt = now - lastRootSampleAt
                    if dt > 0 then
                        displacementSpeed = math.floor(((rootPart.Position - lastRootSamplePosition).Magnitude / dt) * 10 + 0.5) / 10
                    end
                end
                lastRootSamplePosition = rootPart.Position
                lastRootSampleAt = now
            else
                lastRootSamplePosition = nil
                lastRootSampleAt = 0
            end

            if humanoid then
                walkSpeed = humanoid.WalkSpeed
                moveDirectionMagnitude = math.floor(humanoid.MoveDirection.Magnitude * 100 + 0.5) / 100
                local ok, state = pcall(function()
                    return humanoid:GetState()
                end)
                if ok and state then
                    stateName = state.Name
                end
            end

            if character and currentTargetOre then
                targetDistance = math.floor(getDistanceToOre(character, currentTargetOre) * 10 + 0.5) / 10
                oreHealth = formatOreHealthText(currentTargetOre, false)
            end

            if movementDebugLabel then
                pcall(function()
                    movementDebugLabel.Text = table.concat({
                        string.format("mode=%s aura=%s pickup=%s path=%s range=%.0f sprint=%s infstam=%s safetp=%s ts=%.0f", getMovementModeLabel(), tostring(mineAuraEnabled), tostring(autoPickupEnabled), tostring(pathState.playbackActive), mineAuraEnabled and MINE_AURA_RANGE or MINE_RANGE, tostring(movementKeyState[Enum.KeyCode.LeftShift]), tostring(playerState.infiniteStaminaEnabled), tostring(playerState.safeTeleportEnabled), tweenMoveSpeed),
                        string.format("state=%s anchored=%s", stateName, anchored),
                        string.format("walkspeed=%.2f movedir=%.2f", walkSpeed, moveDirectionMagnitude),
                        string.format("vel=%.1f studs/s delta=%.1f", horizontalSpeed, displacementSpeed),
                        string.format("cmd=%s %.2f, %.2f, %.2f", lastMoveCommandSource, lastMoveCommand.X, lastMoveCommand.Y, lastMoveCommand.Z),
                        string.format("targetDist=%s oreHp=%s", targetDistance >= 0 and tostring(targetDistance) or "nil", oreHealth),
                    }, "\n")
                end)
            end

            if pathState.recording and pathState.editorVisible and character then
                local currentRoot = getRootPart(character)
                if currentRoot and (not pathState.lastRecordedNodePosition or (currentRoot.Position - pathState.lastRecordedNodePosition).Magnitude >= PATH_RECORD_NODE_SPACING) then
                    addWorkingPathNode(currentRoot.Position)
                end
            end

            refreshAutoSellDisplay()
            refreshPathEditorButtons()
            task.wait(0.1)
        end
    end)
