function beginNewPathRecording(slotIndex)
	ensurePathStorageSupport(true)
	setFocusedPathSlotIndex(slotIndex or pathState.focusedPathSlotIndex or 1, false)

	if autoMineEnabled then
		stopAutoMine()
	end

	pathState.selectedPathName = nil
	setPathDeleteConfirmSlot(nil)
	pathState.pathDropdownOpen = false
	pathState.workingPath = {
		nodes = {},
		ores = {},
		manualSellNodeIndex = nil,
		spawnName = nil,
	}
	pathState.sellNodeDirty = true
	pathState.sellNodeIndex = nil
	pathState.lastRecordedNodePosition = nil
	pathState.recording = true
	openPathEditor(false)
	if ensureWorkingPathStartNode() then
		refreshPathVisuals()
	else
		setPathEditorStatus("Recording started. Move a little if the first node does not appear right away.", UI_COLORS.muted)
	end
