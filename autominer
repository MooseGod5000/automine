local function _repositionNotifications()
    for index, entry in ipairs(_activeNotifications) do
        local stackIndex = #_activeNotifications - index
        local targetY = -(_NOTIF_BOTTOM_MARGIN + stackIndex * (_NOTIF_HEIGHT + _NOTIF_GAP))
        _TweenService:Create(entry.container, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(1, -_NOTIF_RIGHT_MARGIN, 1, targetY),
        }):Play()
    end
end

local function _removeNotification(entry)
    for index, activeEntry in ipairs(_activeNotifications) do
        if activeEntry == entry then
            table.remove(_activeNotifications, index)
            break
        end
    end
    _repositionNotifications()
end

