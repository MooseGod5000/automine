function processGunProjectileRemote(remoteName, packedArgs)
    if remoteName ~= "InitProjectiles" then
        return packedArgs
    end
    if not (S.silentAimEnabled or S.fastProjectileEnabled or S.noSpreadEnabled) then
        return packedArgs
    end

    local gunItem, sharedData = getCurrentGunSharedData(false)
    if not sharedData then
        gunItem, sharedData = getCurrentGunSharedData(true)
    end

    local targetInfo = nil
    gunFeatureState.lastProjectileTravelTime = nil
    if S.silentAimEnabled then
        local hitRoll = math.random(1, 100)
        local hitChance = math.clamp(tonumber(S.silentAimAccuracy) or 50, 1, 100)
        if hitRoll <= hitChance then
            targetInfo = getSilentAimTargetInfo()
        end
        if not targetInfo and not (S.fastProjectileEnabled or S.noSpreadEnabled) then
            return packedArgs
        end
    end

    local appliedSilentAim = false
    local trackedFastProjectileEntry = nil
    for index = 1, packedArgs.n do
        if isTable(packedArgs[index]) then
            local projectileEntries = collectProjectileEntries(packedArgs[index], 0, {}, {})
            for _, projectileEntry in ipairs(projectileEntries) do
                local projectileType = getCurrentProjectileType(projectileEntry)
                local silentAimChanged = false

                if targetInfo then
                    silentAimChanged = applySilentAimToProjectileEntry(projectileEntry, targetInfo, projectileType, sharedData)
                    appliedSilentAim = appliedSilentAim or silentAimChanged
                end

                if S.fastProjectileEnabled then
                    applyFastProjectileToEntry(projectileEntry, targetInfo)
                    if not trackedFastProjectileEntry and targetInfo and silentAimChanged then
                        trackedFastProjectileEntry = projectileEntry
                    end
                end

                if S.noSpreadEnabled and not silentAimChanged then
                    applyNoSpreadToProjectileEntry(projectileEntry, projectileType, sharedData)
                end
            end
        end
    end

    if S.fastProjectileEnabled and targetInfo and appliedSilentAim and trackedFastProjectileEntry and packedArgs[3] ~= nil then
        scheduleFastProjectileFinalEvent(targetInfo, trackedFastProjectileEntry, packedArgs[3])
    end

    if targetInfo and appliedSilentAim then
        gunFeatureState.currentTargetInfo = targetInfo
    elseif not hasGunAimVisualsEnabled() then
        gunFeatureState.currentTargetInfo = nil
    end

    return packedArgs
end

function hideGunAimDrawings()
