function resolveTwwLeaderboardStateMap(forceRefresh)
    if type(S._espLeaderboardStateMap) == "table" and not forceRefresh then
        return S._espLeaderboardStateMap
    end

    S._espLeaderboardStateMap = nil

    local leaderboard = nil
    local modulesTable = type(resolveGameModules) == "function" and resolveGameModules(forceRefresh) or nil
    if isTable(modulesTable) then
        leaderboard = rawget(modulesTable, "leaderboard") or modulesTable.leaderboard
    end

    if not isTable(leaderboard) then
        local globalModule = rawget(_G, "__AutoMineGlobalModule")
        if isTable(globalModule) and type(globalModule.LoadModule) == "function" then
            local okLoad, loadedModule = pcall(function()
                return globalModule:LoadModule("Leaderboard")
            end)
            if okLoad and isTable(loadedModule) then
                leaderboard = loadedModule
            end
        end
    end

    if not isTable(leaderboard) or type(leaderboard.UpdatePlayers) ~= "function" then
        return nil
    end
    if type(debug) ~= "table" or type(debug.getupvalues) ~= "function" then
        return nil
    end

    local okOuter, outerUpvalues = pcall(debug.getupvalues, leaderboard.UpdatePlayers)
    if not okOuter or type(outerUpvalues) ~= "table" then
        return nil
    end

    local stateHolder = outerUpvalues[2]
    if type(stateHolder) ~= "table" or type(stateHolder.new) ~= "function" then
        return nil
    end

    local okInner, innerUpvalues = pcall(debug.getupvalues, stateHolder.new)
    if not okInner or type(innerUpvalues) ~= "table" or type(innerUpvalues[1]) ~= "table" then
        return nil
    end

    S._espLeaderboardStateMap = innerUpvalues[1]
    return S._espLeaderboardStateMap
end

function getTwwPlayerStateInfo(player)
    local stateMap = resolveTwwLeaderboardStateMap(false)
    local stateEntry = stateMap and stateMap[player]
    local stateObject = stateEntry and stateEntry.StateObject
    local stateInfo = stateObject and stateObject.State
    if type(stateInfo) == "table" then
        return stateInfo
    end

    local character = getWorldCharacterForPlayer(player)
    local roleValue = character and character:FindFirstChild("Role", true)
    local criminalValue = character and character:FindFirstChild("CriminalStatus", true)
    if roleValue or criminalValue then
        return {
            Role = roleValue and roleValue:IsA("StringValue") and roleValue.Value or nil,
            CriminalStatus = criminalValue and criminalValue:IsA("StringValue") and criminalValue.Value or nil,
        }
    end

    return nil
end

function getPlayerEspRoleColor(player)
    local stateInfo = getTwwPlayerStateInfo(player)
    if type(stateInfo) == "table" then
        local criminalStatus = tostring(stateInfo.CriminalStatus or "")
        if criminalStatus ~= "" then
            if criminalStatus == "Menace" then
                return Color3.fromRGB(255, 38, 38), "Outlaw"
            end
            if criminalStatus == "Wanted" then
                return Color3.fromRGB(225, 92, 38), "Outlaw"
            end
            return Color3.fromRGB(150, 18, 18), "Outlaw"
        end

        local roleName = tostring(stateInfo.Role or "")
        if roleName == "Sheriff" then
            return Color3.fromRGB(26, 92, 214), "Law"
        end
        if roleName == "Mayor" then
            return Color3.fromRGB(255, 200, 0), "Law"
        end
        if roleName == "Citizen" then
            return Color3.fromRGB(215, 210, 188), "Law"
        end
        if roleName == "Law" then
            return Color3.fromRGB(0, 41, 117), "Law"
        end
        if roleName == "Outlaw" then
            return Color3.fromRGB(216, 74, 52), "Outlaw"
        end
        if roleName == "Skulled" then
            return Color3.fromRGB(145, 14, 14), "Outlaw"
        end
    end

    if player and player.Team and player.Team.Name == "Lawmen" then
        return Color3.fromRGB(26, 92, 214), "Law"
    end
    if player and player.Team and string.find(string.lower(player.Team.Name), "outlaw", 1, true) then
        return Color3.fromRGB(216, 74, 52), "Outlaw"
    end
    return Color3.new(0.996078, 0.952941, 0.733333), "Law"
end

