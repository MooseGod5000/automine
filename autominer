		or getResolvedItemData(rawget(playerCharacter, "NextItemToEquip") or playerCharacter.NextItemToEquip)
		or getResolvedItemData(rawget(playerCharacter, "SwitchItem") or playerCharacter.SwitchItem)
		or getCurrentEquippedItemData(playerCharacter)
