function beginPathEditing(pathName, slotIndex)
	if not pathName or not pathState.paths[pathName] then
		return
	end

	ensurePathStorageSupport(true)
	setFocusedPathSlotIndex(slotIndex or pathState.focusedPathSlotIndex or 1, true)

	if autoMineEnabled then
		stopAutoMine()
	end

	pathState.workingPath = clonePathData(pathState.paths[pathName])
	pathState.sellNodeDirty = true
	pathState.selectedPathName = pathName
	pathState.lastRecordedNodePosition = nil
	pathState.recording = false
	openPathEditor(true)
end

function setEditNodePlacementEnabled(isEnabled)
	local nextValue = isEnabled == true
	if pathState.editNodePlacementEnabled == nextValue then
		refreshPathEditorButtons()
		return
	end

	pathState.editNodePlacementEnabled = nextValue
	if nextValue then
		pathState.deleteMode = false
		pathState.sellNodePickMode = false
	else
		pathState.selectedNodeIndex = nil
		pathState.draggingNodeIndex = nil
		pathState.draggingNodeAxis = nil
		pathState.dragLastPointerPosition = nil
	end

	refreshPathEditorButtons()
	refreshPathVisuals()
	setPathEditorIdleStatus()
end

function addWorkingPathNode(position)
	if not position then
		return
	end

	position = getGroundAlignedPathPosition(position, cachedCharacter or getCustomCharacter()) or position

	table.insert(pathState.workingPath.nodes, {
		position = position,
	})
	pathState.lastRecordedNodePosition = position
	pathState.sellNodeDirty = true
	recomputeWorkingPathSellNode()
	refreshPathVisuals()
end

ensureWorkingPathStartNode = function()
	if #pathState.workingPath.nodes > 0 then
		return true
	end

	local character = cachedCharacter or getCustomCharacter() or (localPlayer and localPlayer.Character)
	local rootPart = getRootPart(character)
	if not rootPart and character then
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		rootPart = (humanoid and humanoid.RootPart) or character.PrimaryPart
	end
	if rootPart then
		addWorkingPathNode(rootPart.Position)
		return true
	end
	return false
end

function toggleSelectedWorkingPathSellNode()
	if not pathState.editorVisible then
		return false
	end

	pathState.sellNodePickMode = not pathState.sellNodePickMode
	pathState.editNodePlacementEnabled = false
	pathState.deleteMode = false
	pathState.draggingNodeIndex = nil
	pathState.draggingNodeAxis = nil
	pathState.dragLastPointerPosition = nil
	refreshPathEditorButtons()
	if pathState.sellNodePickMode then
		setPathEditorStatus("Click a node to set the sell point. Clicking the current sell node clears it.", UI_COLORS.accent)
	else
		setPathEditorIdleStatus()
	end
	return true
end

function applyWorkingPathSellNodeSelection(nodeIndex)
	local normalizedNodeIndex = normalizePathNodeIndex(nodeIndex, #(pathState.workingPath.nodes or {}))
	if not normalizedNodeIndex then
		return false
	end

	local manualSellNodeIndex = getManualPathSellNodeIndex(pathState.workingPath)
	pathState.selectedNodeIndex = normalizedNodeIndex
	pathState.sellNodePickMode = false
	pathState.draggingNodeIndex = nil
	pathState.draggingNodeAxis = nil
	pathState.dragLastPointerPosition = nil

	if manualSellNodeIndex == normalizedNodeIndex then
		pathState.workingPath.manualSellNodeIndex = nil
		pathState.sellNodeDirty = true
		recomputeWorkingPathSellNode()
		refreshPathVisuals()
		refreshPathEditorButtons()
		setPathEditorStatus("Sell node reset to auto detection.", UI_COLORS.warning)
		return true
	end

	pathState.workingPath.manualSellNodeIndex = normalizedNodeIndex
	pathState.sellNodeDirty = true
	recomputeWorkingPathSellNode()
	refreshPathVisuals()
	refreshPathEditorButtons()
	setPathEditorStatus("Manual sell node set to #" .. tostring(normalizedNodeIndex) .. ".", UI_COLORS.success)
	return true
end

function saveWorkingPath(pathName)
	local trimmedName = string.gsub(tostring(pathName or ""), "^%s+", "")
	trimmedName = string.gsub(trimmedName, "%s+$", "")
	if trimmedName == "" then
		setPathEditorStatus("Enter a path name before saving.", UI_COLORS.warning)
		return false
	end

	if #pathState.workingPath.nodes == 0 then
		setPathEditorStatus("You need at least one node before saving.", UI_COLORS.warning)
		return false
	end
	if not getWorkingPathSpawnName() then
		setPathEditorStatus("Pick a spawn before saving this path.", UI_COLORS.warning)
		return false
	end

	pathState.paths[trimmedName] = clonePathData(pathState.workingPath)
	setPathSlotSelection(pathState.focusedPathSlotIndex, trimmedName, {syncSelectedPath = true})
	setPathDeleteConfirmSlot(nil)
	pathState.pendingPathNameCapture = false
	pathUi.editorNameBox.Visible = false
	pathUi.editorSaveConfirmButton.Visible = false
	pathUi.editorNameBox.Text = trimmedName
	savePathsToStorage(true)
	refreshPathManagerButtons()
	updateAutofarmLayout()
	setPathEditorStatus("Saved path: " .. trimmedName, UI_COLORS.success)
	return true
end

function updateWorkingPath()
	local selectedPathName = tostring(pathState.selectedPathName or "")
	if selectedPathName == "" or not pathState.paths[selectedPathName] then
		setPathEditorStatus("Pick a saved path before updating.", UI_COLORS.warning)
		return false
	end

	if #pathState.workingPath.nodes == 0 then
		setPathEditorStatus("You need at least one node before updating.", UI_COLORS.warning)
		return false
	end
	if not getWorkingPathSpawnName() then
		setPathEditorStatus("Pick a spawn before updating this path.", UI_COLORS.warning)
		return false
	end

	pathState.paths[selectedPathName] = clonePathData(pathState.workingPath)
	setPathSlotSelection(pathState.focusedPathSlotIndex, selectedPathName, {syncSelectedPath = true})
	setPathDeleteConfirmSlot(nil)
	pathUi.editorNameBox.Visible = false
	pathUi.editorSaveConfirmButton.Visible = false
	savePathsToStorage(true)
	refreshPathManagerButtons()
	refreshPathEditorButtons()
	refreshPathVisuals()
	updateAutofarmLayout()
	setPathEditorStatus("Path updated.", UI_COLORS.success)
