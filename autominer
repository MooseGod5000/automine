function ensureSafeTeleportHooks()
	if not (playerState.safeTeleportEnabled or playerState.noRagdollEnabled) then
		return
	end

	local handler = resolveSafeTeleportHandler(false) or resolveSafeTeleportHandler(true)
	if handler and handler ~= playerState.hookedSafeTeleportHandler then
		restoreSafeTeleportHooks()
		playerState.hookedSafeTeleportHandler = handler
	end

	handler = playerState.hookedSafeTeleportHandler
	if isTable(handler) then
		local updateLocalCharPlatform = rawget(handler, "_UpdateLocalCharPlatform") or handler._UpdateLocalCharPlatform
		if type(updateLocalCharPlatform) == "function" and updateLocalCharPlatform ~= playerState.safeTeleportPlatformWrapper then
			playerState.originalSafeTeleportPlatformUpdate = updateLocalCharPlatform
			playerState.safeTeleportPlatformWrapper = function(...)
				if playerState.safeTeleportEnabled then
					return nil
				end
				return playerState.originalSafeTeleportPlatformUpdate(...)
			end
			handler._UpdateLocalCharPlatform = playerState.safeTeleportPlatformWrapper
		end

		local replicateCharacters = rawget(handler, "ReplicateCharacters") or handler.ReplicateCharacters
		if type(replicateCharacters) == "function" and replicateCharacters ~= playerState.safeTeleportReplicateWrapper then
			playerState.originalSafeTeleportReplicateCharacters = replicateCharacters
			playerState.safeTeleportReplicateWrapper = function(self, ...)
				if playerState.safeTeleportEnabled then
					return nil
				end
				return playerState.originalSafeTeleportReplicateCharacters(self, ...)
			end
			handler.ReplicateCharacters = playerState.safeTeleportReplicateWrapper
		end

		local flags = rawget(handler, "Flags") or handler.Flags
		local flagsMetatable = isTable(flags) and getmetatable(flags) or nil
		if type(flagsMetatable) == "table" and type(flagsMetatable.__newindex) == "function"
			and flagsMetatable.__newindex ~= playerState.safeTeleportFlagsNewIndexWrapper then
			local originalNewIndex = flagsMetatable.__newindex
			playerState.hookedSafeTeleportFlagsMetatable = flagsMetatable
			playerState.originalSafeTeleportFlagsNewIndex = originalNewIndex
			playerState.safeTeleportFlagsNewIndexWrapper = function(tableRef, key, value)
				if playerState.safeTeleportEnabled and playerState.safeTeleportBlockedFlags[key] then
					return
				end
				return originalNewIndex(tableRef, key, value)
			end
			flagsMetatable.__newindex = playerState.safeTeleportFlagsNewIndexWrapper
		end
	end

	local ragdollOwner = resolveSafeTeleportRagdollOwner(false) or resolveSafeTeleportRagdollOwner(true)
	if ragdollOwner and ragdollOwner ~= playerState.hookedSafeTeleportRagdollOwner then
		local previousOwner = playerState.hookedSafeTeleportRagdollOwner
		if isTable(previousOwner) and playerState.originalSafeTeleportRagdoll and previousOwner.Ragdoll == playerState.safeTeleportRagdollWrapper then
			previousOwner.Ragdoll = playerState.originalSafeTeleportRagdoll
		end

		local ragdoll = rawget(ragdollOwner, "Ragdoll") or ragdollOwner.Ragdoll
		if type(ragdoll) == "function" then
			playerState.hookedSafeTeleportRagdollOwner = ragdollOwner
			playerState.originalSafeTeleportRagdoll = ragdoll
			playerState.safeTeleportRagdollWrapper = function(...)
				local experimentalState = getExperimentalCFrameTravelState()
				local allowExperimentalRagdoll = type(experimentalState) == "table" and experimentalState.active == true
				if (playerState.safeTeleportEnabled or playerState.noRagdollEnabled) and not allowExperimentalRagdoll then
					return nil
				end
				return playerState.originalSafeTeleportRagdoll(...)
			end
			ragdollOwner.Ragdoll = playerState.safeTeleportRagdollWrapper
		end
	end
end

function restoreNoJumpCooldownHooks()
    if type(playerState.jumpHookConnections) == "table" then
        for _, connection in ipairs(playerState.jumpHookConnections) do
            if connection and type(connection.Enable) == "function" then
                pcall(function()
                    connection:Enable()
                end)
            end
        end
    end

    playerState.jumpHookHumanoid = nil
    playerState.jumpHookConnections = {}
end

function ensureNoJumpCooldownHooks()
    if not playerState.noJumpCooldownEnabled then
        return
    end
    if type(getconnections) ~= "function" then
        return
    end

    local character = getWorldCharacterForPlayer(localPlayer) or localPlayer.Character
    local humanoid = getCharacterHumanoid(character)
    if not humanoid then
        restoreNoJumpCooldownHooks()
        return
    end

    if playerState.jumpHookHumanoid == humanoid and type(playerState.jumpHookConnections) == "table" and #playerState.jumpHookConnections > 0 then
        return
    end

    restoreNoJumpCooldownHooks()
    playerState.jumpHookHumanoid = humanoid
    playerState.jumpHookConnections = {}

    local okConnections, connections = pcall(function()
        return getconnections(humanoid:GetPropertyChangedSignal("Jump"))
    end)
    if not okConnections or type(connections) ~= "table" then
        return
    end

    for _, connection in ipairs(connections) do
        if connection and type(connection.Disable) == "function" then
            local okDisable = pcall(function()
                connection:Disable()
            end)
            if okDisable and type(connection.Enable) == "function" then
                table.insert(playerState.jumpHookConnections, connection)
            end
        end
    end
end

function restoreAutoBreakFreeHooks()
    if playerState.breakFreeOwner and playerState.breakFreeHook then
        local owner = playerState.breakFreeOwner
        local hook = playerState.breakFreeHook
        pcall(function()
            if hook.installedMetatable and getmetatable(owner) == hook.installedMetatable then
                setmetatable(owner, hook.originalMetatable)
            end
        end)
        pcall(function()
            rawset(owner, "BreakFreePerc", hook.shadowValue)
        end)
    end

    playerState.breakFreeOwner = nil
    playerState.breakFreeHook = nil
end

function installAutoBreakFreeHook(owner)
    if not isTable(owner) then
        return false
    end
    if playerState.breakFreeOwner == owner and playerState.breakFreeHook then
        return true
    end

    restoreAutoBreakFreeHooks()

    local originalMetatable = getmetatable(owner)
    if type(originalMetatable) ~= "table" then
        originalMetatable = {}
    end

    local originalIndex = originalMetatable.__index
    local originalNewIndex = originalMetatable.__newindex
    local shadowValue = rawget(owner, "BreakFreePerc")

    if shadowValue == nil then
        if type(originalIndex) == "function" then
            local okIndex, value = pcall(originalIndex, owner, "BreakFreePerc")
            if okIndex then
                shadowValue = value
            end
        elseif type(originalIndex) == "table" then
            shadowValue = rawget(originalIndex, "BreakFreePerc") or originalIndex.BreakFreePerc
        end
    end

    local installedMetatable = {}
    for key, value in pairs(originalMetatable) do
        installedMetatable[key] = value
    end

    installedMetatable.__index = function(tableRef, key)
        if key == "BreakFreePerc" then
            return shadowValue
        end
        if type(originalIndex) == "function" then
            return originalIndex(tableRef, key)
        elseif type(originalIndex) == "table" then
            return originalIndex[key]
        end
        return rawget(tableRef, key)
    end

    installedMetatable.__newindex = function(tableRef, key, value)
        if key == "BreakFreePerc" then
            shadowValue = value
            if playerState.autoBreakFreeEnabled and type(value) == "number" and value > 0 then
                shadowValue = 1
            end
            return
        end
        if type(originalNewIndex) == "function" then
            return originalNewIndex(tableRef, key, value)
        end
        rawset(tableRef, key, value)
    end

    local okSet = pcall(function()
        setmetatable(owner, installedMetatable)
    end)
    if not okSet then
        return false
    end

    playerState.breakFreeOwner = owner
    playerState.breakFreeHook = {
        originalMetatable = originalMetatable,
        installedMetatable = installedMetatable,
        shadowValue = shadowValue,
    }

    pcall(function()
        rawset(owner, "BreakFreePerc", nil)
    end)

    return true
end

function ensureAutoBreakFreeHooks()
    if not playerState.autoBreakFreeEnabled then
        return
    end

    local owner = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
    if installAutoBreakFreeHook(owner) and playerState.breakFreeHook and type(playerState.breakFreeHook.shadowValue) == "number" and playerState.breakFreeHook.shadowValue > 0 then
        playerState.breakFreeHook.shadowValue = 1
    end
end

function runPlayerFeaturePulse()
    local experimentalState = getExperimentalCFrameTravelState()
    local experimentalTravelActive = type(experimentalState) == "table" and experimentalState.active == true
    if not experimentalTravelActive and (playerState.noRagdollEnabled or playerState.autoGetUpEnabled) then
        local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
        local playerCharacter = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
        local characterModel = getWorldCharacterForPlayer(localPlayer) or localPlayer.Character
        local humanoid = getCharacterHumanoid(characterModel)
        if network and playerCharacter and humanoid and type(playerCharacter.CanGetUp) == "function" and playerCharacter:CanGetUp() then
            pcall(function()
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end)
            if type(playerCharacter.ToggleSelfRagdoll) == "function" then
                pcall(function()
                    playerCharacter:ToggleSelfRagdoll(false)
                end)
            end
            if type(network.InvokeServer) == "function" then
                pcall(function()
                    network:InvokeServer("AttemptGetUp")
                end)
            end
        end
    end
end

function ensurePlayerFeatureHooks()
	ensurePlayerStateNetworkHook()

	if playerState.infiniteStaminaEnabled then
		ensureInfiniteStaminaHooks()
	else
		restoreInfiniteStaminaHooks()
	end

	if playerState.safeTeleportEnabled or playerState.noRagdollEnabled then
		ensureSafeTeleportHooks()
	else
		restoreSafeTeleportHooks()
	end

    if playerState.noJumpCooldownEnabled then
        ensureNoJumpCooldownHooks()
    else
        restoreNoJumpCooldownHooks()
    end

    if playerState.autoBreakFreeEnabled then
        ensureAutoBreakFreeHooks()
    else
        restoreAutoBreakFreeHooks()
    end

    ensureGunFeatureHooks()

    runPlayerFeaturePulse()
    runGunFeaturePulse()

	if hasPlayerStateFeatureHooksEnabled() and not playerState.hookRefreshActive then
		playerState.hookRefreshActive = true
		task.spawn(function()
			while hasPlayerStateFeatureHooksEnabled() do
				ensurePlayerStateNetworkHook()
				if playerState.infiniteStaminaEnabled then
					ensureInfiniteStaminaHooks()
				end
				if playerState.safeTeleportEnabled or playerState.noRagdollEnabled then
					ensureSafeTeleportHooks()
				end
                if playerState.noJumpCooldownEnabled then
                    ensureNoJumpCooldownHooks()
                end
                if playerState.autoBreakFreeEnabled then
                    ensureAutoBreakFreeHooks()
                end
                ensureGunFeatureHooks()
                runPlayerFeaturePulse()
                runGunFeaturePulse()
				task.wait(0.35)
			end
			restorePlayerStateNetworkHook()
            restoreNoJumpCooldownHooks()
            restoreAutoBreakFreeHooks()
            restoreGunFeatureHooks()
			playerState.hookRefreshActive = false
		end)
	end
end

function resolveGlobalMiningHandler(forceRefresh)
	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end
	if not isTable(globalModule) then
		return nil
	end

	local handler = rawget(globalModule, "MiningHandler") or globalModule.MiningHandler
	if isTable(handler) and type(handler.HitDeposit) == "function" then
		return handler
	end

	if type(globalModule.LoadModule) == "function" then
		local okLoad, loadedHandler = pcall(function()
			return globalModule:LoadModule("MiningHandler")
		end)
		if okLoad and isTable(loadedHandler) and type(loadedHandler.HitDeposit) == "function" then
			globalModule.MiningHandler = loadedHandler
			return loadedHandler
		end
	end

	return nil
end

function tryMineViaGlobalNetwork(character, targetOre, equippedPickaxe)
	if not mineAuraEnabled or not targetOre then
		return false
	end

	local network = resolveGlobalNetwork(false)
	if not network then
		network = resolveGlobalNetwork(true)
	end
	if not network then
		return false
	end

	local orePart = getOreBasePart(targetOre)
	local orePosition = getOrePosition(targetOre)
	if not orePosition then
		return false
	end
	local depositModel = targetOre
	if orePart and orePart.Parent then
		depositModel = orePart.Parent
	end

	local toolPart = nil
	local activePickaxe = equippedPickaxe or getEquippedPickaxe(character)
	if activePickaxe then
		toolPart = activePickaxe:FindFirstChild("HitBox", true)
			or activePickaxe:FindFirstChild("Hitbox", true)
			or activePickaxe:FindFirstChild("Handle", true)
	end

	local toolPos = orePosition
	local toolVec = Vector3.new(0, -1, 0)
	if toolPart and toolPart:IsA("BasePart") then
		local halfWidth = toolPart.Size.X * 0.5
		toolPos = toolPart.CFrame * Vector3.new(halfWidth, 0, 0)
		toolVec = -toolPart.CFrame.XVector
	end

	local miningHandler = resolveGlobalMiningHandler(false)
	if not miningHandler then
		miningHandler = resolveGlobalMiningHandler(true)
	end

	local localHitAllowed = true
	if miningHandler and depositModel then
		local okHit, hitAllowed = pcall(function()
			return miningHandler:HitDeposit(depositModel, toolPos, toolVec)
		end)
		if okHit then
			localHitAllowed = hitAllowed == true
			if not localHitAllowed then
				pushDebugRateLimited("mine_aura_local_reject", "mine aura local hit rejected", 2)
			end
		else
			localHitAllowed = false
			pushDebugRateLimited("mine_aura_local_error", "mine aura local hit errored", 2)
		end
	end

	if not localHitAllowed then
		return false
	end

	local syncedTime = getSyncedNetworkTime()
	local swingOk = pcall(network.FireServer, network, "MeleeSwing", syncedTime, "Swing")
	local mineOk = pcall(network.FireServer, network, "MineDeposit", syncedTime, depositModel, toolPos, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, targetOre, toolPos, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, orePart, toolPos, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, orePart and orePart.Parent, toolPos, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, depositModel, orePosition, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, targetOre, orePosition, toolVec)
		or pcall(network.FireServer, network, "MineDeposit", syncedTime, orePart, orePosition, toolVec)

	if swingOk or mineOk then
		pushDebugRateLimited("mine_aura_global", "mine aura global network: " .. targetOre.Name, 2)
		return true
	end

	return false
end

function pushMineAuraDebugThrottled(message)
	local now = os.clock()
	if (now - lastMineAuraDebugAt) > 2 then
		lastMineAuraDebugAt = now
		pushDebug(message)
	end
end

function probeToolInfoCandidates(character)
	if type(getgc) ~= "function" then
		return
	end

	local now = os.clock()
	if (now - lastAuraProbeAt) < 8 then
		return
	end
	lastAuraProbeAt = now

	local ok, gcObjects = pcall(getgc, true)
	if not ok or type(gcObjects) ~= "table" then
		return
	end

	local bestSummary = {}
	local bestScores = {}
	local deadline = os.clock() + TOOLINFO_DIRECT_SCAN_BUDGET
	for _, object in ipairs(gcObjects) do
		if os.clock() > deadline then
			break
		end

		if isTable(object) and looksLikeToolInfo(object) then
			local score = scoreToolInfoCandidate(object, character)
			if score >= 4 then
				local index = #bestScores + 1
				bestScores[index] = score
				bestSummary[index] = object
				for i = index, 2, -1 do
					if bestScores[i] > bestScores[i - 1] then
						bestScores[i], bestScores[i - 1] = bestScores[i - 1], bestScores[i]
						bestSummary[i], bestSummary[i - 1] = bestSummary[i - 1], bestSummary[i]
					end
				end
				if #bestScores > 2 then
					table.remove(bestScores)
					table.remove(bestSummary)
				end
			end
		end
	end

	if #bestSummary == 0 then
		pushDebug("aura probe: no candidate toolInfo table")
		return
	end

	local chunks = {}
	for i, candidate in ipairs(bestSummary) do
		local model = rawget(candidate, "Model") or candidate.Model
		local nameHint = rawget(candidate, "Name")
			or candidate.Name
			or rawget(candidate, "ItemName")
			or candidate.ItemName
			or model
		local isEquipped = rawget(candidate, "IsEquipped")
		if isEquipped == nil then
			isEquipped = candidate.IsEquipped
		end
		local hasHitbox = getToolInfoHitbox(candidate) ~= nil
		chunks[i] = string.format(
			"%s eq=%s hb=%s sc=%d",
			tostring(nameHint),
			tostring(isEquipped),
			tostring(hasHitbox),
			bestScores[i]
		)
	end

	pushDebug("aura probe: " .. table.concat(chunks, " | "))
end

function tryMineViaToolInfoNetwork(character, targetOre)
	if not mineAuraEnabled then
		return false
	end

	local toolInfo = resolveToolInfo(false, character)
	if not toolInfo then
		local now = os.clock()
		local lastDirectScan = lastDirectToolInfoScanAt or 0
		if (now - lastAuraForceScanAt) >= AURA_FORCE_SCAN_INTERVAL and (now - lastDirectScan) >= AURA_FORCE_SCAN_INTERVAL then
			lastAuraForceScanAt = now
			toolInfo = resolveToolInfo(true, character)
		end
	end

	if not looksLikeToolInfo(toolInfo) then
		if not auraCapabilitiesReported then
			auraCapabilitiesReported = true
			pushDebug(string.format(
				"aura env getgc=%s getgenv=%s getrenv=%s",
				tostring(type(getgc) == "function"),
				tostring(type(getgenv) == "function"),
				tostring(type(getrenv) == "function")
			))
		end
		probeToolInfoCandidates(character)
		pushMineAuraDebugThrottled("mine aura: tool info not found")
		return false
	end

	if not isLikelyMiningToolInfo(toolInfo, character) then
		return false
	end

	if rawget(toolInfo, "IsEquipped") == false or toolInfo.IsEquipped == false then
		return false
	end

	local toolCharacter = getToolInfoCharacter(toolInfo, character)
	local auraTarget = findNearestOreWithinRange(toolCharacter, targetOre, MINE_AURA_RANGE, true)
	if not auraTarget then
		return false
	end
	if auraTarget ~= targetOre and not isOreNameSelected(getOreGroupName(auraTarget)) then
		pushDebugRateLimited("mine_aura_any_ore_fallback", "mine aura fallback target: " .. tostring(auraTarget.Name), 2)
	end

	local auraTargetPart = getOreBasePart(auraTarget)
	local toolHitbox = getToolInfoHitbox(toolInfo)
	if not auraTargetPart or not toolHitbox then
		pushMineAuraDebugThrottled("mine aura: hitbox/target part missing")
		return false
	end

	local now = tick()
	local cooldown = tonumber(rawget(toolInfo, "Cooldown") or toolInfo.Cooldown) or 1
	if (now - lastMineAuraNetworkHitAt) < cooldown then
		return false
	end

	local syncedTime = getSyncedNetworkTime()
	local halfWidth = toolHitbox.Size.X * 0.5
	local toolPos = toolHitbox.CFrame * Vector3.new(halfWidth, 0, 0)
	local toolVec = -toolHitbox.CFrame.XVector
	local depositModel = auraTarget
	if auraTargetPart and auraTargetPart.Parent then
		depositModel = auraTargetPart.Parent
	end

	local miningHandler = resolveGlobalMiningHandler(false)
	if not miningHandler then
		miningHandler = resolveGlobalMiningHandler(true)
	end
	if miningHandler and depositModel then
		local okHit, hitAllowed = pcall(function()
			return miningHandler:HitDeposit(depositModel, toolPos, toolVec)
		end)
		if not okHit then
			pushMineAuraDebugThrottled("mine aura: local hit errored")
			return false
		end
		if hitAllowed ~= true then
			pushMineAuraDebugThrottled("mine aura: local hit rejected")
			return false
		end
	end

	local swingSent = callToolNetworkActivate(toolInfo, "MeleeSwing", syncedTime, "Swing")
	local mineSent = callToolNetworkActivate(toolInfo, "MineDeposit", syncedTime, depositModel, toolPos, toolVec)
		or callToolNetworkActivate(toolInfo, "MineDeposit", syncedTime, auraTarget, toolPos, toolVec)
		or callToolNetworkActivate(toolInfo, "MineDeposit", syncedTime, auraTargetPart, toolPos, toolVec)
		or callToolNetworkActivate(toolInfo, "MineDeposit", syncedTime, auraTargetPart.Parent, toolPos, toolVec)

	if swingSent or mineSent then
		lastMineAuraNetworkHitAt = now
		pushMineAuraDebugThrottled("mine aura network: " .. auraTarget.Name)
		return true
	end

	return false
end

function tapKey(keyCode)
	if not keyCode or not VirtualInputManager then
		return false
	end

	local ok = pcall(function()
		VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
		task.wait(0.05)
		VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	end)

	return ok
end

function tryHotbarKeys(character)
	if PICKAXE_HOTBAR_KEY then
		return tapKey(PICKAXE_HOTBAR_KEY)
