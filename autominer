	if autoSellObjectActionActivationId > 2000000000 then
		autoSellObjectActionActivationId = 1
	end
	return autoSellObjectActionActivationId
end

function getAutoSellObjectActionNetworkId(instance)
	if typeof(instance) ~= "Instance" then
		return nil
	end

	local ok, networkId = pcall(function()
		return instance:GetAttribute("NetworkId")
	end)
	if ok and networkId ~= nil then
		return networkId
	end

	return nil
end

function waitForAutoSellObjectActionNetworkId(instance, timeoutSeconds)
	if typeof(instance) ~= "Instance" then
		return nil
	end

	local networkId = getAutoSellObjectActionNetworkId(instance)
	if networkId ~= nil then
		return networkId
	end

	local timeoutAt = os.clock() + math.max(0.05, tonumber(timeoutSeconds) or AUTO_SELL_OBJECT_ACTION_NETWORK_ID_WAIT)
	while os.clock() < timeoutAt do
		task.wait(0.03)
		networkId = getAutoSellObjectActionNetworkId(instance)
