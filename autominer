local function mergePathSpawnInfoInto(target, source)
	if not isTable(target) or not isTable(source) then
		return
	end

	for spawnName, info in pairs(source) do
		if type(spawnName) == "string" and spawnName ~= "" and PATH_ALLOWED_SPAWN_LOOKUP[spawnName] == true then
			if isTable(info) then
				target[spawnName] = info
			else
				target[spawnName] = { Name = tostring(info or spawnName) }
			end
		end
	end
end

function resolveSharedDataModule(forceRefresh)
	local cache = rawget(_G, "__AutoMineSharedDataModule")
	if isTable(cache) then
		return cache
	end

	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end

	local sharedData = isTable(globalModule) and (rawget(globalModule, "SharedData") or globalModule.SharedData) or nil
	if not isTable(sharedData) and isTable(globalModule) and type(globalModule.LoadModule) == "function" then
		for _, loadArgs in ipairs({
			{ "SharedData", true },
			{ "SharedData" },
			{ "Data.SharedData", true },
			{ "Data.SharedData" },
		}) do
			local okLoad, loadedSharedData = pcall(function()
				return globalModule:LoadModule(table.unpack(loadArgs))
			end)
			if okLoad and isTable(loadedSharedData) then
				sharedData = loadedSharedData
				globalModule.SharedData = loadedSharedData
				break
			end
		end
	end

	if not isTable(sharedData) then
		local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
		local dataFolder = sharedModules and sharedModules:FindFirstChild("Data")
		local sharedDataModuleScript = dataFolder and dataFolder:FindFirstChild("SharedData")
		if sharedDataModuleScript and sharedDataModuleScript:IsA("ModuleScript") then
			local okRequire, requiredSharedData = pcall(require, sharedDataModuleScript)
			if okRequire and isTable(requiredSharedData) then
				sharedData = requiredSharedData
				if isTable(globalModule) then
					globalModule.SharedData = requiredSharedData
				end
			end
		end
	end

	if isTable(sharedData) then
		_G.__AutoMineSharedDataModule = sharedData
		return sharedData
	end

	return nil
end

function getPathSpawnInfoTable()
	local mergedSpawnInfo = {}
	mergePathSpawnInfoInto(mergedSpawnInfo, FALLBACK_PATH_SPAWN_INFO)

	local okSharedData, sharedData = pcall(function()
		return resolveSharedDataModule(false)
	end)
	local spawnInfo = okSharedData and isTable(sharedData) and (rawget(sharedData, "SpawnInfo") or sharedData.SpawnInfo) or nil
	if isTable(spawnInfo) then
		mergePathSpawnInfoInto(mergedSpawnInfo, spawnInfo)
	end

	if next(mergedSpawnInfo) ~= nil then
		return mergedSpawnInfo
	end
	return FALLBACK_PATH_SPAWN_INFO
end

function getPathSpawnOptionText(spawnName)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	if not normalizedSpawnName or not isAllowedPathSpawnName(normalizedSpawnName) then
		return PATH_SPAWN_PLACEHOLDER_TEXT
	end

	local spawnInfo = getPathSpawnInfoTable()
	local info = isTable(spawnInfo) and spawnInfo[normalizedSpawnName] or nil
	local displayName = isTable(info) and tostring(rawget(info, "Name") or info.Name or normalizedSpawnName) or normalizedSpawnName
	return displayName
end

function resolvePathSpawnOptionValue(rawValue)
	local normalizedValue = normalizePathSpawnName(rawValue)
	if not normalizedValue then
		return nil
	end

	local spawnInfo = getPathSpawnInfoTable()
	if isTable(spawnInfo) and isTable(spawnInfo[normalizedValue]) then
		return normalizedValue
	end

	local loweredValue = safeLower(normalizedValue)
	for spawnName, info in pairs(spawnInfo or {}) do
		if type(spawnName) == "string" then
			local displayName = isTable(info) and tostring(rawget(info, "Name") or info.Name or spawnName) or spawnName
			local optionText = getPathSpawnOptionText(spawnName)
			if loweredValue == safeLower(spawnName)
				or loweredValue == safeLower(displayName)
				or loweredValue == safeLower(optionText) then
				return spawnName
			end
		end
	end

	local extractedKey = string.match(normalizedValue, "%(([^()]+)%)%s*$")
	return normalizePathSpawnName(extractedKey or normalizedValue)
end

function getPathSpawnOptions()
	local spawnInfo = getPathSpawnInfoTable()
	local options = {}
	for _, spawnName in ipairs(PATH_ALLOWED_SPAWN_ORDER) do
		if isTable(spawnInfo[spawnName]) then
			table.insert(options, getPathSpawnOptionText(spawnName))
		end
	end
	return options
end

function isPathSpawnSelectorGuiObjectVisible(guiObject)
	if not guiObject or not guiObject.Parent then
		return false
	end

	local current = guiObject
	while current do
		if current:IsA("GuiObject") then
			local okVisible, isVisible = pcall(function()
				return current.Visible
			end)
			if okVisible and isVisible == false then
				return false
			end
		elseif current:IsA("ScreenGui") then
			local okEnabled, isEnabled = pcall(function()
				return current.Enabled
			end)
			if okEnabled and isEnabled == false then
				return false
			end
		end
		current = current.Parent
	end

	return true
end

function findPathSpawnSelectorGui()
	if not localPlayer then
		return nil, nil, nil
	end

	local playerGui = localPlayer:FindFirstChild("PlayerGui")
	if not playerGui then
		return nil, nil, nil
	end

	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") then
			local screen = child:FindFirstChild("Screen")
			local background = child:FindFirstChild("Background")
			local acceptButton = screen and screen:FindFirstChild("AcceptButton")
			local sideBar = screen and screen:FindFirstChild("SideBar")
			local body = sideBar and sideBar:FindFirstChild("Body")
			local scrollingFrame = body and body:FindFirstChild("ScrollingFrame")
			if screen and background and acceptButton and scrollingFrame then
				return child, screen, scrollingFrame
			end
		end
	end

	return nil, nil, nil
end

function getPathSpawnSelectorMatchCount()
	local guiRoot, screen, scrollingFrame = findPathSpawnSelectorGui()
	if not guiRoot or not screen or not scrollingFrame then
		return 0
	end

	if not isPathSpawnSelectorGuiObjectVisible(screen) then
		return 0
	end
	if not isPathSpawnSelectorGuiObjectVisible(scrollingFrame) then
		return 0
	end

	local matchCount = 0
	for _, button in ipairs(scrollingFrame:GetChildren()) do
		if button:IsA("ImageButton") and PATH_ALLOWED_SPAWN_LOOKUP[button.Name] == true and isPathSpawnSelectorGuiObjectVisible(button) then
			matchCount += 1
		end
	end

	return matchCount
end

function isOnPathSpawnSelectorScreen(_character)
	return getPathSpawnSelectorMatchCount() >= PATH_SPAWN_SELECTOR_MIN_MATCHES
end

