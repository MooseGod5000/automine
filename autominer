function restoreNoRecoilHooks(forceRestore)
    local camModule = gunFeatureState.hookedCamModule
    if forceRestore and isTable(camModule) then
        local registry = getNoRecoilHookRegistry()
        local entry = registry[camModule]
        if type(entry) == "table" then
            if type(entry.originalAddRecoil) == "function" and camModule.AddRecoil == entry.wrapperAddRecoil then
                camModule.AddRecoil = entry.originalAddRecoil
            end
            if type(entry.originalVibrate) == "function" and camModule.Vibrate == entry.wrapperVibrate then
                camModule.Vibrate = entry.originalVibrate
            end
            registry[camModule] = nil
