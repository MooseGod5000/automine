            _TweenService:Create(bottomLine, tweenInfo, {Size = UDim2.new(1, 0, 0, 2)}):Play()
            diamond.Visible = true
        end)

        row.MouseLeave:Connect(function()
            if destroyed then
                return
            end
            _TweenService:Create(row, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(24, 24, 24)}):Play()
            _TweenService:Create(icon, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 255)}):Play()
            _TweenService:Create(label, TweenInfo.new(0.2), {TextColor3 = Color3.new(0.8, 0.8, 0.8)}):Play()
            local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            _TweenService:Create(topLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
            _TweenService:Create(bottomLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
            diamond.Visible = false
        end)

        resetBg.MouseEnter:Connect(function()
            _TweenService:Create(resetBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 30, 30)}):Play()
        end)

        resetBg.MouseLeave:Connect(function()
            _TweenService:Create(resetBg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 30, 30)}):Play()
        end)

        local rowData = {
            registryName = rowKey,
            displayName = rowName,
            row = row,
            keybindLabel = keybindLabel,
            keybindBtn = keybindBtn,
            keybindBg = keybindBg,
            resetBtn = resetBg,
            regEntry = regEntry,
        }
        keybindRows[rowKey] = rowData

        keybindBtn.MouseButton1Click:Connect(function()
            if destroyed then
                return
            end
            _UTILS._createParticleBurst(keybindBg)
            if keybindListening and keybindListeningBtn == keybindBtn then
                stopKeybindListening()
                return
            end
            if keybindListening then
                stopKeybindListening()
            end
            keybindListening = true
            beginKeyCapture()
            keybindListeningBtn = keybindBtn
            keybindLabel.Text = ". . ."
            keybindBg.BorderColor3 = Color3.fromRGB(0, 150, 255)
            keybindLabel.TextColor3 = Color3.fromRGB(0, 200, 255)
            spawnNotification("Press Esc or Backspace to cancel.", "info", true)

            keybindListenConn = _UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if destroyed or not keybindListening or gameProcessed then
                    return
                end
                if input.UserInputType ~= Enum.UserInputType.Keyboard then
                    return
                end
                if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
                    stopKeybindListening()
                    return
                end
                if input.KeyCode ~= Enum.KeyCode.Unknown then
                    S.keybinds[rowKey] = input.KeyCode
                    keybindLabel.Text = input.KeyCode.Name
                    keybindBg.BorderColor3 = Color3.fromRGB(60, 60, 60)
                    keybindLabel.TextColor3 = Color3.new(1, 1, 1)
                    keybindListening = false
                    endKeyCapture()
                    if keybindListenConn then
                        keybindListenConn:Disconnect()
                        keybindListenConn = nil
                    end
                    keybindListeningBtn = nil
                    schedulePersist()
                    refreshDashboard()
                    spawnNotification(rowName .. " has been keybound to " .. input.KeyCode.Name .. ".", "success", true)
                end
            end)
        end)

        resetBg.MouseButton1Click:Connect(function()
            if destroyed then
                return
            end
            _UTILS._createParticleBurst(resetBg)
            if keybindListening and keybindListeningBtn == keybindBtn then
                stopKeybindListening()
            end
            S.keybinds[rowKey] = nil
            keybindLabel.Text = "none"
            keybindBg.BorderColor3 = Color3.fromRGB(60, 60, 60)
            keybindLabel.TextColor3 = Color3.new(1, 1, 1)
            schedulePersist()
            refreshDashboard()
        end)

        return row
    end

    local allKbElements = {}
    local tabOrder = {"Home", "AUTOMINE", "WEAPONS", "PLAYER", "VISUALS", "GAME", "SETTINGS"}

    for _, tabName in ipairs(tabOrder) do
        local tabEntries = {}
        for _, regEntry in ipairs(_buttonRegistry) do
            if regEntry.tab == tabName and regEntry.type ~= "slider" then
                table.insert(tabEntries, regEntry)
            end
        end
        if #tabEntries > 0 then
            local header = createKeybindSectionHeader(tabName)
            table.insert(allKbElements, {element = header, names = {}})
            for _, regEntry in ipairs(tabEntries) do
                local row = createKeybindRow(regEntry)
                table.insert(allKbElements, {element = row, names = {regEntry.name:lower()}})
            end
        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = searchBox.Text:lower()
        if query == "" then
            for _, item in ipairs(allKbElements) do
                item.element.Visible = true
            end
            return
        end
        local currentHeader = nil
        local headerHasMatch = false
        for _, item in ipairs(allKbElements) do
            if #item.names == 0 then
                if currentHeader then
                    currentHeader.Visible = headerHasMatch
                end
                currentHeader = item.element
                headerHasMatch = false
            else
                local matches = false
                for _, name in ipairs(item.names) do
                    if name:find(query, 1, true) then
                        matches = true
                        break
                    end
                end
                item.element.Visible = matches
                if matches then
                    headerHasMatch = true
                end
            end
        end
        if currentHeader then
            currentHeader.Visible = headerHasMatch
        end
    end)

    registerUiSync(_allTextSyncs, function()
        for bindName, rowData in pairs(keybindRows) do
            rowData.keybindLabel.Text = getKeyDisplayName(S.keybinds[bindName])
        end
    end)
end

