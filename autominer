function collectLassoSharedDataCandidates(forceRefresh)
    local candidates = {}
    local seen = {}

    local function tryAdd(sharedData)
        if isTable(sharedData) and not seen[sharedData] then
            seen[sharedData] = true
            table.insert(candidates, sharedData)
        end
    end

    local _, equippedSharedData = getCurrentEquippedLassoItem(forceRefresh)
    tryAdd(equippedSharedData)

    local playerItems = resolveSharedPlayerItems(forceRefresh)
    if isTable(playerItems) then
        for itemType, entry in pairs(playerItems) do
            if isTable(entry) then
                if isLassoSharedData(entry) then
                    tryAdd(entry)
                elseif string.find(safeLower(itemType), "lasso", 1, true) ~= nil then
                    tryAdd(entry)
                else
                    local entrySharedData = rawget(entry, "SharedData") or entry.SharedData
                    if isLassoSharedData(entrySharedData) or isLassoItemTool(entry) then
                        tryAdd(entrySharedData)
                    end
                end
            end
        end
    end

    return candidates
end

