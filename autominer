    end

    local function showDeleteOverlay()
        local selectedName = getSelectedConfigName()
        if not selectedName then
            spawnNotification("No config selected.", "error", true)
            return
        end
        if selectedName == CONFIG_SYSTEM.AUTOSAVE_NAME then
            deleteHeader.Text = "Clear the autosave from last session snapshot?"
        else
            deleteHeader.Text = "Delete config '" .. selectedName .. "'?"
        end
        deleteOverlay.Visible = true
    end

    cancelDeleteButton.MouseButton1Click:Connect(function()
        if destroyed then
            return
        end
        _UTILS._createParticleBurst(cancelDeleteButton)
        hideDeleteOverlay()
    end)

    confirmDeleteButton.MouseButton1Click:Connect(function()
        if destroyed then
            return
        end
        _UTILS._createParticleBurst(confirmDeleteButton)
        local selectedName = getSelectedConfigName()
        if not selectedName then
            hideDeleteOverlay()
            return
        end

        local okDelete = storageDeleteAvailable and storageReadAvailable
        if okDelete then
            okDelete = pcall(function()
                local filePath = getConfigFilePath(selectedName)
                if isfile(filePath) then
                    delfile(filePath)
                end
            end)
        end

        if okDelete then
            if selectedName ~= CONFIG_SYSTEM.AUTOSAVE_NAME then
                local nextNames = {}
                for _, cfgName in ipairs(normalizeSavedConfigNames(CONFIG_SYSTEM.savedConfigs)) do
                    if cfgName ~= selectedName then
                        table.insert(nextNames, cfgName)
                    end
                end
                CONFIG_SYSTEM.savedConfigs = normalizeSavedConfigNames(nextNames)
            end
            if getAutoLoadConfigName() == selectedName then
                CONFIG_SYSTEM.autoLoadConfigName = nil
            end
            CONFIG_SYSTEM.selectedConfigName = nil
            persistConfigSelection()
            syncConfigSelectionLabel()
            if syncConfigRows then
                syncConfigRows()
            end
            if selectedName == CONFIG_SYSTEM.AUTOSAVE_NAME then
                spawnNotification("Cleared autosave from last session.", "success", true)
            else
                spawnNotification("Deleted config: " .. selectedName, "success", true)
            end
        else
            spawnNotification("Could not delete config: " .. selectedName, "error", true)
        end

        hideDeleteOverlay()
    end)

