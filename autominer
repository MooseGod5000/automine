function getMovementModeLabel()
	if movementMode == "tween" then
		return "Tween"
	end
	if movementMode == "cframe" then
		return "CFrame"
	end
	return "Legit"
end

function normalizeMovementMode(value)
	if value == true then
		return "tween"
	end
	if value == false or value == nil then
		return "legit"
	end

	local loweredValue = safeLower(value)
	if loweredValue == "tween" or loweredValue == "cframe" then
		return loweredValue
	end

	return "legit"
end

function setMovementMode(nextMode, debugSource, skipPersistence)
	local nextValue = normalizeMovementMode(nextMode)
	if movementMode == nextValue then
		refreshTweenButton()
		return
	end

	if movementMode == "cframe" or nextValue ~= "cframe" then
		endExperimentalCFrameTravel(cachedCharacter)
	end
	movementMode = nextValue
	tweenModeEnabled = nextValue == "tween"
	cancelActiveMoveTween()
	clearMovementKeys()
	setLastMoveCommand(Vector3.zero, nextValue == "cframe" and "CFrameIdle" or (tweenModeEnabled and "TweenIdle" or "LegitIdle"))
	if autoMineEnabled then
		ensureAutoMineManualMovementLock(cachedCharacter, cachedHumanoid)
	end
	pushDebug("movement mode: " .. getMovementModeLabel() .. (debugSource and (" [" .. tostring(debugSource) .. "]") or ""))
	refreshTweenButton()
	if not skipPersistence and type(schedulePathSettingsPersist) == "function" then
		schedulePathSettingsPersist()
	end
end

