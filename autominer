function getGroundAlignedPathPosition(targetPosition, character)
	if not targetPosition then
		return nil
	end

	local ignoreInstances = {
		getRecordedPathFolder(),
		getVisualizerFolder(),
		findPathPlayerAvoiderVisualizerFolder(),
	}
	if character then
		table.insert(ignoreInstances, character)
	end

	local function castToFloor(upwardOffset, downwardDistance)
		local raycastParams = RaycastParams.new()
		raycastParams.FilterType = Enum.RaycastFilterType.Exclude
		raycastParams.FilterDescendantsInstances = ignoreInstances

		local scanOrigin = Vector3.new(targetPosition.X, targetPosition.Y + upwardOffset, targetPosition.Z)
		local ray = workspace:Raycast(scanOrigin, Vector3.new(0, -downwardDistance, 0), raycastParams)
		if ray and ray.Position and ray.Normal and ray.Normal.Y >= 0.25 then
			return Vector3.new(targetPosition.X, ray.Position.Y + 0.08, targetPosition.Z)
		end

		return nil
	end

	local alignedPosition = castToFloor(1.5, 12) or castToFloor(3, 20)
	if alignedPosition then
		return alignedPosition
	end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = ignoreInstances

	local scanOrigin = Vector3.new(targetPosition.X, targetPosition.Y + TWEEN_GROUND_SCAN_HEIGHT, targetPosition.Z)
	local ray = workspace:Raycast(scanOrigin, Vector3.new(0, -(TWEEN_GROUND_SCAN_HEIGHT * 2), 0), raycastParams)
	if ray and ray.Position then
		return Vector3.new(targetPosition.X, ray.Position.Y + 0.08, targetPosition.Z)
	end

	return Vector3.new(targetPosition.X, targetPosition.Y, targetPosition.Z)
end

function getEditorMouseGroundPosition(character)
	local camera = workspace.CurrentCamera
	if not camera then
		return nil
	end

	local mouseLocation = UserInputService:GetMouseLocation()
	local ray = camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {
		character,
		getRecordedPathFolder(),
		getVisualizerFolder(),
		findPathPlayerAvoiderVisualizerFolder(),
	}

	local hit = workspace:Raycast(ray.Origin, ray.Direction * 1500, raycastParams)
	if hit and hit.Position then
		return getGroundAlignedPathPosition(hit.Position, character)
	end

	return nil
end

function updatePathEditorActiveNodeVisuals()
	local selectedNodeIndex = pathState.selectedNodeIndex
	if not selectedNodeIndex then
		return
	end

	local nodePosition = getPathNodePosition(pathState.workingPath.nodes[selectedNodeIndex])
	local nodePart = pathUi.editorNodeParts[selectedNodeIndex]
	if nodePosition and nodePart and nodePart.Parent then
		nodePart.Position = nodePosition + Vector3.new(0, VISUALIZER_HEIGHT, 0)
	end

	local handleDefinitions = {
		Vector3.new(-1.15, 0, 0),
		Vector3.new(1.15, 0, 0),
		Vector3.new(0, 1.15, 0),
		Vector3.new(0, -1.15, 0),
		Vector3.new(0, 0, 1.15),
		Vector3.new(0, 0, -1.15),
	}

	for index, offset in ipairs(handleDefinitions) do
		local handle = pathUi.editorNodeHandles[index]
		if handle and handle.Parent and nodePosition then
			handle.Position = nodePosition + offset + Vector3.new(0, VISUALIZER_HEIGHT, 0)
		end
	end
end

refreshPathVisuals = function()
	clearRecordedPathVisuals()
	local visualPathData = nil
	local visualSellNodeIndex = nil
	local visualSelectedNodeIndex = nil
	local showNodeHandles = false
	local showDepositLabels = false
	local showSelectedPathPreview = (activeTabName == "Autofarm" or activeTabName == "AUTOMINE")
		and pathState.subTab == "Paths"
		and type(pathState.selectedPathName) == "string"
		and pathState.paths[pathState.selectedPathName] ~= nil

	if pathState.editorVisible then
		local shouldRetrySellNodeAutoDetect = not pathState.sellNodeDirty
			and not pathState.sellNodeIndex
			and not getManualPathSellNodeIndex(pathState.workingPath)
			and #(pathState.workingPath.nodes or {}) > 0
			and (not cachedAutoSellTargets or (#cachedAutoSellTargets == 0 and (os.clock() - lastAutoSellTargetScanAt) >= 3))
		if pathState.sellNodeDirty or shouldRetrySellNodeAutoDetect then
			recomputeWorkingPathSellNode()
		end
		visualPathData = pathState.workingPath
		visualSellNodeIndex = pathState.sellNodeIndex
		visualSelectedNodeIndex = pathState.selectedNodeIndex
		showNodeHandles = pathState.editNodePlacementEnabled == true
		showDepositLabels = pathState.recording
	elseif pathState.playbackActive and pathState.currentPath then
		visualPathData = pathState.currentPath
		visualSellNodeIndex = getPathSellNodeIndex(visualPathData)
	elseif showSelectedPathPreview then
		visualPathData = pathState.paths[pathState.selectedPathName]
		visualSellNodeIndex = getPathSellNodeIndex(visualPathData)
	else
		return
	end

	if not visualPathData or #(visualPathData.nodes or {}) == 0 then
		return
	end

	local previousNodePosition = nil
	local markedOreLookup = {}

	local function getDepositLabelText(groupName, order)
		local oreLabel = getOreLabel(groupName)
		local isVein = string.find(string.lower(oreLabel), "vein", 1, true) ~= nil
		if order then
			return string.format("%d, %s", order, isVein and oreLabel or (oreLabel .. " Ore"))
		end
		return isVein and oreLabel or (oreLabel .. " Deposit")
	end

	local function createOreBillboard(orePart, text, textColor)
		local oreLabel = Instance.new("BillboardGui")
		oreLabel.Name = "OreOrderLabel"
		oreLabel.Size = UDim2.fromOffset(112, 24)
		oreLabel.StudsOffset = Vector3.new(0, 2.65, 0)
		oreLabel.AlwaysOnTop = true
		oreLabel.Parent = orePart

		local oreText = Instance.new("TextLabel")
		oreText.Size = UDim2.new(1, 0, 1, 0)
		oreText.BackgroundTransparency = 1
		oreText.Font = Enum.Font.GothamBold
		oreText.TextSize = 12
		oreText.TextColor3 = textColor
		oreText.TextStrokeTransparency = 0.2
		oreText.Text = text
		oreText.Parent = oreLabel

		table.insert(pathUi.editorOreMarkers, oreLabel)
	end

	local function addMarkedOreHighlights(oreDeposit)
		for _, orePart in ipairs(getOreRenderParts(oreDeposit)) do
			local highlight = Instance.new("Highlight")
			highlight.Name = "MarkedOre"
			highlight.FillTransparency = 0.55
			highlight.OutlineTransparency = 0
			highlight.FillColor = Color3.fromRGB(110, 255, 140)
			highlight.OutlineColor = Color3.fromRGB(255, 220, 90)
			highlight.Adornee = orePart
			highlight.Parent = getRecordedPathFolder()
			table.insert(pathUi.editorOreMarkers, highlight)
		end
	end

	for order, oreTarget in ipairs(visualPathData.ores or {}) do
		local resolvedOre = resolveSavedOreTarget(oreTarget)
		if resolvedOre then
			markedOreLookup[resolvedOre] = {
				order = order,
				groupName = oreTarget.groupName,
			}
		end
	end

	for index, node in ipairs(visualPathData.nodes or {}) do
		local nodePosition = getPathNodePosition(node)
		if not nodePosition then
			continue
		end
		if previousNodePosition then
			createRecordedPathSegment(previousNodePosition, nodePosition, Color3.fromRGB(214, 159, 92))
		end

		local nodePart = Instance.new("Part")
		nodePart.Name = "RecordedNode"
		nodePart.Shape = Enum.PartType.Ball
		nodePart.Size = PATH_RECORD_NODE_SIZE
		nodePart.Anchored = true
		nodePart.CanCollide = false
		nodePart.CanQuery = true
		nodePart.CanTouch = false
		nodePart.Material = Enum.Material.Neon
		nodePart.Transparency = 0.34
		nodePart.Color = index == visualSelectedNodeIndex
			and Color3.fromRGB(255, 214, 117)
			or ((pathState.playbackActive and not pathState.editorVisible and index == pathState.playbackNodeIndex) and Color3.fromRGB(130, 220, 255)
				or (index == visualSellNodeIndex and Color3.fromRGB(105, 220, 130) or Color3.fromRGB(223, 157, 82)))
		nodePart.Position = nodePosition + Vector3.new(0, VISUALIZER_HEIGHT, 0)
		nodePart.Parent = getRecordedPathFolder()
		nodePart:SetAttribute("PathNodeIndex", index)
		pathUi.editorNodeParts[index] = nodePart
		previousNodePosition = nodePosition

		if showNodeHandles and index == visualSelectedNodeIndex then
			local handleDefinitions = {
				{ axis = "X", direction = -1, color = Color3.fromRGB(255, 198, 92), size = Vector3.new(0.72, 0.2, 0.2), offset = Vector3.new(-1.15, 0, 0) },
				{ axis = "X", direction = 1, color = Color3.fromRGB(255, 198, 92), size = Vector3.new(0.72, 0.2, 0.2), offset = Vector3.new(1.15, 0, 0) },
				{ axis = "Y", direction = 1, color = Color3.fromRGB(120, 215, 255), size = Vector3.new(0.2, 0.72, 0.2), offset = Vector3.new(0, 1.15, 0) },
				{ axis = "Y", direction = -1, color = Color3.fromRGB(120, 215, 255), size = Vector3.new(0.2, 0.72, 0.2), offset = Vector3.new(0, -1.15, 0) },
				{ axis = "Z", direction = 1, color = Color3.fromRGB(160, 255, 163), size = Vector3.new(0.2, 0.2, 0.72), offset = Vector3.new(0, 0, 1.15) },
				{ axis = "Z", direction = -1, color = Color3.fromRGB(160, 255, 163), size = Vector3.new(0.2, 0.2, 0.72), offset = Vector3.new(0, 0, -1.15) },
			}

			for _, handleDefinition in ipairs(handleDefinitions) do
				local handle = Instance.new("Part")
				handle.Name = "PathArrow"
				handle.Anchored = true
				handle.CanCollide = false
				handle.CanQuery = true
				handle.CanTouch = false
				handle.Material = Enum.Material.Neon
				handle.Transparency = 0.18
				handle.Color = handleDefinition.color
				handle.Size = handleDefinition.size
				handle.Position = nodePosition + handleDefinition.offset + Vector3.new(0, VISUALIZER_HEIGHT, 0)
				handle.Parent = getRecordedPathFolder()
				handle:SetAttribute("PathNodeIndex", index)
				handle:SetAttribute("PathNodeAxis", handleDefinition.axis)
				handle:SetAttribute("PathNodeDirection", handleDefinition.direction)
				table.insert(pathUi.editorNodeHandles, handle)
			end
		end
	end

	if showDepositLabels then
		local oreDeposits = getOreDepositsFolder()
		if oreDeposits then
			for _, oreFolder in ipairs(oreDeposits:GetChildren()) do
				for _, oreDeposit in ipairs(oreFolder:GetChildren()) do
					local orePart = getOreBasePart(oreDeposit)
					if orePart then
						local markInfo = markedOreLookup[oreDeposit]
						if markInfo then
							addMarkedOreHighlights(oreDeposit)
							createOreBillboard(orePart, getDepositLabelText(markInfo.groupName, markInfo.order), Color3.fromRGB(255, 220, 90))
						else
							createOreBillboard(orePart, getDepositLabelText(oreFolder.Name), Color3.fromRGB(224, 211, 186))
						end
					end
				end
			end
		end
	else
		for resolvedOre, markInfo in pairs(markedOreLookup) do
			local orePart = getOreBasePart(resolvedOre)
			if orePart then
				addMarkedOreHighlights(resolvedOre)
				createOreBillboard(orePart, getDepositLabelText(markInfo.groupName, markInfo.order), Color3.fromRGB(255, 220, 90))
			end
		end
	end
end

