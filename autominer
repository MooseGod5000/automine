function resolveSharedPlayerItems(forceRefresh)
	local cache = rawget(_G, "__AutoMineSharedPlayerItems")
	if isTable(cache) then
		return cache
	end

	local globalModule = rawget(_G, "__AutoMineGlobalModule")
	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end
	if not isTable(globalModule) then
		return nil
	end

	local sharedData = rawget(globalModule, "SharedData") or globalModule.SharedData
	local playerItems = isTable(sharedData) and (rawget(sharedData, "PlayerItems") or sharedData.PlayerItems) or nil
	if not isTable(playerItems) and type(globalModule.LoadModule) == "function" then
		local okLoad, loadedSharedData = pcall(function()
			return globalModule:LoadModule("SharedData")
		end)
		if okLoad and isTable(loadedSharedData) then
			sharedData = loadedSharedData
