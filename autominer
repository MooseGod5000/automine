function installInfiniteStaminaStateHook(stateTable)
	if not isTable(stateTable) then
		return false
	end

	local stateHooks = playerState.stateHooks
	if type(stateHooks) ~= "table" then
		stateHooks = {}
		playerState.stateHooks = stateHooks
	end

	local existingHook = stateHooks[stateTable]
	if existingHook and existingHook.installedMetatable and getmetatable(stateTable) == existingHook.installedMetatable then
		return true
	end

	local originalMetatable = getmetatable(stateTable)
	if originalMetatable ~= nil and type(originalMetatable) ~= "table" then
		return false
	end

	local originalIndex = originalMetatable and originalMetatable.__index or nil
	local originalNewIndex = originalMetatable and originalMetatable.__newindex or nil
	local shadowValue = rawget(stateTable, "Stamina")
	if shadowValue == nil then
		if type(originalIndex) == "function" then
			local ok, value = pcall(originalIndex, stateTable, "Stamina")
			if ok then
				shadowValue = value
			end
		elseif type(originalIndex) == "table" then
			shadowValue = rawget(originalIndex, "Stamina") or originalIndex.Stamina
		end
	end
	if shadowValue == nil then
		shadowValue = playerState.displayStamina or 100
	end

	local hook = {
		shadowValue = shadowValue,
		originalMetatable = originalMetatable,
		originalIndex = originalIndex,
		originalNewIndex = originalNewIndex,
		installedMetatable = nil,
	}

	local installedMetatable = {}
	if originalMetatable then
		for key, value in pairs(originalMetatable) do
			installedMetatable[key] = value
		end
	end

	installedMetatable.__index = function(tableRef, key)
		if key == "Stamina" then
			if playerState.infiniteStaminaEnabled then
				return playerState.displayStamina or 100
			end
			return hook.shadowValue
		end

		local original = hook.originalIndex
		if type(original) == "function" then
			return original(tableRef, key)
		end
		if type(original) == "table" then
			return original[key]
		end
		return nil
	end

	installedMetatable.__newindex = function(tableRef, key, value)
		if key == "Stamina" then
			hook.shadowValue = value
			return
		end

		local original = hook.originalNewIndex
		if type(original) == "function" then
			return original(tableRef, key, value)
		end
		if type(original) == "table" then
			original[key] = value
			return
		end
		rawset(tableRef, key, value)
	end

	hook.installedMetatable = installedMetatable
	stateHooks[stateTable] = hook

	local okSet = pcall(function()
		setmetatable(stateTable, installedMetatable)
	end)
	if not okSet then
		stateHooks[stateTable] = nil
		return false
	end

	pcall(function()
		rawset(stateTable, "Stamina", nil)
	end)

	return true
end

