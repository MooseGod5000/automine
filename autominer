function equipPickaxe(character, humanoid, pickaxe)
	if not (character and humanoid) then
		pushDebug("equip skipped: missing character/humanoid")
		return false
	end
	endExperimentalCFrameTravel(character)

	local equippedPickaxe = getEquippedPickaxe(character)
	if equippedPickaxe then
		cachedPickaxe = equippedPickaxe
		lastPickaxeEquipRequestAt = 0
		lastPickaxeEquipRequestId = nil
		lastPickaxeLoadoutRequestAt = 0
		lastPickaxeLoadoutRequestId = nil
		setStatus("Pickaxe equipped", Color3.fromRGB(140, 220, 140))
		return true
	end

	local storedPickaxe = getStoredPickaxe(character)
	if storedPickaxe then
		cachedPickaxe = storedPickaxe
		pushDebugRateLimited("stored_pickaxe_found", "stored pickaxe found: " .. storedPickaxe:GetFullName(), 2)
	elseif pickaxe and pickaxe.Parent then
		cachedPickaxe = pickaxe
	end

	if pickaxe and pickaxe:IsA("Tool") then
		if pickaxe.Parent ~= character then
			pcall(function()
				humanoid:EquipTool(pickaxe)
			end)
			task.wait(0.1)
		end

		return pickaxe.Parent == character
	end

	local playerCharacter = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
	local playerData = resolvePlayerDataModule(false) or resolvePlayerDataModule(true)
	local playerItems = resolveSharedPlayerItems(false) or resolveSharedPlayerItems(true)

	local loadoutItem, loadoutType, loadoutIndex = findPickaxeLoadoutItem(playerData, playerCharacter, playerItems)
	local inventoryItem = findInventoryPickaxeItem(playerData, playerItems, loadoutItem)
	local loadoutItemScore = scorePickaxeItemCandidate(loadoutItem, playerItems)
	local inventoryItemScore = scorePickaxeItemCandidate(inventoryItem, playerItems)
	local preferredPickaxeItem = inventoryItemScore > loadoutItemScore and inventoryItem or loadoutItem
	local activePickaxeItem = preferredPickaxeItem or inventoryItem or loadoutItem
	local visualItem = getVisualEquippedItemData(playerCharacter)

	if isLikelyPickaxeItem(visualItem, playerItems) then
		local switching = isTable(playerCharacter) and ((rawget(playerCharacter, "IsSwitchingItems") or playerCharacter.IsSwitchingItems) == true)
		setStatus(switching and "Switching to pickaxe" or "Waiting for pickaxe model", Color3.fromRGB(255, 190, 120))
		return false
	end

	if inventoryItem and isTable(playerData) and (not loadoutItem or inventoryItemScore > loadoutItemScore) then
		local setLoadout = rawget(playerData, "SetLoadout") or playerData.SetLoadout
		local slotType = getPickaxeEquipmentType(inventoryItem, playerItems, playerData, playerCharacter)
		local slotIndex = loadoutIndex or findPreferredLoadoutSlot(playerData, slotType, rawget(inventoryItem, "Id") or inventoryItem.Id)
		local inventoryItemId = rawget(inventoryItem, "Id") or inventoryItem.Id or rawget(inventoryItem, "Type") or inventoryItem.Type or PICKAXE_NAME

		if type(setLoadout) == "function" and type(slotType) == "string" and slotType ~= "" and slotIndex ~= nil then
			local now = os.clock()
			if lastPickaxeLoadoutRequestId == inventoryItemId and (now - lastPickaxeLoadoutRequestAt) < PICKAXE_LOADOUT_REQUEST_COOLDOWN then
				setStatus("Waiting for pickaxe hotbar slot", Color3.fromRGB(255, 190, 120))
				return false
			end

			local okSetLoadout = pcall(setLoadout, playerData, slotType, slotIndex, inventoryItem)
			if okSetLoadout then
				lastPickaxeLoadoutRequestId = inventoryItemId
				lastPickaxeLoadoutRequestAt = now
				pushDebug(string.format("assigned pickaxe to %s slot %s", slotType, tostring(slotIndex)))
				setStatus("Adding pickaxe to hotbar", Color3.fromRGB(255, 190, 120))
				task.wait(0.08)
				return false
			end
		end
	end

	if loadoutItem and isTable(playerCharacter) and (not inventoryItem or loadoutItemScore >= inventoryItemScore) then
		local currentItem = getCurrentEquippedItemData(playerCharacter)
		local canSwitchToItem = rawget(playerCharacter, "CanSwitchToItem") or playerCharacter.CanSwitchToItem
		local equipItem = rawget(playerCharacter, "EquipItem") or playerCharacter.EquipItem
		local loadoutItemId = rawget(loadoutItem, "Id") or loadoutItem.Id or rawget(loadoutItem, "Type") or loadoutItem.Type or PICKAXE_NAME

		if isLikelyPickaxeItem(currentItem, playerItems) then
			setStatus("Waiting for pickaxe model", Color3.fromRGB(255, 190, 120))
			return false
		end

		if type(canSwitchToItem) == "function" then
			local okCanSwitch, canSwitch = pcall(canSwitchToItem, playerCharacter, loadoutItem, true)
			if okCanSwitch and not canSwitch then
				if hasPendingLoadoutSync(playerData) then
					setStatus("Waiting for loadout sync", Color3.fromRGB(255, 190, 120))
				else
					setStatus("Pickaxe equip blocked", Color3.fromRGB(255, 190, 120))
				end
				return false
			end
		elseif hasPendingLoadoutSync(playerData) then
			setStatus("Waiting for loadout sync", Color3.fromRGB(255, 190, 120))
			return false
		end

		if (rawget(playerCharacter, "IsSwitchingItems") or playerCharacter.IsSwitchingItems)
			or (rawget(playerCharacter, "ItemSwitchDisabled") or playerCharacter.ItemSwitchDisabled) then
			setStatus("Waiting for item switch", Color3.fromRGB(255, 190, 120))
			return false
		end

		if type(equipItem) == "function" then
			local now = os.clock()
			if lastPickaxeEquipRequestId == loadoutItemId and (now - lastPickaxeEquipRequestAt) < PICKAXE_EQUIP_REQUEST_COOLDOWN then
				return false
			end

			local okEquip = pcall(equipItem, playerCharacter, loadoutItem, true, true)
			if okEquip then
				lastPickaxeEquipRequestId = loadoutItemId
				lastPickaxeEquipRequestAt = now
				pushDebug("requested pickaxe equip: " .. tostring(loadoutItemId))
				setStatus("Equipping pickaxe", Color3.fromRGB(255, 190, 120))
				task.wait(0.08)
				equippedPickaxe = getEquippedPickaxe(character)
				if equippedPickaxe then
					cachedPickaxe = equippedPickaxe
					setStatus("Pickaxe equipped", Color3.fromRGB(140, 220, 140))
					return true
				end
				storedPickaxe = getStoredPickaxe(character)
				if storedPickaxe then
					cachedPickaxe = storedPickaxe
				end
				return false
			end
		end
	end

	if not playerCharacter and not playerData then
		if PICKAXE_HOTBAR_KEY and tapKey(PICKAXE_HOTBAR_KEY) then
			task.wait(0.15)
			equippedPickaxe = getEquippedPickaxe(character)
			if equippedPickaxe then
				cachedPickaxe = equippedPickaxe
				setStatus("Equipped via hotbar key", Color3.fromRGB(140, 220, 140))
				pushDebug("equipped using configured hotbar key")
				return true
			end
		end

		if tryHotbarKeys(character) then
			equippedPickaxe = getEquippedPickaxe(character)
			if equippedPickaxe then
				cachedPickaxe = equippedPickaxe
				setStatus("Equipped via hotbar scan", Color3.fromRGB(140, 220, 140))
				return true
			end
		end

		local remote = getEquipRemote(true)
		if remote then
			pushDebug("trying equip remote: " .. remote:GetFullName())
			local fired = false
			local nameHints = collectPickaxeNameHints(
				activePickaxeItem,
				inventoryItem,
				loadoutItem,
				storedPickaxe,
				pickaxe,
				equippedPickaxe,
				PICKAXE_NAME,
				STORED_PICKAXE_NAME
			)
			for _, hint in ipairs(nameHints) do
				local normalizedHint = stripStoredPickaxePrefix(hint) or hint
				fired = triggerRemote(remote, hint)
					or triggerRemote(remote, normalizedHint)
					or triggerRemote(remote, { Item = hint })
					or triggerRemote(remote, { Item = normalizedHint })
					or triggerRemote(remote, { Item = "LoadoutItem/" .. normalizedHint })
				if fired then
					break
				end
			end
			if not fired then
				fired = triggerRemote(remote, storedPickaxe or pickaxe or activePickaxeItem)
			end

			if fired then
				task.wait(0.2)
				equippedPickaxe = getEquippedPickaxe(character)
				if equippedPickaxe then
					cachedPickaxe = equippedPickaxe
					setStatus("Equipped via remote", Color3.fromRGB(140, 220, 140))
					pushDebug("equip remote worked")
					return true
				end
			end
		end
	end

	if not activePickaxeItem and not storedPickaxe and not pickaxe then
		setStatus("Pickaxe not found in loadout/inventory", Color3.fromRGB(255, 190, 120))
		pushDebugRateLimited("equip_pickaxe_missing", "pickaxe item data not found", 2)
		return false
	end

	setStatus("Couldn't equip pickaxe yet", Color3.fromRGB(255, 190, 120))
	pushDebugRateLimited("equip_failed", "equip failed this pass", 1.5)
	return false
end

function tryMineViaNetwork(remotes, equippedPickaxe, targetOre, orePart, orePosition, character)
	if #remotes == 0 then
		return false
	end

	local pickaxeHints = collectPickaxeNameHints(equippedPickaxe, cachedPickaxe, PICKAXE_NAME)
	for _, mineRemote in ipairs(remotes) do
		if mineRemote and mineRemote.Parent then
			local remoteMined = triggerRemote(mineRemote, targetOre)
				or triggerRemote(mineRemote, orePart)
				or triggerRemote(mineRemote, equippedPickaxe, targetOre)
				or triggerRemote(mineRemote, equippedPickaxe, orePart)
				or triggerRemote(mineRemote)
			if not remoteMined then
				for _, pickaxeHint in ipairs(pickaxeHints) do
					remoteMined = triggerRemote(mineRemote, pickaxeHint, targetOre)
						or triggerRemote(mineRemote, pickaxeHint, orePart)
					if remoteMined then
						break
					end
				end
			end

			if not remoteMined and mineAuraEnabled and orePosition then
				remoteMined = triggerRemote(mineRemote, {
					Tool = equippedPickaxe,
					Target = targetOre,
					Hit = orePart,
					Position = orePosition,
					Distance = MAX_MINE_NETWORK_REACH,
					Reach = MAX_MINE_NETWORK_REACH,
					Character = character,
				})
					or triggerRemote(mineRemote, equippedPickaxe, orePart, orePosition, MAX_MINE_NETWORK_REACH)
					or triggerRemote(mineRemote, orePosition, MAX_MINE_NETWORK_REACH)
					or triggerRemote(mineRemote, targetOre, orePosition, MAX_MINE_NETWORK_REACH)
			end

			if remoteMined then
				return true
			end
		end
	end

	return false
end

function swingPickaxe(character, pickaxe, targetOre)
	if not (character and pickaxe) then
		return false
	end
	endExperimentalCFrameTravel(character)

	local equippedPickaxe = getEquippedPickaxe(character)
	if equippedPickaxe then
		cachedPickaxe = equippedPickaxe
	end

	if mineAuraEnabled then
		if tryMineViaToolInfoNetwork(character, targetOre) then
			return true
		end

		if tryMineViaGlobalNetwork(character, targetOre, equippedPickaxe) then
			return true
		end

		if equippedPickaxe then
			local orePart = targetOre and getOreBasePart(targetOre) or nil
			local orePosition = targetOre and getOrePosition(targetOre) or (orePart and orePart.Position) or nil
			local mineRemotes = getMineRemotes(false, equippedPickaxe, character)
			if tryMineViaNetwork(mineRemotes, equippedPickaxe, targetOre, orePart, orePosition, character) then
				return true
			end
		end

		pushMineAuraDebugThrottled("mine aura: network call failed")
		return false
	end

	if pickaxe:IsA("Tool") and pickaxe.Parent == character then
		local activated = pcall(function()
			pickaxe:Activate()
		end)
		if activated then
			return true
		end
	end

	if equippedPickaxe then
		local orePart = targetOre and getOreBasePart(targetOre) or nil
		local orePosition = targetOre and getOrePosition(targetOre) or (orePart and orePart.Position) or nil
		local mineRemotes = getMineRemotes(false, equippedPickaxe, character)
		if tryMineViaNetwork(mineRemotes, equippedPickaxe, targetOre, orePart, orePosition, character) then
			return true
		end

		local clicked = clickMouse()
		if not clicked then
			pushDebug("swing click failed")
		end
		return clicked
	end

	setStatus("Waiting for equip", Color3.fromRGB(255, 190, 120))
	return false
end

function getPathSellNodeIndex(pathData)
	return select(3, getPathSellTarget(pathData))
end

function setPathResumePlaybackPending(isPending, shouldSave)
	pathState.resumePathPlaybackPending = isPending == true
	if shouldSave then
		savePathsToStorage(false)
	end
end

function getPathCycleRestartSlotIndex()
	if pathState.farmPathsEnabled then
		return getPlayablePathSlotIndex(1)
	end
	return getPathSequenceStartSlotIndex()
end

function shouldUsePathPlayback()
	if not (pathState.playLoopEnabled or pathState.alwaysPlayEnabled or pathState.farmPathsEnabled or pathState.resumePathPlaybackPending) then
		return false
	end
	return getPathSequenceStartSlotIndex() ~= nil
end

function clearPathSpawnReadyState()
	pathState.spawnPlaybackReadySlotIndex = nil
	pathState.spawnPlaybackReadyPathName = nil
	pathState.spawnPlaybackReadySpawnName = nil
end

function markPathSpawnPlaybackReady(pathName, spawnName, slotIndex)
	if type(pathName) ~= "string" then
		return false
	end

	pathState.spawnPlaybackPending = false
	pathState.spawnPlaybackAwaitingRespawn = false
	pathState.spawnPlaybackPendingSlotIndex = nil
	pathState.spawnPlaybackReadySlotIndex = normalizePathSlotIndex(slotIndex)
	pathState.spawnPlaybackReadyPathName = pathName
	pathState.spawnPlaybackReadySpawnName = normalizePathSpawnName(spawnName)
	pathState.spawnPlaybackPendingPathName = nil
	pathState.spawnPlaybackPendingSpawnName = nil
	return true
end

function cancelPendingPathSpawnPlayback(clearReadyState)
	pathState.spawnPlaybackSequenceId = (tonumber(pathState.spawnPlaybackSequenceId) or 0) + 1
	pathState.spawnPlaybackPending = false
	pathState.spawnPlaybackAwaitingRespawn = false
	pathState.spawnPlaybackPendingSlotIndex = nil
	pathState.spawnPlaybackPendingPathName = nil
	pathState.spawnPlaybackPendingSpawnName = nil
	if clearReadyState ~= false then
		clearPathSpawnReadyState()
	end
end

function isPathSpawnSequenceActive(sequenceId)
	return tonumber(sequenceId) ~= nil
		and (tonumber(pathState.spawnPlaybackSequenceId) or 0) == tonumber(sequenceId)
		and (pathState.spawnPlaybackPending or pathState.spawnPlaybackAwaitingRespawn)
end

function isPathPlaybackBusy()
	return (autoMineEnabled and activeFarmMode == "path")
		or pathState.spawnPlaybackPending == true
		or pathState.spawnPlaybackAwaitingRespawn == true
		or type(pathState.spawnPlaybackReadyPathName) == "string"
end

function hasPathPlaybackRespawnCompleted(previousCharacter)
	local character = getCustomCharacter() or (localPlayer and localPlayer.Character) or cachedCharacter
	if not character or not character.Parent then
		return false
	end

	if previousCharacter and previousCharacter.Parent and character ~= previousCharacter then
		return true
	end

	return not isPathPlaybackResetReady(character)
end

function tryResumeReadyPathSpawnPlayback(sourceLabel)
	local readyPathName = pathState.spawnPlaybackReadyPathName
	local readySlotIndex = normalizePathSlotIndex(pathState.spawnPlaybackReadySlotIndex)
	if type(readyPathName) ~= "string" or not readySlotIndex then
		return false
	end

	if getPathSlotSelection(readySlotIndex, false) ~= readyPathName then
		cancelPendingPathSpawnPlayback(true)
		return false
	end

	local readySpawnName = normalizePathSpawnName(pathState.spawnPlaybackReadySpawnName)
	if not consumeReadyPathSpawnPlayback(readyPathName, readySpawnName, readySlotIndex) then
		return false
	end

	cancelPendingPathSpawnPlayback(false)
	pathState.playbackSlotIndex = readySlotIndex
	setFocusedPathSlotIndex(readySlotIndex, true)
	activeFarmMode = "path"
	pushDebug("resuming saved spawn playback from " .. tostring(sourceLabel or "unknown"))
	startAutoMine()
	return true
end

function getPathSpawnCooldownRemaining(spawnName)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	if not normalizedSpawnName then
		return 0
	end

	local replicatedState = resolveGlobalReplicatedState(false) or resolveGlobalReplicatedState(true)
	if not isTable(replicatedState) then
		return 0
	end

	local state = rawget(replicatedState, "State") or replicatedState.State
	local cooldowns = isTable(state) and (rawget(state, "SpawnCooldowns") or state.SpawnCooldowns) or nil
	local cooldownEndsAt = isTable(cooldowns) and tonumber(cooldowns[normalizedSpawnName]) or nil
	local syncedTime = getSyncedNetworkTime()
	if cooldownEndsAt and syncedTime < cooldownEndsAt then
		return cooldownEndsAt - syncedTime
	end
	return 0
end

function formatPathCooldownCountdown(seconds)
	local remaining = math.max(0, tonumber(seconds) or 0)
	if remaining >= 10 then
		return tostring(math.ceil(remaining)) .. "s"
	end
	return string.format("%.1fs", math.ceil(remaining * 10) / 10)
end

function isSpawnUnlockedForPathPlayback(spawnName)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	if not normalizedSpawnName then
		return true
	end

	local playerData = resolvePlayerDataModule(false) or resolvePlayerDataModule(true)
	if not isTable(playerData) then
		return true
	end

	local isSpawnUnlocked = rawget(playerData, "IsSpawnUnlocked") or playerData.IsSpawnUnlocked
	if type(isSpawnUnlocked) ~= "function" then
		return true
	end

	local ok, unlocked = pcall(isSpawnUnlocked, playerData, normalizedSpawnName)
	return not ok or unlocked ~= false
end

function waitForPathSpawnCooldown(sequenceId, spawnName)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	if not normalizedSpawnName then
		return true
	end

	local notified = false
	while isPathSpawnSequenceActive(sequenceId) and pathState.spawnPlaybackPending do
		local remaining = getPathSpawnCooldownRemaining(normalizedSpawnName)
		if remaining <= 0 then
			return true
		end

		local message = normalizedSpawnName .. " is on cooldown, now waiting for it to be off cooldown.... (" .. formatPathCooldownCountdown(remaining) .. ")"
		if not notified then
			notifyUser("Path Spawn", function()
				local currentRemaining = getPathSpawnCooldownRemaining(normalizedSpawnName)
				return normalizedSpawnName .. " is on cooldown, now waiting for it to be off cooldown.... (" .. formatPathCooldownCountdown(currentRemaining) .. ")"
			end, math.max(6, math.ceil(remaining) + 1))
			notified = true
		end
		setStatus(message, Color3.fromRGB(255, 190, 120))
		task.wait(math.clamp(remaining, PATH_SPAWN_WAIT_INTERVAL, 1))
	end

	return false
end

function isPathPlaybackResetReady(character)
	local playerCharacter = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
	if isTable(playerCharacter) then
		local isDead = rawget(playerCharacter, "IsDead")
		if isDead == nil then
			isDead = playerCharacter.IsDead
		end
		if isDead == true then
			return true
		end
	end

	local replicatedState = resolveGlobalReplicatedState(false) or resolveGlobalReplicatedState(true)
	if isTable(replicatedState) then
		local state = rawget(replicatedState, "State") or replicatedState.State
		local deadState = isTable(state) and (rawget(state, "Dead") or state.Dead) or nil
		if deadState == true then
			return true
		end
	end

	if not character or not character.Parent then
		return true
	end

	local humanoid = getHumanoid(character)
	return humanoid == nil or humanoid.Health <= 0
end

function requestPathPlaybackReset(character)
	local attempted = false

	local humanoid = getHumanoid(character)
	if humanoid then
		pcall(function()
			humanoid.Sit = false
		end)
	end

	local network = playerState.hookedNetwork or resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	local fireServer = type(playerState.originalNetworkFireServer) == "function" and playerState.originalNetworkFireServer
		or (network and network.FireServer)
	if network and type(fireServer) == "function" then
		local okRespawnTriggered = pcall(fireServer, network, "RespawnTriggered")
		if okRespawnTriggered then
			attempted = true
		end
	end

	if attempted then
		return true
	end

	if humanoid then
		pcall(function()
			humanoid.Health = 0
		end)
		pcall(function()
			humanoid:ChangeState(Enum.HumanoidStateType.Dead)
		end)
		attempted = true
	end
	if character and character.Parent then
		pcall(function()
			character:BreakJoints()
		end)
		attempted = true
	end
	return attempted
end

function waitForPathPlaybackReset(sequenceId)
	local lastResetAttemptAt = 0
	local resetCooldownNotified = false
	while isPathSpawnSequenceActive(sequenceId) and pathState.spawnPlaybackPending do
		if isOnPathSpawnSelectorScreen() then
			return true
		end

		local character = cachedCharacter or getCustomCharacter() or (localPlayer and localPlayer.Character)
		if isPathPlaybackResetReady(character) then
			return true
		end

		local now = os.clock()
		if lastResetAttemptAt == 0 or (now - lastResetAttemptAt) >= PATH_RESET_RETRY_INTERVAL then
			requestPathPlaybackReset(character)
			if not resetCooldownNotified then
				setStatus("Resetting character for saved spawn", Color3.fromRGB(120, 190, 255))
			end
			lastResetAttemptAt = now
		elseif not resetCooldownNotified and (now - lastResetAttemptAt) >= PATH_RESET_COOLDOWN_NOTICE_DELAY then
			local message = "Reset character is on cooldown, now waiting for it to be off cooldown...."
			notifyUser("Path Spawn", message, 6)
			setStatus(message, Color3.fromRGB(255, 190, 120))
			resetCooldownNotified = true
		end

		task.wait(PATH_SPAWN_WAIT_INTERVAL)
	end

	return false
end

function requestSavedPathRespawn(spawnName)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	if not normalizedSpawnName then
		return false, "spawn missing"
	end

	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	if not network or type(network.InvokeServer) ~= "function" then
		return false, "respawn network unavailable"
	end

	local okInvoke, err = pcall(function()
		network:InvokeServer("Respawn", normalizedSpawnName)
	end)
	if not okInvoke then
		return false, tostring(err)
	end
	return true
end

function consumeReadyPathSpawnPlayback(pathName, spawnName, slotIndex)
	local readyPathName = pathState.spawnPlaybackReadyPathName
	local readySpawnName = normalizePathSpawnName(pathState.spawnPlaybackReadySpawnName)
	local readySlotIndex = normalizePathSlotIndex(pathState.spawnPlaybackReadySlotIndex)
	local expectedSpawnName = normalizePathSpawnName(spawnName)
	local expectedSlotIndex = normalizePathSlotIndex(slotIndex)
	local matches = type(pathName) == "string"
		and readyPathName == pathName
		and readySpawnName == expectedSpawnName
		and readySlotIndex == expectedSlotIndex
	clearPathSpawnReadyState()
	return matches
end

function queueSelectedPathSpawnPlayback(pathName, spawnName, sourceLabel, slotIndex)
	local normalizedSpawnName = normalizePathSpawnName(spawnName)
	local normalizedSlotIndex = normalizePathSlotIndex(slotIndex)
	if type(pathName) ~= "string" or not normalizedSpawnName or not normalizedSlotIndex then
		return false
	end

	local pendingSpawnName = normalizePathSpawnName(pathState.spawnPlaybackPendingSpawnName)
	if (pathState.spawnPlaybackPending or pathState.spawnPlaybackAwaitingRespawn)
		and pathState.spawnPlaybackPendingSlotIndex == normalizedSlotIndex
		and pathState.spawnPlaybackPendingPathName == pathName
		and pendingSpawnName == normalizedSpawnName then
		setStatus("Preparing saved spawn: " .. normalizedSpawnName, Color3.fromRGB(120, 190, 255))
		return true
	end

	if not isSpawnUnlockedForPathPlayback(normalizedSpawnName) then
		local message = normalizedSpawnName .. " is locked right now."
		notifyUser("Path Spawn", message, 6)
		setStatus(message, Color3.fromRGB(255, 190, 120))
		return false
	end

	pathState.spawnPlaybackSequenceId = (tonumber(pathState.spawnPlaybackSequenceId) or 0) + 1
	local sequenceId = pathState.spawnPlaybackSequenceId
	pathState.spawnPlaybackPending = true
	pathState.spawnPlaybackAwaitingRespawn = false
	pathState.spawnPlaybackPendingSlotIndex = normalizedSlotIndex
	pathState.spawnPlaybackPendingPathName = pathName
	pathState.spawnPlaybackPendingSpawnName = normalizedSpawnName
	clearPathSpawnReadyState()
	activeFarmMode = "path"
	setStatus("Preparing saved spawn: " .. normalizedSpawnName, Color3.fromRGB(120, 190, 255))
	pushDebug("path spawn queued from " .. tostring(sourceLabel or "unknown") .. ": " .. normalizedSpawnName)
	if type(refreshButton) == "function" then
		refreshButton()
	end
	if type(refreshPathManagerButtons) == "function" then
		refreshPathManagerButtons()
	end

	task.spawn(function()
		local ok, err = xpcall(function()
			if not waitForPathSpawnCooldown(sequenceId, normalizedSpawnName) then
				return
			end
			if not waitForPathPlaybackReset(sequenceId) then
				return
			end
			if not isPathSpawnSequenceActive(sequenceId) or not pathState.spawnPlaybackPending then
				return
			end

			pathState.spawnPlaybackPending = false
			pathState.spawnPlaybackAwaitingRespawn = true
			local respawnBaselineCharacter = getCustomCharacter() or (localPlayer and localPlayer.Character) or cachedCharacter

			local nextRespawnRequestAt = 0
			local failedRespawnRequests = 0
			local respawnRequestSucceeded = false
			local spawnSelectorWaitStartedAt = os.clock()
			local spawnSelectorConfirmed = false
			while isPathSpawnSequenceActive(sequenceId) and pathState.spawnPlaybackAwaitingRespawn do
				if respawnRequestSucceeded and hasPathPlaybackRespawnCompleted(respawnBaselineCharacter) then
					if markPathSpawnPlaybackReady(pathName, normalizedSpawnName, normalizedSlotIndex) then
						setStatus("Respawn complete, starting path", Color3.fromRGB(140, 220, 140))
						task.defer(function()
							task.wait(0.35)
							tryResumeReadyPathSpawnPlayback("respawn-detected")
						end)
					end
					return
				end

				local now = os.clock()
				if not respawnRequestSucceeded then
					local onSpawnSelectorScreen = isOnPathSpawnSelectorScreen(respawnBaselineCharacter)
					if onSpawnSelectorScreen then
						if not spawnSelectorConfirmed then
							spawnSelectorConfirmed = true
							setStatus("Spawn selector ready, choosing " .. normalizedSpawnName, Color3.fromRGB(120, 190, 255))
						end
					elseif not spawnSelectorConfirmed and (now - spawnSelectorWaitStartedAt) < PATH_SPAWN_SELECTOR_WAIT_TIMEOUT then
						setStatus("Waiting for spawn selector: " .. normalizedSpawnName, Color3.fromRGB(255, 190, 120))
						task.wait(PATH_SPAWN_WAIT_INTERVAL)
						continue
					end
				end

				if now >= nextRespawnRequestAt then
					local okRespawn, respawnErr = requestSavedPathRespawn(normalizedSpawnName)
					if okRespawn then
						failedRespawnRequests = 0
						respawnRequestSucceeded = true
						setStatus("Respawning at " .. normalizedSpawnName, Color3.fromRGB(120, 190, 255))
						nextRespawnRequestAt = now + PATH_RESPAWN_CONFIRM_TIMEOUT
					else
						failedRespawnRequests += 1
						setStatus("Waiting to respawn at " .. normalizedSpawnName, Color3.fromRGB(255, 190, 120))
						nextRespawnRequestAt = now + PATH_RESPAWN_RETRY_INTERVAL
						if failedRespawnRequests >= 5 then
							error("Respawn request failed: " .. tostring(respawnErr))
						end
					end
				end
				task.wait(PATH_SPAWN_WAIT_INTERVAL)
			end
		end, debug.traceback)

		if not ok and (tonumber(pathState.spawnPlaybackSequenceId) or 0) == sequenceId then
			cancelPendingPathSpawnPlayback(true)
			activeFarmMode = nil
			setStatus("Path start failed", Color3.fromRGB(255, 130, 130))
			pushDebug(err)
			if type(refreshButton) == "function" then
				refreshButton()
			end
			if type(refreshPathManagerButtons) == "function" then
				refreshPathManagerButtons()
			end
		end
	end)

	return true
end

function startPathPlaybackForSlot(slotIndex, sourceLabel)
	if not shouldUsePathPlayback() then
		return false
	end

	local selectedSlotIndex = getPlayablePathSlotIndex(slotIndex or getPathSequenceStartSlotIndex() or 1)
	local selectedPathName = getPathSlotSelection(selectedSlotIndex, false)
	if type(selectedPathName) ~= "string" or pathState.paths[selectedPathName] == nil then
		return false
	end

	pathState.playbackSlotIndex = selectedSlotIndex
	setFocusedPathSlotIndex(selectedSlotIndex, true)
	if tryResumeReadyPathSpawnPlayback(sourceLabel) then
		return true
	end

	local selectedSpawnName = getPathSlotSpawnName(selectedSlotIndex)
	activeFarmMode = "path"
	if selectedSpawnName then
		if consumeReadyPathSpawnPlayback(selectedPathName, selectedSpawnName, selectedSlotIndex) then
			cancelPendingPathSpawnPlayback(false)
			startAutoMine()
			return true
		end
		return queueSelectedPathSpawnPlayback(selectedPathName, selectedSpawnName, sourceLabel, selectedSlotIndex)
	end

	cancelPendingPathSpawnPlayback(true)
	startAutoMine()
	return true
end

function startSelectedPathPlayback(sourceLabel)
	return startPathPlaybackForSlot(getPathSequenceStartSlotIndex(), sourceLabel)
end

function resetPathPlaybackState()
	pathState.playbackActive = false
	pathState.playbackSlotIndex = nil
	pathState.playbackNodeIndex = 1
	pathState.playbackOreIndex = 1
	pathState.playbackPathName = nil
	pathState.currentPath = nil
	pathState.entryPathingPending = false
	pathState.playbackSellPending = false
	clearPathPlayerAvoiderDetection()
end

function beginPathPlayback()
	if not shouldUsePathPlayback() then
		resetPathPlaybackState()
		return false
	end

	local selectedSlotIndex = getPlayablePathSlotIndex(pathState.playbackSlotIndex or getPathSequenceStartSlotIndex() or 1)
	local selectedPathName = getPathSlotSelection(selectedSlotIndex, false)
	if not selectedSlotIndex or type(selectedPathName) ~= "string" or pathState.paths[selectedPathName] == nil then
		resetPathPlaybackState()
		return false
	end

	pathState.playbackActive = true
	pathState.playbackSlotIndex = selectedSlotIndex
	pathState.playbackNodeIndex = 1
	pathState.playbackOreIndex = 1
	pathState.playbackPathName = selectedPathName
	pathState.currentPath = clonePathData(pathState.paths[selectedPathName])
	pathState.entryPathingPending = true
	pathState.playbackSellPending = false
	if pathState.resumePathPlaybackPending then
		setPathResumePlaybackPending(false, true)
	end
	return pathState.currentPath ~= nil
end

function tryAdvanceToNextPathSequence(sourceLabel)
	local nextSlotIndex = getNextPlayablePathSlotIndex(pathState.playbackSlotIndex)
	if not nextSlotIndex then
		if (pathState.playLoopEnabled or pathState.alwaysPlayEnabled or pathState.farmPathsEnabled) and serverHopEnabled then
			return tryPathServerHop("Finding a smaller public server for the next path cycle...", getPathCycleRestartSlotIndex(), false)
		end
		if pathState.farmPathsEnabled then
			nextSlotIndex = getPlayablePathSlotIndex(1)
		end
	end

	if not nextSlotIndex then
		return false
	end

	local nextPathName = getPathSlotSelection(nextSlotIndex, false)
	if type(nextPathName) ~= "string" then
		return false
	end

	local nextSpawnName = getPathSlotSpawnName(nextSlotIndex)
	if nextSpawnName then
		task.defer(function()
			if autoMineEnabled and activeFarmMode == "path" then
				stopAutoMine()
			end
			activeFarmMode = "path"
			local ok, started = xpcall(function()
				return startPathPlaybackForSlot(nextSlotIndex, sourceLabel or "sequence")
			end, debug.traceback)
			if not ok then
				autoMineEnabled = false
				activeFarmMode = nil
				setStatus("Path start failed", Color3.fromRGB(255, 130, 130))
				pushDebug(started)
			elseif not started then
				autoMineEnabled = false
				activeFarmMode = nil
				setStatus("Next path could not start", Color3.fromRGB(255, 190, 120))
			end
			if type(refreshPathManagerButtons) == "function" then
				refreshPathManagerButtons()
			end
		end)
		return true
	end

	pathState.playbackSlotIndex = nextSlotIndex
	setFocusedPathSlotIndex(nextSlotIndex, true)
	if beginPathPlayback() then
		setStatus("Following path " .. tostring(pathState.playbackPathName), Color3.fromRGB(120, 190, 255))
		if type(refreshPathManagerButtons) == "function" then
			refreshPathManagerButtons()
		end
		return true
	end
	return false
end

function getCurrentPathPlaybackNode()
	local currentPath = pathState.currentPath
	if not currentPath or #currentPath.nodes == 0 then
		return nil
	end

	if pathState.playbackNodeIndex < 1 or pathState.playbackNodeIndex > #currentPath.nodes then
		return nil
	end

	return currentPath.nodes[pathState.playbackNodeIndex]
end

function advancePathPlaybackNode()
	local currentPath = pathState.currentPath
	if not currentPath or #currentPath.nodes == 0 then
		pathState.playbackNodeIndex = 1
		return
	end

	pathState.playbackNodeIndex += 1
	if pathState.playbackNodeIndex > #currentPath.nodes then
		pathState.playbackActive = false
	end
end

function isPathPlaybackSellReady()
	local lootSummary = getSellableLootSummary(false)
	if isTable(lootSummary) then
		local filledSlots = tonumber(rawget(lootSummary, "filledSlots") or lootSummary.filledSlots) or 0
		local totalSlots = tonumber(rawget(lootSummary, "totalSlots") or lootSummary.totalSlots) or 0
		lastInventoryFilledSlots = filledSlots
		lastInventoryTotalSlots = totalSlots
		return (rawget(lootSummary, "hasLoot") or lootSummary.hasLoot) == true
	end

	local filledSlots, totalSlots = getInventorySlotCounts()
	lastInventoryFilledSlots = filledSlots
	lastInventoryTotalSlots = totalSlots
	return totalSlots <= 0 or filledSlots > 0
end

function getPlayablePathOreForNode(currentPath, nodeIndex, nodePosition)
	local bestOreTarget = nil
	local bestResolvedOre = nil
	local bestDistance = nil

	for _, oreTarget in ipairs(currentPath.ores or {}) do
		if (oreTarget.nodeIndex or 0) == nodeIndex then
			local resolvedOre = resolveSavedOreTarget(oreTarget)
			if resolvedOre then
				local orePosition = getOrePosition(resolvedOre)
				local oreRemaining = getOreRemainingValue(resolvedOre)
				if orePosition and oreRemaining and oreRemaining.Value > 0 then
					local distance = (orePosition - nodePosition).Magnitude
					if distance <= MINE_AURA_RANGE and (not bestDistance or distance < bestDistance) then
						bestDistance = distance
						bestOreTarget = oreTarget
						bestResolvedOre = resolvedOre
					end
				end
			end
		end
	end

	return bestOreTarget, bestResolvedOre
end

function runPathPlaybackStep(character, humanoid, pickaxe, activeToken)
	if not pathState.playbackActive and not beginPathPlayback() then
		return false
	end

	local currentPath = pathState.currentPath
	if not currentPath or #currentPath.nodes == 0 then
		pathState.playbackActive = false
		setStatus("Selected path has no nodes", Color3.fromRGB(255, 190, 120))
		return false
	end

	local entryJoinDistance = movementMode == "cframe"
		and math.max(0.9, WAYPOINT_REACH_DISTANCE * 0.28)
		or WAYPOINT_REACH_DISTANCE
	local playbackReachDistance = movementMode == "cframe"
		and math.max(0.55, WAYPOINT_REACH_DISTANCE * 0.18)
		or math.max(1.8, WAYPOINT_REACH_DISTANCE * 0.6)
	local function getCurrentNodeDistance(position)
		local rootPart = getRootPart(character)
		if not rootPart or not position then
			return math.huge
		end
		return (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) - Vector3.new(position.X, 0, position.Z)).Magnitude
	end

	local sellerPart, sellerPrompt, sellNodeIndex = getPathSellTarget(currentPath, false)
	local pathPickupOptions = {
		maxDistance = PICKUP_RANGE + 0.75,
		arriveRange = PICKUP_RANGE,
		requireAlreadyInReach = true,
	}
	local processedNodes = 0
	while processedNodes < #currentPath.nodes do
		local currentNode = getCurrentPathPlaybackNode()
		if not currentNode then
			pathState.playbackActive = false
			return false
		end

		local currentNodeIndex = pathState.playbackNodeIndex
		local currentNodePosition = getPathNodePosition(currentNode)
		if not currentNodePosition then
			advancePathPlaybackNode()
			processedNodes += 1
			continue
		end
		local currentOreTarget, resolvedOre = getPlayablePathOreForNode(currentPath, currentNodeIndex, currentNodePosition)
		local sellReady = isPathPlaybackSellReady()
		if sellReady then
			pathState.playbackSellPending = true
		end

		local isSellNode = sellNodeIndex and currentNodeIndex == sellNodeIndex
		local activeSellerPart = nil
		local activeSellerPrompt = nil
		local movementTargetPosition = currentNodePosition
		local requiredDistance = pathState.entryPathingPending and entryJoinDistance or playbackReachDistance
		if isSellNode then
			currentTargetOre = nil
			clearMovementKeys()
			setInteractKeyHeld(false)
			if pickaxe and pickaxe:IsA("Tool") and pickaxe.Parent == character then
				pcall(function()
					pickaxe:Deactivate()
				end)
			end
		end
		if isSellNode and pathState.playbackSellPending then
			activeSellerPart, activeSellerPrompt = findNearestAutoSellTarget(character, false)
			if not activeSellerPart then
				sellerPart, sellerPrompt, sellNodeIndex = getPathSellTarget(currentPath, true)
				activeSellerPart = sellerPart
				activeSellerPrompt = sellerPrompt
			end
		end

		local shouldSellHere = isSellNode and pathState.playbackSellPending and getCurrentNodeDistance(currentNodePosition) <= requiredDistance
		currentTargetOre = nil

		if getCurrentNodeDistance(movementTargetPosition) > requiredDistance then
			if processPathPlayerAvoidance(character, movementTargetPosition, activeToken, nil, humanoid, pickaxe) then
				return true
			end
			if not (isSellNode and pathState.playbackSellPending) and tryAutoPickup(character, humanoid, activeToken, pathPickupOptions) then
				return true
			end

			if isSellNode and pathState.playbackSellPending then
				setStatus("Moving to sell node", Color3.fromRGB(232, 184, 96))
			else
				setStatus("Following path " .. tostring(pathState.playbackPathName), Color3.fromRGB(120, 190, 255))
			end
			clearPathVisualization()
			if pathState.entryPathingPending then
				local reachedTarget, moveReason = moveCharacterNearPosition(character, humanoid, movementTargetPosition, requiredDistance, activeToken)
				if not reachedTarget then
					if moveReason == "rubberband" then
						handlePathPlaybackRubberBand(character, movementTargetPosition)
						return true
					end
					if getCurrentNodeDistance(movementTargetPosition) > requiredDistance then
						return false
					end
				end
				pathState.entryPathingPending = false
			else
				local movedToNode, moveReason = moveTowardsRecordedPathNode(character, humanoid, movementTargetPosition, activeToken)
				if not movedToNode and moveReason == "rubberband" then
					handlePathPlaybackRubberBand(character, movementTargetPosition)
					return true
				end
				return movedToNode
			end
		else
			pathState.entryPathingPending = false
			clearPathVisualization()

			if shouldSellHere then
				if not activeSellerPart then
					sellerPart, sellerPrompt, sellNodeIndex = getPathSellTarget(currentPath, true)
					activeSellerPart = sellerPart
					activeSellerPrompt = sellerPrompt
				end

				if activeSellerPart then
					setStatus("Selling on path", Color3.fromRGB(232, 184, 96))
					clearMovementKeys()
					setInteractKeyHeld(false)
					if trySellLootNearTarget(activeSellerPart, activeSellerPrompt, character) then
						pathState.playbackSellPending = false
						if tryAdvanceToNextPathSequence("path-sequence") then
							return true
						end
						if tryServerHopAfterPathSell() then
							return true
						end
						advancePathPlaybackNode()
						return true
					end

					pushDebugRateLimited("path_sell_retry", "path sell: seller found but sell did not complete, retrying", 2)
					setStatus("Waiting for sell to complete", Color3.fromRGB(232, 184, 96))
					task.wait(0.25)
					return true
				else
					pushDebugRateLimited("path_sell_target_missing", "path sell node has no matched seller target", 3)
					setStatus("Waiting for sell target", Color3.fromRGB(255, 190, 120))
					task.wait(0.25)
					return true
				end
			end

			if isSellNode then
				if pathState.playbackSellPending then
					setStatus("Holding at sell node", Color3.fromRGB(232, 184, 96))
					task.wait(0.15)
					return true
				end

				advancePathPlaybackNode()
				processedNodes += 1
				continue
			end

			if currentOreTarget and resolvedOre then
				local avoidanceHandled, avoidReason = processPathPlayerAvoidance(
					character,
					currentNodePosition,
					activeToken,
					nil,
					humanoid,
					pickaxe
				)
				if avoidanceHandled then
					if avoidReason == "advance" then
						advancePathPlaybackNode()
					end
					return true
				end
				currentTargetOre = resolvedOre
				if tryAutoPickup(character, humanoid, activeToken, pathPickupOptions) then
					return true
				end
				setStatus(
					"Mining marked " .. getOreLabel(currentOreTarget.groupName) .. " (" .. formatOreHealthText(resolvedOre) .. ")",
					Color3.fromRGB(140, 220, 140)
				)
				local equipped = equipPickaxe(character, humanoid, pickaxe)
				if not equipped then
					setStatus("Equipping pickaxe", Color3.fromRGB(255, 190, 120))
					task.wait(0.08)
					return true
				end
				pickaxe = getEquippedPickaxe(character) or getStoredPickaxe(character) or pickaxe
				if pickaxe then
					cachedPickaxe = pickaxe
				end
				swingPickaxe(character, pickaxe, resolvedOre)
				if tryAutoPickup(character, humanoid, activeToken, pathPickupOptions) then
					return true
				end
				return true
			end

			if tryAutoPickup(character, humanoid, activeToken, pathPickupOptions) then
				return true
			end

			advancePathPlaybackNode()
			processedNodes += 1
		end
	end

	return true
end

function refreshCachedObjects(forceRefresh)
	local now = os.clock()
	if not forceRefresh and (now - lastRescanAt) < RESCAN_INTERVAL then
		return cachedCharacter, cachedHumanoid, cachedPickaxe
	end

	lastRescanAt = now
	cachedCharacter = getCustomCharacter()
	cachedHumanoid = getHumanoid(cachedCharacter)
	cachedPickaxe = findPickaxe(cachedCharacter)
	if cachedCharacter then
		pushDebug("character: " .. cachedCharacter.Name)
	else
		pushDebug("character not found")
	end
	if cachedPickaxe then
		pushDebug("pickaxe: " .. cachedPickaxe:GetFullName())
		pushDebug("pickaxe name: " .. cachedPickaxe.Name)
	else
		pushDebug("pickaxe not found")
	end

	return cachedCharacter, cachedHumanoid, cachedPickaxe
end

stopAutoMine = function()
	autoMineEnabled = false
	mineAuraEnabled = false
	activeFarmMode = nil
	serverHopInProgress = false
	autoMineToken += 1
	autoMineThread = nil
	cancelPendingPathSpawnPlayback(true)
	resetPathPlaybackState()
	currentTargetOre = nil
	lastAutoDiscardScanAt = 0
	lastAutoDiscardAttemptAt = 0
	lastAutoDiscardItemKey = nil
	lastToggleAt = 0
	ignoreToggleUntil = 0
	setInteractKeyHeld(false)
	clearMovementKeys()
	cancelActiveMoveTween()
	endExperimentalCFrameTravel(cachedCharacter)
	restoreMineAura()
	releaseAutoMineManualMovementLock()
	setLastMoveCommand(Vector3.zero, "stop")
	clearPathVisualization()
	_G.__AutoMineStopLatched = nil
	if cachedHumanoid and cachedCharacter then
		local rootPart = getRootPart(cachedCharacter)
		if rootPart then
			pcall(function()
				cachedHumanoid:MoveTo(rootPart.Position)
			end)
		end
	end
	pushDebug("auto mine disabled")
	setStatus("Idle", Color3.fromRGB(180, 180, 180))
	if type(refreshButton) == "function" then
		refreshButton()
	end
	if type(refreshServerHopDisplay) == "function" then
		refreshServerHopDisplay()
	end
end

function startAutoMine()
	activeFarmMode = "path"
	autoMineEnabled = true
	mineAuraEnabled = true
	auraCapabilitiesReported = false
	lastMineAuraDebugAt = 0
	lastAuraForceScanAt = 0
	cachedDirectToolInfo = nil
	cachedToolInfoOwner = nil
	autoMineToken += 1
	autoMineThread = nil
	currentTargetOre = nil
	lastAutoDiscardScanAt = 0
	lastAutoDiscardAttemptAt = 0
	lastAutoDiscardItemKey = nil
	setInteractKeyHeld(false)
	clearMovementKeys()
	cancelActiveMoveTween()
	setLastMoveCommand(Vector3.zero, "start")
	if not shouldUsePathPlayback() or not beginPathPlayback() then
		autoMineEnabled = false
		activeFarmMode = nil
		resetPathPlaybackState()
		error("No saved path selected")
	end
	refreshCachedObjects(true)
	ensureAutoMineManualMovementLock(cachedCharacter, cachedHumanoid)
	if type(refreshButton) == "function" then
		refreshButton()
	end
	local activeToken = autoMineToken
	local targetOre = nil
	autoMineThread = task.spawn(function()
		local ok, err = xpcall(function()
			pushDebug("auto mine loop started")
			while autoMineEnabled and activeToken == autoMineToken do
				local character = cachedCharacter
				local humanoid = cachedHumanoid
				local pickaxe = cachedPickaxe

				if serverHopInProgress then
					task.wait(0.25)
					continue
				end

				if not character or not character.Parent then
					character, humanoid, pickaxe = refreshCachedObjects(true)
				elseif not pickaxe or not pickaxe.Parent then
					character, humanoid, pickaxe = refreshCachedObjects(true)
				end

				if character and humanoid then
					ensureAutoMineManualMovementLock(character, humanoid)
					if tryAutoDiscardLastSlotOre(character, activeToken) then
						task.wait(0.08)
						continue
					end

					local delayEquipForTravel = shouldDelayExperimentalCFrameEquip()
					if not delayEquipForTravel then
						local equipped = equipPickaxe(character, humanoid, pickaxe)
						if not equipped then
							task.wait(AUTO_MINE_INTERVAL)
							continue
						end
					end

					pickaxe = getEquippedPickaxe(character) or getStoredPickaxe(character) or pickaxe
					if pickaxe then
						cachedPickaxe = pickaxe
					end

					local auraPickaxe = getEquippedPickaxe(character) or getStoredPickaxe(character) or pickaxe
					if mineAuraEnabled then
						applyMineAuraToPickaxe(auraPickaxe)
					else
						restoreMineAura()
					end

					if pathState.playbackActive then
						runPathPlaybackStep(character, humanoid, pickaxe, activeToken)
						task.wait(0.03)
						continue
					end

					if tryAdvanceToNextPathSequence("path-finished") then
						task.wait(0.03)
						continue
					end

					pathState.playLoopEnabled = false
					savePathsToStorage(true)
					stopAutoMine()
					setStatus("Path finished", Color3.fromRGB(140, 220, 140))
					refreshPathManagerButtons()
					return
				else
					currentTargetOre = nil
					setStatus("Character/humanoid missing", Color3.fromRGB(255, 190, 120))
				end

				task.wait(AUTO_MINE_INTERVAL)
			end
		end, debug.traceback)

		if not ok and activeToken == autoMineToken then
			autoMineEnabled = false
			mineAuraEnabled = false
			serverHopInProgress = false
			resetPathPlaybackState()
			currentTargetOre = nil
			setInteractKeyHeld(false)
			clearMovementKeys()
			cancelActiveMoveTween()
			endExperimentalCFrameTravel(cachedCharacter)
			restoreMineAura()
			releaseAutoMineManualMovementLock()
			setLastMoveCommand(Vector3.zero, "error")
			setStatus("Script error, see debug", Color3.fromRGB(255, 130, 130))
			pushDebug(err)
		end

		if activeToken == autoMineToken or not autoMineEnabled then
			autoMineThread = nil
		end
	end)
end

