function looksLikePlayerDataModule(candidate)
	if not isTable(candidate) then
		return false
	end

	local setLoadout = rawget(candidate, "SetLoadout") or candidate.SetLoadout
	local getLoadout = rawget(candidate, "GetLoadout") or candidate.GetLoadout
	local getContainer = rawget(candidate, "GetContainer") or candidate.GetContainer
	local inventoryContainer = rawget(candidate, "InventoryContainer") or candidate.InventoryContainer
	return type(setLoadout) == "function"
		or (type(getLoadout) == "function" and (type(getContainer) == "function" or isTable(inventoryContainer)))
end

function extractSyncedTime(source)
	if not isTable(source) then
		return nil
	end

	local syncedTime = rawget(source, "SyncedTime") or source.SyncedTime
	if isTable(syncedTime) and type(syncedTime.GetTime) == "function" then
		return syncedTime
	end

	return nil
end

resolveGameModules = function(forceRefresh)
	if cachedGameModules and hasPlrCharacterModule(cachedGameModules) then
		return cachedGameModules
	end

	local now = os.clock()
	if not forceRefresh and (now - lastModuleScanAt) < RESCAN_INTERVAL then
		return nil
	end

	lastModuleScanAt = now

	for _, root in ipairs(getEnvironmentTables()) do
		local directMain = rawget(root, "mainModule") or root.mainModule
		local directMainAlt = rawget(root, "MainModule") or root.MainModule

		local candidates = {
			rawget(root, "Modules") or root.Modules,
			rawget(root, "modules") or root.modules,
			directMain and (rawget(directMain, "Modules") or directMain.Modules),
			directMainAlt and (rawget(directMainAlt, "Modules") or directMainAlt.Modules),
			root,
		}

		for _, candidate in ipairs(candidates) do
			if hasPlrCharacterModule(candidate) then
				cachedGameModules = candidate
				cachedMainModule = rawget(candidate, "mainModule")
					or candidate.mainModule
					or rawget(candidate, "MainModule")
					or candidate.MainModule
					or directMain
					or directMainAlt
				return cachedGameModules
			end
		end
	end

	return nil
end

function resolveSyncedTime(forceRefresh)
	if cachedSyncedTime and type(cachedSyncedTime.GetTime) == "function" then
		return cachedSyncedTime
	end

	local modulesTable = resolveGameModules(forceRefresh)
	if modulesTable then
		local moduleMain = rawget(modulesTable, "mainModule")
			or modulesTable.mainModule
			or rawget(modulesTable, "MainModule")
			or modulesTable.MainModule
		if moduleMain then
			cachedMainModule = moduleMain
		end
	end

	local mainSynced = extractSyncedTime(cachedMainModule)
	if mainSynced then
		cachedSyncedTime = mainSynced
		return cachedSyncedTime
	end

	for _, root in ipairs(getEnvironmentTables()) do
		local synced = extractSyncedTime(root)
			or extractSyncedTime(rawget(root, "mainModule") or root.mainModule)
			or extractSyncedTime(rawget(root, "MainModule") or root.MainModule)
		if synced then
			cachedSyncedTime = synced
			return cachedSyncedTime
		end
	end

	local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
	local globalModuleScript = sharedModules and sharedModules:FindFirstChild("Global")
	if globalModuleScript and globalModuleScript:IsA("ModuleScript") then
		local okRequire, globalModule = pcall(require, globalModuleScript)
		if okRequire and isTable(globalModule) then
			local synced = extractSyncedTime(globalModule)
			if not synced and type(globalModule.LoadModule) == "function" then
				local okLoad, syncedModule = pcall(function()
					return globalModule:LoadModule("SyncedTime")
				end)
				if okLoad and isTable(syncedModule) and type(syncedModule.GetTime) == "function" then
					synced = syncedModule
				end
			end
			if synced then
				cachedSyncedTime = synced
				return cachedSyncedTime
			end
		end
	end

	return nil
end

function getSyncedNetworkTime()
	local syncedTime = resolveSyncedTime(false)
	if syncedTime and type(syncedTime.GetTime) == "function" then
		local ok, value = pcall(function()
			return syncedTime:GetTime()
		end)
		if ok and type(value) == "number" then
			return value
		end
	end

	return 0
end

function isStoredPickaxeName(name)
	if type(name) ~= "string" or name == "" then
		return false
	end

	local lowered = safeLower(tostring(name)):gsub("\\", "/")
	return string.find(lowered, "loadoutitem/", 1, true) ~= nil
		and string.find(lowered, "pickaxe", 1, true) ~= nil
end

function isEquippedPickaxeName(name)
	if type(name) ~= "string" or name == "" then
		return false
	end

	local lowered = safeLower(tostring(name)):gsub("\\", "/")
	return string.find(lowered, "loadoutitem/", 1, true) == nil
		and string.find(lowered, "pickaxe", 1, true) ~= nil
end

function matchesPickaxeName(instance)
	local name = typeof(instance) == "Instance" and instance.Name or instance
	if type(name) ~= "string" or name == "" then
		return false
	end

	return string.find(safeLower(tostring(name)):gsub("\\", "/"), "pickaxe", 1, true) ~= nil
end

function stripStoredPickaxePrefix(name)
	if type(name) ~= "string" or name == "" then
		return nil
	end

	local normalized = tostring(name):gsub("\\", "/")
	local lowered = safeLower(normalized)
	local prefix = "loadoutitem/"
	if string.sub(lowered, 1, #prefix) == prefix then
		return string.sub(normalized, #prefix + 1)
	end

	return normalized
end

function appendPickaxeNameHint(hints, seen, value)
	if type(value) ~= "string" or value == "" then
		return
	end

	local normalized = tostring(value):gsub("\\", "/")
	if not matchesPickaxeName(normalized) then
		return
	end

	local function addHint(name)
		if type(name) == "string" and name ~= "" and not seen[name] then
			seen[name] = true
			table.insert(hints, name)
		end
	end

	local baseName = stripStoredPickaxePrefix(normalized) or normalized
	local strippedItemName = type(baseName) == "string" and string.gsub(baseName, "Item$", "") or baseName
	addHint(baseName)
	addHint("LoadoutItem/" .. baseName)
	if strippedItemName ~= baseName then
		addHint(strippedItemName)
		addHint("LoadoutItem/" .. strippedItemName)
	end
	if string.sub(baseName, -4) ~= "Item" then
		addHint(baseName .. "Item")
	end
	if type(strippedItemName) == "string" and strippedItemName ~= "" and string.sub(strippedItemName, -4) ~= "Item" then
		addHint(strippedItemName .. "Item")
	end
end

function collectPickaxeNameHints(...)
	local hints = {}
	local seen = {}
	local visitedTables = {}

	local function scanValue(value)
		if value == nil then
			return
		end

		if type(value) == "string" then
			appendPickaxeNameHint(hints, seen, value)
			return
		end

		if typeof(value) == "Instance" then
			appendPickaxeNameHint(hints, seen, value.Name)
			return
		end

		if not isTable(value) or visitedTables[value] then
			return
		end

		visitedTables[value] = true
		for _, key in ipairs({
			"Type",
			"Id",
			"Name",
			"DisplayName",
			"ItemType",
			"VariantOf",
			"Model",
			"ModelName",
			"WorldModel",
			"WorldModelName",
			"ViewModel",
			"ViewModelName",
		}) do
			scanValue(rawget(value, key) or value[key])
		end

		scanValue(rawget(value, "ItemData") or value.ItemData)
	end

	for index = 1, select("#", ...) do
		scanValue(select(index, ...))
	end

	return hints
end

