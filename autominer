function S._buildDynamiteSpectateIgnoreList(targetCharacter)
    local ignoreList = {}
    local entitiesFolder = workspace:FindFirstChild("WORKSPACE_Entities")
    if entitiesFolder then
        ignoreList[#ignoreList + 1] = entitiesFolder
    end
    local playersFolder = getTwwEntityPlayersFolder()
    if playersFolder then
        for _, character in ipairs(playersFolder:GetChildren()) do
            if character and character ~= targetCharacter then
                ignoreList[#ignoreList + 1] = character
            end
        end
    end
    if targetCharacter then
        ignoreList[#ignoreList + 1] = targetCharacter
    end
    local localWorldCharacter = getWorldCharacterForPlayer(localPlayer)
    if localWorldCharacter and localWorldCharacter ~= targetCharacter then
        ignoreList[#ignoreList + 1] = localWorldCharacter
    end
    return ignoreList
end

function S._stepDynamiteSpectateZoomSpring(dt)
    local minDistance = 3
    local maxDistance = 24
    local goal = math.clamp(tonumber(S._dynamiteSpectateTargetDistance) or tonumber(S._dynamiteSpectateDistance) or 8, minDistance, maxDistance)
    local currentDistance = math.clamp(tonumber(S._dynamiteSpectateDistance) or goal, minDistance, maxDistance)
    local currentVelocity = tonumber(S._dynamiteSpectateZoomVelocity) or 0
    local stepDt = math.max(tonumber(dt) or 0, 1 / 240)
    local omega = 4.5 * 2 * math.pi
    local distanceDelta = goal - currentDistance
    local omegaDt = omega * stepDt
    local decay = math.exp(-omegaDt)
    local nextDistance = goal + (currentVelocity * stepDt - distanceDelta * (omegaDt + 1)) * decay
    local nextVelocity = ((distanceDelta * omega - currentVelocity) * omegaDt + currentVelocity) * decay
    if nextDistance < minDistance then
        nextDistance = minDistance
        nextVelocity = 0
    elseif nextDistance > maxDistance then
        nextDistance = maxDistance
        nextVelocity = 0
    end
    S._dynamiteSpectateDistance = nextDistance
    S._dynamiteSpectateZoomVelocity = nextVelocity
    return nextDistance
end

function S._resolveDynamiteSpectatePopper(camera, desiredCFrame, focusPosition, targetCharacter)
    if not (camera and desiredCFrame and typeof(focusPosition) == "Vector3") then
        return desiredCFrame
    end
    local desiredDistance = (desiredCFrame.Position - focusPosition).Magnitude
    local cutoff = 0
    pcall(function()
        camera.CFrame = desiredCFrame
        camera.Focus = CFrame.new(focusPosition)
        cutoff = tonumber(camera:GetLargestCutoffDistance(S._buildDynamiteSpectateIgnoreList(targetCharacter))) or 0
    end)
    if math.abs(desiredDistance - (tonumber(S._dynamiteSpectateLastZoomLevel) or 0)) > 0.001 then
        S._dynamiteSpectateLastPopAmount = 0
    end
    local lastPopAmount = tonumber(S._dynamiteSpectateLastPopAmount) or 0
    if cutoff < lastPopAmount then
        cutoff = lastPopAmount
    end
    if cutoff > 0 then
        desiredCFrame = desiredCFrame + desiredCFrame.LookVector * cutoff
        S._dynamiteSpectateLastPopAmount = math.max(cutoff - 0.3, 0)
    else
        S._dynamiteSpectateLastPopAmount = 0
    end
    S._dynamiteSpectateLastZoomLevel = desiredDistance
    return desiredCFrame
end

local function restoreDynamiteSpectateCamera()
    if not S._dynamiteSpectateCameraActive then
        return
    end
    if S._dynamiteSpectateRenderConnection then
        S._dynamiteSpectateRenderConnection:Disconnect()
        S._dynamiteSpectateRenderConnection = nil
    end
    if S._dynamiteSpectateInputConnection then
        S._dynamiteSpectateInputConnection:Disconnect()
        S._dynamiteSpectateInputConnection = nil
    end
    if S._dynamiteSpectateInputBeganConnection then
        S._dynamiteSpectateInputBeganConnection:Disconnect()
        S._dynamiteSpectateInputBeganConnection = nil
    end
    if S._dynamiteSpectateInputEndedConnection then
        S._dynamiteSpectateInputEndedConnection:Disconnect()
        S._dynamiteSpectateInputEndedConnection = nil
    end
    local camera = workspace.CurrentCamera
    if not camera then
        return
    end
    local localCharacter = localPlayer and localPlayer.Character
    local humanoid = localCharacter and localCharacter:FindFirstChildOfClass("Humanoid")
    local rootPart = getRootPart(localCharacter)
    pcall(function()
        if S._dynamiteSpectatePreDragMouseBehavior ~= nil then
            _UserInputService.MouseBehavior = S._dynamiteSpectatePreDragMouseBehavior
            S._dynamiteSpectatePreDragMouseBehavior = nil
        else
            _UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        end
        if S._dynamiteSpectatePreDragMouseIconEnabled ~= nil then
            _UserInputService.MouseIconEnabled = S._dynamiteSpectatePreDragMouseIconEnabled
            S._dynamiteSpectatePreDragMouseIconEnabled = nil
        end
        if S._dynamiteSpectatePreviousType then
            camera.CameraType = S._dynamiteSpectatePreviousType
        else
            camera.CameraType = Enum.CameraType.Custom
        end
        if S._dynamiteSpectatePreviousSubject then
            camera.CameraSubject = S._dynamiteSpectatePreviousSubject
        else
            local localWorldCharacter = getWorldCharacterForPlayer(localPlayer) or localCharacter
            local localWorldHumanoid = localWorldCharacter and (localWorldCharacter:FindFirstChild("Humanoid") or localWorldCharacter:FindFirstChildOfClass("Humanoid"))
            local localWorldRoot = getTwwModelRoot(localWorldCharacter) or rootPart
            camera.CameraSubject = localWorldHumanoid or humanoid or localWorldRoot or camera.CameraSubject
        end
        if typeof(S._dynamiteSpectatePreviousCFrame) == "CFrame" then
            camera.CFrame = S._dynamiteSpectatePreviousCFrame
        end
    end)
    S._dynamiteSpectatePreviousType = nil
    S._dynamiteSpectatePreviousSubject = nil
    S._dynamiteSpectatePreviousCFrame = nil
    S._dynamiteSpectateLastMousePos = nil
    S._dynamiteSpectateRotateHeld = false
    S._dynamiteSpectateLastPopAmount = 0
    S._dynamiteSpectateLastZoomLevel = nil
    S._dynamiteSpectateZoomVelocity = 0
    S._dynamiteSpectateCameraActive = false
end

local function updateDynamiteSpectateCamera()
    if not (S.dynamiteSpectateEnabled and S.dynamiteTarget == "Player") then
        restoreDynamiteSpectateCamera()
        return
    end
    local camera = workspace.CurrentCamera
    if not camera then
        restoreDynamiteSpectateCamera()
        return
    end
    if not S._dynamiteSpectateCameraActive then
        S._dynamiteSpectatePreviousType = camera.CameraType
        S._dynamiteSpectatePreviousSubject = camera.CameraSubject
        S._dynamiteSpectatePreviousCFrame = camera.CFrame
    end
    if not S._dynamiteSpectateInputBeganConnection then
        S._dynamiteSpectateInputBeganConnection = _UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if destroyed or not isSessionActive() or gameProcessed then
                return
            end
            if not (S.dynamiteSpectateEnabled and S.dynamiteTarget == "Player") then
                return
            end
            if input.UserInputType == Enum.UserInputType.MouseButton2 then
                S._dynamiteSpectateRotateHeld = true
                S._dynamiteSpectateLastMousePos = nil
                S._dynamiteSpectatePreDragMouseBehavior = _UserInputService.MouseBehavior
                S._dynamiteSpectatePreDragMouseIconEnabled = _UserInputService.MouseIconEnabled
                pcall(function()
                    _UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
                    _UserInputService.MouseIconEnabled = false
                end)
            end
        end)
    end
    if not S._dynamiteSpectateInputEndedConnection then
        S._dynamiteSpectateInputEndedConnection = _UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton2 then
                S._dynamiteSpectateRotateHeld = false
                S._dynamiteSpectateLastMousePos = nil
                pcall(function()
                    if S._dynamiteSpectatePreDragMouseBehavior ~= nil then
                        _UserInputService.MouseBehavior = S._dynamiteSpectatePreDragMouseBehavior
                    else
                        _UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                    end
                    if S._dynamiteSpectatePreDragMouseIconEnabled ~= nil then
                        _UserInputService.MouseIconEnabled = S._dynamiteSpectatePreDragMouseIconEnabled
                    else
                        _UserInputService.MouseIconEnabled = true
                    end
                end)
                S._dynamiteSpectatePreDragMouseBehavior = nil
                S._dynamiteSpectatePreDragMouseIconEnabled = nil
            end
        end)
    end
    if not S._dynamiteSpectateInputConnection then
        S._dynamiteSpectateInputConnection = _UserInputService.InputChanged:Connect(function(input, gameProcessed)
            if destroyed or not isSessionActive() or gameProcessed then
                return
            end
            if not (S.dynamiteSpectateEnabled and S.dynamiteTarget == "Player") then
                return
            end
            if input.UserInputType == Enum.UserInputType.MouseWheel then
                local zoomDelta = tonumber(input.Position.Z) or 0
                local currentGoal = tonumber(S._dynamiteSpectateTargetDistance) or tonumber(S._dynamiteSpectateDistance) or 8
                S._dynamiteSpectateTargetDistance = math.clamp(currentGoal - zoomDelta * 1.75, 3, 24)
            elseif input.UserInputType == Enum.UserInputType.MouseMovement and S._dynamiteSpectateRotateHeld == true then
                local delta = input.Delta
                S._dynamiteSpectateYaw = (tonumber(S._dynamiteSpectateYaw) or 0) + delta.X * 0.00375
                S._dynamiteSpectatePitch = math.clamp((tonumber(S._dynamiteSpectatePitch) or math.rad(8)) + delta.Y * 0.00285, math.rad(-65), math.rad(65))
            end
        end)
    end
    if not S._dynamiteSpectateRenderConnection then
        S._dynamiteSpectateRenderConnection = _RunService.RenderStepped:Connect(function(dt)
            if destroyed or not isSessionActive() then
                restoreDynamiteSpectateCamera()
                return
            end
            if not (S.dynamiteSpectateEnabled and S.dynamiteTarget == "Player") then
                restoreDynamiteSpectateCamera()
                return
            end
            local liveCharacter, _, liveRootPart, liveFocusPart = getDynamiteSpectateTargetData()
            if not liveCharacter or not liveRootPart then
                return
            end
            local liveCamera = workspace.CurrentCamera
            if not liveCamera then
                return
            end
            local focusPosition = (liveFocusPart or liveRootPart).Position + Vector3.new(0, 0.35, 0)
            local distance = tonumber(S._dynamiteSpectateDistance)
            local yaw = tonumber(S._dynamiteSpectateYaw)
            local pitch = tonumber(S._dynamiteSpectatePitch)
            if not distance or not yaw or not pitch then
                local defaultOffset = (-liveRootPart.CFrame.LookVector * 8) + Vector3.new(0, 2.6, 0)
                local currentOffset = liveCamera.CFrame.Position - focusPosition
                if currentOffset.Magnitude < 3 or currentOffset.Magnitude > 30 then
                    currentOffset = defaultOffset
                end
                distance = math.clamp(currentOffset.Magnitude, 3, 24)
                yaw = math.atan2(currentOffset.Z, currentOffset.X)
                pitch = math.asin(math.clamp(currentOffset.Y / math.max(distance, 0.001), -1, 1))
                if not pitch or pitch ~= pitch then
                    pitch = math.rad(8)
                end
                S._dynamiteSpectateDistance = distance
                S._dynamiteSpectateTargetDistance = distance
                S._dynamiteSpectateYaw = yaw
                S._dynamiteSpectatePitch = pitch
                S._dynamiteSpectateZoomVelocity = 0
            end
            distance = S._stepDynamiteSpectateZoomSpring(dt)
            local orbitOffset = Vector3.new(
                math.cos(pitch) * math.cos(yaw),
                math.sin(pitch),
                math.cos(pitch) * math.sin(yaw)
            ) * distance
            local cameraPosition = focusPosition + orbitOffset
            pcall(function()
                liveCamera.CameraType = Enum.CameraType.Scriptable
                liveCamera.CFrame = S._resolveDynamiteSpectatePopper(liveCamera, CFrame.lookAt(cameraPosition, focusPosition), focusPosition, liveCharacter)
                liveCamera.Focus = CFrame.new(focusPosition)
            end)
        end)
    end
    S._dynamiteSpectateCameraActive = true
end

