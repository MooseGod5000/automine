function clampTweenSpeed(value)
	return math.clamp(value, TWEEN_SPEED_MIN, TWEEN_SPEED_MAX)
end

function setTweenSpeed(value, skipPersistence)
	local nextValue = clampTweenSpeed(value)
	local changed = math.abs((tonumber(tweenMoveSpeed) or TWEEN_MOVE_SPEED) - nextValue) > 0.001
	tweenMoveSpeed = nextValue
	if tweenSpeedBox then
		tweenSpeedBox.Text = tostring(math.floor(tweenMoveSpeed + 0.5))
	end
	if changed and not skipPersistence and type(schedulePathSettingsPersist) == "function" then
		schedulePathSettingsPersist()
	end
end

function getEffectiveCFrameSpeed()
	local sliderSpeed = math.max(tonumber(tweenMoveSpeed) or TWEEN_MOVE_SPEED, 1)
	if sliderSpeed <= 10 then
		return sliderSpeed
	end
	if sliderSpeed <= 40 then
		return 10 + ((sliderSpeed - 10) * 1.25)
	end
	return 47.5 + ((sliderSpeed - 40) * 1.55)
end

function restoreMineAura()
	for part, original in pairs(auraOriginalParts) do
		if part and part.Parent then
			pcall(function()
				part.Size = original.Size
			end)
		end
		auraOriginalParts[part] = nil
	end
end

function applyMineAuraToPickaxe(pickaxe)
	if not mineAuraEnabled or not pickaxe then
		return
	end

	for _, descendant in ipairs(pickaxe:GetDescendants()) do
		if descendant:IsA("BasePart") then
			local partName = safeLower(descendant.Name)
			if string.find(partName, "hitbox", 1, true) ~= nil then
				if not auraOriginalParts[descendant] then
					auraOriginalParts[descendant] = {
						Size = descendant.Size,
					}
				end

				pcall(function()
					local baseSize = auraOriginalParts[descendant].Size
					descendant.Size = Vector3.new(
						baseSize.X * MINE_AURA_MULTIPLIER,
						baseSize.Y * MINE_AURA_MULTIPLIER,
						baseSize.Z * MINE_AURA_MULTIPLIER
					)
				end)
			end
		end
	end
end

function pushDebug(text)
	local line = tostring(text)
	if debugLines[1] == line then
		return
	end

	warn("[AutoMine] " .. line)

	table.insert(debugLines, 1, line)
	while #debugLines > 3 do
		table.remove(debugLines)
	end

	if debugLabel then
		pcall(function()
			debugLabel.Text = table.concat(debugLines, "\n")
		end)
	end
end

function pushDebugRateLimited(key, text, interval)
	local now = os.clock()
	local throttle = interval or 1
	local lastTime = debugCooldowns[key] or 0
	if (now - lastTime) < throttle then
		return
	end

	debugCooldowns[key] = now
	pushDebug(text)
end

function notifyUser(title, text, duration)
    local textProvider = type(text) == "function" and text or nil
    local notifyText = textProvider and tostring(textProvider() or "") or tostring(text or "")
    local notifyTitle = tostring(title or "Automine")
    if type(spawnNotification) == "function" then
        local lowered = safeLower(notifyTitle)
        local notifType = "info"
        if string.find(lowered, "warn", 1, true) then
            notifType = "warning"
        elseif string.find(lowered, "error", 1, true) then
            notifType = "error"
        elseif string.find(lowered, "success", 1, true) then
            notifType = "success"
        end
        local updater = nil
        if textProvider then
            updater = function()
                return notifyTitle .. ": " .. tostring(textProvider() or notifyText)
            end
        end
        spawnNotification(notifyTitle .. ": " .. notifyText, notifType, true, duration, updater)
    else
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = notifyTitle,
                Text = notifyText,
                Duration = duration or 4,
            })
        end)
    end
    pushDebug((title and (title .. ": ") or "") .. tostring(text or ""))
end

function notifyRubberBandDetected()
	local now = os.clock()
	if (now - lastRubberBandNoticeAt) < RUBBERBAND_NOTIFY_COOLDOWN then
		return
	end

	lastRubberBandNoticeAt = now
	if type(spawnNotification) == "function" then
		spawnNotification("Rubber band detected.", "warning", true, 3)
	else
		notifyUser("Warning", "Rubber band detected.", 3)
	end
end

function handlePathPlaybackRubberBand(character, targetPosition)
	cancelActiveMoveTween()
	clearMovementKeys()
	setInteractKeyHeld(false)
	if movementMode == "cframe" and type(endExperimentalCFrameTravel) == "function" then
		endExperimentalCFrameTravel(character)
	end
	local closestNodeIndex = nil
	local closestNodeDistance = nil
	local rootPart = getRootPart(character)
	if rootPart and pathState.currentPath then
		closestNodeIndex, closestNodeDistance = getClosestPlaybackPathNodeIndex(pathState.currentPath, rootPart.Position)
		if closestNodeIndex then
			pathState.playbackNodeIndex = closestNodeIndex
			pathState.entryPathingPending = true
		end
	end
	setStatus("Rubber band detected", Color3.fromRGB(255, 190, 120))
	pushDebugRateLimited(
		"path_rubberband",
		"rubber band detected while pathing to "
			.. (typeof(targetPosition) == "Vector3" and string.format("(%.1f, %.1f, %.1f)", targetPosition.X, targetPosition.Y, targetPosition.Z) or "node"),
		1.25
	)
	if closestNodeIndex then
		pushDebugRateLimited(
			"path_rubberband_resync",
			string.format("rubber band resync -> node %d (%.1f studs)", closestNodeIndex, tonumber(closestNodeDistance) or -1),
			1.25
		)
	end
	notifyRubberBandDetected()
	task.wait(RUBBERBAND_RETRY_DELAY)
end

function getCallableGlobal(name)
	local direct = rawget(_G, name)
	if type(direct) == "function" then
		return direct
	end

	if type(getgenv) == "function" then
		local ok, environment = pcall(getgenv)
		if ok and type(environment) == "table" and type(environment[name]) == "function" then
			return environment[name]
		end
	end

	return nil
end

function ensurePathStorageSupport(showNotice)
	if pathState.storageChecked then
		if showNotice and not pathState.storageSupported and not pathState.storageNoticeShown then
			notifyUser("Path Storage", "Missing executor file APIs: " .. table.concat(pathState.storageMissing, ", "), 6)
			pathState.storageNoticeShown = true
		end
		return pathState.storageSupported
	end

	local missing = {}
	for _, functionName in ipairs({ "writefile", "readfile", "isfile", "makefolder" }) do
		if not getCallableGlobal(functionName) then
			table.insert(missing, functionName)
		end
	end

	if not getCallableGlobal("listfiles") then
		table.insert(missing, "listfiles")
	end

	pathState.storageChecked = true
	pathState.storageMissing = missing
	pathState.storageSupported = #missing == 0 or (#missing == 1 and missing[1] == "listfiles")

	if showNotice and not pathState.storageSupported and not pathState.storageNoticeShown then
		notifyUser("Path Storage", "Missing executor file APIs: " .. table.concat(pathState.storageMissing, ", "), 6)
		pathState.storageNoticeShown = true
	end

	return pathState.storageSupported
end

function sanitizePathStorageKey(rawValue)
	local cleaned = tostring(rawValue or "local")
	cleaned = string.gsub(cleaned, "[^%w_%-]", "_")
	cleaned = string.gsub(cleaned, "_+", "_")
	return cleaned ~= "" and cleaned or "local"
end

function getPathStorageFilePath()
	local deviceKey = nil
	local hwidFunction = getCallableGlobal("gethwid")
	if hwidFunction then
		local ok, value = pcall(hwidFunction)
		if ok and value then
			deviceKey = value
		end
	end

	if not deviceKey then
		deviceKey = tostring(LocalPlayer.UserId)
	end

	local fileName = string.format("%s_%s.json", PATH_STORAGE_FILE_PREFIX, sanitizePathStorageKey(deviceKey))
	return PATH_STORAGE_FOLDER .. "\\" .. fileName
end

function vectorToData(vector)
	return {
		x = math.floor(vector.X * 100 + 0.5) / 100,
		y = math.floor(vector.Y * 100 + 0.5) / 100,
		z = math.floor(vector.Z * 100 + 0.5) / 100,
	}
end

function vectorFromData(data)
	if type(data) ~= "table" then
		return nil
	end

	return Vector3.new(tonumber(data.x) or 0, tonumber(data.y) or 0, tonumber(data.z) or 0)
end

function normalizePathNodeIndex(index, nodeCount)
	local numericIndex = tonumber(index)
	if not numericIndex then
		return nil
	end

	numericIndex = math.floor(numericIndex)
	if numericIndex < 1 or numericIndex > math.max(tonumber(nodeCount) or 0, 0) then
		return nil
	end

	return numericIndex
end

function getManualPathSellNodeIndex(pathData)
	local nodes = pathData and pathData.nodes or {}
	return normalizePathNodeIndex(pathData and pathData.manualSellNodeIndex, #nodes)
end

function getPathNodePosition(node)
	if typeof(node) == "Vector3" then
		return node
	end
	if type(node) == "table" then
		if typeof(node.position) == "Vector3" then
			return node.position
		end
		local nestedPosition = vectorFromData(node.position)
		if nestedPosition then
			return nestedPosition
		end
	end
	return nil
end

function getClosestPlaybackPathNodeIndex(pathData, worldPosition)
	if type(pathData) ~= "table" or typeof(worldPosition) ~= "Vector3" then
		return nil, nil
	end

	local nodes = pathData.nodes or {}
	local bestNodeIndex = nil
	local bestDistance = nil
	local flatWorldPosition = Vector3.new(worldPosition.X, 0, worldPosition.Z)
	for nodeIndex, node in ipairs(nodes) do
		local nodePosition = getPathNodePosition(node)
		if nodePosition then
			local flatNodePosition = Vector3.new(nodePosition.X, 0, nodePosition.Z)
			local distance = (flatWorldPosition - flatNodePosition).Magnitude
			if not bestDistance or distance < bestDistance then
				bestDistance = distance
				bestNodeIndex = nodeIndex
			end
		end
	end

	return bestNodeIndex, bestDistance
end

function setPathNodePosition(pathData, nodeIndex, position)
	if not pathData or not position then
		return false
	end

	local currentNode = pathData.nodes and pathData.nodes[nodeIndex]
	if not currentNode then
		return false
	end

	if typeof(currentNode) == "Vector3" then
		pathData.nodes[nodeIndex] = position
		return true
	end

	if type(currentNode) == "table" then
		currentNode.position = position
		return true
	end

	pathData.nodes[nodeIndex] = position
	return true
end

function serializePathData(pathData)
	local serialized = {
		nodes = {},
		ores = {},
		manualSellNodeIndex = getManualPathSellNodeIndex(pathData),
		spawnName = normalizePathSpawnName(pathData and pathData.spawnName),
	}

	for _, node in ipairs(pathData.nodes or {}) do
		local nodePosition = getPathNodePosition(node)
		if nodePosition then
			table.insert(serialized.nodes, {
				position = vectorToData(nodePosition),
			})
		end
	end

	for _, ore in ipairs(pathData.ores or {}) do
		table.insert(serialized.ores, {
			groupName = ore.groupName,
			position = vectorToData(ore.position),
			nodeIndex = ore.nodeIndex,
		})
	end

	return serialized
end

function deserializePathData(pathData)
	local result = {
		nodes = {},
		ores = {},
		manualSellNodeIndex = nil,
		spawnName = normalizePathSpawnName(pathData and pathData.spawnName),
	}

	for _, node in ipairs(pathData and pathData.nodes or {}) do
		local position = getPathNodePosition(node) or vectorFromData(node)
		if position then
			table.insert(result.nodes, {
				position = position,
			})
		end
	end

	for _, ore in ipairs(pathData and pathData.ores or {}) do
		local position = vectorFromData(ore.position)
		if position then
			table.insert(result.ores, {
				groupName = ore.groupName,
				position = position,
				nodeIndex = tonumber(ore.nodeIndex) or 0,
			})
		end
	end

	result.manualSellNodeIndex = normalizePathNodeIndex(pathData and pathData.manualSellNodeIndex, #result.nodes)

	return result
end

function getSavedPathNamesOrdered()
	local names = {}
	for pathName in pairs(pathState.paths) do
		table.insert(names, pathName)
	end
	table.sort(names, function(left, right)
		return string.lower(left) < string.lower(right)
	end)
	return names
end

function savePathsToStorage(showNotice)
	if not ensurePathStorageSupport(showNotice) then
		return false
	end

	ensurePathSlotState()
	local serializedPaths = {}
	for pathName, pathData in pairs(pathState.paths) do
		serializedPaths[pathName] = serializePathData(pathData)
	end

	local serializedPathSlots = {}
	for slotIndex = 1, MAX_PATH_PLAYBACK_SLOTS do
		serializedPathSlots[slotIndex] = getPathSlotSelection(slotIndex, true)
	end

	local payload = {
		version = 3,
		settings = {
			selectedPathName = pathState.selectedPathName,
			pathSlots = serializedPathSlots,
			pathSectionCount = pathState.pathSectionCount,
			focusedPathSlotIndex = pathState.focusedPathSlotIndex,
			sequenceStartSlotIndex = pathState.sequenceStartSlotIndex,
			alwaysPlayEnabled = pathState.alwaysPlayEnabled,
			farmPathsEnabled = pathState.farmPathsEnabled == true,
			staffHopEnabled = pathState.staffHopEnabled == true,
			playerAvoiderEnabled = pathState.playerAvoiderEnabled == true,
			playerAvoiderDistance = getPathPlayerAvoiderDistance(),
			playerAvoiderShowCorridor = pathState.playerAvoiderShowCorridor == true,
			playLoopEnabled = false,
			resumePathPlaybackPending = pathState.resumePathPlaybackPending == true,
			markOreKey = pathState.markOreKey and pathState.markOreKey.Name or DEFAULT_AUTOFARM_KEY.Name,
			recordNodeSpacing = getPathRecordNodeSpacing(),
			movementMode = normalizeMovementMode(movementMode),
			tweenMoveSpeed = clampTweenSpeed(tweenMoveSpeed),
			serverHopEnabled = serverHopEnabled == true,
		},
		paths = serializedPaths,
	}

	local makefolderFunction = getCallableGlobal("makefolder")
	local writefileFunction = getCallableGlobal("writefile")
	pcall(makefolderFunction, PATH_STORAGE_FOLDER)
	local ok = false
	local err = nil
	ok, err = pcall(writefileFunction, getPathStorageFilePath(), HttpService:JSONEncode(payload))

	if not ok then
		notifyUser("Path Storage", "Failed to save paths: " .. tostring(err), 5)
		return false
	end

	return true
end

function loadPathsFromStorage()
	if not ensurePathStorageSupport(false) then
		return false
	end

	local isfileFunction = getCallableGlobal("isfile")
	local readfileFunction = getCallableGlobal("readfile")
	local filePath = getPathStorageFilePath()
	local okExists, exists = pcall(isfileFunction, filePath)
	if not okExists or not exists then
		return false
	end

	local okRead, contents = pcall(readfileFunction, filePath)
	if not okRead or type(contents) ~= "string" or contents == "" then
		return false
	end

	local okDecode, payload = pcall(function()
		return HttpService:JSONDecode(contents)
	end)
	if not okDecode or type(payload) ~= "table" then
		notifyUser("Path Storage", "Saved path data could not be read.", 5)
		return false
	end

	pathState.paths = {}
	for pathName, pathData in pairs(payload.paths or {}) do
		pathState.paths[pathName] = deserializePathData(pathData)
	end

	local settings = payload.settings or {}
	ensurePathSlotState()
	pathState.selectedPathName = nil
	pathState.pathSlots = {nil, nil, nil, nil}
	pathState.pathSectionCount = 1
	pathState.focusedPathSlotIndex = 1
	pathState.sequenceStartSlotIndex = 1
	pathState.alwaysPlayEnabled = false
	pathState.farmPathsEnabled = false
	pathState.staffHopEnabled = false
	pathState.playerAvoiderEnabled = S.pathPlayerAvoiderEnabled == true
	pathState.playerAvoiderDistance = math.clamp(math.floor((tonumber(S.pathPlayerAvoiderDistance) or DEFAULTS.pathPlayerAvoiderDistance) + 0.5), 1, 200)
	pathState.playerAvoiderShowCorridor = S.pathPlayerAvoiderShowCorridor == true
	pathState.playLoopEnabled = false
	pathState.resumePathPlaybackPending = false
	if type(settings.markOreKey) == "string" and Enum.KeyCode[settings.markOreKey] then
		pathState.markOreKey = Enum.KeyCode[settings.markOreKey]
	end
	if type(settings.recordNodeSpacing) == "number" then
		setPathRecordNodeSpacing(settings.recordNodeSpacing, true)
	end
	if type(settings.movementMode) == "string" then
		setMovementMode(settings.movementMode, "storage", true)
	end
	if type(settings.tweenMoveSpeed) == "number" then
		setTweenSpeed(settings.tweenMoveSpeed, true)
	end
	if isTable(settings.pathSlots) then
		for slotIndex = 1, MAX_PATH_PLAYBACK_SLOTS do
			local slotName = settings.pathSlots[slotIndex]
			if type(slotName) == "string" and pathState.paths[slotName] ~= nil then
				pathState.pathSlots[slotIndex] = slotName
			end
		end
	else
		local selectedPathName = settings.selectedPathName
		if type(selectedPathName) == "string" and pathState.paths[selectedPathName] ~= nil then
			pathState.pathSlots[1] = selectedPathName
		end
	end
	if type(settings.pathSectionCount) == "number" then
		pathState.pathSectionCount = settings.pathSectionCount
	else
		local highestConfiguredSlot = 1
		for slotIndex = MAX_PATH_PLAYBACK_SLOTS, 1, -1 do
			if type(pathState.pathSlots[slotIndex]) == "string" then
				highestConfiguredSlot = slotIndex
				break
			end
		end
		pathState.pathSectionCount = highestConfiguredSlot
	end
	pathState.focusedPathSlotIndex = normalizePathSlotIndex(settings.focusedPathSlotIndex) or 1
	pathState.sequenceStartSlotIndex = normalizePathSlotIndex(settings.sequenceStartSlotIndex) or 1
	pathState.farmPathsEnabled = settings.farmPathsEnabled == true
	pathState.staffHopEnabled = settings.staffHopEnabled == true
	pathState.playerAvoiderEnabled = settings.playerAvoiderEnabled == true
	pathState.playerAvoiderDistance = math.clamp(math.floor((tonumber(settings.playerAvoiderDistance) or pathState.playerAvoiderDistance or DEFAULTS.pathPlayerAvoiderDistance) + 0.5), 1, 200)
	if type(settings.playerAvoiderShowCorridor) == "boolean" then
		pathState.playerAvoiderShowCorridor = settings.playerAvoiderShowCorridor
	end
	S.pathPlayerAvoiderEnabled = pathState.playerAvoiderEnabled
	S.pathPlayerAvoiderDistance = pathState.playerAvoiderDistance
	S.pathPlayerAvoiderShowCorridor = pathState.playerAvoiderShowCorridor
	serverHopEnabled = settings.serverHopEnabled == true
	ensurePathSlotState()
	setFocusedPathSlotIndex(pathState.focusedPathSlotIndex, true)

	return true
end

