function ensureGunAimDrawings()
    if type(Drawing) ~= "table" or type(Drawing.new) ~= "function" then
        if not gunFeatureState.warnedAimUnavailable then
            gunFeatureState.warnedAimUnavailable = true
            spawnNotification("Drawing API unavailable. Aim visuals could not start.", "warning", true)
        end
        return false
    end

    if not gunFeatureState.fovCircle then
        gunFeatureState.fovCircle = Drawing.new("Circle")
        gunFeatureState.fovCircle.Filled = false
        gunFeatureState.fovCircle.Thickness = 1.6
        gunFeatureState.fovCircle.Color = Color3.new(1, 1, 1)
        gunFeatureState.fovCircle.Visible = false
    end

    if not gunFeatureState.fovSquare then
        gunFeatureState.fovSquare = Drawing.new("Square")
        gunFeatureState.fovSquare.Filled = false
        gunFeatureState.fovSquare.Thickness = 1.6
        gunFeatureState.fovSquare.Color = Color3.new(1, 1, 1)
        gunFeatureState.fovSquare.Visible = false
    end

    if not gunFeatureState.snapline then
        gunFeatureState.snapline = Drawing.new("Line")
        gunFeatureState.snapline.Thickness = 1.5
        gunFeatureState.snapline.Color = Color3.new(1, 1, 1)
        gunFeatureState.snapline.Visible = false
    end

    if not gunFeatureState.lassoSnapline then
        gunFeatureState.lassoSnapline = Drawing.new("Line")
        gunFeatureState.lassoSnapline.Thickness = 1.5
        gunFeatureState.lassoSnapline.Color = Color3.new(1, 1, 1)
        gunFeatureState.lassoSnapline.Visible = false
    end

    if type(gunFeatureState.fovPolygonLines) ~= "table" then
        gunFeatureState.fovPolygonLines = {}
    end
    while #gunFeatureState.fovPolygonLines < 6 do
        local polygonLine = Drawing.new("Line")
        polygonLine.Thickness = 1.6
        polygonLine.Color = Color3.new(1, 1, 1)
        polygonLine.Visible = false
        table.insert(gunFeatureState.fovPolygonLines, polygonLine)
    end

    return true
end

function getGunFovPolygonSides(shapeName)
    local shape = tostring(shapeName or "Circle")
    if shape == "Triangle" then
        return 3
    end
    if shape == "Hexagon" then
        return 6
    end
    return 0
end

function updateGunAimVisuals()
    if not hasGunAimVisualsEnabled() then
        hideGunAimDrawings()
        gunFeatureState.currentTargetInfo = nil
        gunFeatureState.currentLassoTargetInfo = nil
        return
    end
    if not ensureGunAimDrawings() then
        return
    end

    local cursor = getGunAimCursorPosition()
    local radius = math.clamp(tonumber(S.gunFovRadius) or 200, 10, 2000)
    local shapeName = tostring(S.gunFovShape or "Circle")
    local targetInfo = S.silentAimEnabled and getSilentAimTargetInfo() or nil
    local lassoTargetInfo = (S.lassoSilentAimEnabled and S.lassoSnaplineEnabled) and getLassoSilentAimTargetInfo() or nil
    gunFeatureState.currentTargetInfo = targetInfo
    gunFeatureState.currentLassoTargetInfo = lassoTargetInfo

    hideGunAimDrawings()

    if S.gunFovEnabled then
        if shapeName == "Square" and gunFeatureState.fovSquare then
            gunFeatureState.fovSquare.Position = Vector2.new(cursor.X - radius, cursor.Y - radius)
            gunFeatureState.fovSquare.Size = Vector2.new(radius * 2, radius * 2)
            gunFeatureState.fovSquare.Color = Color3.new(1, 1, 1)
            gunFeatureState.fovSquare.Visible = true
        else
            local polygonSides = getGunFovPolygonSides(shapeName)
            if polygonSides > 0 then
                local startAngle = -math.pi * 0.5
                local points = {}
                for index = 1, polygonSides do
                    local angle = startAngle + ((index - 1) * (math.pi * 2 / polygonSides))
                    points[index] = Vector2.new(
                        cursor.X + math.cos(angle) * radius,
                        cursor.Y + math.sin(angle) * radius
                    )
                end
                for index, line in ipairs(gunFeatureState.fovPolygonLines) do
                    if line and index <= polygonSides then
                        local nextIndex = (index % polygonSides) + 1
                        line.From = points[index]
                        line.To = points[nextIndex]
                        line.Color = Color3.new(1, 1, 1)
                        line.Visible = true
                    elseif line then
                        line.Visible = false
                    end
                end
            elseif gunFeatureState.fovCircle then
                gunFeatureState.fovCircle.Position = cursor
                gunFeatureState.fovCircle.Radius = radius
                gunFeatureState.fovCircle.Color = Color3.new(1, 1, 1)
                gunFeatureState.fovCircle.NumSides = 64
                gunFeatureState.fovCircle.Visible = true
            end
        end
    end

    if S.gunSnaplineEnabled and targetInfo and gunFeatureState.snapline then
        gunFeatureState.snapline.From = cursor
        gunFeatureState.snapline.To = targetInfo.screenPosition
        gunFeatureState.snapline.Color = Color3.new(1, 1, 1)
        gunFeatureState.snapline.Visible = true
    end

    if S.lassoSilentAimEnabled and S.lassoSnaplineEnabled and lassoTargetInfo and gunFeatureState.lassoSnapline then
        gunFeatureState.lassoSnapline.From = cursor
        gunFeatureState.lassoSnapline.To = lassoTargetInfo.screenPosition
        gunFeatureState.lassoSnapline.Color = Color3.new(1, 1, 1)
        gunFeatureState.lassoSnapline.Visible = true
    end
end

function ensureGunAimRenderLoop()
    if not hasGunAimVisualsEnabled() then
        clearGunAimDrawings()
        return
    end
    if gunFeatureState.renderConnection then
        return
    end

    gunFeatureState.renderConnection = _RunService.RenderStepped:Connect(function()
        if destroyed or not isSessionActive() or not hasGunAimVisualsEnabled() then
            clearGunAimDrawings()
            return
        end
        updateGunAimVisuals()
    end)
end

