local _glitchSymbols = {"@", "!", "9", "6", "=", "<", "?", "$", "&"}
local _activeDecode = 0

function _UTILS._animateNotifText(label, targetText)
    if not label then
        return
    end
    local currentStr = ""
    for i = 1, #targetText do
        if destroyed or not isSessionActive() or not label.Parent then
            return
        end
        local char = targetText:sub(i, i)
        if char == " " then
            currentStr = currentStr .. char
            label.Text = currentStr
        else
            label.Text = currentStr .. _glitchSymbols[math.random(1, #_glitchSymbols)]
            task.wait(0.04)
            currentStr = currentStr .. char
            label.Text = currentStr
        end
    end
end

function _UTILS._animateTabTitle(label, targetText)
    if not label then
        return
    end
    _activeDecode = _activeDecode + 1
    local currentDecode = _activeDecode
    local currentStr = ""
    for i = 1, #targetText do
        if destroyed or not isSessionActive() or not label.Parent then
            return
        end
        if currentDecode ~= _activeDecode then
            label.Text = targetText
            return
        end
        local char = targetText:sub(i, i)
        if char == " " then
            currentStr = currentStr .. char
            label.Text = currentStr
        else
            label.Text = currentStr .. _glitchSymbols[math.random(1, #_glitchSymbols)]
            task.wait(0.08)
            if currentDecode ~= _activeDecode then
                label.Text = targetText
                return
            end
            currentStr = currentStr .. char
            label.Text = currentStr
        end
    end
end

function _UTILS._createParticleBurst(parent)
    if destroyed or not parent or not parent.Parent then
        return
    end
    local mouse = localPlayer and localPlayer:GetMouse()
    if not mouse then
        return
    end
    local absPos = parent.AbsolutePosition
    local absSize = parent.AbsoluteSize
    local relativeX = mouse.X - absPos.X
    local relativeY = mouse.Y - absPos.Y
    if relativeX < 0 or relativeY < 0 or relativeX > absSize.X or relativeY > absSize.Y then
        relativeX = absSize.X / 2
        relativeY = absSize.Y / 2
    end
    for _ = 1, 10 do
        local square = Instance.new("Frame")
        square.Size = UDim2.new(0, 6, 0, 6)
        square.Position = UDim2.new(0, relativeX, 0, relativeY)
        square.AnchorPoint = Vector2.new(0.5, 0.5)
        square.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        square.BackgroundTransparency = 0
        square.BorderSizePixel = 0
        square.ZIndex = (parent.ZIndex or 1) + 4
        square.Parent = parent
        Instance.new("UICorner", square).CornerRadius = UDim.new(1, 0)
        local direction = Vector2.new(math.random(-10, 10), math.random(-10, 10))
        if direction.Magnitude <= 0 then
            direction = Vector2.new(1, 0)
        else
            direction = direction.Unit
        end
        local distance = math.random(30, 60)
        local duration = 0.4
        square:TweenPosition(
            UDim2.new(0, relativeX + direction.X * distance, 0, relativeY + direction.Y * distance),
            Enum.EasingDirection.Out.Name,
            Enum.EasingStyle.Quad.Name,
            duration,
            true
        )
        _TweenService:Create(square, TweenInfo.new(duration), {BackgroundTransparency = 1}):Play()
        game:GetService("Debris"):AddItem(square, duration + 0.1)
    end
end

local function keyNameToCode(name)
    local normalized = type(name) == "string" and name:lower() or ""
    if type(name) ~= "string" or normalized == "" or normalized == "none" then
        return nil
    end
    local ok, result = pcall(function()
        return Enum.KeyCode[name]
    end)
    if ok then
        return result
    end
    return nil
end

local function getStorageId()
    local hwid = ""
    pcall(function()
        if gethwid then
