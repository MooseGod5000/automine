function shouldBlockPlayerStateRemote(remoteName)
	if playerState.infiniteStaminaEnabled and remoteName == "LowerStamina" then
		return true
	end

	if playerState.noFallDamageEnabled and (remoteName == "DamageSelf" or remoteName == "TrainSmack") then
		return true
	end

	return playerState.safeTeleportEnabled and playerState.safeTeleportBlockedRemotes[remoteName] == true
end

function restorePlayerStateNetworkHook()
	if playerState.hookedNetwork
		and playerState.originalNetworkFireServer
		and playerState.hookedNetwork.FireServer == playerState.networkFireServerWrapper then
		playerState.hookedNetwork.FireServer = playerState.originalNetworkFireServer
	end

	playerState.hookedNetwork = nil
	playerState.originalNetworkFireServer = nil
	playerState.networkFireServerWrapper = nil
end

function ensurePlayerStateNetworkHook()
	if not hasPlayerStateNetworkHookEnabled() then
		restorePlayerStateNetworkHook()
		return
	end

	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	if not network or type(network.FireServer) ~= "function" then
		return
	end

	if network ~= playerState.hookedNetwork or network.FireServer ~= playerState.networkFireServerWrapper then
		restorePlayerStateNetworkHook()
		playerState.hookedNetwork = network
		playerState.originalNetworkFireServer = network.FireServer
		playerState.networkFireServerWrapper = function(self, remoteName, ...)
			if shouldBlockPlayerStateRemote(remoteName) then
				return nil
			end
            local packedArgs = table.pack(...)
            if shouldSuppressTrackedFastProjectileRemote(remoteName, packedArgs) then
                return nil
            end
            packedArgs = processGunProjectileRemote(remoteName, packedArgs) or packedArgs
			return playerState.originalNetworkFireServer(self, remoteName, table.unpack(packedArgs, 1, packedArgs.n))
		end
		network.FireServer = playerState.networkFireServerWrapper
	end
end

function restoreInfiniteStaminaHooks()
	if type(playerState.stateHooks) == "table" then
		for stateTable, hook in pairs(playerState.stateHooks) do
			if isTable(stateTable) and type(hook) == "table" then
				pcall(function()
					if hook.installedMetatable and getmetatable(stateTable) == hook.installedMetatable then
						setmetatable(stateTable, hook.originalMetatable)
					end
				end)
				pcall(function()
					rawset(stateTable, "Stamina", hook.shadowValue)
				end)
			end
		end
	end

	playerState.stateHooks = {}
end

