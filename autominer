	end

	ok, err = pcall(function()
		TeleportService:TeleportToPlaceInstance(game.PlaceId, tostring(serverId))
	end)
	if ok then
		return true
	end

	return false, err
end

function tryPathServerHop(reasonText, resumeSlotIndex, forceHop)
	if (not forceHop and not serverHopEnabled) or serverHopInProgress then
		return false
	end

	local normalizedResumeSlotIndex = normalizePathSlotIndex(resumeSlotIndex)
	serverHopInProgress = true
	setStatus("Finding a smaller server...", Color3.fromRGB(120, 190, 255))
	setServerHopStatus(tostring(reasonText or "Finding a smaller public server..."), Color3.fromRGB(120, 190, 255))
	if normalizedResumeSlotIndex then
		setPathSequenceStartSlotIndex(normalizedResumeSlotIndex)
		setPathResumePlaybackPending(true, true)
	else
		setPathResumePlaybackPending(false, true)
	end
	if type(refreshServerHopDisplay) == "function" then
		refreshServerHopDisplay()
	end

	local queuedOk, queueErr = queueCurrentScriptForServerHop()
	if not queuedOk then
		pushDebug("server hop queue: " .. tostring(queueErr))
		pushDebug("server hop will rely on auto-execute or rerunning the script")
	end

	local targetServer, findErr = findSmallServerHopTarget()
	if not targetServer then
		serverHopInProgress = false
		if normalizedResumeSlotIndex then
			setPathResumePlaybackPending(false, true)
		end
		setServerHopStatus("Hop failed: " .. tostring(findErr), Color3.fromRGB(255, 190, 120))
		pushDebug("server hop failed: " .. tostring(findErr))
		if type(refreshServerHopDisplay) == "function" then
			refreshServerHopDisplay()
		end
		return false
	end

	local playersNow = tonumber(targetServer.playing) or 0
	local maxPlayers = tonumber(targetServer.maxPlayers) or 0
	pushDebug(string.format("server hop target: %s (%d/%d)", tostring(targetServer.id), playersNow, maxPlayers))
	setStatus(string.format("Server hopping (%d/%d)", playersNow, maxPlayers), Color3.fromRGB(120, 190, 255))
	setServerHopStatus(string.format("Joining a %d / %d server...", playersNow, maxPlayers), Color3.fromRGB(120, 190, 255))

	local teleported, teleportErr = teleportToServerInstance(targetServer.id)
	if not teleported then
		serverHopInProgress = false
		if normalizedResumeSlotIndex then
			setPathResumePlaybackPending(false, true)
		end
		setServerHopStatus("Hop failed: " .. tostring(teleportErr), Color3.fromRGB(255, 190, 120))
		pushDebug("server hop teleport failed: " .. tostring(teleportErr))
		if type(refreshServerHopDisplay) == "function" then
			refreshServerHopDisplay()
		end
		return false
	end

	if type(refreshServerHopDisplay) == "function" then
		refreshServerHopDisplay()
	end

	return true
end

function remoteMatchesKeywords(remote, keywords)
	local name = safeLower(remote.Name)
	for _, keyword in ipairs(keywords) do
		if string.find(name, safeLower(keyword), 1, true) ~= nil then
			return true
		end
	end
	return false
end

function findRemote(roots, keywords)
	for _, root in ipairs(roots) do
		if root then
			for _, descendant in ipairs(root:GetDescendants()) do
				if (
					descendant:IsA("RemoteEvent")
					or descendant:IsA("RemoteFunction")
					or descendant:IsA("BindableEvent")
					or descendant:IsA("BindableFunction")
				) and remoteMatchesKeywords(descendant, keywords) then
					return descendant
				end
			end
		end
	end

	return nil
end

function findRemotes(roots, keywords, maxCount)
	local results = {}
	local seen = {}

	for _, root in ipairs(roots) do
		if root then
			for _, descendant in ipairs(root:GetDescendants()) do
				local isRemote = descendant:IsA("RemoteEvent")
					or descendant:IsA("RemoteFunction")
					or descendant:IsA("BindableEvent")
					or descendant:IsA("BindableFunction")

				if isRemote and not seen[descendant] and remoteMatchesKeywords(descendant, keywords) then
					seen[descendant] = true
					table.insert(results, descendant)
					if maxCount and #results >= maxCount then
						return results
					end
				end
			end
		end
	end

	return results
end

