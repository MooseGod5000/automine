        if playerState.originalSwimCanSwitchToItem and owner.CanSwitchToItem == playerState.swimCanSwitchWrapper then
            owner.CanSwitchToItem = playerState.originalSwimCanSwitchToItem
        end
        if playerState.originalSwimUpdate and owner.Update == playerState.swimUpdateWrapper then
            owner.Update = playerState.originalSwimUpdate
        end
    end

    playerState.hookedSwimOwner = nil
    playerState.originalSwimCanSwitchToItem = nil
    playerState.swimCanSwitchWrapper = nil
    playerState.originalSwimUpdate = nil
    playerState.swimUpdateWrapper = nil
end

function ensureEquipWhileSwimmingHooks()
    if not playerState.equipWhileSwimmingEnabled then
        return
    end

    local owner = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
    if not isTable(owner) then
        return
    end
    if owner ~= playerState.hookedSwimOwner then
        restoreEquipWhileSwimmingHooks()
        playerState.hookedSwimOwner = owner
    end

    local canSwitch = rawget(owner, "CanSwitchToItem") or owner.CanSwitchToItem
    if type(canSwitch) == "function" and canSwitch ~= playerState.swimCanSwitchWrapper then
        playerState.originalSwimCanSwitchToItem = canSwitch
        playerState.swimCanSwitchWrapper = function(self, ...)
            if playerState.equipWhileSwimmingEnabled and type(self) == "table" then
                self.Swimming = false
            end
            return playerState.originalSwimCanSwitchToItem(self, ...)
        end
        owner.CanSwitchToItem = playerState.swimCanSwitchWrapper
    end

    local updateFn = rawget(owner, "Update") or owner.Update
    if type(updateFn) == "function" and updateFn ~= playerState.swimUpdateWrapper then
        playerState.originalSwimUpdate = updateFn
        playerState.swimUpdateWrapper = function(self, ...)
            if playerState.equipWhileSwimmingEnabled and type(self) == "table" then
                self.Swimming = false
            end
            return playerState.originalSwimUpdate(self, ...)
        end
        owner.Update = playerState.swimUpdateWrapper
    end
end

