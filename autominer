function getCharacterGroundPoint(character, rootPart)
	local activeRoot = rootPart or getRootPart(character)
	if not activeRoot then
		return nil
	end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {
		getRecordedPathFolder(),
		getVisualizerFolder(),
		findPathPlayerAvoiderVisualizerFolder(),
	}
	if character then
		table.insert(raycastParams.FilterDescendantsInstances, character)
	end

	local scanOrigin = activeRoot.Position + Vector3.new(0, 0.75, 0)
	local ray = workspace:Raycast(scanOrigin, Vector3.new(0, -12, 0), raycastParams)
	if ray and ray.Position and ray.Normal and ray.Normal.Y >= 0.25 then
		return ray.Position
	end

	local groundAligner = rawget(_G, "getGroundAlignedPathPosition")
	if type(groundAligner) == "function" then
		return groundAligner(activeRoot.Position, character)
	end

	return nil
end

function getCharacterGroundClearance(character, rootPart)
	local activeRoot = rootPart or getRootPart(character)
	if not activeRoot then
		return math.max(TWEEN_GROUND_CLEARANCE - 0.08, 2.4)
	end

	local groundPoint = getCharacterGroundPoint(character, activeRoot)
	if groundPoint then
		local clearance = activeRoot.Position.Y - groundPoint.Y
		if clearance == clearance and clearance > 0.25 then
			return math.clamp(clearance, 1.6, 4.5)
		end
	end

	return math.max(TWEEN_GROUND_CLEARANCE - 0.08, 2.4)
end

function getPathFollowGroundClearance(character, rootPart)
	local currentClearance = getCharacterGroundClearance(character, rootPart)
	return math.clamp(currentClearance, 1.85, math.max(2.45, TWEEN_GROUND_CLEARANCE - 0.7))
end

function getPathFollowSurfaceTarget(character, rootPart, nextXZ, flatDirection, stepDistance, fallbackPosition)
	if not nextXZ then
		return fallbackPosition
	end

	local activeRoot = rootPart or getRootPart(character)
	local clearanceOffset = getPathFollowGroundClearance(character, activeRoot)
	local probePosition = Vector3.new(nextXZ.X, activeRoot and activeRoot.Position.Y or nextXZ.Y, nextXZ.Z)
	local stepGround = getGroundAlignedPathPosition(probePosition, character)
	local fallbackY = typeof(fallbackPosition) == "Vector3" and fallbackPosition.Y or probePosition.Y
	if not stepGround then
		stepGround = Vector3.new(nextXZ.X, fallbackY, nextXZ.Z)
	end

	local desiredGroundY = stepGround.Y
	if flatDirection and flatDirection.Magnitude > 0.001 then
		local lookAheadDistance = math.min(math.max((tonumber(stepDistance) or 0.5) * 1.15, 1.15), 3.6)
		local lookAheadProbe = probePosition + (flatDirection.Unit * lookAheadDistance)
		local aheadGround = getGroundAlignedPathPosition(lookAheadProbe, character)
		if aheadGround and aheadGround.Y > desiredGroundY then
			desiredGroundY = math.max(desiredGroundY, aheadGround.Y - 0.08)
		end
	end

	local desiredStepY = desiredGroundY + clearanceOffset
	if activeRoot then
		local horizontalStep = (
			Vector3.new(nextXZ.X, 0, nextXZ.Z) - Vector3.new(activeRoot.Position.X, 0, activeRoot.Position.Z)
		).Magnitude
		local verticalDelta = desiredStepY - activeRoot.Position.Y
		local verticalStep = math.max(0.3, math.min((horizontalStep * 1.15) + 0.45, 5.25))
		desiredStepY = activeRoot.Position.Y + math.clamp(verticalDelta, -verticalStep, verticalStep)
	end

	return Vector3.new(nextXZ.X, desiredStepY, nextXZ.Z)
end

function getSafeTweenTargetPosition(character, targetPosition)
	local rootPart = getRootPart(character)
	if not rootPart or not targetPosition then
		return targetPosition
	end

	local groundAligner = rawget(_G, "getGroundAlignedPathPosition")
	if type(groundAligner) == "function" then
		local grounded = groundAligner(targetPosition, character)
		if grounded then
			local clearanceOffset = getCharacterGroundClearance(character, rootPart)
			return Vector3.new(targetPosition.X, grounded.Y + clearanceOffset, targetPosition.Z)
		end
	end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {
		character,
		getRecordedPathFolder(),
		getVisualizerFolder(),
		findPathPlayerAvoiderVisualizerFolder(),
	}

	local scanOrigin = Vector3.new(targetPosition.X, targetPosition.Y + TWEEN_GROUND_SCAN_HEIGHT, targetPosition.Z)
	local ray = workspace:Raycast(scanOrigin, Vector3.new(0, -(TWEEN_GROUND_SCAN_HEIGHT * 2), 0), raycastParams)
	if ray and ray.Position and ray.Normal and ray.Normal.Y >= 0.25 then
		local minY = ray.Position.Y + getCharacterGroundClearance(character, rootPart)
		return Vector3.new(targetPosition.X, math.max(targetPosition.Y, minY), targetPosition.Z)
	end

	return targetPosition
end

local function projectPointOntoSegment(point, segmentStart, segmentFinish)
	local segmentDelta = segmentFinish - segmentStart
	local segmentLengthSquared = segmentDelta:Dot(segmentDelta)
	if segmentLengthSquared <= 1e-4 then
		return segmentStart, 0, (point - segmentStart).Magnitude, 0
	end

	local alpha = math.clamp((point - segmentStart):Dot(segmentDelta) / segmentLengthSquared, 0, 1)
	local projectedPoint = segmentStart + (segmentDelta * alpha)
	return projectedPoint, alpha, (point - projectedPoint).Magnitude, math.sqrt(segmentLengthSquared)
end

local function buildPathPlayerAvoiderSegments(rootPosition, currentTargetPosition)
	local segments = {}
	if typeof(rootPosition) ~= "Vector3" then
		return segments
	end

	local lookAheadDistance = math.max(1, getPathPlayerAvoiderDistance())
	local remainingDistance = lookAheadDistance
	local traveledDistance = 0
	local currentPath = pathState.currentPath
	local playbackNodeIndex = math.max(1, tonumber(pathState.playbackNodeIndex) or 1)
	local segmentStart = rootPosition

	local function appendSegment(segmentEnd, nodeIndex)
		if typeof(segmentEnd) ~= "Vector3" or remainingDistance <= 0 then
			return false
		end

		local segmentDelta = segmentEnd - segmentStart
		local segmentLength = segmentDelta.Magnitude
		if segmentLength <= 0.05 then
			segmentStart = segmentEnd
			return false
		end

		local segmentDistance = math.min(segmentLength, remainingDistance)
		local cappedFinish = segmentLength > segmentDistance
			and (segmentStart + (segmentDelta.Unit * segmentDistance))
			or segmentEnd

		table.insert(segments, {
			start = segmentStart,
			finish = cappedFinish,
			length = segmentDistance,
			nodeIndex = nodeIndex,
			distanceStart = traveledDistance,
		})

		traveledDistance += segmentDistance
		remainingDistance -= segmentDistance
		segmentStart = cappedFinish
		return remainingDistance <= 0
	end

	if typeof(currentTargetPosition) == "Vector3" and appendSegment(currentTargetPosition, playbackNodeIndex) then
		return segments
	end

	if not currentPath or type(currentPath.nodes) ~= "table" then
		return segments
	end

	for nodeIndex = playbackNodeIndex + 1, #currentPath.nodes do
		local nodePosition = getPathNodePosition(currentPath.nodes[nodeIndex])
		if nodePosition and appendSegment(nodePosition, nodeIndex) then
			break
		end
	end

	return segments
end

local function buildPathPlayerAvoiderRetreatSegments(rootPosition)
	local segments = {}
	if typeof(rootPosition) ~= "Vector3" then
		return segments
	end

	local currentPath = pathState.currentPath
	if not currentPath or type(currentPath.nodes) ~= "table" then
		return segments
	end

	local remainingDistance = math.max(PATH_PLAYER_AVOIDER_BACKUP_STEP_DISTANCE, 1)
	local traveledDistance = 0
	local playbackNodeIndex = math.max(1, tonumber(pathState.playbackNodeIndex) or 1)
	local segmentStart = rootPosition

	local function appendSegment(segmentEnd, nodeIndex)
		if typeof(segmentEnd) ~= "Vector3" or remainingDistance <= 0 then
			return false
		end

		local segmentDelta = segmentEnd - segmentStart
		local segmentLength = segmentDelta.Magnitude
		if segmentLength <= 0.05 then
			segmentStart = segmentEnd
			return false
		end

		local segmentDistance = math.min(segmentLength, remainingDistance)
		local cappedFinish = segmentLength > segmentDistance
			and (segmentStart + (segmentDelta.Unit * segmentDistance))
			or segmentEnd

		table.insert(segments, {
			start = segmentStart,
			finish = cappedFinish,
			length = segmentDistance,
			nodeIndex = nodeIndex,
			distanceStart = traveledDistance,
		})

		traveledDistance += segmentDistance
		remainingDistance -= segmentDistance
		segmentStart = cappedFinish
		return remainingDistance <= 0
	end

	for nodeIndex = playbackNodeIndex - 1, 1, -1 do
		local nodePosition = getPathNodePosition(currentPath.nodes[nodeIndex])
		if nodePosition and appendSegment(nodePosition, nodeIndex) then
			break
		end
	end

	return segments
end

local function samplePathPlayerAvoiderPoint(segments, sampleDistance)
	if type(segments) ~= "table" or #segments == 0 then
		return nil
	end

	local remaining = math.max(0, tonumber(sampleDistance) or 0)
	for _, segment in ipairs(segments) do
		local segmentLength = tonumber(segment.length) or 0
		if segmentLength > 0.05 then
			if remaining <= segmentLength then
				local direction = segment.finish - segment.start
				if direction.Magnitude <= 0.05 then
					return segment.finish
				end
				return segment.start + (direction.Unit * remaining)
			end
			remaining -= segmentLength
		end
	end

	return segments[#segments].finish
end

local function isPathPlayerAvoiderLineClear(originPosition, targetPosition, localCharacter, targetCharacter)
	if typeof(originPosition) ~= "Vector3" or typeof(targetPosition) ~= "Vector3" then
		return false
	end

	local direction = targetPosition - originPosition
	if direction.Magnitude <= 0.05 then
		return true
	end

	local ignoreInstances = {
		localCharacter,
		targetCharacter,
		getRecordedPathFolder(),
		getVisualizerFolder(),
		findPathPlayerAvoiderVisualizerFolder(),
	}
	local ignoreFolder = workspace:FindFirstChild("Ignore")
	if ignoreFolder then
		table.insert(ignoreInstances, ignoreFolder)
	end

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = ignoreInstances

	local result = workspace:Raycast(originPosition, direction, raycastParams)
	if not result then
		return true
	end

	return targetCharacter and result.Instance and result.Instance:IsDescendantOf(targetCharacter)
end

local function isPathPlayerAvoiderCandidateReachable(localCharacter, candidateCharacter, candidateRootPart, projectedPoint)
	if not (localCharacter and candidateCharacter and candidateRootPart and typeof(projectedPoint) == "Vector3") then
		return false
	end

	local pathFloor = getGroundAlignedPathPosition(projectedPoint, localCharacter) or projectedPoint
	local playerFloor = getGroundAlignedPathPosition(candidateRootPart.Position, candidateCharacter) or candidateRootPart.Position
	if math.abs(playerFloor.Y - pathFloor.Y) > PATH_PLAYER_AVOIDER_LAYER_TOLERANCE then
		return false
	end

	local rayOrigin = pathFloor + Vector3.new(0, 1.8, 0)
	local rayTarget = candidateRootPart.Position + Vector3.new(0, 1.4, 0)
	return isPathPlayerAvoiderLineClear(rayOrigin, rayTarget, localCharacter, candidateCharacter)
end

local function findPathPlayerAvoiderTarget(character, currentTargetPosition)
	if not (isPathPlayerAvoiderEnabled() and pathState.playbackActive and pathState.currentPath) then
		return nil
	end

	local rootPart = getRootPart(character)
	if not rootPart then
		return nil
	end

	local segments = buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition)
	local flatForwardDirection = nil
	if typeof(currentTargetPosition) == "Vector3" then
		flatForwardDirection = Vector3.new(
			currentTargetPosition.X - rootPart.Position.X,
			0,
			currentTargetPosition.Z - rootPart.Position.Z
		)
	end
	if (not flatForwardDirection or flatForwardDirection.Magnitude <= 0.001) and #segments > 0 then
		local firstSegment = segments[1]
		flatForwardDirection = Vector3.new(
			firstSegment.finish.X - firstSegment.start.X,
			0,
			firstSegment.finish.Z - firstSegment.start.Z
		)
	end
	if #segments == 0 then
		return nil
	end

	local bestEmergencyCandidate = nil
	local bestCandidate = nil
	for _, player in ipairs(_Players:GetPlayers()) do
		if player ~= localPlayer then
			local candidateCharacter = getWorldCharacterForPlayer(player)
			local candidateRootPart = getTwwModelRoot(candidateCharacter) or getRootPart(candidateCharacter)
			if candidateCharacter and candidateRootPart and isCharacterAlive(candidateCharacter) then
				local localDistance = (candidateRootPart.Position - rootPart.Position).Magnitude
				if localDistance <= PATH_PLAYER_AVOIDER_EMERGENCY_DISTANCE
					and isPathPlayerAvoiderCandidateReachable(character, candidateCharacter, candidateRootPart, rootPart.Position) then
					local flatToPlayer = Vector3.new(
						candidateRootPart.Position.X - rootPart.Position.X,
						0,
						candidateRootPart.Position.Z - rootPart.Position.Z
					)
					local relativeDot = 0
					if flatForwardDirection and flatForwardDirection.Magnitude > 0.001 and flatToPlayer.Magnitude > 0.001 then
						relativeDot = flatForwardDirection.Unit:Dot(flatToPlayer.Unit)
					end
					local emergencyAction = relativeDot < -0.1 and "advance" or "backup"
					if not bestEmergencyCandidate or localDistance < bestEmergencyCandidate.localDistance then
						bestEmergencyCandidate = {
							player = player,
							character = candidateCharacter,
							rootPart = candidateRootPart,
							projectedPoint = rootPart.Position,
							alongDistance = 0,
							lateralDistance = 0,
							localDistance = localDistance,
							action = emergencyAction,
						}
					end
				end

				for _, segment in ipairs(segments) do
					local projectedPoint, alpha, lateralDistance, segmentLength = projectPointOntoSegment(
						candidateRootPart.Position,
						segment.start,
						segment.finish
					)
					if lateralDistance <= PATH_PLAYER_AVOIDER_CORRIDOR_RADIUS then
						local segmentDirection = segment.finish - segment.start
						if segmentLength > 0.05 and not (alpha <= 0.001 and (candidateRootPart.Position - segment.start):Dot(segmentDirection.Unit) < -0.75) then
							local alongDistance = (segment.distanceStart or 0) + (segment.length * alpha)
							if alongDistance <= getPathPlayerAvoiderDistance()
								and isPathPlayerAvoiderCandidateReachable(character, candidateCharacter, candidateRootPart, projectedPoint) then
								if not bestCandidate
									or alongDistance < bestCandidate.alongDistance
									or (math.abs(alongDistance - bestCandidate.alongDistance) <= 0.1 and lateralDistance < bestCandidate.lateralDistance) then
									bestCandidate = {
										player = player,
										character = candidateCharacter,
										rootPart = candidateRootPart,
										projectedPoint = projectedPoint,
										alongDistance = alongDistance,
										lateralDistance = lateralDistance,
										localDistance = localDistance,
										action = localDistance <= PATH_PLAYER_AVOIDER_BACKUP_TRIGGER_DISTANCE and "backup" or "wait",
									}
								end
							end
						end
					end
				end
			end
		end
	end

	if bestEmergencyCandidate then
		return bestEmergencyCandidate
	end

	return bestCandidate
end

function getPathPlayerAvoiderTarget(character, currentTargetPosition)
	if not (type(pathState) == "table" and isPathPlayerAvoiderEnabled() and pathState.playbackActive) then
		clearPathPlayerAvoiderDetection()
		return nil
	end

	local rootPart = getRootPart(character)
	if rootPart and type(updatePathPlayerAvoiderCorridorVisualization) == "function" then
		local segments = buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition)
		updatePathPlayerAvoiderCorridorVisualization(rootPart.Position, segments)
	elseif type(clearPathPlayerAvoiderCorridorVisualization) == "function" then
		clearPathPlayerAvoiderCorridorVisualization()
	end

	local now = os.clock()
	local cachedResult = pathState.playerAvoiderLastResult
	if cachedResult and (now - (tonumber(pathState.playerAvoiderLastScanAt) or 0)) < PATH_PLAYER_AVOIDER_SCAN_INTERVAL then
		if cachedResult and rootPart and type(updatePathPlayerAvoiderCorridorVisualization) == "function" then
			local cachedSegments = buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition)
			updatePathPlayerAvoiderCorridorVisualization(rootPart.Position, cachedSegments, cachedResult)
		end
		return cachedResult
	end

	local nextResult = findPathPlayerAvoiderTarget(character, currentTargetPosition)
	pathState.playerAvoiderLastScanAt = now
	pathState.playerAvoiderLastResult = nextResult
	if rootPart and type(updatePathPlayerAvoiderCorridorVisualization) == "function" then
		local liveSegments = buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition)
		updatePathPlayerAvoiderCorridorVisualization(rootPart.Position, liveSegments, nextResult)
	end
	if nextResult then
		updatePathPlayerAvoiderVisual(nextResult.player, nextResult.character, nextResult.rootPart)
	else
		destroyPathPlayerAvoiderVisual()
		pathState.playerAvoiderBlockedPlayerName = nil
	end

	return nextResult
end

local function getPathPlayerAvoiderRetreatTarget(character, rootPart, currentTargetPosition)
	if not rootPart then
		return nil
	end

	local retreatTarget = samplePathPlayerAvoiderPoint(
		buildPathPlayerAvoiderRetreatSegments(rootPart.Position),
		PATH_PLAYER_AVOIDER_BACKUP_STEP_DISTANCE
	)
	if retreatTarget then
		return retreatTarget
	end

	local forwardSegments = buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition)
	for _, segment in ipairs(forwardSegments) do
		local segmentDelta = segment.finish - segment.start
		if segmentDelta.Magnitude > 0.05 then
			local fallbackTarget = rootPart.Position - (segmentDelta.Unit * PATH_PLAYER_AVOIDER_BACKUP_STEP_DISTANCE)
			local groundedTarget = getGroundAlignedPathPosition(fallbackTarget, character)
			return groundedTarget or fallbackTarget
		end
	end

	return nil
end

local function getPathPlayerAvoiderAdvanceTarget(rootPart, currentTargetPosition)
	if not rootPart then
		return nil
	end
	return samplePathPlayerAvoiderPoint(
		buildPathPlayerAvoiderSegments(rootPart.Position, currentTargetPosition),
		PATH_PLAYER_AVOIDER_BACKUP_STEP_DISTANCE
	)
end

local function cancelPathPlayerAvoiderMining(character, pickaxe)
	currentTargetOre = nil
	setInteractKeyHeld(false)
	if pickaxe and pickaxe:IsA("Tool") and pickaxe.Parent == character then
		pcall(function()
			pickaxe:Deactivate()
		end)
		return
	end

	local equippedPickaxe = character and getEquippedPickaxe(character)
	if equippedPickaxe and equippedPickaxe:IsA("Tool") then
		pcall(function()
			equippedPickaxe:Deactivate()
		end)
	end
end

local function movePathPlayerAvoiderTarget(character, humanoid, targetPosition, activeToken)
	if not (character and typeof(targetPosition) == "Vector3") then
		return false
	end

	pathState.playerAvoiderInternalMove = true
	local ok, moved = pcall(function()
		if movementMode == "legit" then
			return moveTowardsPosition(
				character,
				humanoid or getHumanoid(character),
				targetPosition,
				activeToken,
				getDirectPathTravelTimeout(character, targetPosition, 0.28)
			)
		end
		if movementMode == "cframe" then
			return cframeCharacterTowards(
				character,
				targetPosition,
				activeToken,
				getDirectPathTravelTimeout(character, targetPosition, 0.45),
				math.max(0.55, WAYPOINT_REACH_DISTANCE * 0.18),
				{
					flatPathFollow = true,
					useUndergroundOffset = false,
				}
			)
		end
		return moveTowardsRecordedPathNode(
			character,
			humanoid or getHumanoid(character),
			targetPosition,
			activeToken
		)
	end)
	pathState.playerAvoiderInternalMove = false
	if not ok then
		pushDebug(tostring(moved))
		return false
	end
	return moved == true
end

function processPathPlayerAvoidance(character, currentTargetPosition, activeToken, forwardDirection, humanoid, pickaxe)
	if not (character and isPathPlayerAvoiderEnabled() and pathState.playbackActive) then
		clearPathPlayerAvoiderDetection()
		return false
	end
	if pathState.playerAvoiderInternalMove == true then
		return false
	end
	if activeToken and activeToken ~= autoMineToken then
		return false
	end

	local rootPart = getRootPart(character)
	if not rootPart then
		clearPathPlayerAvoiderDetection()
		return false
	end

	local blocker = getPathPlayerAvoiderTarget(character, currentTargetPosition)
	if not blocker then
		return false
	end

	local playerName = blocker.player and blocker.player.Name or "Player"
	cancelPathPlayerAvoiderMining(character, pickaxe)
	clearMovementKeys()
	cancelActiveMoveTween()
	setInteractKeyHeld(false)
	if movementMode ~= "cframe" or blocker.action == "wait" then
		endExperimentalCFrameTravel(character)
	end

	if blocker.action == "backup" then
		local retreatDirection = typeof(forwardDirection) == "Vector3" and (-Vector3.new(forwardDirection.X, 0, forwardDirection.Z)) or Vector3.zero
		local retreatTarget = getPathPlayerAvoiderRetreatTarget(character, rootPart, currentTargetPosition)
		setStatus("Backing up from " .. playerName, Color3.fromRGB(255, 190, 120))
		setLastMoveCommand(retreatDirection, "PathAvoidBack")
		if retreatTarget then
			movePathPlayerAvoiderTarget(character, humanoid, retreatTarget, activeToken)
		elseif currentTargetPosition then
			local advanceFallback = getPathPlayerAvoiderAdvanceTarget(rootPart, currentTargetPosition)
			if advanceFallback then
				movePathPlayerAvoiderTarget(character, humanoid, advanceFallback, activeToken)
			else
				task.wait(PATH_PLAYER_AVOIDER_WAIT_STEP)
			end
		else
			task.wait(PATH_PLAYER_AVOIDER_WAIT_STEP)
		end
		return true, "backup"
	end

	if blocker.action == "advance" then
		local advanceDirection = typeof(forwardDirection) == "Vector3" and Vector3.new(forwardDirection.X, 0, forwardDirection.Z) or Vector3.zero
		local advanceTarget = getPathPlayerAvoiderAdvanceTarget(rootPart, currentTargetPosition)
		setStatus("Moving ahead from " .. playerName, Color3.fromRGB(255, 190, 120))
		setLastMoveCommand(advanceDirection, "PathAvoidAdvance")
		if advanceTarget then
			movePathPlayerAvoiderTarget(character, humanoid, advanceTarget, activeToken)
		else
			task.wait(PATH_PLAYER_AVOIDER_WAIT_STEP)
		end
		return true, "advance"
	end

	setStatus("Waiting for " .. playerName .. " to move", Color3.fromRGB(255, 190, 120))
	setLastMoveCommand(Vector3.zero, "PathAvoidWait")
	task.wait(PATH_PLAYER_AVOIDER_WAIT_STEP)
	return true, "wait"
end

function findNearestOreInFolders(character, oreFolders)
	local rootPart = getRootPart(character)
	if not rootPart or not isTable(oreFolders) then
		return nil
	end

	local nearestOre = nil
	local nearestDistance = nil

	for _, oreFolder in ipairs(oreFolders) do
		if oreFolder and oreFolder.Parent then
			for _, oreDeposit in ipairs(oreFolder:GetChildren()) do
				local oreRemaining = getOreRemainingValue(oreDeposit)
				local orePosition = getOrePosition(oreDeposit)
				if oreRemaining and oreRemaining.Value > 0 and orePosition then
					local distance = (rootPart.Position - orePosition).Magnitude
					if not nearestDistance or distance < nearestDistance then
						nearestDistance = distance
						nearestOre = oreDeposit
					end
				end
			end
		end
	end

	return nearestOre, nearestDistance
end

function findNearestOre(character)
	if not hasSelectedOres() then
		return nil
	end

	return findNearestOreInFolders(character, getSelectedOreFolders())
end

function findNearestAnyOre(character)
	local oreDeposits = getOreDepositsFolder()
	if not oreDeposits then
		return nil
	end

	local oreFolders = {}
	for _, oreFolder in ipairs(oreDeposits:GetChildren()) do
		if oreFolder and oreFolder:IsA("Folder") then
			table.insert(oreFolders, oreFolder)
		end
	end

	return findNearestOreInFolders(character, oreFolders)
end

function findNearestOreWithinRange(character, preferredOre, maxDistance, allowAnyOreFallback)
	local distanceLimit = maxDistance or MINE_AURA_RANGE
	if not character then
		return nil, nil
	end

	if preferredOre and preferredOre.Parent and isOreNameSelected(getOreGroupName(preferredOre)) and isOreAvailable(preferredOre) then
		local preferredDistance = getDistanceToOre(character, preferredOre)
		if preferredDistance <= distanceLimit then
			return preferredOre, preferredDistance
		end
	end

	local nearestOre, nearestDistance = findNearestOre(character)
	if nearestOre and nearestDistance and nearestDistance <= distanceLimit then
		return nearestOre, nearestDistance
	end

	if allowAnyOreFallback == true then
		local fallbackOre, fallbackDistance = findNearestAnyOre(character)
		if fallbackOre and fallbackDistance and fallbackDistance <= distanceLimit then
			return fallbackOre, fallbackDistance
		end
	end

	return nil, nil
end

function walkHumanoidTowards(character, humanoid, targetPosition, activeToken, timeout)
	local startedAt = os.clock()
	local lastProgressAt = startedAt
	local lastPosition = nil

	while autoMineEnabled and activeToken == autoMineToken and (os.clock() - startedAt) < (timeout or MOVE_TIMEOUT) do
		local rootPart = getRootPart(character)
		if not rootPart then
			break
		end

		local currentPosition = rootPart.Position
		local flatTarget = Vector3.new(targetPosition.X, currentPosition.Y, targetPosition.Z)
		local delta = flatTarget - currentPosition
		local distance = delta.Magnitude

		if distance <= WAYPOINT_REACH_DISTANCE then
			clearMovementKeys()
			setLastMoveCommand(Vector3.zero, "arrived")
			return true
		end

		local direction = delta.Unit
		local basisForward = nil
		local basisRight = nil

		local camera = workspace.CurrentCamera
		if camera then
			local camForward = Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z)
			if camForward.Magnitude > 0.01 then
				basisForward = camForward.Unit
				local camRight = Vector3.new(camera.CFrame.RightVector.X, 0, camera.CFrame.RightVector.Z)
				if camRight.Magnitude > 0.01 then
					basisRight = camRight.Unit
				end
			end
		end

		if not basisForward or not basisRight then
			local rootForward = Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z)
			local rootRight = Vector3.new(rootPart.CFrame.RightVector.X, 0, rootPart.CFrame.RightVector.Z)
			if rootForward.Magnitude > 0.01 and rootRight.Magnitude > 0.01 then
				basisForward = rootForward.Unit
				basisRight = rootRight.Unit
			end
		end

		local forwardDot = basisForward and basisForward:Dot(direction) or 0
		local rightDot = basisRight and basisRight:Dot(direction) or 0

		local pressW = forwardDot > MOVE_DIRECTION_DEADZONE
		local pressS = forwardDot < -MOVE_DIRECTION_DEADZONE
		local pressD = rightDot > MOVE_SIDE_DEADZONE
		local pressA = rightDot < -MOVE_SIDE_DEADZONE

		if not (pressW or pressS or pressA or pressD) then
			pressW = true
		end

		setMovementKey(Enum.KeyCode.W, pressW)
		setMovementKey(Enum.KeyCode.A, pressA)
		setMovementKey(Enum.KeyCode.S, pressS)
		setMovementKey(Enum.KeyCode.D, pressD)
		setMovementKey(Enum.KeyCode.LeftShift, pressW or pressA or pressS or pressD)
		setLastMoveCommand(direction, "InputKeys")

		if lastPosition and (currentPosition - lastPosition).Magnitude > 0.15 then
			lastProgressAt = os.clock()
		end
		lastPosition = currentPosition

		if (os.clock() - lastProgressAt) > WALK_PROGRESS_TIMEOUT then
			pushDebug("walk stalled before reaching waypoint")
			break
		end

		task.wait(0.05)
	end

	clearMovementKeys()
	setLastMoveCommand(Vector3.zero, "stop")
	return false
end

function tweenCharacterTowards(character, targetPosition, activeToken, timeout)
	local rootPart = getRootPart(character)
	if not rootPart then
		return false
	end

	clearMovementKeys()
	cancelActiveMoveTween()

	local safeTarget = getSafeTweenTargetPosition(character, targetPosition)

	local currentPosition = rootPart.Position
	local delta = safeTarget - currentPosition
	local distance = delta.Magnitude
	if distance <= WAYPOINT_REACH_DISTANCE then
		setLastMoveCommand(Vector3.zero, "TweenArrived")
		return true
	end

	local direction = delta.Unit
	setLastMoveCommand(direction, "Tween")

	local moveTime = math.min(timeout or MOVE_TIMEOUT, math.max(0.08, distance / tweenMoveSpeed))
	local flatDirection = Vector3.new(direction.X, 0, direction.Z)
	if flatDirection.Magnitude < 0.001 then
		flatDirection = Vector3.new(0, 0, -1)
	end
	local goalCFrame = CFrame.lookAt(safeTarget, safeTarget + flatDirection)

	local tween = TweenService:Create(
		rootPart,
		TweenInfo.new(moveTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{ CFrame = goalCFrame }
	)
	activeMoveTween = tween

	local completed = false
	local connection = tween.Completed:Connect(function()
		completed = true
	end)

	tween:Play()

	local startedAt = os.clock()
	while autoMineEnabled and activeToken == autoMineToken and not completed and (os.clock() - startedAt) < (moveTime + 0.35) do
		task.wait(0.03)
	end

	connection:Disconnect()
	if activeMoveTween == tween then
		activeMoveTween = nil
	end
	if not completed then
		pcall(function()
			tween:Cancel()
		end)
	end

	return getDistanceToPosition(character, safeTarget) <= (WAYPOINT_REACH_DISTANCE + 1.5)
end

function cframeCharacterTowards(character, targetPosition, activeToken, timeout, arriveDistance, movementOptions)
	local rootPart = getRootPart(character)
	if not rootPart then
		return false
	end

	clearMovementKeys()
	cancelActiveMoveTween()

	local useFlatPathFollow = type(movementOptions) == "table" and movementOptions.flatPathFollow == true
	local useUndergroundOffset = type(movementOptions) == "table" and movementOptions.useUndergroundOffset == true
	local effectiveUndergroundOffset = 0
	local workingTarget = targetPosition
	if useUndergroundOffset and typeof(targetPosition) == "Vector3" then
		workingTarget = targetPosition - Vector3.new(0, effectiveUndergroundOffset, 0)
	end
	local safeTarget = useUndergroundOffset and workingTarget or getSafeTweenTargetPosition(character, workingTarget)
	local function getFlatPathFollowClearance(activeRootPart)
		local liveClearance = getCharacterGroundClearance(character, activeRootPart or rootPart)
		return math.clamp(liveClearance, 1.85, math.max(2.45, TWEEN_GROUND_CLEARANCE - 0.7))
	end
	if useFlatPathFollow then
		if useUndergroundOffset then
			safeTarget = workingTarget
		else
			local groundedTarget = getGroundAlignedPathPosition(workingTarget, character) or workingTarget
			local clearanceOffset = getFlatPathFollowClearance(rootPart)
			safeTarget = Vector3.new(workingTarget.X, groundedTarget.Y + clearanceOffset, workingTarget.Z)
		end
	end
	local wantedDistance = math.max(0.2, tonumber(arriveDistance) or WAYPOINT_REACH_DISTANCE)
	local startedAt = os.clock()
	local lastStepAt = startedAt
	local cframeTravelSpeed = getEffectiveCFrameSpeed()
	local initialVerticalGap = safeTarget and math.abs((safeTarget.Y or rootPart.Position.Y) - rootPart.Position.Y) or 0
	local undergroundVerticalTolerance = math.max(0.85, math.min(4.4, wantedDistance + 0.85 + (initialVerticalGap * 0.04)))
	local travelTimeout = (timeout or MOVE_TIMEOUT) + (useUndergroundOffset and math.min(2.2, initialVerticalGap * 0.05) or 0)
	local undergroundRejectCount = 0
	local undergroundCooldownUntil = 0
	local lastUndergroundGoalY = nil
	local lastUndergroundBaseFlatDistance = nil
	local lastAppliedUndergroundOffset = 0

	while autoMineEnabled and activeToken == autoMineToken do
		rootPart = getRootPart(character)
		if not rootPart then
			return false
		end

		local loopNow = os.clock()
		if useUndergroundOffset then
			local baseFlatDistance = (Vector3.new(targetPosition.X, 0, targetPosition.Z) - Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)).Magnitude
			if lastUndergroundGoalY and math.abs(lastAppliedUndergroundOffset) > 0.15 then
				local verticalCorrection = rootPart.Position.Y > (lastUndergroundGoalY + 1.6)
				local distanceCorrection = lastUndergroundBaseFlatDistance and baseFlatDistance > (lastUndergroundBaseFlatDistance + math.max(1.1, wantedDistance * 0.45))
				if verticalCorrection or distanceCorrection then
					undergroundRejectCount += 1
				else
					undergroundRejectCount = math.max(0, undergroundRejectCount - 1)
				end
				if undergroundRejectCount >= 2 then
					undergroundCooldownUntil = loopNow + 0.35
					undergroundRejectCount = 0
				end
			end

			local offsetScale = 1
			if loopNow < undergroundCooldownUntil then
				offsetScale = 0
			end
			local liveUndergroundOffset = effectiveUndergroundOffset * offsetScale
			workingTarget = targetPosition - Vector3.new(0, liveUndergroundOffset, 0)
			safeTarget = workingTarget
			lastUndergroundBaseFlatDistance = baseFlatDistance
			lastAppliedUndergroundOffset = liveUndergroundOffset
		elseif useFlatPathFollow then
			local groundedTarget = getGroundAlignedPathPosition(workingTarget, character) or workingTarget
			local clearanceOffset = getFlatPathFollowClearance(rootPart)
			safeTarget = Vector3.new(workingTarget.X, groundedTarget.Y + clearanceOffset, workingTarget.Z)
		end

		local delta = safeTarget - rootPart.Position
		local flatDelta = Vector3.new(delta.X, 0, delta.Z)
		local distance = delta.Magnitude
		local flatDistance = flatDelta.Magnitude
		local verticalDistance = math.abs(delta.Y)
		local reachedTarget = false
		if useUndergroundOffset then
			reachedTarget = distance <= wantedDistance or (flatDistance <= wantedDistance and verticalDistance <= undergroundVerticalTolerance)
		elseif useFlatPathFollow then
			local flatPathVerticalTolerance = math.max(0.6, math.min(1.4, wantedDistance + 0.35))
			reachedTarget = distance <= wantedDistance or (flatDistance <= wantedDistance and verticalDistance <= flatPathVerticalTolerance)
		else
			reachedTarget = flatDistance <= wantedDistance or distance <= wantedDistance
		end
		if reachedTarget then
			setLastMoveCommand(Vector3.zero, "CFrameArrived")
			return true
		end

		local direction = distance > 0.001 and delta.Unit or Vector3.zero
		local flatDirection = flatDistance > 0.001 and flatDelta.Unit or Vector3.new(direction.X, 0, direction.Z)
		if flatDirection.Magnitude < 0.001 then
			flatDirection = Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z)
		end
		if flatDirection.Magnitude < 0.001 then
			flatDirection = Vector3.new(0, 0, -1)
		end

		if useFlatPathFollow then
			local avoidanceHandled = processPathPlayerAvoidance(
				character,
				targetPosition,
				activeToken,
				flatDirection,
				getHumanoid(character)
			)
			if avoidanceHandled then
				lastStepAt = os.clock()
				continue
			end
		end

		local stepTime = math.clamp(loopNow - lastStepAt, 1 / 240, 0.08)
		lastStepAt = loopNow
		local stepDistance = math.clamp(cframeTravelSpeed * stepTime, 0.02, 6.5)
		local safeStepTarget = nil
		if useFlatPathFollow then
			local horizontalStep = math.min(stepDistance, flatDistance)
			local nextXZ = rootPart.Position + (flatDirection * horizontalStep)
			if useUndergroundOffset then
				local verticalDelta = safeTarget.Y - rootPart.Position.Y
				local verticalStep = math.max(
					0.85,
					math.min(
						(stepDistance * 1.2) + (math.abs(effectiveUndergroundOffset) * 0.08) + (verticalDistance * 0.12),
						4.5
					)
				)
				local nextY = rootPart.Position.Y + math.clamp(verticalDelta, -verticalStep, verticalStep)
				safeStepTarget = Vector3.new(nextXZ.X, nextY, nextXZ.Z)
			else
				local steppedGroundTarget = getGroundAlignedPathPosition(Vector3.new(nextXZ.X, safeTarget.Y, nextXZ.Z), character)
				local desiredStepY = safeTarget.Y
				if steppedGroundTarget then
					desiredStepY = steppedGroundTarget.Y + getFlatPathFollowClearance(rootPart)
				end
				local verticalDelta = desiredStepY - rootPart.Position.Y
				local verticalStep = math.max(0.3, math.min((horizontalStep * 1.15) + 0.45, 5.25))
				local nextY = rootPart.Position.Y + math.clamp(verticalDelta, -verticalStep, verticalStep)
				safeStepTarget = Vector3.new(nextXZ.X, nextY, nextXZ.Z)
			end
		else
			local stepTarget = rootPart.Position + (direction * math.min(stepDistance, distance))
			safeStepTarget = useUndergroundOffset and stepTarget or getSafeTweenTargetPosition(character, stepTarget)
		end
		setLastMoveCommand(flatDirection, "CFrame")
		if useUndergroundOffset then
			lastUndergroundGoalY = safeStepTarget and safeStepTarget.Y or nil
		end

		local stepStartPosition = rootPart.Position
		local stepStartFlatDistance = flatDistance
		local rotationOnly = rootPart.CFrame - rootPart.Position
		local goalCFrame = CFrame.new(safeStepTarget) * rotationOnly
		local moved = false
		if EXPERIMENTAL_AUTOMINE_CFRAME then
			moved = applyExperimentalCFrameGoal(character, goalCFrame)
		else
			moved = pcall(function()
				rootPart.CFrame = goalCFrame
			end)
		end
		if not moved then
			break
		end

		if (loopNow - startedAt) >= travelTimeout then
			break
		end

		RunService.Heartbeat:Wait()
		local liveRootPart = getRootPart(character)
		if not liveRootPart then
			return false
		end
		local liveFlatPosition = Vector3.new(liveRootPart.Position.X, 0, liveRootPart.Position.Z)
		local safeFlatTarget = Vector3.new(safeTarget.X, 0, safeTarget.Z)
		local stepStartFlatPosition = Vector3.new(stepStartPosition.X, 0, stepStartPosition.Z)
		local expectedStepFlatPosition = Vector3.new(safeStepTarget.X, 0, safeStepTarget.Z)
		local liveFlatDistance = (safeFlatTarget - liveFlatPosition).Magnitude
		local actualStepFlatDelta = liveFlatPosition - stepStartFlatPosition
		local movedOppositeDirection = actualStepFlatDelta.Magnitude > 0.75
			and actualStepFlatDelta.Unit:Dot(flatDirection) < -0.45
		local deviatedFromStep = (liveFlatPosition - expectedStepFlatPosition).Magnitude > RUBBERBAND_STEP_DEVIATION_DISTANCE
		local snappedBackwards = liveFlatDistance > (stepStartFlatDistance + RUBBERBAND_BACKTRACK_DISTANCE)
		if snappedBackwards or (deviatedFromStep and movedOppositeDirection) then
			clearMovementKeys()
			setLastMoveCommand(Vector3.zero, "CFrameRubberBand")
			pushDebugRateLimited(
				"cframe_rubberband_step",
				string.format("cframe rubber band: %.1f -> %.1f", stepStartFlatDistance, liveFlatDistance),
				0.8
			)
			return false, "rubberband"
		end
	end

	clearMovementKeys()
	setLastMoveCommand(Vector3.zero, "CFrameStop")
	local rootPart = getRootPart(character)
	if rootPart and safeTarget then
		local delta = safeTarget - rootPart.Position
		local flatDistance = Vector3.new(delta.X, 0, delta.Z).Magnitude
		local verticalDistance = math.abs(delta.Y)
		local finishSlack = math.max(0.2, wantedDistance * 0.4)
		if useUndergroundOffset then
			return delta.Magnitude <= (wantedDistance + finishSlack) or (flatDistance <= (wantedDistance + finishSlack) and verticalDistance <= (undergroundVerticalTolerance + finishSlack))
		end
		return flatDistance <= (wantedDistance + finishSlack) or delta.Magnitude <= (wantedDistance + finishSlack)
	end
	return false
end

function moveTowardsPosition(character, humanoid, targetPosition, activeToken, timeout)
	if movementMode == "tween" then
		return tweenCharacterTowards(character, targetPosition, activeToken, timeout)
	end
	if movementMode == "cframe" then
		return cframeCharacterTowards(character, targetPosition, activeToken, timeout, nil, {
			useUndergroundOffset = false,
		})
	end

	return walkHumanoidTowards(character, humanoid, targetPosition, activeToken, timeout)
end

function getSegmentedPathTarget(currentPosition, finalTarget, maxDistance)
	local delta = finalTarget - currentPosition
	local distance = delta.Magnitude
	if distance <= (maxDistance or PATH_SEGMENT_DISTANCE) then
		return finalTarget
	end

	local direction = delta.Unit
	return currentPosition + (direction * (maxDistance or PATH_SEGMENT_DISTANCE))
end

function getDirectPathTravelTimeout(character, targetPosition, minimumTime)
	local rootPart = getRootPart(character)
	if not rootPart or not targetPosition then
		return math.max(tonumber(minimumTime) or 0.35, MOVE_TIMEOUT)
	end

	local flatDistance = (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) - Vector3.new(targetPosition.X, 0, targetPosition.Z)).Magnitude
	local travelSpeed = movementMode == "cframe" and getEffectiveCFrameSpeed() or math.max(tonumber(tweenMoveSpeed) or TWEEN_MOVE_SPEED, 1)
	return math.max(tonumber(minimumTime) or 0.35, (flatDistance / travelSpeed) + 0.4)
end

function moveTowardsRecordedPathNode(character, humanoid, targetPosition, activeToken)
	if not targetPosition then
		return false
	end

	local rootPart = getRootPart(character)
	if not rootPart or not autoMineEnabled or activeToken ~= autoMineToken then
		return false
	end

	local pathReachDistance = movementMode == "cframe"
		and math.max(0.55, WAYPOINT_REACH_DISTANCE * 0.18)
		or math.max(1.8, WAYPOINT_REACH_DISTANCE * 0.6)
	local flatDelta = Vector3.new(targetPosition.X - rootPart.Position.X, 0, targetPosition.Z - rootPart.Position.Z)
	local flatDistance = flatDelta.Magnitude
	if flatDistance <= pathReachDistance then
		cancelActiveMoveTween()
		clearMovementKeys()
		setLastMoveCommand(Vector3.zero, "PathArrived")
		return true
	end

	if movementMode == "cframe" then
		clearMovementKeys()
		cancelActiveMoveTween()
		local goalDirection = flatDelta.Magnitude > 0.001 and flatDelta.Unit or Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z)
		if goalDirection.Magnitude < 0.001 then
			goalDirection = Vector3.new(0, 0, -1)
		end
		setLastMoveCommand(goalDirection, "PathCFrame")
		return cframeCharacterTowards(
			character,
			targetPosition,
			activeToken,
			getDirectPathTravelTimeout(character, targetPosition, 0.45),
			pathReachDistance,
			{
				flatPathFollow = true,
				useUndergroundOffset = false,
			}
		)
	end

	local groundedTarget = getGroundAlignedPathPosition(targetPosition, character) or targetPosition
	local currentGroundPoint = getCharacterGroundPoint(character, rootPart)
	if currentGroundPoint then
		currentGroundPoint = Vector3.new(rootPart.Position.X, currentGroundPoint.Y, rootPart.Position.Z)
	else
		currentGroundPoint = Vector3.new(rootPart.Position.X, groundedTarget.Y, rootPart.Position.Z)
	end

	local segmentGroundTarget = getSegmentedPathTarget(
		currentGroundPoint,
		groundedTarget,
		math.max(pathReachDistance + 0.9, PATH_RECORD_NODE_SPACING * 0.45)
	)
	local goalDirection = flatDelta.Magnitude > 0.001 and flatDelta.Unit or Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z)
	if goalDirection.Magnitude < 0.001 then
		goalDirection = Vector3.new(0, 0, -1)
	end

	local pathGroundClearance = math.max(2.05, math.min(getCharacterGroundClearance(character, rootPart) + 0.12, 3.1))
	local goalY = math.max(segmentGroundTarget.Y + pathGroundClearance, rootPart.Position.Y - 0.4)

	local goalPosition = Vector3.new(
		segmentGroundTarget.X,
		goalY,
		segmentGroundTarget.Z
	)

	clearMovementKeys()
	cancelActiveMoveTween()
	setLastMoveCommand(goalDirection, movementMode == "cframe" and "PathCFrame" or "PathTween")

	local moveDistance = (goalPosition - rootPart.Position).Magnitude
	local moveTime = math.clamp(moveDistance / math.max(tweenMoveSpeed, 10), 0.05, 0.18)
	local tween = TweenService:Create(
		rootPart,
		TweenInfo.new(moveTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{ CFrame = CFrame.lookAt(goalPosition, goalPosition + goalDirection) }
	)
	activeMoveTween = tween

	local connection = nil
	connection = tween.Completed:Connect(function()
		if connection then
			connection:Disconnect()
		end
		if activeMoveTween == tween then
			activeMoveTween = nil
		end
	end)

	tween:Play()
	return true
end

function moveCharacterNearPosition(character, humanoid, targetPosition, arriveRange, activeToken)
	if not targetPosition then
		return false
	end

	local wantedRange = arriveRange or WAYPOINT_REACH_DISTANCE
	if movementMode == "cframe" then
		return cframeCharacterTowards(
			character,
			targetPosition,
			activeToken,
			getDirectPathTravelTimeout(character, targetPosition, 0.5),
			wantedRange
		)
	end

	local function getPathArrivalDistance()
		local rootPart = getRootPart(character)
		if not rootPart then
			return math.huge
		end
		return (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) - Vector3.new(targetPosition.X, 0, targetPosition.Z)).Magnitude
	end

	if getPathArrivalDistance() <= wantedRange then
		return true
	end

	local rootPart = getRootPart(character)
	if not rootPart then
		return false
	end

	local attempts = 0
	while autoMineEnabled and activeToken == autoMineToken and attempts < PATH_REPLAN_ATTEMPTS do
		attempts += 1

		if getPathArrivalDistance() <= wantedRange then
			return true
		end

		rootPart = getRootPart(character)
		if not rootPart then
			return false
		end

		local pathTarget = getSegmentedPathTarget(rootPart.Position, targetPosition, PATH_SEGMENT_DISTANCE)
		local usingSegmentTarget = (pathTarget - targetPosition).Magnitude > 1
		local path = PathfindingService:CreatePath({
			AgentCanJump = true,
			WaypointSpacing = PATH_WAYPOINT_SPACING,
		})

		local computed = pcall(function()
			path:ComputeAsync(rootPart.Position, pathTarget)
		end)

		if computed and path.Status == Enum.PathStatus.Success then
			local waypoints = path:GetWaypoints()
			local points = {}
			for _, waypoint in ipairs(waypoints) do
				table.insert(points, waypoint.Position)
			end
			visualizePathPoints(points, targetPosition)

			local progressed = false
			for _, waypoint in ipairs(waypoints) do
				if not autoMineEnabled or activeToken ~= autoMineToken then
					return false
				end

				if getPathArrivalDistance() <= wantedRange then
					return true
				end

				if waypoint.Action == Enum.PathWaypointAction.Jump then
					humanoid.Jump = true
				end

				local reached = moveTowardsPosition(character, humanoid, waypoint.Position, activeToken, MOVE_TIMEOUT)
				if reached then
					progressed = true
				else
					break
				end
			end

			if progressed and usingSegmentTarget then
				pushDebugRateLimited("path_segment_progress", "pathing seller in segments", 2)
			elseif progressed then
				task.wait(0.05)
			else
				pushDebugRateLimited("path_segment_stall", "path segment stalled", 1.5)
			end
		else
			visualizePathPoints({ rootPart.Position, pathTarget }, targetPosition)

			local fallbackTarget = pathTarget
			if movementMode == "tween" then
				pushDebugRateLimited("tween_path_fallback", "tween fallback -> walk segment", 1.5)
				if not walkHumanoidTowards(character, humanoid, fallbackTarget, activeToken, MOVE_TIMEOUT) then
					break
				end
			else
				if not moveTowardsPosition(character, humanoid, fallbackTarget, activeToken, MOVE_TIMEOUT) then
					break
				end
			end
		end
	end

	return getPathArrivalDistance() <= wantedRange
end

function moveCharacterNearOre(character, humanoid, oreDeposit, activeToken, arriveRange)
	local orePosition = getOrePosition(oreDeposit)
	if not orePosition then
		pushDebug("ore missing position")
		return false
	end

	local desiredRange = arriveRange or MINE_RANGE

	if getDistanceToPosition(character, orePosition) <= desiredRange then
		return true
	end

	local rootPart = getRootPart(character)
	if not rootPart then
		pushDebug("root part not found")
		return false
	end

	setStatus("Walking to " .. getOreDisplayName(oreDeposit), Color3.fromRGB(120, 190, 255))

	local movedNear = moveCharacterNearPosition(character, humanoid, orePosition, desiredRange, activeToken)
	if movedNear and getDistanceToPosition(character, orePosition) <= desiredRange then
		return true
	end

	pushDebug(safeLower(getMovementModeLabel()) .. " move failed")
	return false
end

function tryAutoPickup(character, humanoid, activeToken, options)
	options = type(options) == "table" and options or nil
	if not autoPickupEnabled then
		return false
	end

	local pickupRange = math.max(0.5, tonumber(options and options.arriveRange) or PICKUP_RANGE)
	local pickupReachSlack = math.max(0.55, pickupRange * 0.18)
	local maxPickupDistance = tonumber(options and options.maxDistance) or AUTO_PICKUP_MAX_DISTANCE
	if maxPickupDistance < pickupRange then
		maxPickupDistance = pickupRange
	end
	local requireAlreadyInReach = options and options.requireAlreadyInReach == true
	local dropItem, distance = findNearestDroppedItem(character, maxPickupDistance)
	if not dropItem then
		return false
	end
	if requireAlreadyInReach and (not distance or distance > (pickupRange + pickupReachSlack)) then
		return false
	end

	local dropPart = getDroppedItemBasePart(dropItem)
	if not dropPart then
		return false
	end
	endExperimentalCFrameTravel(character)
	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	local actionGroupInstance, networkId = resolveDroppedPickupActionTarget(dropItem, dropPart)

	local dropName = getDropItemTypeName(dropItem)
	local dropLabel = getPickupLabel(dropName)
	pushDebug("pickup target: " .. dropLabel .. " (" .. tostring(math.floor((distance or 0) + 0.5)) .. ")")
	setStatus("Picking up " .. dropLabel, Color3.fromRGB(165, 220, 140))

	local reached = true
	if requireAlreadyInReach then
		reached = getDistanceToPosition(character, dropPart.Position) <= (pickupRange + pickupReachSlack)
	else
		reached = moveCharacterNearPosition(character, humanoid, dropPart.Position, pickupRange, activeToken)
	end
	if not reached then
		pushDebug("pickup move failed")
		return false
	end

	if tryPickupDroppedItemViaNetwork(network, dropItem, dropPart, actionGroupInstance, networkId) then
		pushDebug("picked instantly: " .. dropLabel)
		return true
	end

	if tryPickupDroppedItemViaObjectAction(network, dropItem, dropPart, actionGroupInstance, networkId) then
		pushDebug("picked via object action: " .. dropLabel)
		return true
	end

	facePosition(character, dropPart.Position)
	clearMovementKeys()

	local startedAt = os.clock()
	setInteractKeyHeld(true)
	while autoMineEnabled and activeToken == autoMineToken and dropItem.Parent and (os.clock() - startedAt) < PICKUP_HOLD_SECONDS do
		task.wait(0.05)
	end
	setInteractKeyHeld(false)

	if dropItem.Parent then
		pushDebug("pickup timeout: " .. dropLabel)
	else
		pushDebug("picked: " .. dropLabel)
	end

	return true
end

function getSellTargetBasePart(instance)
	if typeof(instance) ~= "Instance" then
		return nil
	end

	if instance:IsA("Model") then
		return instance.PrimaryPart
			or instance:FindFirstChild("HumanoidRootPart")
			or instance:FindFirstChildWhichIsA("BasePart", true)
	end

	if instance:IsA("Attachment") and instance.Parent and instance.Parent:IsA("BasePart") then
		return instance.Parent
	end

	if instance:IsA("BillboardGui") or instance:IsA("SurfaceGui") then
		local adornee = instance.Adornee
		if adornee and adornee:IsA("BasePart") then
			return adornee
		end

		local parent = instance.Parent
		if parent and parent:IsA("BasePart") then
			return parent
		end
	end

	if instance:IsA("ProximityPrompt") or instance:IsA("ClickDetector") then
		local parent = instance.Parent
		if parent and parent:IsA("BasePart") then
			return parent
		end
	end

	if instance:IsA("BasePart") then
		return instance
	end

	return instance:FindFirstChildWhichIsA("BasePart", true)
end

function textMatchesAutoSellHints(text)
	if type(text) ~= "string" then
		return false
	end

	if AUTO_SELL_SHOP_TYPES[text] then
		return true
	end

	local loweredText = safeLower(text)
	for shopType in pairs(AUTO_SELL_SHOP_TYPES) do
		if string.find(loweredText, safeLower(shopType), 1, true) then
			return true
		end
	end

	for _, hint in ipairs(AUTO_SELL_SHOP_NAME_HINTS) do
		if string.find(loweredText, hint, 1, true) then
			return true
		end
	end

	return false
end

function getAutoSellMatchScore(instance)
	if typeof(instance) ~= "Instance" then
		return 100
	end

	local bestScore = 100
	local function considerText(text)
		if type(text) ~= "string" or text == "" then
			return
		end

		local lowered = safeLower(text)
		if string.find(lowered, "sell loot", 1, true) then
			bestScore = math.min(bestScore, 0)
		elseif AUTO_SELL_SHOP_TYPES[text] then
			bestScore = math.min(bestScore, 0)
		elseif textMatchesAutoSellHints(text) then
			bestScore = math.min(bestScore, 3)
		end
	end

	considerText(instance.Name)
	for _, attributeName in ipairs(AUTO_SELL_SHOP_ATTRIBUTE_NAMES) do
		considerText(instance:GetAttribute(attributeName))
	end
	for attributeName, attributeValue in pairs(instance:GetAttributes()) do
		considerText(attributeName)
		considerText(attributeValue)
	end

	if instance:IsA("ProximityPrompt") then
		considerText(instance.ActionText)
		considerText(instance.ObjectText)
		if safeLower(instance.ActionText) == "sell loot" then
			bestScore = math.min(bestScore, 0)
		end
	end

	for _, child in ipairs(instance:GetChildren()) do
		considerText(child.Name)
		if child:IsA("StringValue") or child:IsA("IntValue") then
			considerText(tostring(child.Value))
		end
	end

	return bestScore
end

function isSellPromptInstance(instance)
	return getAutoSellMatchScore(instance) <= 1
end

function instanceMatchesAutoSellShop(instance)
	if typeof(instance) ~= "Instance" then
		return false
	end

	local directName = instance.Name
	if textMatchesAutoSellHints(directName) then
		return true
	end

	for _, attributeName in ipairs(AUTO_SELL_SHOP_ATTRIBUTE_NAMES) do
		local attributeValue = instance:GetAttribute(attributeName)
		if textMatchesAutoSellHints(attributeValue) then
			return true
		end
	end

	for attributeName, attributeValue in pairs(instance:GetAttributes()) do
		if textMatchesAutoSellHints(attributeName) or textMatchesAutoSellHints(attributeValue) then
			return true
		end
	end

	if instance:IsA("ProximityPrompt") then
		if textMatchesAutoSellHints(instance.ActionText) or textMatchesAutoSellHints(instance.ObjectText) then
			return true
		end
	end

	for _, child in ipairs(instance:GetChildren()) do
		if textMatchesAutoSellHints(child.Name) then
			return true
		end

		if child:IsA("StringValue") or child:IsA("IntValue") then
			if textMatchesAutoSellHints(tostring(child.Value)) then
				return true
			end
		end
	end

	return false
end

function getAutoSellTargetCandidates(forceRefresh)
	local now = os.clock()
	if cachedAutoSellTargets and not forceRefresh then
		if #cachedAutoSellTargets > 0 then
			return cachedAutoSellTargets
		end

		if (now - lastAutoSellTargetScanAt) < 3 then
			return cachedAutoSellTargets
		end
	end

	lastAutoSellTargetScanAt = now
	local candidates = {}
	local seenParts = {}

	local function tryAddTarget(instance, basePart)
		if not basePart or not basePart.Parent or seenParts[basePart] then
			return
		end

		seenParts[basePart] = true
		table.insert(candidates, {
			part = basePart,
			instance = instance or basePart,
			score = getAutoSellMatchScore(instance or basePart),
		})
	end

	local configuredPart, configuredGui = getConfiguredGeneralShopTarget()
	tryAddTarget(configuredGui or configuredPart, configuredPart)

	local searchRoots = {
		workspace:FindFirstChild("WORKSPACE_Geometry"),
		getInteractablesFolder(),
		workspace:FindFirstChild("WORKSPACE_Entities"),
	}

	for _, searchRoot in ipairs(searchRoots) do
		if searchRoot then
			for _, descendant in ipairs(searchRoot:GetDescendants()) do
				if (descendant:IsA("BillboardGui") or descendant:IsA("SurfaceGui") or descendant:IsA("ProximityPrompt"))
					and instanceMatchesAutoSellShop(descendant)
				then
					tryAddTarget(descendant, getSellTargetBasePart(descendant))
				end
			end
		end
	end

	cachedAutoSellTargets = candidates
	return cachedAutoSellTargets
end

function getNodeDistanceToSellTarget(nodePosition, targetPart)
	if not nodePosition or not targetPart or not targetPart:IsA("BasePart") then
		return math.huge
	end

	local localPosition = targetPart.CFrame:PointToObjectSpace(nodePosition)
	local halfSize = targetPart.Size * 0.5
	return Vector3.new(
		math.max(math.abs(localPosition.X) - halfSize.X, 0),
		0,
		math.max(math.abs(localPosition.Z) - halfSize.Z, 0)
	).Magnitude
end

function getBestSellTargetForPath(pathData, preferredNodeIndex, forceRefresh)
	if type(pathData) ~= "table" then
		return nil, nil, nil, nil
	end

	local nodes = pathData.nodes or {}
	if #nodes == 0 then
		return nil, nil, nil, nil
	end

	local normalizedPreferredNodeIndex = normalizePathNodeIndex(preferredNodeIndex, #nodes)
	local candidates = getAutoSellTargetCandidates(forceRefresh)
	local bestPart = nil
	local bestInstance = nil
	local bestNodeIndex = nil
	local bestDistance = nil
	local bestScore = nil
	local bestMetric = nil

	for _, candidate in ipairs(candidates or {}) do
		local candidateNodeIndexes = {}
		if normalizedPreferredNodeIndex then
			candidateNodeIndexes[1] = normalizedPreferredNodeIndex
		else
			for index = 1, #nodes do
				candidateNodeIndexes[index] = index
			end
		end

		for _, nodeIndex in ipairs(candidateNodeIndexes) do
			local node = nodes[nodeIndex]
			local nodePosition = getPathNodePosition(node)
			local distance = nodePosition and getNodeDistanceToSellTarget(nodePosition, candidate.part) or math.huge
			if distance < math.huge then
				local metric = distance + ((candidate.score or 0) * 12)
				if not bestMetric
					or metric < bestMetric
					or (metric == bestMetric and distance < (bestDistance or math.huge))
				then
					bestMetric = metric
					bestDistance = distance
					bestScore = candidate.score
					bestNodeIndex = nodeIndex
					bestPart = candidate.part
					bestInstance = candidate.instance
				end
			end
		end
	end

	return bestPart, bestInstance, bestNodeIndex, bestDistance
end

function getPathSellTarget(pathData, forceRefresh)
	local manualSellNodeIndex = getManualPathSellNodeIndex(pathData)
	local sellerPart, sellerInstance, autoNodeIndex, autoDistance = getBestSellTargetForPath(pathData, manualSellNodeIndex, forceRefresh)
	if not sellerPart and not forceRefresh then
		sellerPart, sellerInstance, autoNodeIndex, autoDistance = getBestSellTargetForPath(pathData, manualSellNodeIndex, true)
	end

	if manualSellNodeIndex then
		return sellerPart, sellerInstance, manualSellNodeIndex, autoDistance
	end

	if autoNodeIndex and autoDistance and autoDistance <= PATH_RECORD_SELL_DISTANCE then
		return sellerPart, sellerInstance, autoNodeIndex, autoDistance
	end

	return sellerPart, sellerInstance, nil, autoDistance
end

function findNearestAutoSellTarget(character, forceRefresh)
	local rootPart = getRootPart(character)
	if not rootPart then
		return nil, nil, nil
	end

	local bestPart = nil
	local bestDistance = nil
	local bestInstance = nil
	local bestScore = nil
	local bestMetric = nil

	for _, candidate in ipairs(getAutoSellTargetCandidates(forceRefresh) or {}) do
		local distance = (rootPart.Position - candidate.part.Position).Magnitude
		local metric = distance + ((candidate.score or 0) * 12)
		if not bestMetric
			or metric < bestMetric
			or (metric == bestMetric and distance < (bestDistance or math.huge))
		then
			bestMetric = metric
			bestScore = candidate.score
			bestDistance = distance
			bestPart = candidate.part
			bestInstance = candidate.instance
		end
	end

	if not bestPart and not forceRefresh then
		return findNearestAutoSellTarget(character, true)
	end

	return bestPart, bestInstance, bestDistance
end

function pushNearbySellPromptHints(character)
	local rootPart = getRootPart(character)
	if not rootPart then
		return
	end

	local nearbyHints = {}
	local searchRoots = {
		getInteractablesFolder(),
		workspace:FindFirstChild("WORKSPACE_Entities"),
		workspace:FindFirstChild("WORKSPACE_Map"),
		workspace:FindFirstChild("Map"),
	}

	for _, searchRoot in ipairs(searchRoots) do
		if searchRoot then
			for _, descendant in ipairs(searchRoot:GetDescendants()) do
				if descendant:IsA("ProximityPrompt") then
					local actionText = tostring(descendant.ActionText or "")
					local objectText = tostring(descendant.ObjectText or "")
					if actionText ~= "" or objectText ~= "" then
						local basePart = getSellTargetBasePart(descendant)
						if basePart then
							local distance = (rootPart.Position - basePart.Position).Magnitude
							if distance <= 90 then
								table.insert(nearbyHints, {
									distance = distance,
									text = string.format("%s / %s", actionText, objectText),
									name = descendant:GetFullName(),
								})
							end
						end
					end
				end
			end
		end
	end

	table.sort(nearbyHints, function(left, right)
		return left.distance < right.distance
	end)

	for index = 1, math.min(#nearbyHints, 3) do
		local hint = nearbyHints[index]
		pushDebugRateLimited(
			"sell_prompt_hint_" .. tostring(index),
			string.format("sell prompt nearby: %d studs | %s | %s", math.floor(hint.distance + 0.5), hint.text, hint.name),
			6
		)
	end
end

function findSellPromptForTarget(targetInstance, targetPart)
	local candidates = {}
	local seen = {}

	local function tryAdd(instance)
		if typeof(instance) ~= "Instance" or seen[instance] then
			return
		end
		seen[instance] = true
		table.insert(candidates, instance)
	end

	local instanceCursor = targetInstance
	for _ = 1, 4 do
		if not instanceCursor then
			break
		end
		tryAdd(instanceCursor)
		instanceCursor = instanceCursor.Parent
	end

	if targetInstance then
		for _, descendant in ipairs(targetInstance:GetDescendants()) do
			tryAdd(descendant)
		end
	end

	if targetPart then
		tryAdd(targetPart)
		for _, descendant in ipairs(targetPart:GetDescendants()) do
			tryAdd(descendant)
		end
	end

	local bestPrompt = nil
	local bestScore = nil
	for _, candidate in ipairs(candidates) do
		if candidate:IsA("ProximityPrompt") then
			local score = getAutoSellMatchScore(candidate)
			if not bestScore or score < bestScore then
				bestScore = score
				bestPrompt = candidate
			end
		end
	end

	return bestPrompt
end

function getSellInteractKey(targetInstance, targetPart)
	local prompt = findSellPromptForTarget(targetInstance, targetPart)
	if prompt then
		local keyCode = prompt.KeyboardKeyCode
		if keyCode and keyCode ~= Enum.KeyCode.Unknown then
			pushDebugRateLimited("sell_prompt_key", "sell prompt key: " .. formatKeyCodeName(keyCode), 4)
			return keyCode, prompt
		end
	end

	return INTERACT_SECONDARY_KEY, prompt
end

function waitForSellInventoryDrop(filledBefore, timeoutSeconds, lootSummaryBefore)
	local timeoutAt = os.clock() + math.max(0.1, tonumber(timeoutSeconds) or 0.8)
	local latestFilled = filledBefore
	local latestLootSummary = nil

	while os.clock() < timeoutAt do
		latestLootSummary = getSellableLootSummary(false)
		if wasSellableLootReduced(lootSummaryBefore, latestLootSummary) then
			local summaryFilledSlots = tonumber(rawget(latestLootSummary, "filledSlots") or latestLootSummary.filledSlots)
			if summaryFilledSlots ~= nil then
				latestFilled = summaryFilledSlots
			else
				latestFilled = select(1, getInventorySlotCounts())
			end
			return true, latestFilled, latestLootSummary
		end

		latestFilled = select(1, getInventorySlotCounts())
		if latestFilled < filledBefore then
			return true, latestFilled, latestLootSummary
		end
		task.wait(0.05)
	end

	latestLootSummary = getSellableLootSummary(false)
	if wasSellableLootReduced(lootSummaryBefore, latestLootSummary) then
		local summaryFilledSlots = tonumber(rawget(latestLootSummary, "filledSlots") or latestLootSummary.filledSlots)
		if summaryFilledSlots ~= nil then
			latestFilled = summaryFilledSlots
		else
			latestFilled = select(1, getInventorySlotCounts())
		end
		return true, latestFilled, latestLootSummary
	end

	latestFilled = select(1, getInventorySlotCounts())
	return latestFilled < filledBefore, latestFilled, latestLootSummary
end

function tryFireSellPromptDirectly(prompt)
	if not (prompt and prompt:IsA("ProximityPrompt")) then
		return false
	end

	if type(fireproximityprompt) == "function" then
		for _, args in ipairs({
			{},
			{ 0 },
			{ 0, true },
			{ tonumber(prompt.HoldDuration) or 0, true },
		}) do
			local ok = pcall(function()
				fireproximityprompt(prompt, unpack(args))
			end)
			if ok then
				return true
			end
		end
	end

	local okBegin = pcall(function()
		prompt:InputHoldBegin()
	end)
	if okBegin then
		task.wait(math.max(0.05, tonumber(prompt.HoldDuration) or 0))
		pcall(function()
			prompt:InputHoldEnd()
		end)
		return true
	end

	return false
end

