				humanoid.UseJumpPower = autoMineLockedUseJumpPower
			end
		end)
		pcall(function()
			if autoMineLockedJumpPower ~= nil then
				humanoid.JumpPower = autoMineLockedJumpPower
			end
		end)
		pcall(function()
			if autoMineLockedJumpHeight ~= nil then
				humanoid.JumpHeight = autoMineLockedJumpHeight
			end
		end)
	end

	autoMineLockedHumanoid = nil
	autoMineLockedWalkSpeed = nil
	autoMineLockedUseJumpPower = nil
	autoMineLockedJumpPower = nil
	autoMineLockedJumpHeight = nil
	autoMineLockedAutoRotate = nil
end

local function releaseAutoMineManualMovementLock()
	if autoMineInputLockBound and ContextActionService then
		pcall(function()
			ContextActionService:UnbindAction(AUTOMINE_INPUT_LOCK_ACTION_NAME)
		end)
	end
	autoMineInputLockBound = false

	if autoMineLockedControls and type(autoMineLockedControls.Enable) == "function" then
		pcall(autoMineLockedControls.Enable, autoMineLockedControls)
	end
	autoMineLockedControls = nil

	restoreAutoMineMovementHumanoid()
end

local function ensureAutoMineManualMovementLock(character, humanoid)
	if not autoMineEnabled then
		releaseAutoMineManualMovementLock()
		return
	end

	if ContextActionService and movementMode ~= "legit" and not autoMineInputLockBound then
		local okBind = pcall(function()
			ContextActionService:BindActionAtPriority(
				AUTOMINE_INPUT_LOCK_ACTION_NAME,
				function()
					return Enum.ContextActionResult.Sink
				end,
				false,
				Enum.ContextActionPriority.High.Value,
				table.unpack(AUTO_MINE_INPUT_LOCK_ITEMS)
			)
		end)
		autoMineInputLockBound = okBind == true
	end

	if movementMode ~= "legit" then
		if not autoMineLockedControls then
			autoMineLockedControls = getLocalPlayerControls()
			if autoMineLockedControls and type(autoMineLockedControls.Disable) == "function" then
				pcall(autoMineLockedControls.Disable, autoMineLockedControls)
			end
		end

		if humanoid and autoMineLockedHumanoid ~= humanoid then
			restoreAutoMineMovementHumanoid()
			autoMineLockedHumanoid = humanoid
			autoMineLockedWalkSpeed = humanoid.WalkSpeed
			autoMineLockedAutoRotate = humanoid.AutoRotate
			autoMineLockedUseJumpPower = humanoid.UseJumpPower
			autoMineLockedJumpPower = humanoid.JumpPower
			autoMineLockedJumpHeight = humanoid.JumpHeight
		end

		if humanoid then
			pcall(function()
				humanoid.WalkSpeed = 0
				humanoid.AutoRotate = false
				humanoid.Jump = false
				if humanoid.UseJumpPower then
					humanoid.JumpPower = 0
				else
					humanoid.JumpHeight = 0
				end
				humanoid:Move(Vector3.zero)
			end)
		end
		return
	end

	if autoMineInputLockBound and ContextActionService then
		pcall(function()
			ContextActionService:UnbindAction(AUTOMINE_INPUT_LOCK_ACTION_NAME)
		end)
	end
	autoMineInputLockBound = false

	if autoMineLockedControls and type(autoMineLockedControls.Enable) == "function" then
		pcall(autoMineLockedControls.Enable, autoMineLockedControls)
	end
	autoMineLockedControls = nil
	restoreAutoMineMovementHumanoid()

	if humanoid and not areAutoMineMovementKeysHeld() then
		pcall(function()
			humanoid.Jump = false
			humanoid:Move(Vector3.zero)
		end)
	end
end

