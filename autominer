function updatePathPlayerAvoiderCorridorVisualization(rootPosition, segments, blocker)
	if not (isPathPlayerAvoiderEnabled() and isPathPlayerAvoiderShowCorridorEnabled() and pathState.playbackActive) then
		clearPathPlayerAvoiderCorridorVisualization()
		return
	end
	if typeof(rootPosition) ~= "Vector3" or type(segments) ~= "table" or #segments == 0 then
		clearPathPlayerAvoiderCorridorVisualization()
		return
	end

	local firstSegment = segments[1]
	local lastSegment = segments[#segments]
	if not firstSegment or not lastSegment then
		clearPathPlayerAvoiderCorridorVisualization()
		return
	end

	local now = os.clock()
	local signature = table.concat({
		math.floor(rootPosition.X * 2 + 0.5),
		math.floor(rootPosition.Y * 2 + 0.5),
		math.floor(rootPosition.Z * 2 + 0.5),
		#segments,
		math.floor(firstSegment.finish.X * 2 + 0.5),
		math.floor(firstSegment.finish.Z * 2 + 0.5),
		math.floor(lastSegment.finish.X * 2 + 0.5),
		math.floor(lastSegment.finish.Z * 2 + 0.5),
		blocker and "1" or "0",
	}, ":")
	if signature == lastPlayerAvoiderVizSignature and (now - lastPlayerAvoiderVizAt) < PATH_PLAYER_AVOIDER_VIZ_REFRESH_INTERVAL then
		return
	end

	clearPathPlayerAvoiderCorridorVisualization()
	lastPlayerAvoiderVizAt = now
	lastPlayerAvoiderVizSignature = signature

	local corridorColor = blocker and Color3.fromRGB(255, 116, 72) or Color3.fromRGB(255, 166, 64)
	local segmentWidth = PATH_PLAYER_AVOIDER_CORRIDOR_RADIUS * 2
	for _, segment in ipairs(segments) do
		createPathPlayerAvoiderCorridorSegment(segment.start, segment.finish, segmentWidth, corridorColor)
	end

	local marker = Instance.new("Part")
	marker.Name = "AvoiderOrigin"
	marker.Shape = Enum.PartType.Ball
	marker.Size = Vector3.new(0.55, 0.55, 0.55)
	marker.Anchored = true
	marker.CanCollide = false
	marker.CanQuery = false
	marker.CanTouch = false
	marker.Material = Enum.Material.Neon
	marker.Color = corridorColor
	marker.Transparency = 0.4
	marker.Position = rootPosition + Vector3.new(0, VISUALIZER_HEIGHT, 0)
	marker.Parent = getPathPlayerAvoiderVisualizerFolder()
end

