	if not isTable(globalModule) then
		resolveGlobalNetwork(forceRefresh)
		globalModule = rawget(_G, "__AutoMineGlobalModule")
	end
	if isTable(globalModule) then
		local handlerFromGlobal = rawget(globalModule, "RepCharHandler") or globalModule.RepCharHandler
		if isTable(handlerFromGlobal) then
			local repChar = rawget(handlerFromGlobal, "LocalRepChar") or handlerFromGlobal.LocalRepChar
			if isTable(repChar) then
				return repChar
			end
			local getRepChar = rawget(handlerFromGlobal, "GetRepChar") or handlerFromGlobal.GetRepChar
			if type(getRepChar) == "function" and localPlayer then
				local okGet, result = pcall(getRepChar, handlerFromGlobal, localPlayer)
				if okGet and isTable(result) then
