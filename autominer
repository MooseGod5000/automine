	end

	local entities = workspace:FindFirstChild("WORKSPACE_Entities")
	local playersFolder = entities and entities:FindFirstChild("Players")
	if not playersFolder then
		return nil
	end

	local exactMatch = playersFolder:FindFirstChild(LocalPlayer.Name)
