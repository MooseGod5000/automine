function triggerRemote(remote, ...)
	if not remote then
		return false
	end

	local packedArgs = table.pack(...)

	local ok = pcall(function()
		if remote:IsA("RemoteEvent") then
			remote:FireServer(table.unpack(packedArgs, 1, packedArgs.n))
		elseif remote:IsA("RemoteFunction") then
			remote:InvokeServer(table.unpack(packedArgs, 1, packedArgs.n))
		elseif remote:IsA("BindableEvent") then
			remote:Fire(table.unpack(packedArgs, 1, packedArgs.n))
		elseif remote:IsA("BindableFunction") then
			remote:Invoke(table.unpack(packedArgs, 1, packedArgs.n))
		end
	end)

	return ok
end

function isToolInfoPickaxe(toolInfo)
	if not isTable(toolInfo) then
		return false
	end

	local directNameHint = rawget(toolInfo, "Name")
		or toolInfo.Name
		or rawget(toolInfo, "ItemName")
		or toolInfo.ItemName
		or rawget(toolInfo, "Type")
		or toolInfo.Type
		or rawget(toolInfo, "ItemType")
		or toolInfo.ItemType
		or rawget(toolInfo, "ClassName")
		or toolInfo.ClassName
	if string.find(safeLower(directNameHint), "pickaxe", 1, true) ~= nil then
		return true
	end

	if rawget(toolInfo, "CanMine") == true or toolInfo.CanMine == true then
		return true
	end

	local model = rawget(toolInfo, "Model") or toolInfo.Model
	if typeof(model) == "Instance" then
		local modelName = safeLower(model.Name)
		return string.find(modelName, "pickaxe", 1, true) ~= nil
	end

	local modelHint = safeLower(model)
	if string.find(modelHint, "pickaxe", 1, true) ~= nil then
		return true
	end

	return string.find(modelHint, "mine", 1, true) ~= nil
end

function getToolInfoCharacter(toolInfo, fallbackCharacter)
	local character = rawget(toolInfo, "Character") or toolInfo.Character
	if typeof(character) == "Instance" and character:IsA("Model") then
		return character
	end

	return fallbackCharacter
end

function getToolInfoHitbox(toolInfo)
	local hitbox = rawget(toolInfo, "Hitbox") or toolInfo.Hitbox
	if typeof(hitbox) == "Instance" and hitbox:IsA("BasePart") then
		return hitbox
	end

	local model = rawget(toolInfo, "Model") or toolInfo.Model
	if typeof(model) == "Instance" then
		local found = model:FindFirstChild("HitBox", true)
			or model:FindFirstChild("Hitbox", true)
			or model:FindFirstChild("Handle", true)
		if found and found:IsA("BasePart") then
			return found
		end
	end

	return nil
end

function isLikelyMiningToolInfo(toolInfo, character)
	if not looksLikeToolInfo(toolInfo) then
		return false
	end

	if isToolInfoPickaxe(toolInfo) then
		return true
	end

	local isEquipped = rawget(toolInfo, "IsEquipped")
	if isEquipped == nil then
		isEquipped = toolInfo.IsEquipped
	end

	local toolCharacter = getToolInfoCharacter(toolInfo, nil)
	local characterMatches = (not character) or (not toolCharacter) or (toolCharacter == character)
	local hasHitbox = getToolInfoHitbox(toolInfo) ~= nil

	return characterMatches and isEquipped ~= false and hasHitbox
end

function scoreToolInfoCandidate(toolInfo, character)
	local score = 0
	if looksLikeToolInfo(toolInfo) then
		score += 2
	end
	if isToolInfoPickaxe(toolInfo) then
		score += 4
	end
	if getToolInfoHitbox(toolInfo) then
		score += 2
	end

	local isEquipped = rawget(toolInfo, "IsEquipped")
	if isEquipped == nil then
		isEquipped = toolInfo.IsEquipped
	end
	if isEquipped == true then
		score += 2
	elseif isEquipped == nil then
		score += 1
	end

	local toolCharacter = getToolInfoCharacter(toolInfo, nil)
	if character and toolCharacter == character then
		score += 3
	elseif toolCharacter then
		score += 1
	end

	return score
end

function resolveToolInfo(forceRefresh, character)
	if cachedDirectToolInfo and isLikelyMiningToolInfo(cachedDirectToolInfo, character) then
		local cachedCharacter = getToolInfoCharacter(cachedDirectToolInfo, nil)
		if not character or not cachedCharacter or cachedCharacter == character then
			return cachedDirectToolInfo
		end
		cachedDirectToolInfo = nil
	end

	local _, ownerToolInfo = resolveToolInfoOwner(forceRefresh)
	if ownerToolInfo and isLikelyMiningToolInfo(ownerToolInfo, character) then
		cachedDirectToolInfo = ownerToolInfo
		return ownerToolInfo
	end

	if type(getgc) ~= "function" then
		return nil
	end

	local now = os.clock()
	if not forceRefresh and (now - lastDirectToolInfoScanAt) < AURA_FORCE_SCAN_INTERVAL then
		return nil
	end
	lastDirectToolInfoScanAt = now

	local ok, gcObjects = pcall(getgc, true)
	if not ok or type(gcObjects) ~= "table" then
		return nil
	end

	local bestMatch = nil
	local bestScore = -math.huge
	local deadline = os.clock() + TOOLINFO_DIRECT_SCAN_BUDGET
	for _, object in ipairs(gcObjects) do
		if os.clock() > deadline then
			break
		end

		if isTable(object) and isLikelyMiningToolInfo(object, character) then
			local isEquipped = rawget(object, "IsEquipped")
			if isEquipped == nil then
				isEquipped = object.IsEquipped
			end

			local objectCharacter = getToolInfoCharacter(object, nil)
			local characterMatches = (not character) or (not objectCharacter) or objectCharacter == character
			local equippedMatches = (isEquipped == nil) or (isEquipped == true)

			if characterMatches and equippedMatches then
				local score = scoreToolInfoCandidate(object, character)
				if score > bestScore then
					bestScore = score
					bestMatch = object
				end
				if score >= 9 then
					cachedDirectToolInfo = object
					return object
				end
			end
		end
	end

	cachedDirectToolInfo = bestMatch
	return bestMatch
end

