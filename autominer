local function cleanupExistingGui()
    local roots = {_CoreGui}
    if localPlayer then
        local playerGui = localPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            table.insert(roots, playerGui)
        end
    end
    for _, root in ipairs(roots) do
        local existing = root and root:FindFirstChild("FOBGuiOnlyRoot")
        if existing then
            pcall(function()
                existing:Destroy()
            end)
        end
        local overlay = root and root:FindFirstChild("FobGuiOnlyFpsPingOverlay")
        if overlay then
            pcall(function()
                overlay:Destroy()
            end)
        end
        local legacyAutoMine = root and root:FindFirstChild("WildWestAutoMineGui")
        if legacyAutoMine then
            pcall(function()
                legacyAutoMine:Destroy()
            end)
        end
        if root then
            for _, child in ipairs(root:GetChildren()) do
                if child:IsA("ScreenGui") and child.Name:match("^DropdownGui_") then
                    pcall(function()
                        child:Destroy()
                    end)
                end
            end
        end
    end
    for _, folderName in ipairs({"AutoMineRecordedPathViz", "AutoMinePathViz", "AutoMinePathAvoiderViz"}) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            pcall(function()
                folder:Destroy()
            end)
        end
    end
end

