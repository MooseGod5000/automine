	return getAutoSellObjectActionNetworkId(instance)
end

function findAutoSellActionGroupAncestor(instance)
	local current = typeof(instance) == "Instance" and instance or nil
	local depth = 0

	while current and depth < 8 do
		if AUTO_SELL_SHOP_TYPES[current.Name] then
			return current
		end
		current = current.Parent
		depth = depth + 1
	end

	return nil
end

function resolveAutoSellActionGroupTarget(targetInstance, targetPart)
	local roots = {}
	local seen = {}

	local function pushRoot(instance)
		if typeof(instance) == "Instance" and not seen[instance] then
			seen[instance] = true
			table.insert(roots, instance)
		end
	end

	pushRoot(targetInstance)
	pushRoot(targetPart)

	local current = typeof(targetInstance) == "Instance" and targetInstance or nil
	for _ = 1, 2 do
		current = current and current.Parent or nil
		pushRoot(current)
	end

	current = typeof(targetPart) == "Instance" and targetPart or nil
	for _ = 1, 2 do
		current = current and current.Parent or nil
		pushRoot(current)
	end

	local function tryResolveInstance(instance)
		local actionGroupInstance = findAutoSellActionGroupAncestor(instance)
		if not actionGroupInstance then
			return nil, nil, nil
		end

		local networkId = getAutoSellObjectActionNetworkId(actionGroupInstance)
		if networkId == nil then
			networkId = waitForAutoSellObjectActionNetworkId(actionGroupInstance, AUTO_SELL_OBJECT_ACTION_NETWORK_ID_WAIT)
		end

		if networkId ~= nil then
			return actionGroupInstance, networkId, actionGroupInstance.Name
		end

		return nil, nil, nil
	end

	for _, instance in ipairs(roots) do
		local actionGroupInstance, networkId, actionGroupType = tryResolveInstance(instance)
		if actionGroupInstance then
			return actionGroupInstance, networkId, actionGroupType
		end
	end

	for _, root in ipairs(roots) do
		local okDescendants, descendants = pcall(function()
			return root:GetDescendants()
		end)
		if okDescendants and type(descendants) == "table" then
			for _, descendant in ipairs(descendants) do
				if AUTO_SELL_SHOP_TYPES[descendant.Name] then
					local networkId = getAutoSellObjectActionNetworkId(descendant)
					if networkId == nil then
						networkId = waitForAutoSellObjectActionNetworkId(descendant, AUTO_SELL_OBJECT_ACTION_NETWORK_ID_WAIT)
					end

					if networkId ~= nil then
						return descendant, networkId, descendant.Name
					end
				end
			end
		end
	end

	return nil, nil, nil
end

function trySellLootViaObjectAction(network, targetPart, targetInstance, confirmSellSuccess)
	if not network or type(network.FireServer) ~= "function" then
		return false
	end

	local actionGroupInstance, networkId, actionGroupType = resolveAutoSellActionGroupTarget(targetInstance, targetPart)
	if not actionGroupInstance or networkId == nil then
		pushDebugRateLimited("sell_object_action_missing", "sell object action group not resolved", 2)
		return false
	end

	pushDebugRateLimited(
		"sell_object_action_target",
		string.format("sell object action: %s | %s", tostring(actionGroupType), tostring(actionGroupInstance:GetFullName())),
		4
	)

	local activationId = getNextAutoSellObjectActionActivationId()
	local okStart = pcall(network.FireServer, network, "ObjectActionStarted", networkId, "Secondary", getSyncedNetworkTime(), activationId)
	if not okStart then
		return false
	end

	task.wait(AUTO_SELL_OBJECT_ACTION_DURATION)

	local finishTimestamp = getSyncedNetworkTime()
	local okFinish = pcall(network.FireServer, network, "ObjectActionFinished", activationId, finishTimestamp)
	if not okFinish then
		pcall(network.FireServer, network, "ObjectActionCancelled", activationId, finishTimestamp)
		return false
	end

	return confirmSellSuccess(AUTO_SELL_OBJECT_ACTION_CONFIRM_TIMEOUT)
end

function trySellLootNearTarget(targetPart, targetInstance, character)
	endExperimentalCFrameTravel(character or cachedCharacter)
	local filledBefore, totalBefore = getInventorySlotCounts()
	local lootSummaryBefore = getSellableLootSummary(false) or getSellableLootSummary(true)
	lastInventoryFilledSlots = filledBefore
	lastInventoryTotalSlots = totalBefore
	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	local promptKey = nil
	local matchedPrompt = nil

	local function confirmSellSuccess(timeoutSeconds)
		local sold, filledAfter, lootSummaryAfter = waitForSellInventoryDrop(filledBefore, timeoutSeconds, lootSummaryBefore)
		lastInventoryFilledSlots = filledAfter
		if isTable(lootSummaryAfter) then
			local summaryTotalSlots = tonumber(rawget(lootSummaryAfter, "totalSlots") or lootSummaryAfter.totalSlots)
			if summaryTotalSlots ~= nil then
				lastInventoryTotalSlots = summaryTotalSlots
			end
		end
		if sold then
			local soldLootValue = getSoldLootValue(lootSummaryBefore, lootSummaryAfter)
			local soldMessage = soldLootValue > 0
				and ("Sold $" .. formatMoneyAmount(soldLootValue) .. " worth of ores.")
				or "Sold ores."
			if type(spawnNotification) == "function" then
				spawnNotification(soldMessage, "success", true, 3)
			else
				notifyUser("Success", soldMessage, 3)
			end
			return true
		end
		return false
	end

	if trySellLootViaObjectAction(network, targetPart, targetInstance, confirmSellSuccess) then
		return true
	end

	if network and type(network.FireServer) == "function" then
		pcall(network.FireServer, network, "SellAllLoot")
		pcall(network.FireServer, network, "SellAllLoot", targetInstance)
		pcall(network.FireServer, network, "SellAllLoot", targetPart)
	end

	if confirmSellSuccess(0.65) then
		return true
	end

	promptKey, matchedPrompt = getSellInteractKey(targetInstance, targetPart)
	if matchedPrompt and matchedPrompt:IsA("ProximityPrompt") then
		pushDebugRateLimited(
			"sell_prompt_match",
			string.format("sell prompt matched: %s / %s", tostring(matchedPrompt.ActionText or ""), tostring(matchedPrompt.ObjectText or "")),
			4
		)

		if tryFireSellPromptDirectly(matchedPrompt) and confirmSellSuccess(math.max(0.7, (tonumber(matchedPrompt.HoldDuration) or 0) + 0.35)) then
			return true
		end
	end

	local function tryPromptKey(keyCode)
		if not keyCode then
			return false
		end

		local holdSeconds = SELL_HOLD_SECONDS
		if matchedPrompt and matchedPrompt:IsA("ProximityPrompt") then
			holdSeconds = math.max(SELL_HOLD_SECONDS, tonumber(matchedPrompt.HoldDuration) or 0)
		end

		if keyCode == autoFarmKeybind then
			suppressAutoFarmHotkey = true
			ignoreToggleUntil = os.clock() + 0.5
		end

		local pressed = sendKeyState(keyCode, true)
		task.wait(holdSeconds)
		sendKeyState(keyCode, false)
		task.wait(0.35)

		if keyCode == autoFarmKeybind then
			suppressAutoFarmHotkey = false
		end

		if not pressed then
			return false
		end

		return confirmSellSuccess(0.5)
	end

	local activeCharacter = character or cachedCharacter
	if activeCharacter and targetPart then
		facePosition(activeCharacter, targetPart.Position)
	end

	if tryPromptKey(promptKey) then
		return true
	end

	if promptKey ~= INTERACT_KEY and tryPromptKey(INTERACT_KEY) then
		return true
	end

	if promptKey ~= Enum.KeyCode.F and INTERACT_KEY ~= Enum.KeyCode.F and tryPromptKey(Enum.KeyCode.F) then
		return true
	end

	return false
end

function getDroppedItemPickupActionName(instance)
	if typeof(instance) ~= "Instance" then
		return nil
	end

	if instance.Name == "PickupItem" then
		return "PickupItem"
	end

	for _, attributeName in ipairs(AUTO_PICKUP_ACTION_ATTRIBUTE_NAMES) do
		local okAttribute, attributeValue = pcall(function()
			return instance:GetAttribute(attributeName)
		end)
		if okAttribute and type(attributeValue) == "string" and attributeValue == "PickupItem" then
			return "PickupItem"
		end

		local valueObject = instance:FindFirstChild(attributeName)
		if valueObject and valueObject:IsA("StringValue") and valueObject.Value == "PickupItem" then
			return "PickupItem"
		end
	end

	return nil
end

function resolveDroppedPickupActionTarget(dropItem, dropPart)
	local roots = {}
	local seen = {}

	local function pushRoot(instance)
		if typeof(instance) == "Instance" and not seen[instance] then
			seen[instance] = true
			table.insert(roots, instance)
		end
	end

	local pickupItem = typeof(dropItem) == "Instance" and dropItem:FindFirstChild("PickupItem", true) or nil
	pushRoot(dropItem)
	pushRoot(dropPart)
	pushRoot(pickupItem)
	pushRoot(pickupItem and pickupItem.Parent or nil)

	local current = typeof(dropItem) == "Instance" and dropItem or nil
	for _ = 1, 3 do
		current = current and current.Parent or nil
		pushRoot(current)
	end

	current = typeof(dropPart) == "Instance" and dropPart or nil
	for _ = 1, 2 do
		current = current and current.Parent or nil
		pushRoot(current)
	end

	local function tryResolveInstance(instance)
		local currentInstance = typeof(instance) == "Instance" and instance or nil
		local depth = 0
		while currentInstance and depth < 8 do
			if getDroppedItemPickupActionName(currentInstance) == "PickupItem" then
				local networkId = getAutoSellObjectActionNetworkId(currentInstance)
				if networkId == nil then
					networkId = waitForAutoSellObjectActionNetworkId(currentInstance, AUTO_SELL_OBJECT_ACTION_NETWORK_ID_WAIT)
				end
				if networkId ~= nil then
					return currentInstance, networkId
				end
			end
			currentInstance = currentInstance.Parent
			depth += 1
		end
		return nil, nil
	end

	for _, instance in ipairs(roots) do
		local actionGroupInstance, networkId = tryResolveInstance(instance)
		if actionGroupInstance and networkId ~= nil then
			return actionGroupInstance, networkId
		end
	end

	for _, root in ipairs(roots) do
		local okDescendants, descendants = pcall(function()
			return root:GetDescendants()
		end)
		if okDescendants and type(descendants) == "table" then
			for _, descendant in ipairs(descendants) do
				if getDroppedItemPickupActionName(descendant) == "PickupItem" then
					local networkId = getAutoSellObjectActionNetworkId(descendant)
					if networkId == nil then
						networkId = waitForAutoSellObjectActionNetworkId(descendant, AUTO_SELL_OBJECT_ACTION_NETWORK_ID_WAIT)
					end
					if networkId ~= nil then
						return descendant, networkId
					end
				end
			end
		end
	end

	return nil, nil
end

function waitForDroppedItemCollected(dropItem, timeoutSeconds)
	local timeoutAt = os.clock() + math.max(0.05, tonumber(timeoutSeconds) or AUTO_PICKUP_OBJECT_ACTION_CONFIRM_TIMEOUT)
	while os.clock() < timeoutAt do
		if typeof(dropItem) ~= "Instance" or not dropItem.Parent or isDroppedItemDisabled(dropItem) then
			return true
		end
		task.wait(0.03)
	end

	return typeof(dropItem) ~= "Instance" or not dropItem.Parent or isDroppedItemDisabled(dropItem)
end

