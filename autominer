        end)
        task.spawn(function()
            _UTILS._animateNotifText(titleLabel, message)
        end)
        _TweenService:Create(timerBar, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
        task.wait(0.3)
        if not timerBar.Parent or dismissing then
            return
        end
        timerStarted = true
        updateTimerBar()
        timerConnection = _RunService.Heartbeat:Connect(function(dt)
            if destroyed or dismissing or not notifContainer.Parent then
                stopTimerLoop()
                return
            end
            if type(messageUpdater) == "function" then
                local okText, updatedMessage = pcall(messageUpdater)
                if okText then
                    updatedMessage = tostring(updatedMessage or message)
                    if updatedMessage ~= message then
                        message = updatedMessage
                        titleLabel.Text = updatedMessage
                    end
                end
            end
            if not timerStarted or hoverPaused then
                return
            end
            timerRemaining = math.max(0, timerRemaining - dt)
            updateTimerBar()
            if timerRemaining <= 0 then
                task.spawn(dismissNotification)
            end
        end)
    end)
end

function evaluateTwwStaffPlayer(player)
    if not player or player == localPlayer then
        return false
    end

    local cached = S._staffCache[player.UserId]
    if cached ~= nil then
        return cached
    end

    local roleName = nil
    local okRole = pcall(function()
        roleName = player:GetRoleInGroup(S._staffGroupId)
    end)

    if okRole and roleName and S._staffRoles[roleName] then
        cached = {
            roleName = roleName,
        }
    else
        cached = false
    end

    S._staffCache[player.UserId] = cached
    return cached
end

function checkTwwStaffPlayer(player)
    if not player or player == localPlayer then
        return
    end

    task.spawn(function()
        local staffData = evaluateTwwStaffPlayer(player)
        if not staffData then
            return
        end

        if S.staffNotifyEnabled then
            spawnNotification("STAFF ALERT: " .. player.Name .. " (" .. tostring(staffData.roleName or "Staff") .. ") is in your server.", "warning", true)
        end
        if pathState and pathState.staffHopEnabled then
            local resumeSlotIndex = getPathCycleRestartSlotIndex()
            if tryPathServerHop("Staff detected, hopping servers...", resumeSlotIndex, true) then
                return
            end
        end
        if S.staffKickEnabled then
            localPlayer:Kick("Staff detected in your server: " .. player.Name .. " (" .. tostring(staffData.roleName or "Staff") .. ")")
        end
    end)
end

function scanCurrentTwwStaff(mode)
    for _, player in ipairs(_Players:GetPlayers()) do
        if player ~= localPlayer then
            local staffData = evaluateTwwStaffPlayer(player)
            if staffData then
                if mode == "notify" then
                    spawnNotification("STAFF ALERT: " .. player.Name .. " (" .. tostring(staffData.roleName or "Staff") .. ") is in your server.", "warning", true)
                    if pathState and pathState.staffHopEnabled then
                        local resumeSlotIndex = getPathCycleRestartSlotIndex()
                        if tryPathServerHop("Staff detected, hopping servers...", resumeSlotIndex, true) then
                            return
                        end
                    end
                elseif mode == "kick" then
                    localPlayer:Kick("Staff detected in your server: " .. player.Name .. " (" .. tostring(staffData.roleName or "Staff") .. ")")
                    return
                end
            end
        end
    end
end

