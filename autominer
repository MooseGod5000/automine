	end

	for _, model in ipairs(playersFolder:GetChildren()) do
		if model:IsA("Model") and model:FindFirstChildOfClass("Humanoid") then
			local loweredName = safeLower(model.Name)
			if loweredName == safeLower(LocalPlayer.Name) or loweredName == tostring(LocalPlayer.UserId) then
