	local rootPart = getRootPart(activeCharacter)
	local changed = false

	if isTable(repChar) then
		state.repChar = repChar
		changed = true
	end

	if rootPart then
		if state.originalRootAnchored == nil then
			state.originalRootAnchored = rootPart.Anchored
		end
		pcall(function()
			rootPart.Anchored = true
			rootPart.Velocity = Vector3.zero
			rootPart.RotVelocity = Vector3.zero
		end)
		pcall(function()
			rootPart.AssemblyLinearVelocity = Vector3.zero
			rootPart.AssemblyAngularVelocity = Vector3.zero
		end)
		changed = true
	end

	return changed
end

