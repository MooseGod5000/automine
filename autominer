function endExperimentalCFrameTravel(character)
	local state = getExperimentalCFrameTravelState()
	if not state.active then
		return
	end

	local activeCharacter = character or state.character
	local repChar = state.repChar or resolveLocalRepChar(false)
	local playerCharacter = state.playerCharacter or resolvePlayerCharacterModule(false)
	local humanoid = state.humanoid or getHumanoid(activeCharacter)
	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	local rootPart = getRootPart(activeCharacter)

	if isTable(repChar) then
		repChar.LocalForceCFrame = nil
	end

	if isTable(playerCharacter) then
		if state.usedSoftSelfRagdoll and type(rawget(playerCharacter, "ToggleSelfRagdoll") or playerCharacter.ToggleSelfRagdoll) == "function" then
			pcall(playerCharacter.ToggleSelfRagdoll, playerCharacter, false)
		end
		if state.usedControlLost and type(rawget(playerCharacter, "GainControl") or playerCharacter.GainControl) == "function" then
			pcall(playerCharacter.GainControl, playerCharacter)
		end
	end

	if humanoid then
		pcall(function()
			humanoid.Jump = false
			humanoid:Move(Vector3.zero)
		end)
	end

	if state.usedServerRagdoll and network and type(network.InvokeServer) == "function" then
		pcall(function()
			network:InvokeServer("AttemptGetUp")
		end)
	end

	if rootPart and state.originalRootAnchored ~= nil then
		pcall(function()
			rootPart.Anchored = state.originalRootAnchored
		end)
	end

	playerState.experimentalCFrameTravel = {}
end

function beginExperimentalCFrameTravel(character)
	if not (EXPERIMENTAL_AUTOMINE_CFRAME and movementMode == "cframe" and character) then
		return false
	end

	local state = getExperimentalCFrameTravelState()
	if state.active and state.character == character then
		return true
	end
	if state.active then
		endExperimentalCFrameTravel()
		state = getExperimentalCFrameTravelState()
	end

	local playerCharacter = resolvePlayerCharacterModule(false) or resolvePlayerCharacterModule(true)
	local repChar = resolveLocalRepChar(false) or resolveLocalRepChar(true)
	local humanoid = getHumanoid(character)

	state.active = true
	state.character = character
	state.playerCharacter = playerCharacter
	state.repChar = repChar
	state.humanoid = humanoid

	if isTable(playerCharacter) and type(rawget(playerCharacter, "OnControlLost") or playerCharacter.OnControlLost) == "function" then
		local okControlLost = pcall(playerCharacter.OnControlLost, playerCharacter)
		state.usedControlLost = okControlLost and true or false
	end

	local ragdolls = ensureExperimentalSoftRagdollBypass()
	if ragdolls and isTable(playerCharacter) then
		local ragdollMethod = rawget(playerCharacter, "Ragdoll") or playerCharacter.Ragdoll
		if type(ragdollMethod) == "function" then
			local okServerRagdoll = pcall(ragdollMethod, playerCharacter, nil, true)
			state.usedServerRagdoll = okServerRagdoll and true or false
			state.usedSoftSelfRagdoll = okServerRagdoll and true or false
		end
		if not state.usedSoftSelfRagdoll then
			local toggleSelfRagdoll = rawget(playerCharacter, "ToggleSelfRagdoll") or playerCharacter.ToggleSelfRagdoll
			if type(toggleSelfRagdoll) == "function" then
				local okSoftRagdoll = pcall(toggleSelfRagdoll, playerCharacter, true)
				state.usedSoftSelfRagdoll = okSoftRagdoll and true or false
			end
		end
	end

	if humanoid then
		pcall(function()
			if type(humanoid.UnequipTools) == "function" then
				humanoid:UnequipTools()
			end
			humanoid.Jump = false
			humanoid:Move(Vector3.zero)
		end)
	end

	if isTable(playerCharacter) and not state.usedControlLost then
		if type(rawget(playerCharacter, "EquipItem") or playerCharacter.EquipItem) == "function" then
			pcall(playerCharacter.EquipItem, playerCharacter, nil, true)
		end
		if type(rawget(playerCharacter, "StopAllTracks") or playerCharacter.StopAllTracks) == "function" then
			pcall(playerCharacter.StopAllTracks, playerCharacter)
		end
	end

	enforceExperimentalCFrameFreezeState(character)
	return true
end

