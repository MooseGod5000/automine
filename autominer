    dropList.Parent = dropFrame

    local dropLayout = Instance.new("UIListLayout")
    dropLayout.SortOrder = Enum.SortOrder.Name
    dropLayout.Parent = dropList

    local function normalizeDropdownSearchText(text)
        local normalized = tostring(text or ""):lower()
        normalized = normalized:gsub("^%s+", "")
        normalized = normalized:gsub("^%[x%]%s*", "")
        normalized = normalized:gsub("^\226\156\147%s*", "")
        return normalized
    end

    local function dropdownTextMatchesQuery(haystackText, queryText)
        local normalizedHaystack = normalizeDropdownSearchText(haystackText)
        if normalizedHaystack == "" then
            return false
        end
        if normalizedHaystack:find(queryText, 1, true) then
            return true
        end
        local compactHaystack = normalizedHaystack:gsub("%s+", "")
        local compactQuery = tostring(queryText or ""):gsub("%s+", "")
        return compactQuery ~= "" and compactHaystack:find(compactQuery, 1, true) ~= nil
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = normalizeDropdownSearchText(searchBox.Text)
        for _, child in pairs(dropList:GetChildren()) do
            if child:IsA("TextButton") then
                if query == "" then
                    child.Visible = true
                else
                    local found = false
                    local haystacks = {
                        child:GetAttribute("SearchText"),
                        normalizeDropdownSearchText(child.Name),
                        normalizeDropdownSearchText(child.Text),
                    }
                    for _, haystack in ipairs(haystacks) do
                        if dropdownTextMatchesQuery(haystack, query) then
                            found = true
                            break
                        end
                    end
                    if not found then
                        for _, desc in pairs(child:GetChildren()) do
                            if desc:IsA("TextLabel") and dropdownTextMatchesQuery(desc.Text, query) then
                                found = true
                                break
                            end
                        end
                    end
                    child.Visible = found
                end
            end
        end
    end)

    local ddDragging = false
    local ddDragInput, ddDragStart, ddStartPos
    local ddTargetRot, ddCurrentRot, ddLastMouseX = 0, 0, nil

    dropFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            ddDragging = true
            ddDragStart = input.Position
            ddStartPos = dropFrame.Position
        end
    end)

    _UserInputService.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and ddDragging then
            ddDragInput = input
        end
    end)

    _UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            ddDragging = false
        end
    end)

    _RunService.RenderStepped:Connect(function(dt)
        if dropGui.Enabled then
            if ddDragging and ddDragInput then
                local delta = ddDragInput.Position - ddDragStart
                local dest = UDim2.new(ddStartPos.X.Scale, ddStartPos.X.Offset + delta.X, ddStartPos.Y.Scale, ddStartPos.Y.Offset + delta.Y)
                dropFrame.Position = dropFrame.Position:Lerp(dest, math.min(dt * 20, 1))
                if ddLastMouseX then
                    ddTargetRot = math.clamp(-(ddDragInput.Position.X - ddLastMouseX) * 0.7, -15, 15)
                end
                ddLastMouseX = ddDragInput.Position.X
            else
                ddLastMouseX = nil
                ddTargetRot = 0
            end
            ddCurrentRot = ddCurrentRot + (ddTargetRot - ddCurrentRot) * math.min(dt * 10, 1)
            dropFrame.Rotation = ddCurrentRot
        end
    end)

    local function positionDropdown(anchorGuiObject)
        local camera = workspace.CurrentCamera
        local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
        local padding = 10
        local frameWidth = dropFrame.AbsoluteSize.X > 0 and dropFrame.AbsoluteSize.X or 240
        local frameHeight = dropFrame.AbsoluteSize.Y > 0 and dropFrame.AbsoluteSize.Y or 220
        local defaultX = math.floor((viewport.X - frameWidth) * 0.5)
        local defaultY = math.floor((viewport.Y - frameHeight) * 0.5)

        if typeof(anchorGuiObject) == "Instance" and anchorGuiObject:IsA("GuiObject") then
            local anchorPos = anchorGuiObject.AbsolutePosition
            local anchorSize = anchorGuiObject.AbsoluteSize
            local targetX = anchorPos.X + anchorSize.X + 12
            local targetY = anchorPos.Y
            local maxX = math.max(padding, viewport.X - frameWidth - padding)
            local maxY = math.max(padding, viewport.Y - frameHeight - padding)

            if targetX > maxX then
                targetX = anchorPos.X - frameWidth - 12
            end

            targetX = math.clamp(targetX, padding, maxX)
            targetY = math.clamp(targetY, padding, maxY)
            dropFrame.Position = UDim2.fromOffset(targetX, targetY)
            return
        end

        dropFrame.Position = UDim2.fromOffset(defaultX, defaultY)
    end

    local function showDropdown(anchorGuiObject)
        searchBox.Text = ""
        positionDropdown(anchorGuiObject)
        dropGui.Enabled = true
    end

    local function hideDropdown()
        dropGui.Enabled = false
    end

    closeDropBtn.MouseButton1Click:Connect(hideDropdown)
    table.insert(_allDropdownGuis, dropGui)
    table.insert(_extraCleanupGuis, dropGui)

    return dropFrame, dropList, searchBox, showDropdown, hideDropdown
end

