function trimConfigName(rawValue)
    return (tostring(rawValue or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

function sanitizeConfigFileKey(rawValue)
    local cleaned = trimConfigName(rawValue)
    cleaned = cleaned:gsub("[/\\:%*%?\"<>|]", "_")
    cleaned = cleaned:gsub("%s+", "_")
    cleaned = cleaned:gsub("[^%w%-%_]", "_")
    cleaned = cleaned:gsub("_+", "_")
    return cleaned ~= "" and cleaned or "config"
end

function normalizeSavedConfigNames(source)
    local result = {}
    local seen = {}

    if type(source) == "table" then
        for _, rawName in ipairs(source) do
            local trimmed = trimConfigName(rawName)
            if trimmed ~= "" and trimmed ~= CONFIG_SYSTEM.AUTOSAVE_NAME and not seen[trimmed] then
                seen[trimmed] = true
                table.insert(result, trimmed)
            end
        end
    end

    table.sort(result, function(a, b)
        return a:lower() < b:lower()
    end)

    return result
end

function getConfigFilePath(name)
    local fileKey = tostring(name) == CONFIG_SYSTEM.AUTOSAVE_NAME and CONFIG_SYSTEM.AUTOSAVE_FILE_KEY or sanitizeConfigFileKey(name)
    local fileName = fileKey .. ".cfg"
    if storageFolderApisAvailable then
        return CONFIG_SYSTEM.FOLDER .. "/" .. fileName
    end
    return fileName
end

function getSelectedConfigName()
    local selected = trimConfigName(CONFIG_SYSTEM.selectedConfigName)
