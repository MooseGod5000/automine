	end

	local amount = tonumber(
		rawget(inventoryItem, "Amount")
			or inventoryItem.Amount
			or rawget(inventoryItem, "Count")
			or inventoryItem.Count
			or rawget(inventoryItem, "Quantity")
			or inventoryItem.Quantity
			or rawget(inventoryItem, "StackSize")
