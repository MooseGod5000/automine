function getPickaxeTextScore(value)
	if type(value) ~= "string" then
		return 0
	end

	local normalized = safeLower(value):gsub("[^%w]", "")
	if normalized == "" then
		return 0
	end
	local tier = tonumber(string.match(normalized, "tier(%d+)pickaxe"))
	if tier ~= nil then
		return 20 + tier
	end
	if string.find(normalized, "basicpickaxe", 1, true) ~= nil then
		return 21
	end
	if string.find(normalized, "pickaxe", 1, true) ~= nil then
		return 8
	end
	if string.find(normalized, "pickax", 1, true) ~= nil then
		return 7
	end
	return 0
end

function resolveSharedItemData(playerItems, item)
	item = getResolvedItemData(item)
	if not isTable(playerItems) or not isTable(item) then
		return nil
	end

	local itemType = rawget(item, "Type") or item.Type
	if type(itemType) ~= "string" or itemType == "" then
		return nil
	end

	return rawget(playerItems, itemType) or playerItems[itemType]
end

function scorePickaxeItemCandidate(item, playerItems)
	item = getResolvedItemData(item)
	if not isTable(item) then
		return 0
	end

	local bestScore = 0
	local function scanSource(source)
		if not isTable(source) then
			return
		end

		for _, key in ipairs({
			"Type",
			"Id",
			"Name",
			"DisplayName",
			"ItemType",
			"VariantOf",
			"Model",
			"ModelName",
			"WorldModel",
			"WorldModelName",
			"ViewModel",
			"ViewModelName",
		}) do
			local score = getPickaxeTextScore(rawget(source, key) or source[key])
			if score > bestScore then
				bestScore = score
			end
		end

		if rawget(source, "IsPickaxe") == true or source.IsPickaxe == true then
			bestScore = math.max(bestScore, 9)
		end
		if rawget(source, "Pickaxe") == true or source.Pickaxe == true then
			bestScore = math.max(bestScore, 9)
		end
		if rawget(source, "MinePower") ~= nil or source.MinePower ~= nil
			or rawget(source, "MiningPower") ~= nil or source.MiningPower ~= nil
			or rawget(source, "PickaxePower") ~= nil or source.PickaxePower ~= nil then
			bestScore = math.max(bestScore, 7)
		end
		local pickaxeTier = tonumber(rawget(source, "PickaxeTier") or source.PickaxeTier)
		if pickaxeTier ~= nil then
			bestScore = math.max(bestScore, 20 + pickaxeTier)
		end
	end

	scanSource(item)
	scanSource(resolveSharedItemData(playerItems, item))
	return bestScore
end

function isLikelyPickaxeItem(item, playerItems)
	return scorePickaxeItemCandidate(item, playerItems) > 0
end

function getPlayerCharacterItemData(playerCharacter, methodName)
	if not isTable(playerCharacter) then
