local function clonePlayerEspMethods(source)
    local cloned = {
        Text = false,
        Box = false,
        Tracer = false,
        Figure = false,
    }

    if type(source) == "table" then
        for _, methodName in ipairs(PLAYER_ESP_METHOD_ORDER) do
            cloned[methodName] = source[methodName] == true
        end
    end

    if not cloned.Text and not cloned.Box and not cloned.Tracer and not cloned.Figure then
        cloned.Text = true
    end

    return cloned
end

local function cloneGunTargetPriority(source)
    local cloned = {
        Players = false,
        NPCs = false,
        Entities = false,
    }

    if type(source) == "table" then
        for _, priorityName in ipairs(GUN_TARGET_PRIORITY_ORDER) do
            cloned[priorityName] = source[priorityName] == true
        end
    end

    if not cloned.Players and not cloned.NPCs and not cloned.Entities then
        cloned.Players = true
    end

    return cloned
end

local function cloneAutomineWebhookOptions(source)
    local cloned = {
        ["Track earnings"] = true,
        ["Track flags"] = false,
    }

    if type(source) == "table" then
        for _, optionName in ipairs(AUTOMINE_WEBHOOK_TRACK_OPTION_ORDER) do
            if source[optionName] ~= nil then
                cloned[optionName] = source[optionName] == true
            end
        end
    end

    if not cloned["Track earnings"] and not cloned["Track flags"] then
        cloned["Track earnings"] = true
    end

    return cloned
end

local function normalizePathPlayerAvoiderMethod(value)
    local candidate = tostring(value or DEFAULTS.pathPlayerAvoiderMethod)
    for _, methodName in ipairs(PATH_PLAYER_AVOIDER_METHOD_ORDER) do
        if string.lower(candidate) == string.lower(methodName) then
