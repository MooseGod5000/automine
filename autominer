	return true
end

function deleteSelectedPath(slotIndex)
	local targetSlotIndex = normalizePathSlotIndex(slotIndex) or pathState.focusedPathSlotIndex or 1
	local selectedName = getPathSlotSelection(targetSlotIndex, false)
	if not selectedName or not pathState.paths[selectedName] then
		return false
	end

	pathState.paths[selectedName] = nil
	clearPathReferences(selectedName)
	if pathState.playbackPathName == selectedName
		or pathState.spawnPlaybackPendingPathName == selectedName
		or pathState.spawnPlaybackReadyPathName == selectedName then
		pathState.playLoopEnabled = false
		pathState.alwaysPlayEnabled = false
		pathState.resumePathPlaybackPending = false
		resetPathPlaybackState()
		cancelPendingPathSpawnPlayback(true)
	end
	if pathState.editorVisible and pathState.editingSavedPath then
		pathState.editorVisible = false
		clearRecordedPathVisuals()
	end
	setFocusedPathSlotIndex(targetSlotIndex, true)
	setPathDeleteConfirmSlot(nil)
	savePathsToStorage(true)
	refreshPathManagerButtons()
	refreshPathEditorButtons()
	refreshPathVisuals()
	updateAutofarmLayout()
	notifyUser("Paths", "Deleted path: " .. selectedName, 4)
	return true
end

function tryMarkHoveredOre()
	if not pathState.editorVisible then
		return false
	end

	ensureWorkingPathStartNode()
	if #pathState.workingPath.nodes == 0 then
		setPathEditorStatus("Record at least one node before marking ores.", UI_COLORS.warning)
		return false
	end

	local mouse = LocalPlayer:GetMouse()
	local oreDeposit = mouse and getOreDepositFromInstance(mouse.Target)
	if not oreDeposit then
		setPathEditorStatus("Hover an ore deposit, then press the mark key.", UI_COLORS.warning)
		return false
	end

	local orePosition = getOrePosition(oreDeposit)
	local groupName = getOreGroupName(oreDeposit)
	if not orePosition then
		setPathEditorStatus("That ore could not be resolved right now.", UI_COLORS.warning)
		return false
	end
	if not groupName then
		setPathEditorStatus("That ore type could not be identified right now.", UI_COLORS.warning)
		return false
	end

	for order, existingOre in ipairs(pathState.workingPath.ores) do
		if existingOre.groupName == groupName and existingOre.position and (existingOre.position - orePosition).Magnitude <= 6 then
			table.remove(pathState.workingPath.ores, order)
			refreshPathVisuals()
			setPathEditorStatus("Unmarked " .. getOreLabel(groupName) .. ".", UI_COLORS.warning)
			return false
		end
	end

	local nodeIndex, nodeDistance = getClosestPathNodeIndex(orePosition)
	if not nodeIndex or nodeDistance > MINE_AURA_RANGE then
		setPathEditorStatus("Move a sphere closer to that ore before marking it.", UI_COLORS.warning)
		return false
	end

	table.insert(pathState.workingPath.ores, {
		groupName = groupName,
		position = orePosition,
		nodeIndex = nodeIndex,
	})
	refreshPathVisuals()
	setPathEditorStatus("Marked ore #" .. tostring(#pathState.workingPath.ores) .. ": " .. getOreLabel(groupName), UI_COLORS.success)
	return true
end

function toggleAutoMineFromControl(sourceLabel)
	return togglePathLoopFromControl(sourceLabel)
end

function togglePathLoopFromControl(sourceLabel, slotIndex)
	if os.clock() < ignoreToggleUntil then
		pushDebug("path play toggle ignored from " .. sourceLabel)
		return
	end

	local now = os.clock()
	if (now - lastToggleAt) < TOGGLE_DEBOUNCE then
		pushDebug("path play toggle ignored by debounce")
		return
	end
	lastToggleAt = now

	local requestedStartSlot = getPlayablePathSlotIndex(slotIndex or pathState.sequenceStartSlotIndex or 1)
	if not requestedStartSlot then
		pushDebug("path play start blocked: no path selected")
		setStatus("Pick a saved path first", Color3.fromRGB(255, 190, 120))
		return
	end
	setPathSequenceStartSlotIndex(requestedStartSlot)
	setFocusedPathSlotIndex(requestedStartSlot, true)

	local pathActive = isPathPlaybackBusy()
	if pathActive then
		pathState.playLoopEnabled = false
		if autoMineEnabled and activeFarmMode == "path" then
			stopAutoMine()
		else
			cancelPendingPathSpawnPlayback(true)
			activeFarmMode = nil
			setStatus("Idle", Color3.fromRGB(180, 180, 180))
		end
	else
		pathState.playLoopEnabled = true
		if autoMineEnabled then
			stopAutoMine()
		end
		activeFarmMode = "path"
		local ok, started = xpcall(function()
			return startPathPlaybackForSlot(requestedStartSlot, sourceLabel)
		end, debug.traceback)
		if not ok then
