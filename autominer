function getSelectedPickupSummary()
	local itemNames = getSelectedPickupNamesOrdered()
	if #itemNames == 0 then
		return "No pickup filter"
	end

	if #itemNames == 1 then
		return getPickupLabel(itemNames[1])
	end

	if #itemNames == 2 then
		return getPickupLabel(itemNames[1]) .. ", " .. getPickupLabel(itemNames[2])
	end

	return string.format("%s, %s +%d", getPickupLabel(itemNames[1]), getPickupLabel(itemNames[2]), #itemNames - 2)
end

function getDropItemTypeName(dropItem)
	if not dropItem then
		return nil
	end

	local pickupItem = dropItem:FindFirstChild("PickupItem", true)
	local candidates = {
		dropItem:GetAttribute("ItemType"),
		dropItem:GetAttribute("ItemName"),
		dropItem:GetAttribute("Type"),
		dropItem.Name,
	}

	if pickupItem then
		table.insert(candidates, pickupItem:GetAttribute("ItemType"))
		table.insert(candidates, pickupItem:GetAttribute("ItemName"))
		table.insert(candidates, pickupItem:GetAttribute("Type"))

		for _, childName in ipairs({ "ItemType", "ItemName", "Type", "ItemId" }) do
			local valueObject = pickupItem:FindFirstChild(childName)
			if valueObject and valueObject:IsA("StringValue") then
				table.insert(candidates, valueObject.Value)
			end
		end
	end

	for _, candidate in ipairs(candidates) do
		if type(candidate) == "string" and AUTO_PICKUP_LABELS[candidate] then
			return candidate
		end
	end

	local fallbackName = tostring(dropItem.Name or "")
	local loweredFallback = safeLower(fallbackName)
	for itemName in pairs(AUTO_PICKUP_LABELS) do
		if string.find(loweredFallback, safeLower(itemName), 1, true) then
			return itemName
		end
	end

	return dropItem.Name
end

function isAutoPickupDropAllowed(dropItem)
	if not autoPickupWhitelistEnabled then
		return true
	end

	local itemName = getDropItemTypeName(dropItem)
	return itemName ~= nil and selectedPickupNames[itemName] == true
end

function getInventorySlotsFrame()
	if cachedInventorySlotsFrame and cachedInventorySlotsFrame.Parent then
		return cachedInventorySlotsFrame
	end

	local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not playerGui then
		cachedInventorySlotsFrame = nil
		return nil
	end

	local inventoryUI = playerGui:FindFirstChild("InventoryUI") or playerGui:FindFirstChild("InventoryUI", true)
	local inventory = inventoryUI and inventoryUI:FindFirstChild("Inventory")
	local container = inventory and inventory:FindFirstChild("Container")
	local body = container and container:FindFirstChild("Body")
	local page = body and body:FindFirstChild("Page")
	local scrollingFrame = page and page:FindFirstChild("ScrollingFrame")

	if not scrollingFrame then
		for _, descendant in ipairs(playerGui:GetDescendants()) do
			if descendant:IsA("ScrollingFrame") and descendant.Name == "ScrollingFrame" then
				local slotTemplate = descendant:FindFirstChild("SlotTemplate") or descendant:FindFirstChild("SlotTemplate", true)
				local containerFrame = slotTemplate and slotTemplate:FindFirstChild("Container")
				local viewportFrame = containerFrame and containerFrame:FindFirstChild("ViewportFrame")
				if viewportFrame then
					scrollingFrame = descendant
					break
				end
			end
		end
	end

	cachedInventorySlotsFrame = scrollingFrame
	return cachedInventorySlotsFrame
end

function getViewportFrameItemName(viewportFrame)
	if not viewportFrame then
		return nil
	end

	for _, child in ipairs(viewportFrame:GetChildren()) do
		local isVisualItem = not child:IsA("Camera")
			and not child:IsA("UIAspectRatioConstraint")
			and not child:IsA("UISizeConstraint")
			and not child:IsA("UIScale")
			and not child:IsA("UIPadding")
			and not child:IsA("UICorner")
			and not child:IsA("UIStroke")
			and not child:IsA("UIGradient")
		if isVisualItem then
			return child.Name
		end
	end

	return nil
end

function getInventorySlotCounts()
	local scrollingFrame = getInventorySlotsFrame()
	if not scrollingFrame then
		return 0, 0
	end

	local filledSlots = 0
	local totalSlots = 0

	for _, child in ipairs(scrollingFrame:GetDescendants()) do
		local container = child:FindFirstChild("Container")
		local viewportFrame = container and container:FindFirstChild("ViewportFrame")
		if viewportFrame and child.Name == "SlotTemplate" then
			totalSlots += 1
			if getViewportFrameItemName(viewportFrame) then
				filledSlots += 1
			end
		end
	end

	return filledSlots, totalSlots
end

function getOrderedInventorySlotFrames()
	local scrollingFrame = getInventorySlotsFrame()
	if not scrollingFrame then
		return {}
	end

	local slotFrames = {}
	for _, descendant in ipairs(scrollingFrame:GetDescendants()) do
		local container = descendant:FindFirstChild("Container")
		local viewportFrame = container and container:FindFirstChild("ViewportFrame")
		if viewportFrame and descendant.Name == "SlotTemplate" then
			table.insert(slotFrames, descendant)
		end
	end

	table.sort(slotFrames, function(left, right)
		local leftOrder = tonumber(left.LayoutOrder) or 0
		local rightOrder = tonumber(right.LayoutOrder) or 0
		if leftOrder ~= rightOrder then
			return leftOrder < rightOrder
		end
		return tostring(left:GetFullName()) < tostring(right:GetFullName())
	end)

	return slotFrames
end

function normalizeInventoryItemLookupName(rawName)
	if type(rawName) ~= "string" or rawName == "" then
		return nil
	end

	local normalized = safeLower(rawName):gsub("[^%w]", "")
	if normalized == "" then
		return nil
	end

	return normalized
end

function resolveSharedPlayerItemRecordByName(rawName, forceRefresh)
	local normalized = normalizeInventoryItemLookupName(rawName)
	if not normalized then
		return nil, nil
	end

	local playerItems = resolveSharedPlayerItems(forceRefresh)
	if not isTable(playerItems) then
		return nil, nil
	end

	for itemType, sharedItemData in pairs(playerItems) do
		if isTable(sharedItemData) then
			local nameCandidates = {
				itemType,
				rawget(sharedItemData, "Display") or sharedItemData.Display,
				rawget(sharedItemData, "Name") or sharedItemData.Name,
			}
			for _, candidateName in ipairs(nameCandidates) do
				if type(candidateName) == "string" and normalized == safeLower(candidateName):gsub("[^%w]", "") then
					return itemType, sharedItemData
				end
			end
		end
	end

	return nil, nil
end

function getSharedInventoryDiscardFlags(sharedItemData)
	if not isTable(sharedItemData) then
		return false, false
	end

	local isLoot = (rawget(sharedItemData, "IsLoot") or sharedItemData.IsLoot) == true
	local droppable = rawget(sharedItemData, "Droppable")
	if droppable == nil then
		droppable = sharedItemData.Droppable
	end
	local canBeDiscarded = rawget(sharedItemData, "CanBeDiscarded")
	if canBeDiscarded == nil then
		canBeDiscarded = sharedItemData.CanBeDiscarded
	end

	local hasDiscardAction = false
	local validActions = rawget(sharedItemData, "ValidActions") or sharedItemData.ValidActions
	if isTable(validActions) then
		for key, value in pairs(validActions) do
			local actionName = nil
			if type(key) == "string" and value then
				actionName = key
			elseif type(value) == "string" then
				actionName = value
			end
			local normalizedAction = actionName and safeLower(actionName) or nil
			if normalizedAction and (string.find(normalizedAction, "drop", 1, true) or string.find(normalizedAction, "throw", 1, true) or string.find(normalizedAction, "discard", 1, true)) then
				hasDiscardAction = true
				break
			end
		end
	end

	return droppable == true or canBeDiscarded == true or hasDiscardAction, isLoot
end

function isOreInventoryType(itemType)
	return type(itemType) == "string" and INVENTORY_ORE_LABELS[itemType] ~= nil
end

function getInventoryOreLabel(itemType)
	return INVENTORY_ORE_LABELS[itemType] or tostring(itemType or "Unknown")
end

function getInventoryDiscardDisplayName(discardState)
	if not isTable(discardState) then
		return "item"
	end

	local itemType = rawget(discardState, "itemType") or discardState.itemType
	local sharedItemData = rawget(discardState, "sharedItemData") or discardState.sharedItemData
	local displayName = isTable(sharedItemData) and (rawget(sharedItemData, "Display") or sharedItemData.Display) or nil
	if type(displayName) == "string" and displayName ~= "" then
		return displayName
	end

	if isOreInventoryType(itemType) then
		return getInventoryOreLabel(itemType)
	end

	local visualName = rawget(discardState, "visualName") or discardState.visualName
	if type(visualName) == "string" and visualName ~= "" then
		return visualName
	end

	return tostring(itemType or "item")
end

function getOrderedInventoryItems(inventoryContainer)
	local items = isTable(inventoryContainer) and (rawget(inventoryContainer, "Items") or inventoryContainer.Items) or nil
	if not isTable(items) then
		return {}
	end

	local orderedItems = {}
	for key, inventoryItem in pairs(items) do
		if isTable(inventoryItem) then
			table.insert(orderedItems, {
				key = key,
				numericKey = tonumber(key),
				item = inventoryItem,
			})
		end
	end

	table.sort(orderedItems, function(left, right)
		if left.numericKey and right.numericKey and left.numericKey ~= right.numericKey then
			return left.numericKey < right.numericKey
		end
		if left.numericKey ~= nil and right.numericKey == nil then
			return true
		end
		if right.numericKey ~= nil and left.numericKey == nil then
			return false
		end
		return tostring(left.key) < tostring(right.key)
	end)

	return orderedItems
end

function getLastInventorySlotOreState(forceRefresh)
	local playerData = resolvePlayerDataModule(forceRefresh)
	local playerItems = resolveSharedPlayerItems(forceRefresh)
	local inventoryContainer = getResolvedInventoryContainer(playerData)
	if not (isTable(playerData) and isTable(playerItems) and isTable(inventoryContainer)) then
		return nil, "inventory container unavailable"
	end

	local orderedItems = getOrderedInventoryItems(inventoryContainer)
	local filledSlots = #orderedItems
	local totalSlots = tonumber(rawget(inventoryContainer, "Size") or inventoryContainer.Size) or 0
	if totalSlots <= 0 then
		return nil, "inventory size unavailable"
	end
	if filledSlots < totalSlots then
		return nil, string.format("waiting for last slot (%d/%d)", filledSlots, totalSlots)
	end

	local candidateEntry = orderedItems[#orderedItems]
	local inventoryItem = nil
	if isTable(candidateEntry) then
		inventoryItem = candidateEntry.item
	end

	local itemType = isTable(inventoryItem) and (rawget(inventoryItem, "Type") or inventoryItem.Type) or nil
	if not isOreInventoryType(itemType) then
		return nil, "last slot item not ore: " .. tostring(itemType or "nil")
	end

	local sharedItemData = rawget(playerItems, itemType) or playerItems[itemType]
	local isDiscardable, isLoot = getSharedInventoryDiscardFlags(sharedItemData)
	if not isTable(inventoryItem) or not isDiscardable or isLoot ~= true then
		return nil, "last slot ore blocked: " .. tostring(itemType)
	end

	local itemId = isTable(inventoryItem) and (rawget(inventoryItem, "Id") or inventoryItem.Id) or nil
	local visualName = nil
	local slotFrames = getOrderedInventorySlotFrames()
	local lastSlot = slotFrames[#slotFrames]
	if lastSlot then
		local container = lastSlot:FindFirstChild("Container")
		local viewportFrame = container and container:FindFirstChild("ViewportFrame")
		visualName = getViewportFrameItemName(viewportFrame)
	end

	return {
		slotFrame = lastSlot,
		visualName = visualName,
		itemType = itemType,
		itemId = itemId,
		inventoryItem = inventoryItem,
		sharedItemData = sharedItemData,
		isLoot = isLoot,
		filledSlots = filledSlots,
		totalSlots = totalSlots,
	}, nil
end

function hasRemainingPathOresToMine(currentPath, nodeIndex)
	if not isTable(currentPath) then
		return false
	end

	local currentNodeIndex = math.max(1, tonumber(nodeIndex) or 1)
	for _, oreTarget in ipairs(currentPath.ores or {}) do
		local oreNodeIndex = tonumber(oreTarget.nodeIndex) or 0
		if oreNodeIndex >= currentNodeIndex then
			local resolvedOre = resolveSavedOreTarget(oreTarget)
			local oreRemaining = getOreRemainingValue(resolvedOre)
			if resolvedOre and oreRemaining and (tonumber(oreRemaining.Value) or 0) > 0 then
				return true
			end
		end
	end

	return false
end

function shouldPreserveLastSlotOreForSell(discardState)
	if activeFarmMode ~= "path" or not pathState.playbackActive or not pathState.playbackSellPending then
		return false
	end

	if isTable(discardState) and (rawget(discardState, "isLoot") or discardState.isLoot) ~= true then
		return false
	end

	local currentPath = pathState.currentPath
	if not isTable(currentPath) then
		return false
	end

	if hasRemainingPathOresToMine(currentPath, pathState.playbackNodeIndex) then
		return false
	end

	return isPathPlaybackSellReady()
end

function waitForLastSlotOreDiscard(beforeSummary, discardedState, timeoutSeconds)
	local deadline = os.clock() + math.max(0.1, tonumber(timeoutSeconds) or AUTO_LAST_SLOT_ORE_DISCARD_CONFIRM_TIMEOUT)
	while os.clock() < deadline do
		task.wait(0.05)

		local afterSummary = getSellableLootSummary(false) or getSellableLootSummary(true)
		if isTable(beforeSummary) and isTable(afterSummary) and wasSellableLootReduced(beforeSummary, afterSummary) then
			return true
		end

		local latestState = getLastInventorySlotOreState(false) or getLastInventorySlotOreState(true)
		if not latestState then
			return true
		end
		if latestState.itemType ~= discardedState.itemType then
			return true
		end
		if type(discardedState.itemId) == "string"
			and type(latestState.itemId) == "string"
			and latestState.itemId ~= discardedState.itemId then
			return true
		end
	end

	return false
end

function collectInventoryDiscardActionNames(sharedItemData)
	local actionNames = {}
	local seen = {}
	local function pushActionName(value)
		if type(value) ~= "string" or value == "" or seen[value] then
			return
		end
		seen[value] = true
		table.insert(actionNames, value)
	end

	local validActions = isTable(sharedItemData) and (rawget(sharedItemData, "ValidActions") or sharedItemData.ValidActions) or nil
	if isTable(validActions) then
		for key, value in pairs(validActions) do
			if type(key) == "string" and value then
				pushActionName(key)
			elseif type(value) == "string" then
				pushActionName(value)
			end
		end
	end

	pushActionName("DropItem")
	pushActionName("ThrowAway")
	pushActionName("DiscardItem")
	pushActionName("DropInventoryItem")
	pushActionName("DiscardInventoryItem")
	pushActionName("DropContainerItem")
	pushActionName("DestroyInventoryItem")
	pushActionName("RemoveInventoryItem")
	return actionNames
end

function collectKeywordMethodNames(owner, baseNames)
	local methodNames = {}
	local seen = {}
	local function pushMethodName(name)
		if type(name) ~= "string" or name == "" or seen[name] then
			return
		end
		seen[name] = true
		table.insert(methodNames, name)
	end

	for _, name in ipairs(baseNames or {}) do
		pushMethodName(name)
	end

	if not isTable(owner) then
		return methodNames
	end

	for key, value in pairs(owner) do
		if type(key) == "string" and type(value) == "function" then
			local normalizedKey = safeLower(key)
			if string.find(normalizedKey, "drop", 1, true)
				or string.find(normalizedKey, "throw", 1, true)
				or string.find(normalizedKey, "discard", 1, true)
				or string.find(normalizedKey, "destroy", 1, true)
				or string.find(normalizedKey, "remove", 1, true)
				or string.find(normalizedKey, "delete", 1, true) then
				pushMethodName(key)
			end
		end
	end

	return methodNames
end

function getPlayerCharacterItemObject(playerCharacter, itemType)
	if not isTable(playerCharacter) or type(itemType) ~= "string" or itemType == "" then
		return nil
	end

	local getItem = rawget(playerCharacter, "GetItem") or playerCharacter.GetItem
	if type(getItem) ~= "function" then
		return nil
	end

	local okItem, itemObject = pcall(getItem, playerCharacter, itemType)
	if okItem and isTable(itemObject) then
		return itemObject
	end

	return nil
end

function tryAutoDiscardLastSlotOre(character, activeToken)
	if not autoMineEnabled or activeToken ~= autoMineToken then
		return false
	end

	local now = os.clock()
	if (now - lastAutoDiscardScanAt) < AUTO_LAST_SLOT_ORE_DISCARD_SCAN_INTERVAL then
		return false
	end
	lastAutoDiscardScanAt = now

	local discardState, discardReason = getLastInventorySlotOreState(false)
	if not discardState then
		discardState, discardReason = getLastInventorySlotOreState(true)
	end
	if not discardState then
		pushDebugRateLimited("last_slot_discard_probe", "last-slot discard: " .. tostring(discardReason or "not ready"), 2)
		return false
	end
	if shouldPreserveLastSlotOreForSell(discardState) then
		pushDebugRateLimited(
			"last_slot_discard_preserve",
			"last-slot discard: keeping final " .. tostring(getInventoryDiscardDisplayName(discardState)) .. " for sell",
			2
		)
		return false
	end

	local itemType = discardState.itemType
	local discardKey = tostring(itemType) .. ":" .. tostring(discardState.itemId or discardState.visualName or "slot")
	if lastAutoDiscardItemKey == discardKey and (now - lastAutoDiscardAttemptAt) < AUTO_LAST_SLOT_ORE_DISCARD_COOLDOWN then
		return false
	end

	local playerData = resolvePlayerDataModule(false) or resolvePlayerDataModule(true)
	local inventoryContainer = getResolvedInventoryContainer(playerData)
	local inventoryItem = discardState.inventoryItem
	if not isTable(playerData) or not isTable(inventoryContainer) or not isTable(inventoryItem) then
		return false
	end

	local inventoryItemId = rawget(inventoryItem, "Id") or inventoryItem.Id
	local inventoryContainerId = rawget(inventoryContainer, "Id") or inventoryContainer.Id
	if type(inventoryItemId) ~= "string" or inventoryItemId == "" then
		return false
	end

	lastAutoDiscardAttemptAt = now
	lastAutoDiscardItemKey = discardKey

	local lootSummaryBefore = getSellableLootSummary(false) or getSellableLootSummary(true)
	local discardLabel = getInventoryDiscardDisplayName(discardState)
	pushDebugRateLimited(
		"last_slot_discard_attempt",
		string.format(
			"last-slot discard attempt: %s (%d/%d)",
			tostring(discardLabel),
			tonumber(discardState.filledSlots) or 0,
			tonumber(discardState.totalSlots) or 0
		),
		1.5
	)

	setStatus("Discarding " .. discardLabel, Color3.fromRGB(255, 190, 120))
	clearMovementKeys()
	setInteractKeyHeld(false)
	endExperimentalCFrameTravel(character)

	local discardMethod = rawget(inventoryContainer, "DiscardItem") or inventoryContainer.DiscardItem
	if type(discardMethod) == "function" then
		local okCall, callErr = pcall(discardMethod, inventoryContainer, inventoryItem)
		if okCall and waitForLastSlotOreDiscard(lootSummaryBefore, discardState, AUTO_LAST_SLOT_ORE_DISCARD_CONFIRM_TIMEOUT) then
			pushDebug("discarded last-slot ore via inventory container discard")
			return true
		elseif not okCall then
			pushDebugRateLimited("last_slot_discard_method_error", "last-slot discard method error: " .. tostring(callErr), 2)
		end
	else
		pushDebugRateLimited("last_slot_discard_method_missing", "last-slot discard: inventory container has no DiscardItem method", 2)
	end

	local network = resolveGlobalNetwork(false) or resolveGlobalNetwork(true)
	if network and type(network.FireServer) == "function" and type(inventoryContainerId) == "string" and inventoryContainerId ~= "" then
		local okFire, fireErr = pcall(function()
			network:FireServer("ContainerDiscardItem", inventoryContainerId, inventoryItemId)
		end)
		if okFire and waitForLastSlotOreDiscard(lootSummaryBefore, discardState, AUTO_LAST_SLOT_ORE_DISCARD_CONFIRM_TIMEOUT) then
			pushDebug("discarded last-slot ore via ContainerDiscardItem")
			return true
		elseif not okFire then
			pushDebugRateLimited("last_slot_discard_network_error", "last-slot discard network error: " .. tostring(fireErr), 2)
		end
	elseif type(inventoryContainerId) ~= "string" or inventoryContainerId == "" then
		pushDebugRateLimited("last_slot_discard_container_id", "last-slot discard: inventory container id missing", 2)
	else
		pushDebugRateLimited("last_slot_discard_network_missing", "last-slot discard: network FireServer unavailable", 2)
	end

	pushDebugRateLimited("last_slot_discard_failed", "last-slot discard failed for " .. tostring(discardLabel), 2)
	return false
end

function getInventoryItemStackAmount(inventoryItem)
	if not isTable(inventoryItem) then
