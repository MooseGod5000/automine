do
    local isToggling = false
    local function toggleVisibility()
        if isToggling or destroyed then
            return
        end
        isToggling = true
        if hubWrapper.Visible then
            hideAllDropdowns()
            _TweenService:Create(hubWrapper, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 380),
            }):Play()
            task.delay(0.5, function()
                if hubWrapper.Parent then
                    hubWrapper.Visible = false
                end
                if type(refreshPathEditorButtons) == "function" then
                    refreshPathEditorButtons()
                end
                isToggling = false
            end)
        else
            hubWrapper.Size = UDim2.new(0, 0, 0, 380)
            hubWrapper.Visible = true
            if type(refreshPathEditorButtons) == "function" then
                refreshPathEditorButtons()
            end
            _TweenService:Create(hubWrapper, TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 600, 0, 380),
            }):Play()
            task.delay(0.8, function()
                isToggling = false
            end)
        end
    end

    _UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if destroyed or not isSessionActive() or gameProcessed then
            return
        end
        if isCapturingKey() or _UserInputService:GetFocusedTextBox() then
            return
        end
        if input.KeyCode == guiToggleKeyCode then
            toggleVisibility()
        end
    end)
end

do
    _UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if destroyed or not isSessionActive() or gameProcessed then
            return
        end
        if isCapturingKey() or _UserInputService:GetFocusedTextBox() then
            return
        end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then
            return
        end
        local keyCode = input.KeyCode
        if keyCode == Enum.KeyCode.Unknown then
            return
        end
        if keyCode == (S.keybinds.dynamiteMark or Enum.KeyCode.F) then
            toggleHoveredDynamitePlayerMark()
            if S.dynamiteTarget == "Player" and S.dynamiteMarkPlayersEnabled then
                return
            end
        end
        for bindKey, boundKey in pairs(S.keybinds) do
            if boundKey == keyCode then
                local bindTab, bindName = bindKey:match("^(.+):(.+)$")
                if bindTab and bindName then
                    for _, regEntry in ipairs(_buttonRegistry) do
                        if regEntry.name == bindName and regEntry.tab == bindTab then
                            if (regEntry.type == "toggle" or regEntry.type == "button" or regEntry.type == "special") and regEntry.onClickFn then
                                regEntry.onClickFn()
                                syncAllUi()
                            end
                            break
                        end
                    end
                end
            end
        end
    end)
end

local function showHub()
    hubWrapper.Size = UDim2.new(0, 0, 0, 380)
    hubWrapper.Visible = true
    if type(refreshPathEditorButtons) == "function" then
        refreshPathEditorButtons()
    end
    _TweenService:Create(hubWrapper, TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 600, 0, 380),
    }):Play()
    local initialTab = AUTOMINE_ONLY_MODE and "AUTOMINE" or "Home"
    switchTab(initialTab)
    activeTabName = initialTab == "AUTOMINE" and "Autofarm" or initialTab
    task.spawn(function()
        task.wait(0.2)
        animateCurrentTitle(initialTab)
    end)
end

