                refreshPathEditorButtons()
                setPathEditorStatus("That key is already used by the GUI toggle.", UI_COLORS.warning)
                return
            end
            pathState.markOreKey = input.KeyCode
            pendingKeybindAction = nil
            savePathsToStorage(false)
            pushDebug("mark ore key: " .. formatKeyCodeName(pathState.markOreKey))
            refreshPathEditorButtons()
            return
        end
        if _UserInputService:GetFocusedTextBox() then
            return
        end
