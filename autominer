        if pathState.draggingNodeIndex and input.UserInputType == Enum.UserInputType.MouseMovement then
            local nodePosition = getPathNodePosition(pathState.workingPath.nodes[pathState.draggingNodeIndex])
            if nodePosition then
                if pathState.draggingNodeAxis == "FREE" then
                    local movedPosition = getEditorMouseGroundPosition(cachedCharacter or getCustomCharacter())
                    if movedPosition then
                        setPathNodePosition(pathState.workingPath, pathState.draggingNodeIndex, movedPosition)
                    end
                elseif pathState.dragLastPointerPosition then
                    local delta = input.Position - pathState.dragLastPointerPosition
                    local sensitivity = 0.045
                    if pathState.draggingNodeAxis == "X" then
                        setPathNodePosition(pathState.workingPath, pathState.draggingNodeIndex, nodePosition + Vector3.new(delta.X * sensitivity, 0, 0))
                    elseif pathState.draggingNodeAxis == "Y" then
                        setPathNodePosition(pathState.workingPath, pathState.draggingNodeIndex, nodePosition + Vector3.new(0, -delta.Y * sensitivity, 0))
                    elseif pathState.draggingNodeAxis == "Z" then
                        setPathNodePosition(pathState.workingPath, pathState.draggingNodeIndex, nodePosition + Vector3.new(0, 0, -delta.Y * sensitivity))
                    end
                    pathState.dragLastPointerPosition = input.Position
                end
                pathState.sellNodeDirty = true
                recomputeWorkingPathSellNode()
