local function createToggleRow(name, parentList, getStateFn, onClickFn)
    local row, icon, label, topLine, bottomLine, diamond = createRow(name)
    row.Parent = parentList
    local updateVis = applyHoverState(row, icon, label, topLine, bottomLine, diamond, true, getStateFn)
    local toggleAnimating = false
    local toggleAnimToken = 0

    local textContainer = Instance.new("Frame")
    textContainer.Size = UDim2.new(0, 50, 1, 0)
    textContainer.Position = UDim2.new(1, -65, 0, 0)
    textContainer.BackgroundTransparency = 1
