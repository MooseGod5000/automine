    onLabel.Position = UDim2.new(1, 0, 0, 0)
    onLabel.BackgroundTransparency = 1
    onLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    onLabel.Text = "ON"
    onLabel.Font = Enum.Font.GothamMedium
    onLabel.TextSize = 13
    onLabel.TextXAlignment = Enum.TextXAlignment.Right
    onLabel.Parent = textContainer

    local function syncLabels(forceInstant)
        if toggleAnimating and not forceInstant then
            updateVis(false)
            return
        end
        if getStateFn() then
            offLabel.Position = UDim2.new(-1, 0, 0, 0)
            onLabel.Position = UDim2.new(0, 0, 0, 0)
        else
            offLabel.Position = UDim2.new(0, 0, 0, 0)
            onLabel.Position = UDim2.new(1, 0, 0, 0)
        end
        updateVis(false)
    end

    syncLabels()
    registerUiSync(_allToggleSyncs, syncLabels)

    if _currentRegistryTab then
        registerButtonEntry({
            name = name,
            tab = _currentRegistryTab,
            type = "toggle",
            getStateFn = getStateFn,
            onClickFn = onClickFn,
        })
    end

    row.MouseButton1Click:Connect(function()
        if destroyed then
            return
        end
        _UTILS._createParticleBurst(row)
        onClickFn()
        toggleAnimating = true
        toggleAnimToken = toggleAnimToken + 1
        local myAnimToken = toggleAnimToken
        local slideInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        if getStateFn() then
            _TweenService:Create(offLabel, slideInfo, {Position = UDim2.new(-1, 0, 0, 0)}):Play()
            _TweenService:Create(onLabel, slideInfo, {Position = UDim2.new(0, 0, 0, 0)}):Play()
        else
            _TweenService:Create(offLabel, slideInfo, {Position = UDim2.new(0, 0, 0, 0)}):Play()
            _TweenService:Create(onLabel, slideInfo, {Position = UDim2.new(1, 0, 0, 0)}):Play()
        end
        updateVis(true)
        task.defer(function()
            pcall(syncAllUi)
        end)
        task.delay(0.31, function()
            if destroyed or myAnimToken ~= toggleAnimToken then
                return
            end
            toggleAnimating = false
            syncLabels(true)
        end)
    end)

    return row, updateVis, syncLabels, label, offLabel, onLabel
end

local function createSliderRow(name, parentList, initialValue, onValueChanged, getStateFn, minValue, maxValue, opts)
    local smin = minValue or 0
    local smax = maxValue or 100
    local span = math.max(1, smax - smin)
    opts = opts or {}
    local decimals = math.max(0, math.floor(tonumber(opts.decimals) or 0))
    local step = tonumber(opts.step)
    if not step or step <= 0 then
        step = decimals > 0 and (10 ^ (-decimals)) or 1
    end
    local textBoxWidth = math.max(30, math.floor(tonumber(opts.textBoxWidth) or (decimals > 0 and 42 or 30)))
    local trackWidth = math.max(72, math.floor(tonumber(opts.trackWidth) or 158))
    local trackRightInset = math.max(trackWidth + 8, math.floor(tonumber(opts.trackRightInset) or 170))
    local labelWidth = math.max(72, math.floor(tonumber(opts.labelWidth) or math.max(96, 140 - math.max(0, textBoxWidth - 30))))

    local row, icon, label, topLine, bottomLine, diamond = createRow(name)
    row.Parent = parentList
    icon.Visible = false
    label.Position = UDim2.new(0, 20 + textBoxWidth + 8, 0, 0)
    label.Size = UDim2.new(0, labelWidth, 1, 0)

    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(0, textBoxWidth, 0, 22)
    textBox.Position = UDim2.new(0, 20, 0.5, -11)
    textBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    textBox.BorderSizePixel = 1
    textBox.BorderColor3 = Color3.fromRGB(45, 45, 45)
    textBox.TextColor3 = Color3.new(1, 1, 1)
    textBox.Font = Enum.Font.GothamMedium
    textBox.TextSize = 12
    textBox.ClearTextOnFocus = false
    textBox.Parent = row
    Instance.new("UICorner", textBox).CornerRadius = UDim.new(0, 4)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, trackWidth, 0, 14)
    track.Position = UDim2.new(1, -trackRightInset, 0.5, -7)
    track.BackgroundTransparency = 1
    track.Parent = row

    local trackLayout = Instance.new("UIListLayout")
    trackLayout.FillDirection = Enum.FillDirection.Horizontal
    trackLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    trackLayout.SortOrder = Enum.SortOrder.LayoutOrder
    trackLayout.Padding = UDim.new(0, 2)
    trackLayout.Parent = track

    local tickCount = 40
    local tickFrames = {}
    for i = 1, tickCount do
        local tickFrame = Instance.new("Frame")
        tickFrame.LayoutOrder = i
        tickFrame.Size = UDim2.new(0, 2, 0, 2)
        tickFrame.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        tickFrame.BorderSizePixel = 0
        tickFrame.Parent = track
        tickFrames[i] = tickFrame
    end

    local currentVal = nil
    local function formatSliderValue(val)
        if decimals > 0 then
            return string.format("%." .. tostring(decimals) .. "f", val)
        end
        return tostring(math.floor(val + 0.5))
    end

    local function normalizeSliderValue(val)
        val = tonumber(val) or smin
        val = math.floor((val / step) + 0.5) * step
        val = math.clamp(val, smin, smax)
        if decimals > 0 then
            local formatted = tonumber(string.format("%." .. tostring(decimals) .. "f", val))
            if formatted then
                val = formatted
            end
        else
            val = math.floor(val + 0.5)
        end
        return val
    end

    local function updateVal(val, suppressCallback)
        val = normalizeSliderValue(val)
        if currentVal == val then
            textBox.Text = formatSliderValue(val)
            return
        end
        currentVal = val
        textBox.Text = formatSliderValue(val)
        local pct = (val - smin) / span
        local activeCount = math.floor(pct * (tickCount - 1)) + 1
        for i = 1, tickCount do
            local tickSize
            local tickColor
            if i < activeCount then
                tickSize = UDim2.new(0, 2, 0, 8)
                tickColor = Color3.new(0.8, 0.8, 0.8)
            elseif i == activeCount then
                tickSize = UDim2.new(0, 2, 0, 14)
                tickColor = Color3.new(1, 1, 1)
            else
                tickSize = UDim2.new(0, 2, 0, 2)
                tickColor = Color3.fromRGB(60, 60, 60)
            end
            _TweenService:Create(tickFrames[i], TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = tickSize,
                BackgroundColor3 = tickColor,
            }):Play()
        end
        if onValueChanged and not suppressCallback then
            onValueChanged(val)
        end
    end

    updateVal(initialValue or smin, true)

    textBox.FocusLost:Connect(function()
        if destroyed then
            return
        end
        local num = tonumber(textBox.Text)
        if num then
            updateVal(num, false)
        else
            textBox.Text = formatSliderValue(currentVal or smin)
        end
    end)

    local interact = Instance.new("TextButton")
    interact.Size = UDim2.new(1, -70, 1, 0)
    interact.Position = UDim2.new(0, 70, 0, 0)
    interact.BackgroundTransparency = 1
    interact.Text = ""
    interact.Parent = row

    local isDragging = false
    local function updateFromMouse(input)
        local trackX = track.AbsolutePosition.X
        local trackW = track.AbsoluteSize.X
        local pct = math.clamp((input.Position.X - trackX) / trackW, 0, 1)
        updateVal(smin + pct * span, false)
    end

    interact.InputBegan:Connect(function(input)
        if destroyed then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            updateFromMouse(input)
        end
    end)

    _UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    _UserInputService.InputChanged:Connect(function(input)
        if destroyed then
            return
        end
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateFromMouse(input)
        end
    end)

    row.MouseEnter:Connect(function()
        if destroyed then
            return
        end
        _TweenService:Create(row, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
        _TweenService:Create(label, TweenInfo.new(0.2), {TextColor3 = Color3.new(1, 1, 1)}):Play()
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        _TweenService:Create(topLine, tweenInfo, {Size = UDim2.new(1, 0, 0, 2)}):Play()
        _TweenService:Create(bottomLine, tweenInfo, {Size = UDim2.new(1, 0, 0, 2)}):Play()
        diamond.Visible = true
    end)

    row.MouseLeave:Connect(function()
        if destroyed then
            return
        end
        _TweenService:Create(row, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(24, 24, 24)}):Play()
        _TweenService:Create(label, TweenInfo.new(0.2), {TextColor3 = Color3.new(0.8, 0.8, 0.8)}):Play()
        local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        _TweenService:Create(topLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
        _TweenService:Create(bottomLine, tweenInfo, {Size = UDim2.new(0, 0, 0, 2)}):Play()
        diamond.Visible = false
    end)

    registerUiSync(_allSliderSyncs, function()
        local value = getStateFn and getStateFn() or currentVal or initialValue or smin
        updateVal(value, true)
    end)

    if _currentRegistryTab then
        registerButtonEntry({
            name = name,
            tab = _currentRegistryTab,
            type = "slider",
            defaultVal = initialValue,
        })
    end

    return row, updateVal, function()
        return currentVal
    end, label, textBox
end

local function hideAllDropdowns()
    for _, frame in ipairs(_dropdownFrames) do
        frame.Visible = false
    end
    for _, dropGui in ipairs(_allDropdownGuis) do
        if dropGui then
