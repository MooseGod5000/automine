function findNearestDroppedItem(character, maxDistance)
	local droppedItems = getDroppedItemsFolder()
	local rootPart = getRootPart(character)
	if not droppedItems or not rootPart then
		return nil, nil
	end

	local nearestItem = nil
	local nearestDistance = nil
	local limit = maxDistance or math.huge

	for _, dropItem in ipairs(droppedItems:GetChildren()) do
		if not isDroppedItemDisabled(dropItem) and isAutoPickupDropAllowed(dropItem) then
			local part = getDroppedItemBasePart(dropItem)
			if part then
				local distance = (rootPart.Position - part.Position).Magnitude
				if distance <= limit and (not nearestDistance or distance < nearestDistance) then
					nearestDistance = distance
					nearestItem = dropItem
				end
			end
		end
	end

	return nearestItem, nearestDistance
end

